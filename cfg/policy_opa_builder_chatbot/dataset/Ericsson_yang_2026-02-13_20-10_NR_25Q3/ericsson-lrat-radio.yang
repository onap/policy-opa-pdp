      type boolean;
      default "true";
      description "Default value: true.";
    }
    leaf lbActivationThreshold {
      type eytypes:int32_range_0-16000;
      default "0";
      description "range 0..16000; Default value: 0.";
    }
    leaf caTriggeredRedirectionActive {
