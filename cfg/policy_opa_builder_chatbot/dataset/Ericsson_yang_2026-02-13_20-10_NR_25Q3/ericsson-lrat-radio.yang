      }
      leaf a3RsrpFreqQciOffsetAdjustment {
        type eytypes:int32_range_-150-150;
        default "0";
        units "dB";
        description "range -150..150; Default value: 0.";
      }
      leaf a3RsrqFreqQciOffsetAdjustment {
        type eytypes:int32_range_-150-150;
        default "0";
        units "dB";
        description "range -150..150; Default value: 0.";
      }
      leaf timeToTriggerA3 {
        type int32;
        default "-1";
        units "ms";
        description "Default value: -1.";
      }
      leaf timeToTriggerA3Rsrq {
        type int32;
        default "-1";
        units "ms";
        description "Default value: -1.";
