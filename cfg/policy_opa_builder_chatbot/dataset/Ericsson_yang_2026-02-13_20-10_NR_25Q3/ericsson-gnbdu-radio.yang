      container attributes {
      leaf sd {
        type eytypes:int32_range_0-16777215;
        description "range 0..16777215.";
      }
      leaf sst {
        type eytypes:int32_range_0-255;
        description "range 0..255.";
      }
      }
    }
    leaf-list spidRfspList {
