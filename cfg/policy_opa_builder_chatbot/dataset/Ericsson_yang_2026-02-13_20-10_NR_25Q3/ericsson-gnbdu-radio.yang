        type string {
          length "3";
          pattern "[02345679][0-9][0-9]";
        }
        description "length 3..3.";
      }
      leaf mnc {
        type string {
          length "2..3";
          pattern "(([0-9][0-9][0-9])|([0-9][0-9]))";
        }
        description "length 2..3.";
      }
      }
    }
    list sNSSAIList {
      key "id";
