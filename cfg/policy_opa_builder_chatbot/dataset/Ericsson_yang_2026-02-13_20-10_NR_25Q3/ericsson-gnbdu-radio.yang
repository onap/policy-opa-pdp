  augment "/emael:ManagedElement/GNBDUFunction/TrafficDefinitions/TrafficDefinition/TrafficSet" {
    list TrafficSetMember {
      description "Additional definitions from MOM:min/max-elements:0/4; Definition of traffic set member. Instances TrafficSetMember=Default_SA and Default_ENDC are created automatically when parent MO instance is created, unless created manually in same transaction. Instance TrafficSetMember=Default_SA is created automatically when TrafficSet=Default instance is created, unless created manually in same transaction. Instance TrafficSetMember=Default_ENDC is created automatically when TrafficSet=Default_ENDC instance is created, unless created manually in same transaction. But only if Default_ENDC instance does not already exist as a sibling under TrafficDefinition instance. Attributes sNSSAIList, pLMNIdList and spidRfspList must be empty in instance TrafficSetMember=Default_SA or TrafficSetMember=Default_ENDC but cannot all be empty in any other instance of TrafficSetMember under same parent TrafficSet instance. Precondition: Instance TrafficSetMember=Default_SA can only be created in same transaction as parent MO instance and cannot be deleted unless parent MO instance is deleted. Instance TrafficSetMember=Default_ENDC can be deleted only if it is in same transaction created in another MO instance sibling to its parent or only if parent MO instance is deleted. Other instances can be created and deleted at any time. Maximum 3 TrafficSetMember instances, with RDN different from Default_ENDC, can be created under parent TrafficSet=Default_ENDC instance. Maximum 3 TrafficSetMember instances, with RDN different from Default_SA, can be created under parent TrafficSet=Default instance. Instance TrafficSetMember=Default_SA must have trafficCategory set to SA. Instance TrafficSetMember=Default_ENDC must have trafficCategory set to ENDC. Maximum one TrafficSetMember=Default_SA instance can be created under same TrafficDefinition instance. Maximum one TrafficSetMember=Default_ENDC instance can be created under same TrafficDefinition instance. Instance TrafficSetMember=Default_SA must be created under TrafficSet=Default instance. Instance TrafficSetMember=Default_ENDC must be created under TrafficSet=Default or Default_ENDC instance.";
      key "trafficSetMemberId";
      leaf trafficSetMemberId {
        type leafref {
          path "../attributes/trafficSetMemberId";
        }
      }
      container attributes {
        uses TrafficSetMember-attributes;
      }
    }
  }

