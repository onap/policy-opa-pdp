      description "Additional definitions from MOM:min/max-elements:0/8; Configuration of inactivity timer profile for UE groups. Instance InactivityProfileUeCfg=Base is created automatically when parent MO instance is created, unless created manually in same transaction. Attributes prefUeGroupList, ueGroupList and ueConfGroupList must be empty in instance InactivityProfileUeCfg=Base but cannot all be empty in any other instance of InactivityProfileUeCfg under same parent InactivityProfile instance. Value 0 is no longer allowed and is planned to be removed from the valid range of prefUeGroupList and ueGroupList. Precondition: Instance InactivityProfileUeCfg=Base can only be created in same transaction as parent MO instance and cannot be deleted unless parent MO instance is deleted. Other instances can be created and deleted at any time. Maximum 7 InactivityProfileUeCfg instances, with RDN different from Base, can be created under parent MO instance.";
      key "inactivityProfileUeCfgId";
      leaf inactivityProfileUeCfgId {
        type leafref {
          path "../attributes/inactivityProfileUeCfgId";
        }
      }
      container attributes {
        uses InactivityProfileUeCfg-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/GNBCUCPFunction/UeCC/InitialCg" {
    list InitialCgUeCfg {
      description "Additional definitions from MOM:min/max-elements:0/8; Initial cell group UE configuration group. Instance InitialCgUeCfg=Base is created automatically when parent MO instance is created, unless created manually in same transaction. Each UE configuration group identifier can only be defined in one ueConfGroupList among InitialCgUeCfg instances contained under parent InitialCg instance. Any combination of one UE group identifier in ueGroupList and one preference UE group identifier in prefUeGroupList must be unique among InitialCgUeCfg instances contained under parent InitialCg instance. Attributes prefUeGroupList, ueGroupList and ueConfGroupList must be empty in instance InitialCgUeCfg=Base but cannot all be empty in any other instance of InitialCgUeCfg under same parent InitialCg instance. Precondition: Instance InitialCgUeCfg=Base can only be created in same transaction as parent MO instance and cannot be deleted unless parent MO instance is deleted. Other instances can be created and deleted at any time. Maximum 7 InitialCgUeCfg instances, with RDN different from Base, can be created under parent MO instance.";
      key "initialCgUeCfgId";
