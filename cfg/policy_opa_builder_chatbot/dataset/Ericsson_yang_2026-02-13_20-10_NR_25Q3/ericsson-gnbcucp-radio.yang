  grouping AdditionalPLMNInfo-attributes {
    leaf additionalPLMNInfoId {
      type string;
      mandatory true;
    }
    leaf nRTAC {
      type int32;
      config false;
    }
    list pLMNIdList {
      config false;
      container attributes {
      leaf mcc {
        type string {
          length "3";
          pattern "[02345679][0-9][0-9]";
        }
        description "length 3..3.";
      }
      leaf mnc {
        type string {
          length "2..3";
          pattern "(([0-9][0-9][0-9])|([0-9][0-9]))";
        }
        description "length 2..3.";
      }
      }
    }
  }
  grouping AdmissionControl-attributes {
    leaf admissionControlId {
      type string;
      mandatory true;
    }
  }
  grouping AdmissionLimit-attributes {
    leaf admissionLimitId {
      type string;
      mandatory true;
    }
    leaf ccLoadThreshold {
      type eytypes:int32_range_0-100;
      default "0";
      units "percent";
      description "range 0..100; Default value: 0.";
    }
    leaf maxConnectedUe {
      type int32 {
        range "0..10000";
      }
      default "0";
      description "range 0..10000; Default value: 0.";
    }
    leaf maxConnectedUeOffloadISHo {
      type int32 {
        range "0..10000";
      }
      default "10000";
      description "range 0..10000; Default value: 10000.";
    }
    leaf preemptionRate {
      type eytypes:int32_range_0-100;
      default "80";
      units "percent";
      description "range 0..100; Default value: 80.";
    }
    leaf-list reservedBy {
      type string;
    }
  }
  grouping AdmissionPriority-attributes {
    leaf admissionPriorityId {
      type string;
      mandatory true;
    }
    leaf-list reservedBy {
      type string;
    }
    leaf ueConfGroupType {
