    }
    leaf-list pmLicDlPrbUsedDistr {
      description "Distribution of DL PRB capacity usages with configured bin step size. Y represents PRB license unit. It comes from BbProcessingResource::pmLicPrbUnit. PDF ranges: [0]: From 0 to Y PRBs ... [n]: From (n*Y)+1 to (n+1)*Y PRBs ... [47]: Above 47*Y+1 PRBs Scanner: Primary.";
      type uint32;
      max-elements 48;
    }
    leaf pmFlexPdcpPktDiscDlEth {
      description "Number of DL packets (unicast DRB PDCP SDUs or MBMS SYNC SDUs) discarded in the Ethernet part of the eNB. Differentiated by filter parameters in PmFlexCounterFilter MO. Following filter parameters are applicable: - PLMN - UE_CATEGORY - SPID - CE_LEVEL Unit: ms Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmZtemporary166 {
      description "Normally this counter is not used, it can however sometimes be temporarily used for very late additions in a release. If so, for description see Network Impact Report in the CPI. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmLicDlCapUsedBrSum {
      description "Accumulated sum of DL Baseband capacity usage for Bandwidth Reduced UEs. Unit: kbps Deprecated: Since 18.Q4. Planned to be removed. Scanner: Not included in any predefined scanner; MOM flags: noNotification.";
      type uint32;
      config false;
      status deprecated;
    }
    leaf pmLicUlCapActual {
      description "The X percentile of the utilization for uplink baseband capacity during a measurement period. The value for X is given by the attribute ENodeBFunction::licUlBbPercentileConf. The data that is evaluated is the same as for the counter BbProcessingResource::pmLicUlCapDistr. Source Data: ENodeBFunction::licUlBbPercentileConf and pmLicUlCapDistr Unit: % Scanner: Primary.";
      type int32;
      config false;
    }
    leaf-list pmZtemporary53 {
      description "Normally this counter is not used, it can however sometimes be temporarily used for very late additions in a release. If so, for description see Network Impact Report in the CPI. Scanner: Not included in any predefined scanner.";
      type uint32;
      max-elements 20;
    }
    leaf pmZtemporary48 {
      description "Normally this counter is not used, it can however sometimes be temporarily used for very late additions in a release. If so, for description see Network Impact Report in the CPI. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmZtemporary49 {
      description "Normally this counter is not used, it can however sometimes be temporarily used for very late additions in a release. If so, for description see Network Impact Report in the CPI. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf-list pmZtemporary152 {
      description "Normally this counter is not used, it can however sometimes be temporarily used for very late additions in a release. If so, for description see Network Impact Report in the CPI. Scanner: Not included in any predefined scanner.";
      type uint32;
      max-elements 20;
    }
    leaf-list pmBbmDlSePttReservation {
      description "Distribution of filtered downlink scheduling entity utilization and reservation level for each Capacity Module. Corresponds to following formula: (reservation for DL scheduling entity PTT) + (DL scheduling entity utilization). PDF ranges: [0]: Total MSR load [0..5] % [1]: Total MSR load ]5..10] % [2]: Total MSR load ]10..15] % [3]: Total MSR load ]15..20] % [4]: Total MSR load ]20..25] % [5]: Total MSR load ]25..30] % [6]: Total MSR load ]30..35] % [7]: Total MSR load ]35..40] % [8]: Total MSR load ]40..45] % [9]: Total MSR load ]45..50] % [10]: Total MSR load ]50..55] % [11]: Total MSR load ]55..60] % [12]: Total MSR load ]60..65] % [13]: Total MSR load ]65..70] % [14]: Total MSR load ]70..75] % [15]: Total MSR load ]75..80] % [16]: Total MSR load ]80..85] % [17]: Total MSR load ]85..90] % [18]: Total MSR load ]90..95] % [19]: Total MSR load ]95..100] % Scanner: Not included in any predefined scanner.";
      type uint32;
      max-elements 20;
    }
    leaf pmZtemporary156 {
      description "Normally this counter is not used, it can however sometimes be temporarily used for very late additions in a release. If so, for description see Network Impact Report in the CPI. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf-list pmBbmUlSeUtilization {
      description "Distribution of filtered UL scheduling entity utilization level for each Capacity Module. Note that only resources scheduled with high priority are considered. PDF ranges: [0]: [0..5]% [1]: ]5..10]% [2]: ]10..15]% [3]: ]15..20]% [4]: ]20..25]% [5]: ]25..30]% [6]: ]30..35]% [7]: ]35..40]% [8]: ]40..45]% [9]: ]45..50]% [10]: ]50..55]% [11]: ]55..60]% [12]: ]60..65]% [13]: ]65..70]% [14]: ]70..75]% [15]: ]75..80]% [16]: ]80..85]% [17]: ]85..90]% [18]: ]90..95]% [19]: ]95..100]% Scanner: Not included in any predefined scanner.";
      type uint32;
      max-elements 20;
    }
    leaf pmZtemporary162 {
      description "Normally this counter is not used, it can however sometimes be temporarily used for very late additions in a release. If so, for description see Network Impact Report in the CPI. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmLicUlCapUsedMax {
      description "Maximum (high-water mark) value of uplink Baseband capacity usage. Counter works only with single capacity module LTE configurations. Unit: kbps Scanner: Primary.";
      type int32;
      config false;
    }
    leaf pmLicUlPrbUsedMax {
      description "Maximum (high-water mark) value of UL PRB capacity use for LTE traffic. NB-IoT inband usage is not included. Unit: PRB Scanner: Primary.";
      type int32;
      config false;
    }
    leaf-list pmBbmHwResCaPreemptDistr {
      description "Distribution of hardware resource usage for each Capacity Module for carrier aggregation preemption thresholds. Hardware resource utilization usage corresponds to 100 * (Total number of connected UEs + Total number of configured SCells) / Maximum RRC Connected Users. Maximum number of RRC connected users is limited by Baseband hardware capacity. For more information, see Supported Capacity and Configurations. Note: if caMaxSCellsPreemptionThres is equal to caUpswitchPreemptionThres, bin [1] is not stepped. If caUpswitchPreemptionThres is equal to caPreemptionThreshold, bin [2] is not stepped. If caMaxSCellsPreemptionThres, caUpswitchPreemptionThres and caPreemptionThreshold are all equal to 0, bin [1], bin [2] and bin [3] are not stepped. If caMaxSCellsPreemptionThres, caUpswitchPreemptionThres and caPreemptionThreshold have the same value other than 0, bin [1] and bin [2] are not stepped. PDF ranges: [0]: [0..100-caMaxSCellsPreemptionThres]% [1]: ]100-caMaxSCellsPreemptionThres..100-caUpswitchPreemptionThres]% [2]: ]100-caUpswitchPreemptionThres..100-caPreemptionThreshold]% [3]: ]100-caPreemptionThreshold..100]% Scanner: Not included in any predefined scanner.";
      type uint32;
      max-elements 4;
    }
    leaf pmPdcpPktDiscDlEthFormat {
      description "Number of downlink DRB packets (PDCP SDUs) discarded in Ethernet part of RBS because downlink consistency check fails. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmPdcpPktDiscUlEthPacing {
      description "Number of uplink DRB packets (PDCP SDUs) discarded in the Ethernet part of the RBS due UL pacing functionality. Scanner: Primary.";
      type uint32;
      config false;
    }
    leaf pmRohcCidSum {
      description "Sum of all sample values recorded for number of ROHC context IDs. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmLicDlCapUsedSamp {
      description "Total number of measured samples of DL Baseband capacity usage. Scanner: Primary.";
      type uint32;
      config false;
    }
    leaf pmPdcpPktDiscDlEthX2Fwd {
      description "Number of downlink DRB packets (PDCP SDUs) discarded in Ethernet part of RBS because of downlink X2 forwarding pacing functionality. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmZtemporary153 {
      description "Normally this counter is not used, it can however sometimes be temporarily used for very late additions in a release. If so, for description see Network Impact Report in the CPI. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmLicDlPrbCapActual {
      description "The X percentile of the utilization for downlink PRB capacity during a measurement period. The value for X is given by the attribute ENodeBFunction::licDlPrbPercentileConf. The data that is evaluated is the same as for the counter BbProcessingResource::pmLicDlPrbCapDistr. Source Data: ENodeBFunction::licDlPrbPercentileConf and pmLicDlPrbCapDistr Unit: % Scanner: Primary.";
      type int32;
      config false;
    }
    leaf pmLicUlCapUsedSamp {
      description "Total number of measured samples of UL Baseband capacity usage. Scanner: Primary.";
      type uint32;
      config false;
    }
    leaf-list pmBbmDlSeUtilization {
      description "Distribution of filtered DL scheduling entity utilization level for each Capacity Module. Note that only resources scheduled with high priority are considered. PDF ranges: [0]: [0..5]% [1]: ]5..10]% [2]: ]10..15]% [3]: ]15..20]% [4]: ]20..25]% [5]: ]25..30]% [6]: ]30..35]% [7]: ]35..40]% [8]: ]40..45]% [9]: ]45..50]% [10]: ]50..55]% [11]: ]55..60]% [12]: ]60..65]% [13]: ]65..70]% [14]: ]70..75]% [15]: ]75..80]% [16]: ]80..85]% [17]: ]85..90]% [18]: ]90..95]% [19]: ]95..100]% Scanner: Not included in any predefined scanner.";
      type uint32;
      max-elements 20;
    }
  }
}
