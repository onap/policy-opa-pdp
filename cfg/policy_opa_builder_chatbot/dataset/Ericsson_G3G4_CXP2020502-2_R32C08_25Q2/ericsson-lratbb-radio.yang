module ericsson-lratbb-radio {
  yang-version 1.1;
  namespace "urn:com:ericsson:ecim:LratBb";
  prefix lratbb;
  import ericsson-yang-types {
    prefix eytypes;
  }
  import ericsson-equip-radio {
    prefix equiprdo;
  }
  import ericsson-field-replaceable-unit-radio {
    prefix frurdo;
  }
  import ericsson-managed-element {
    prefix emael;
  }
  description "Auto-generated from Ericsson CPI MOM XML 15554-lza7016014_33-v1uenfk.xml\nRepresents Baseband processing resource in a DU or a Capacity Module used for eNodeB application in RBS. MO instance is created automatically when first LTE cell of a Capacity Module is unlocked. In DU, ManagedElementData::autoConfigurationAllowed must be set to true to enable autoconfiguration function. MO can be deleted manually. The RDNs of these MOs are BbProcessingResource=1 to BbProcessingResource=2.";
  revision "2026-03-29" {
    description "Ericsson G3G4, version: CXP2020502/2-R32C08";
  }

  augment "/emael:ManagedElement/equiprdo:Equipment/frurdo:FieldReplaceableUnit" {
    list BbProcessingResource {
      description "Additional definitions from MOM:min/max-elements:0/2;root; Represents Baseband processing resource in a DU or a Capacity Module used for eNodeB application in RBS. MO instance is created automatically when first LTE cell of a Capacity Module is unlocked. In DU, ManagedElementData::autoConfigurationAllowed must be set to true to enable autoconfiguration function. MO can be deleted manually. The RDNs of these MOs are BbProcessingResource=1 to BbProcessingResource=2.";
      key "bbProcessingResourceId";
      leaf bbProcessingResourceId {
        type leafref {
          path "../attributes/bbProcessingResourceId";
        }
      }
      container attributes {
      uses BbProcessingResource-attributes;
      }
    }
  }
  grouping BbProcessingResource-attributes {
    leaf bbProcessingResourceId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf licCapDistr {
      description "Share of licensed capacity that is distributed to Baseband processing resource instance. Relevant for eNodeB in dual Capacity Module configuration, such as when ENodeBFunction MO is supported by 2 or 3 Capacity Modules, each with a BbProcessingResource MO. Default setup is ENodeBFunction::licCapDistrMethod is SYSTEM, and BbProcessingResource::licCapDistr is 0. In runtime, licCapDistr shows distribution made automatically by RBS. If ENodeBFunction::licCapDistrMethod is OPERATOR, licCapDistr decides allowed capacity for each BbProcessingResource MO.; range 0..100; Default value: 0.";
      type eytypes:int32_range_0-100;
      default "0";
      units "percent";
    }
    leaf licPrbUnit {
      description "Bin step size representing PRB license unit for the DL/UL distribution of PRB capacity usage.; range 1..600; Default value: 25.";
      type int32 {
        range "1..600";
      }
      default "25";
      units "PRB";
    }
    leaf dlBbCapacityMaxLimit {
      description "Max DL baseband capacity available on unlocked Baseband hardware. Maximum limit of DL capacity that can be granted by baseband HWAC. This level sets the limit at emergency unlock.; range -1..65535.";
      type eytypes:int64_range_-1-65535;
      config false;
      units "Mbps";
    }
    leaf dlBbCapacityNet {
      description "Granted downlink Baseband capacity. Available capacity of corresponding Baseband HWAC property per Capacity Module.; range -1..65535.";
      type eytypes:int64_range_-1-65535;
      config false;
      units "Mbps";
    }
    leaf ulBbCapacityMaxLimit {
      description "Max UL baseband capacity available on unlocked Baseband hardware. Maximum limit of UL capacity that can be granted by baseband HWAC. This level sets the limit at emergency unlock.; range -1..65535.";
      type eytypes:int64_range_-1-65535;
      config false;
      units "Mbps";
    }
    leaf ulBbCapacityNet {
      description "Granted uplink Baseband capacity. Available capacity of corresponding Baseband HWAC property per Capacity Module.; range -1..65535.";
      type eytypes:int64_range_-1-65535;
      config false;
      units "Mbps";
    }
    leaf-list pmBbmUlPrbUtilization {
      description "Distribution of filtered UL PRB utilization level for each Capacity Module. Note that only resources scheduled with high priority are considered. PDF ranges: [0]: [0..5]% [1]: ]5..10]% [2]: ]10..15]% [3]: ]15..20]% [4]: ]20..25]% [5]: ]25..30]% [6]: ]30..35]% [7]: ]35..40]% [8]: ]40..45]% [9]: ]45..50]% [10]: ]50..55]% [11]: ]55..60]% [12]: ]60..65]% [13]: ]65..70]% [14]: ]70..75]% [15]: ]75..80]% [16]: ]80..85]% [17]: ]85..90]% [18]: ]90..95]% [19]: ]95..100]% Scanner: Not included in any predefined scanner.";
      type uint32;
      max-elements 20;
    }
    leaf pmLicDlCapUsedBrSamp {
      description "Number of measured samples of DL Baseband capacity usage for Bandwidth Reduced UEs. Deprecated: Since 18.Q4. Planned to be removed. Scanner: Not included in any predefined scanner; MOM flags: noNotification.";
      type uint32;
      config false;
      status deprecated;
    }
    leaf-list pmBbmDlPrbPttReservation {
      description "Distribution of filtered downlink PRB utilization and reservation level for each Capacity Module. Corresponds to following formula: (reservation for DL PRB PTT) + (DL PRB utilization). PDF ranges: [0]: Total MSR load [0..5] % [1]: Total MSR load ]5..10] % [2]: Total MSR load ]10..15] % [3]: Total MSR load ]15..20] % [4]: Total MSR load ]20..25] % [5]: Total MSR load ]25..30] % [6]: Total MSR load ]30..35] % [7]: Total MSR load ]35..40] % [8]: Total MSR load ]40..45] % [9]: Total MSR load ]45..50] % [10]: Total MSR load ]50..55] % [11]: Total MSR load ]55..60] % [12]: Total MSR load ]60..65] % [13]: Total MSR load ]65..70] % [14]: Total MSR load ]70..75] % [15]: Total MSR load ]75..80] % [16]: Total MSR load ]80..85] % [17]: Total MSR load ]85..90] % [18]: Total MSR load ]90..95] % [19]: Total MSR load ]95..100] % Scanner: Not included in any predefined scanner.";
      type uint32;
      max-elements 20;
    }
    leaf pmLicDlPrbUsedSum {
      description "Accumulated sum of DL PRB capacity usage. Unit: PRB Scanner: Primary.";
      type uint32;
      config false;
    }
    leaf pmLicDlCapUsedMax {
      description "Maximum (high-water mark) value of downlink Baseband capacity usage. Counter works only with single capacity module LTE configurations. Unit: kbps Scanner: Primary.";
      type int32;
      config false;
    }
    leaf pmPdcpPktDiscDlNoUeCtxt {
      description "Number of DRB packets (PDCP SDUs) discarded in downlink because specific TEID is not mapped to any UE context. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmPucchCqiResUtilBbm {
      description "Maximum utilization of CQI resources in the BbProcessingResource. Unit: % Scanner: Not included in any predefined scanner.";
      type int32;
      config false;
    }
    leaf pmLicUlPrbUsedSum {
      description "Accumulated sum of UL PRB capacity usage. Unit: PRB Scanner: Primary.";
      type uint32;
      config false;
    }
    leaf-list pmLicDlPrbCapDistr {
      description "Shows the utilization of DL PRB capacity relative to the minimum of installed license for DL PRB Capacity or hardware PRB capacity limit. Expressed as percentage of the minimum of license limit or hardware PRB capacity limit. PDF ranges: [0]: [0..5]%, [1]: ]5..10]%, [2]: ]10..15]%, [3]: ]15..20]%, [4]: ]20..25]%, [5]: ]25..30]%, [6]: ]30..35]%, [7]: ]35..40]%, [8]: ]40..45]%, [9]: ]45..50]%, [10]: ]50..55]%, [11]: ]55..60]%, [12]: ]60..65]%, [13]: ]65..70]%, [14]: ]70..75]%, [15]: ]75..80]%, [16]: ]80..85]%, [17]: ]85..90]%, [18]: ]90..95]%, [19]: ]95..100]% Note: 0 on all bins is a reserved value set that indicates the cell has been disabled for the entire ROP. If cell is active, no utilization has occurred for the entire ROP. Unit: % Scanner: Primary.";
      type uint32;
      max-elements 20;
    }
    leaf pmLicDlCapUsedSumMbps {
      description "Accumulated sum of downlink Baseband capacity usage. Unit: Mbit/s Scanner: Primary.";
      type uint32;
      config false;
    }
    leaf pmPucchCqiResCongBbm {
      description "The number of times a PUCCH allocation request for CQI resource(s) could not be granted due to lack of resources. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmRohcCidSamp {
      description "Counts number of times corresponding Sum counters are incremented. Associated ACC PM counter is BbProcessingResource.pmRohcCidSum. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
