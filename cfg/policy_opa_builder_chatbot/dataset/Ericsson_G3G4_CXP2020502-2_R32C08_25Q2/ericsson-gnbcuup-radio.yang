    leaf-list pmPdcpPktRecDlDiscAqm5qi {
      description "Total number of packets (PDCP SDUs) discarded for each 5QI over S1-U in downlink because of AQM. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf pmGtpuEchoRtdSum {
      description "Aggregated sum of all round-trip delay (RTD) values measured for GTP-U Echo messages, processing time at responder is included. Unit: microsecond.";
      type uint64;
      config false;
    }
    leaf-list pmPdcpVolTransUl5qi {
      description "Total volume of packets (PDCP SDUs) transmitted for each 5QI over S1-U in uplink. Unit: 1 kilobit (1 000 bits) Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf pmGtpuEchoRtdMax {
      description "Maximum round-trip delay (RTD) measured for GTP-U Echo messages, processing time at responder is included. Unit: microsecond.";
      type int64;
