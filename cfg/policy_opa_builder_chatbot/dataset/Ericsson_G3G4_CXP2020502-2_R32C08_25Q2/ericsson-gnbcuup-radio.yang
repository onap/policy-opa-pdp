      description "Reference to an instance of EndpointResource MO. Defines transport network configuration for specific PLMN or NSSAI. If empty, GNBCUUPFunction::endpointResourceRef is used..";
      type string;
    }
    list pLMNIdList {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct sequence entry.";
      }
      min-elements 0;
      max-elements 12;
      uses PLMNId-struct;
    }
    leaf resourcePartitionMemberId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    list sNSSAIList {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct sequence entry.";
      }
      min-elements 0;
      max-elements 1024;
      uses SliceSelectionAssistInfo-struct;
    }
  }
  grouping ResourcePartitions-attributes {
    leaf resourcePartitionsId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping RpUserPlaneLink-attributes {
    leaf echoPeerStatus {
      description "Peer connectivity status for link. Result of GTP-U path monitoring..";
      type enumeration {
        enum UNKNOWN;
        enum REACHABLE;
        enum UNREACHABLE;
      }
      config false;
    }
    leaf localEndPoint {
      description "Local IP address used for initialization of underlying GTPU transport. IP address can be an IPv4 or an IPv6 address.; length 2..39.";
      type string {
        length "2..39";
      }
      config false;
    }
    leaf monitoringStatus {
      description "Status of GTP-U echo path monitoring for link..";
      type enumeration {
        enum INACTIVE;
        enum ACTIVE;
      }
      config false;
    }
    leaf remoteEndPoint {
      description "Remote IP address used for initialization of underlying GTPU transport. IP address can be an IPv4 or an IPv6 address.; length 2..39.";
      type string {
        length "2..39";
      }
      config false;
    }
    leaf rpUserPlaneLinkId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list pmPdcpVolUlHdrProf2Rohc5qi {
      description "Total volume of uncompressed PDCP SDU headers that are transmitted from ROHC entity using profile 2 in uplink for each 5QI. Unit: kilobit (1 000 bits) Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktTransDlIntgQos {
      description "Total number of PDCP PDUs transmitted with integrity protection for each QoS in radio processing user plane in downlink. QoS indicator can be 5QI or QCI. In NR-DC, PDUs are also counted when gNodeB acts as Secondary Node. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktLossUlToQos {
      description "Total number of packets (PDCP PDUs) lost, received as out of order, or discarded for each QoS indicator in radio processing user plane in uplink because of late receival. QoS indicator can be 5QI or QCI. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktTransDlAggrQos {
      description "Number of packets (PDCP PDUs) transmitted for each QoS indicator on radio processing user plane link in downlink while bearer is in dual connectivity aggregation state. QoS indicator can be 5QI or QCI. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktTransDlRetransQos {
      description "Total number of packets (PDCP SDUs) retransmitted for each QoS indicator on radio processing user plane link in downlink. QoS indicator can be 5QI or QCI. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpVolUlCmpHdrProf1Rohc5qi {
      description "Total volume of compressed PDCP SDU headers that are received in ROHC entity using profile 1 in uplink for each 5QI. Unit: kilobit (1 000 bits) Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktTransDlAckQos {
      description "Total number of packets (PDCP PDUs) acknowledged for each QoS indicator in radio processing user plane in downlink. QoS indicator can be 5QI or QCI. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpVolTransDlAggrQos {
      description "Volume of packets (PDCP SDUs) transmitted for each QoS indicator on radio processing user plane link in downlink while bearer is in dual connectivity aggregation state. QoS indicator can be 5QI or QCI. Unit: 1 kilobit (1 000 bits) Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktRecUlDiscIntgQos {
      description "Total number of PDCP PDUs discarded because of failed integrity verification for each QoS indicator in radio processing user plane in uplink. QoS indicator can be 5QI or QCI. In NR-DC, discarded packets are also counted when gNodeB acts as Secondary Node. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktRecUlQos {
      description "Total number of packets (PDCP PDUs) received for each QoS indicator in radio processing user plane in uplink. QoS indicator can be 5QI or QCI. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktTransDlQos {
      description "Total number of packets (PDCP PDUs) transmitted for each QoS indicator in radio processing user plane in downlink. QoS indicator can be 5QI or QCI. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktLossUlQos {
      description "Total number of packets (PDCP PDUs) lost, received as out of order, or discarded for each QoS indicator in radio processing user plane in uplink. QoS indicator can be 5QI or QCI. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpVolDlCmpHdrProf1Rohc5qi {
      description "Total volume of compressed PDCP SDU headers that are transmitted from ROHC entity using profile 1 in downlink for each 5QI. Unit: kilobit (1 000 bits) Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktTransDlDiscAqmQos {
      description "Total number of packets (PDCP PDUs) discarded for each QoS indicator in radio processing user plane in downlink because of AQM. QoS indicator can be 5QI or QCI. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktTransDlDiscQos {
      description "Total number of packets (PDCP PDUs) discarded or lost for each QoS indicator in radio processing user plane in downlink. QoS indicator can be 5QI or QCI. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpVolDlHdrProf2Rohc5qi {
      description "Total volume of uncompressed PDCP SDU headers that are received in ROHC entity using profile 2 in downlink for each 5QI. Unit: kilobit (1 000 bits) Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpVolTransDlRetransQos {
      description "Total volume of packets (PDCP SDUs) retransmitted for each QoS indicator on radio processing user plane link in downlink. QoS indicator can be 5QI or QCI. Unit: 1 kilobit (1 000 bits) Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktRecUlIntgQos {
      description "Total number of PDCP PDUs with integrity protection received for each QoS indicator in radio processing user plane in uplink. QoS indicator can be 5QI or QCI. In NR-DC, PDUs are also counted when gNodeB acts as Secondary Node. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpVolUlHdrProf1Rohc5qi {
      description "Total volume of uncompressed PDCP SDU headers that are transmitted from ROHC entity using profile 1 in uplink for each 5QI. Unit: kilobit (1 000 bits) Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpVolTransDlQos {
      description "Total volume of packets (PDCP SDUs) transmitted for each QoS indicator in radio processing user plane in downlink. QoS indicator can be 5QI or QCI. Unit: 1 kilobit (1 000 bits) Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpVolDlHdrProf1Rohc5qi {
      description "Total volume of uncompressed PDCP SDU headers that are received in ROHC entity using profile 1 in downlink for each 5QI. Unit: kilobit (1 000 bits) Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpVolRecUlQos {
      description "Total volume of packets (PDCP SDUs) received for each QoS indicator in radio processing user plane in uplink. QoS indicator can be 5QI or QCI. Unit: 1 kilobit (1 000 bits) Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktRecUlOooQos {
      description "Total number of packets (PDCP PDUs) received in radio processing user plane in uplink that are transferred to S1-U or NG-U with PDCP sequence number that is out of order. Counted for each QoS indicator (5QI or QCI) separately. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpVolUlCmpHdrProf2Rohc5qi {
      description "Total volume of compressed PDCP SDU headers that are received in ROHC entity using profile 2 in uplink for each 5QI. Unit: kilobit (1 000 bits) Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpVolDlCmpHdrProf2Rohc5qi {
      description "Total volume of compressed PDCP SDU headers that are transmitted from ROHC entity using profile 2 in downlink for each 5QI. Unit: kilobit (1 000 bits) Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktLossUlToDiscQos {
      description "Total number of packets (PDCP PDUs) discarded for each QoS indicator in radio processing user plane in uplink because of late arrival or because packet is a duplicate. QoS indicator is 5QI or QCI. Compressed: True.";
      type uint64;
      max-elements 256;
    }
  }
