  grouping GtpuSupervision-attributes {
    leaf gtpuErrorIndDscp {
      description "DSCP value used when sending GTP-U Error Indication messages on user plane paths.; range 0..63; Default value: 40.";
      type eytypes:int32_range_0-63;
      default "40";
    }
    leaf gtpuSupervisionId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping GtpuSupervisionProfile-attributes {
    leaf-list endpointResourceRef {
      description "References to instances of EndpointResource MO. If empty, GtpuSupervisionProfile instance covers grandparent GNBCUUPFunction instance for interfaces in interfaceList..";
      type string;
      ordered-by user;
      min-elements 0;
      max-elements 20;
    }
    leaf gtpuEchoDscp {
      description "DSCP value used when sending GTP-U Echo Request. Value is applicable if gtpuEchoEnabled is true.; range 0..63; Default value: 14.";
      type eytypes:int32_range_0-63;
      default "14";
    }
    leaf gtpuEchoEnabled {
      description "Whether GTP-U supervision is enabled. When enabled, path or paths with given interfaces and local IP addresses are supervised by gNodeB-CU-UP that sends echo request. If three consecutive echo requests with 60-second period receive responses, path connectivity is considered reachable. If five consecutive echo requests with 3-second period do not receive responses, path connectivity is considered lost. When path connectivity is lost, no traffic is allocated to the path. A GtpuSupervisionProfile instance defines supervision for one or several interfaces among interface names NG, S1, X2, and XN. It can only act within its grandparent GNBCUUPFunction instance. There are three main configuration alternatives based on interfaceList and endpointResourceRef. Alternative 1: interfaceList is non-empty, endpointResourceRef is empty. GtpuSupervisionProfile instance covers grandparent GNBCUUPFunction instance for interfaces in interfaceList. Alternative 2: interfaceList is empty, endpointResourceRef is non-empty. GtpuSupervisionProfile instance covers LocalIpEndpoint instances under referenced EndpointResource instances. Empty interfaceList means \"all interfaces NG, S1, X2, and XN\" and matches any interface in LocalIpEndpoint::interfaceList. Alternative 3: interfaceList is non-empty, endpointResourceRef is non-empty. GtpuSupervisionProfile instance covers LocalIpEndpoint instances under referenced EndpointResource instances, for matching interfaces. Matching means listed in both interfaceList and LocalIpEndpoint::interfaceList. GtpuSupervisionProfile MO is not applicable to LocalIPsecEndpoint MO.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf gtpuSupervisionProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list interfaceList {
      description "List of user plane interfaces that need to be supervised. Can only contain InterfaceName values S1, X2, NG, and XN. If endpointResourceRef is non-empty, interfaces are compared to LocalIpEndpoint::interfaceList for finding match. If empty, and endpointResourceRef is non-empty, all interfaces S1, X2, NG and XN are compared to LocalIpEndpoint::interfaceList for finding match..";
      type InterfaceName;
      min-elements 0;
      max-elements 4;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping L4sCfg-attributes {
    leaf dlL4sHighThresh {
      description "High threshold in L4S. Threshold above which L4S Congestion Experienced marking probability is 100 %.; range 5..100; Default value: 20.";
      type int32 {
        range "5..100";
      }
      default "20";
      units "ms";
    }
    leaf dlL4sLowThresh {
      description "Low threshold in L4S. Threshold below which L4S Congestion Experienced marking probability is 0 %.; range 1..50; Default value: 8.";
      type int32 {
        range "1..50";
      }
      default "8";
      units "ms";
    }
    leaf dlL4sMode {
      description "L4S mode in downlink. L4S mechanism reduces RLC latency but it can impact throughput..";
      type enumeration {
        enum DISABLED;
        enum QUEUE_BASED;
      }
    }
    leaf l4sCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping LocalIpEndpoint-attributes {
    leaf-list addressRef {
      description "Reference to an instance of AddressIPv4 or AddressIPv6 MO. Dual stack is not supported, only one IP address can be referenced..";
      type string;
      ordered-by user;
      min-elements 1;
      max-elements 2;
    }
    leaf-list interfaceList {
      description "List of user plane interfaces that use the referenced AddressIPv4 or AddressIPv6. Allowed values: NG, S1, X2 and XN. Combination of interface and mode must be unique across LocalIpEndpoint instances under EndpointResource instance..";
      type InterfaceName;
      min-elements 1;
      max-elements 6;
    }
    leaf localIpEndpointId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf mode {
      description "User plane interface redundancy mode. Only applicable when interfaceList is S1..";
      type enumeration {
        enum NORMAL;
        enum BACKUP_IP;
      }
    }
  }
  grouping LocalIPsecEndpoint-attributes {
    leaf-list interfaceList {
      description "List of interfaces that use referenced outer address AddressIPv4 or AddressIPv6. Allowed values are X2 and XN. Interface must be unique across LocalIPsecEndpoint instances under EndpointResource instance..";
      type InterfaceName;
      min-elements 1;
      max-elements 2;
    }
    leaf localIPsecEndpointId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list outerIpAddressRef {
      description "Reference to an instance of AddressIPv4 or AddressIPv6 MO. Must be unique among LocalIPsecEndpoint instances under EndpointResource instance. Dual stack is not supported, only one IP address can be referenced..";
      type string;
      ordered-by user;
      min-elements 1;
      max-elements 2;
    }
  }
  grouping PpControlLink-attributes {
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operationalState..";
      type AvailStatus;
      min-elements 0;
    }
    leaf detailedAvailabilityInfoTemp {
      description "Additional Info for the availabilityStatus FAILED and DEPENDENCY_FAILED. The FailureCause has the format: <causeID> <cause Slogan> [<cause description>] Example: 1 TLS LICENSE NOT INSTALLED The TLS License installation is a prerequisite for Service Discovery.; length 1..256.";
      type string {
        length "1..256";
      }
      config false;
    }
    leaf localEndPoint {
      description "Local IP address used for initialization of underlying TCP connection. IP address can be an IPv4 or an IPv6 address.; length 2..39.";
      type string {
        length "2..39";
      }
      config false;
    }
    leaf operationalState {
      description "The operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf ppControlLinkId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf remoteEndPoint {
      description "Remote IP address used for initialization of underlying TCP connection. IP address can be an IPv4 or an IPv6 address.; length 2..39.";
      type string {
        length "2..39";
      }
      config false;
    }
    leaf pmEndcNrDrbSetupAtt {
      description "Total number of EN-DC DRB setup attempts. Deprecated: Since 25.Q2. Planned to be removed. Replaced by GNBCUUPFunction::pmEndcDrbSetupAtt; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf pmDrbLevelSumSa {
      description "Sum of all sample values recorded for number of NR SA DRBs. In NR-DC, DRBs are also counted when gNodeB acts as Secondary Node. Deprecated: Since 25.Q2. Planned to be removed. Replaced by GNBCUUPFunction::pmDrbLevelSumSa; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf pmDrbLevelMaxSa {
      description "Peak number of NR SA DRBs. In NR-DC, DRBs are also counted when gNodeB acts as Secondary Node. Deprecated: Since 25.Q2. Planned to be removed. Replaced by GNBCUUPFunction::pmDrbLevelMaxSa; MOM flags: noNotification.";
      type int64;
      config false;
      status deprecated;
    }
    leaf pmDrbLevelMaxEndc {
      description "Peak number of EN-DC DRBs. Deprecated: Since 25.Q2. Planned to be removed. Replaced by GNBCUUPFunction::pmDrbLevelMaxEndc; MOM flags: noNotification.";
      type int64;
      config false;
      status deprecated;
    }
    leaf pmPduSessionLevelMax {
      description "Peak number of PDU sessions. Deprecated: Since 25.Q2. Planned to be removed. Replaced by GNBCUUPFunction::pmPduSessionLevelMax; MOM flags: noNotification.";
      type int64;
      config false;
      status deprecated;
    }
    leaf pmEndcNrDrbSetupSucc {
      description "Successful number of EN-DC DRB setups. Deprecated: Since 25.Q2. Planned to be removed. Replaced by GNBCUUPFunction::pmEndcDrbSetupSucc; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf pmPduSessionLevelSamp {
      description "Number of times corresponding sum counter is stepped. Associated ACC pm counter is pmPduSessionLevelSum. Deprecated: Since 25.Q2. Planned to be removed. Replaced by GNBCUUPFunction::pmPduSessionLevelSamp; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf pmPduSessionLevelSum {
      description "Sum of all sample values recorded for number of PDU sessions. Deprecated: Since 25.Q2. Planned to be removed. Replaced by GNBCUUPFunction::pmPduSessionLevelSum; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf pmDrbLevelSamp {
      description "Number of times corresponding sum counter is stepped. Associated ACC pm counters are pmDrbLevelSumEndc and pmDrbLevelSumSa. Deprecated: Since 25.Q2. Planned to be removed. Replaced by GNBCUUPFunction::pmDrbLevelSamp; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf pmDrbLevelSumEndc {
      description "Sum of all sample values recorded for number of EN-DC DRBs. Deprecated: Since 25.Q2. Planned to be removed. Replaced by GNBCUUPFunction::pmDrbLevelSumEndc; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
  }
  grouping PpControlTermination-attributes {
    leaf ppControlTerminationId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping ResourcePartition-attributes {
    leaf related5qiTableRef {
      description "Reference to an instance of CUUP5qiTable MO..";
      type string;
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance. Currently not used..";
      type string;
      min-elements 0;
    }
    leaf resourcePartitionId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
