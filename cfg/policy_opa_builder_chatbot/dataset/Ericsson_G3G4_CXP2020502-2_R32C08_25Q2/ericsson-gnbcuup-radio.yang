    }
    leaf-list pmGtpuEchoRtdDistr {
      description "Distribution of round-trip delay (RTD) values measured for GTP-U Echo messages, processing time at responder is included. Ranges: Bin[0]: [0..2000] us Bin[1]: [2001..5000] us Bin[2]: [5001..10000] us Bin[3]: [10001..20000] us Bin[4]: [20001..] us.";
      type uint64;
      max-elements 5;
    }
    leaf pmGtpuEchoRtdSamp {
      description "Aggregated number of round-trip delay (RTD) values measured for GTP-U Echo messages..";
      type uint64;
      config false;
    }
    leaf-list pmPdcpPktRecDl5qi {
