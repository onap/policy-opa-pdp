  grouping UserPlaneProfile-attributes {
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained UserPlaneProfileUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
    leaf userPlaneProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping UserPlaneProfileCfg-attributes {
    leaf dcDlAggActTime {
      description "Required PDCP SDU queue age for activating PDCP downlink aggregation. PDCP downlink aggregation is activated for bearers where a packet spends longer time than this attribute value in PDCP SDU queue. Activating PDCP downlink aggregation for a bearer requires following: - UE is capable of PDCP downlink aggregation. - License for LTE-NR Downlink Aggregation is present and feature is active.; range 0..1000; Default value: 1.";
      type eytypes:int32_range_0-1000;
      default "1";
      units "ms";
    }
    leaf dcDlAggAgeDiffPreferredCg {
      description "Cell group used during suspension of PDCP downlink aggregation due to high queue age difference. Cell group used for downlink transmission when PDCP downlink aggregation is temporary suspended when dcDlAggAgeDiffThresh is exceeded..";
      type enumeration {
        enum MCG;
        enum SCG;
        enum YOUNGEST_CG;
      }
    }
    leaf dcDlAggAgeDiffProhibitTime {
      description "Prohibition time for PDCP downlink aggregation at high downlink PDU queue age difference. Time during which PDCP downlink aggregation is prohibited after exceeding dcDlAggAgeDiffThresh. Value 0 corresponds to infinity or until bearer is reconfigured.; range 0..10000; Default value: 200.";
      type eytypes:int32_range_0-10000;
      default "200";
      units "ms";
    }
    leaf dcDlAggAgeDiffThresh {
      description "PDU queue age difference threshold for temporary prohibition of PDCP downlink aggregation. Minimum age difference between oldest PDCP PDUs for MCG and SCG not yet RLC-acknowledged by UE. This triggers a temporary prohibition of PDCP downlink aggregation. If 0, check for minimum downlink PDU queue age difference is disabled.; range 0..3000; Default value: 150.";
      type eytypes:int32_range_0-3000;
      default "150";
      units "ms";
    }
    leaf dcDlAggCgPrio {
      description "Prioritized cell group during active PDCP downlink aggregation. Prioritized cell group for transmission during active PDCP downlink aggregation. If DcDlCfg::dcDlAggCgPrioOverride is non-empty, it overrides this attribute..";
      type enumeration {
        enum MCG_PRIO;
        enum SCG_PRIO;
        enum EQUAL_PRIO;
      }
    }
    leaf dcDlAggExpiryTimer {
      description "Expiry timer for when PDCP downlink aggregation is deactivated. When a bearer with PDCP downlink aggregation activated has empty PDCP SDU and PDU queues for longer than this attribute value, PDCP downlink aggregation is deactivated and bearer returns to packet scheduling on dlPdcpPreferredCg.; range 0..10000; Default value: 100.";
      type eytypes:int32_range_0-10000;
      default "100";
      units "ms";
    }
    leaf dcDlAggMcgDrxWakeupTime {
      description "Time since last transmitted user data packet after which MCG is considered to be in DRX sleep. A cell croup considered to be in DRX sleep is secured to be awake again before used for PDCP downlink aggregation. Value 0 means infinity, that is, MCG DRX awake function is turned off.; range 0..1000; Default value: 80.";
      type eytypes:int32_range_0-1000;
      default "80";
      units "ms";
    }
    leaf dcDlAggScgDrxWakeupTime {
      description "Time since last transmitted user data packet after which SCG is considered to be in DRX sleep. A cell group considered to be in DRX sleep is secured to be awake again before used for PDCP downlink aggregation. Value 0 means infinity, that is, SCG DRX awake function is turned off.; range 0..1000; Default value: 80.";
      type eytypes:int32_range_0-1000;
      default "80";
      units "ms";
    }
    leaf dlPdcpMcgInitialRate {
      description "Estimated initial rate on MCG of a dual-connectivity-configured radio bearer.; range 0..10000; Default value: 20.";
      type eytypes:int32_range_0-10000-1;
      default "20";
      units "Mbps";
    }
    leaf dlPdcpMcgSpsTargetTime {
      description "Target buffer depth in gNodeB-DU for PDCP PDUs on MCG radio resources.; range 0..1000; Default value: 25.";
      type eytypes:int32_range_0-1000;
      default "25";
      units "ms";
    }
    leaf dlPdcpPreferredCg {
      description "Cell group preferred to be used when PDCP downlink aggregation is inactive. If DcDlCfg::dlPdcpPreferredCgOverride is non-empty, it overrides this attribute..";
      type enumeration {
        enum MCG;
        enum SCG;
        enum KEEP_SCG;
      }
    }
    leaf dlPdcpScgInitialRate {
      description "Estimated initial rate on SCG of a dual-connectivity-configured radio bearer.; range 0..10000; Default value: 100.";
      type eytypes:int32_range_0-10000-1;
      default "100";
      units "Mbps";
    }
    leaf dlPdcpScgRetProhibitTime {
      description "Minimum time between two consecutive switches enabling use of downlink SCG radio resources.; range 0..1000; Default value: 400.";
      type eytypes:int32_range_0-1000;
      default "400";
      units "ms";
    }
    leaf dlPdcpScgSpsTargetTime {
      description "Target buffer depth in gNodeB-DU for PDCP PDUs on SCG radio resources.; range 0..1000; Default value: 25.";
      type eytypes:int32_range_0-1000;
      default "25";
      units "ms";
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf ulPdcpScgRetProhibitTime {
      description "Minimum time between two consecutive switches enabling use of uplink SCG radio resources.; range 0..10000; Default value: 1000.";
      type eytypes:int32_range_0-10000;
      default "1000";
      units "ms";
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
    leaf userPlaneProfileCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping UserPlaneProfileCgCat-attributes {
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
    leaf userPlaneProfileCgCatId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping UserPlaneProfileCgCatCfg-attributes {
    leaf-list cgCategoryList {
      description "Cell group category list. If empty, MO instance does not match any incoming UE connection..";
      type eytypes:int32_range_0-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
    leaf userPlaneProfileCgCatCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf userPlaneProfileRef {
      description "Reference to an instance of UserPlaneProfile MO..";
      type string;
      mandatory true;
    }
  }
  grouping UserPlaneProfileUeCfg-attributes {
    leaf dcDlAggActTime {
      description "Required PDCP SDU queue age for activating PDCP downlink aggregation. PDCP downlink aggregation is activated for bearers where a packet spends longer time than attribute value in PDCP SDU queue. Activating PDCP downlink aggregation for a bearer requires following: - UE is capable of PDCP downlink aggregation. - License for LTE-NR Downlink Aggregation is present and feature is active.; range 0..1000; Default value: 1.";
      type eytypes:int32_range_0-1000;
      default "1";
      units "ms";
    }
    leaf dcDlAggAgeDiffPreferredCg {
      description "Cell group used during suspension of PDCP downlink aggregation due to high queue age difference. Cell group used for downlink transmission when PDCP downlink aggregation is temporary suspended when dcDlAggAgeDiffThresh is exceeded..";
      type enumeration {
        enum MCG;
        enum SCG;
        enum YOUNGEST_CG;
      }
    }
    leaf dcDlAggAgeDiffProhibitTime {
      description "Prohibit time for PDCP downlink aggregation at high downlink PDU queue age difference. Time during which PDCP downlink aggregation is prohibited after exceeding dcDlAggAgeDiffThresh. Value 0 corresponds to infinity or until bearer is reconfigured.; range 0..10000; Default value: 200.";
      type eytypes:int32_range_0-10000;
      default "200";
      units "ms";
    }
    leaf dcDlAggAgeDiffThresh {
      description "PDU queue age difference threshold for temporary prohibition of PDCP downlink aggregation. Minimum age difference between oldest PDCP PDUs for MCG and SCG not yet RLC-acknowledged by UE. This triggers a temporary prohibition of PDCP downlink aggregation. If 0, check for minimum downlink PDU queue age difference is disabled.; range 0..3000; Default value: 150.";
      type eytypes:int32_range_0-3000;
      default "150";
      units "ms";
    }
    leaf dcDlAggCgPrio {
      description "Prioritized cell group during active PDCP downlink aggregation. Prioritized cell group for transmission during active PDCP downlink aggregation. Overridden by DcDlCfg::dcDlAggCgPrioOverride if DcDlCfg::dcDlAggCgPrioOverride is non-empty..";
      type enumeration {
        enum MCG_PRIO;
        enum SCG_PRIO;
        enum EQUAL_PRIO;
      }
    }
    leaf dcDlAggExpiryTimer {
      description "Expiry timer for when PDCP downlink aggregation can be deactivated. When a bearer with PDCP downlink aggregation activated has had empty PDCP SDU and PDU queues for longer than attribute value, PDCP downlink aggregation is deactivated and bearer returns to packet scheduling on dlPdcpPreferredCg.; range 0..10000; Default value: 100.";
      type eytypes:int32_range_0-10000;
      default "100";
      units "ms";
    }
    leaf dcDlAggHighAirIfLoadThresh {
      description "PDCP downlink aggregation is prohibited when any of MCG or SCG load exceeds this value. If 0, PDCP downlink aggregation will not be prohibited due to high load.; range 0..100.";
      type eytypes:int32_range_0-100;
      units "percent";
    }
    leaf dcDlAggHighLatencyThresh {
      description "PDCP downlink aggregation is prohibited when MCG or SCG one-way link latency exceeds this value. If 0, PDCP downlink aggregation will not be prohibited due to high link latency.; range 0..100.";
      type eytypes:int32_range_0-100-12;
      units "ms";
    }
    leaf dcDlAggMcgDrxWakeupTime {
      description "Time since last transmitted user data packet after which MCG is considered to be in DRX sleep. A Cell Group considered to be in DRX sleep is secured to be awake again before used for PDCP downlink aggregation. Value 0 means infinity, that is, MCG DRX awake function is turned off.; range 0..1000; Default value: 80.";
      type eytypes:int32_range_0-1000;
      default "80";
      units "ms";
    }
    leaf dcDlAggScgDrxWakeupTime {
      description "Time since last transmitted user data packet after which SCG is considered to be in DRX sleep. A Cell Group considered to be in DRX sleep is secured to be awake again before used for PDCP downlink aggregation. Value 0 means infinity, that is, SCG DRX awake function is turned off.; range 0..1000; Default value: 80.";
      type eytypes:int32_range_0-1000;
      default "80";
      units "ms";
    }
    leaf dlPdcpMcgInitialRate {
      description "Estimated initial rate on MCG of a dual-connectivity-configured radio bearer.; range 0..10000; Default value: 20.";
      type eytypes:int32_range_0-10000-1;
      default "20";
      units "Mbps";
    }
    leaf dlPdcpMcgSpsTargetTime {
      description "Target buffer depth in DU for PDCP PDUs on MCG leg.; range 0..1000; Default value: 25.";
      type eytypes:int32_range_0-1000;
      default "25";
      units "ms";
    }
    leaf dlPdcpPreferredCg {
      description "Cell group preferred to be used when PDCP downlink aggregation is inactive. Overridden by DcDlCfg::dlPdcpPreferredCgOverride if DcDlCfg::dlPdcpPreferredCgOverride is non-empty..";
      type enumeration {
        enum MCG;
        enum SCG;
        enum KEEP_SCG;
      }
    }
    leaf dlPdcpScgInitialRate {
      description "Estimated initial rate on SCG of a dual-connectivity-configured radio bearer.; range 0..10000; Default value: 100.";
      type eytypes:int32_range_0-10000-1;
      default "100";
      units "Mbps";
    }
    leaf dlPdcpScgRetProhibitTime {
      description "Minimum time between two consecutive switches enabling use of downlink SCG Radio Resources.; range 0..1000; Default value: 400.";
      type eytypes:int32_range_0-1000;
      default "400";
      units "ms";
    }
    leaf dlPdcpScgSpsTargetTime {
      description "Target buffer depth in DU for PDCP PDUs on SCG leg.; range 0..1000; Default value: 25.";
      type eytypes:int32_range_0-1000;
      default "25";
      units "ms";
    }
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 32;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf ulPdcpScgRetProhibitTime {
      description "Minimum time between two consecutive switches enabling use of uplink SCG Radio Resources.; range 0..10000; Default value: 1000.";
      type eytypes:int32_range_0-10000;
      default "1000";
      units "ms";
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
    leaf userPlaneProfileCfgRef {
      description "Reference to an instance of UserPlaneProfileCfg MO. UserPlaneProfileCfg MO contains same PDCP parameters as UserPlaneProfileUeCfg MO. If empty, attributes according to this MO class definition are used. If non-empty, attributes from referenced MO instance are used..";
      type string;
    }
    leaf userPlaneProfileUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping X2ULink-attributes {
    leaf echoPeerStatus {
      description "Peer connectivity status for link. Result of GTP-U path monitoring..";
      type enumeration {
        enum UNKNOWN;
        enum REACHABLE;
        enum UNREACHABLE;
      }
      config false;
    }
    leaf localEndPoint {
      description "Local IP address for X2 user plane connection. The IP address can be an IPv4 or an IPv6 address.; length 2..39.";
      type string {
        length "2..39";
      }
      config false;
    }
    leaf monitoringStatus {
      description "Status of GTP-U echo path monitoring for link..";
      type enumeration {
        enum INACTIVE;
        enum ACTIVE;
      }
      config false;
    }
    leaf remoteEndPoint {
      description "Remote IP address for X2 user plane connection. The IP address can be an IPv4 or an IPv6 address.; length 2..39.";
      type string {
        length "2..39";
      }
      config false;
    }
    leaf x2ULinkId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list pmPdcpPktFwdTransDlQos {
      description "Number of downlink session DRB packets transmitted during forwarding over X2 user plane for each QoS. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktFwdTransDlDiscQos {
      description "Number of discarded downlink session DRB packets out of those that need to be transmitted during packet forwarding for each QoS over X2 user plane. Compressed: True.";
      type uint64;
      max-elements 256;
    }
  }
  grouping X2UTermination-attributes {
    leaf x2UTerminationId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list pmPdcpPktFwdRecDlDiscQos {
      description "Number of discarded downlink session DRB packets out of those received during packet forwarding over X2 user plane for each QoS. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmPdcpPktFwdRecDlQos {
      description "Number of downlink session DRB packets received during forwarding over X2 user plane for each QoS. Packets received during incoming IRAT inter-system handover from LTE are excluded from this measurement and instead included in GNBCUUPFunction_pmPdcpPktFwdRecDlQos. Compressed: True.";
      type uint64;
      max-elements 256;
    }
  }
}
