    }
    leaf pmGtpuEchoRespRejRcvd {
      description "Total number of received but rejected GTP-U Echo Response messages..";
      type uint64;
      config false;
    }
    leaf pmGtpuEchoRtdMin {
      description "Minimum round-trip delay (RTD) measured for GTP-U Echo messages, processing time at responder is included. Unit: microsecond.";
      type int64;
      config false;
    }
    leaf pmGtpuEchoRespNotRcvd {
      description "Total number of missing GTP-U Echo Response messages..";
      type uint64;
      config false;
    }
    leaf-list pmPdcpPktTransUl5qi {
      description "Total number of packets (PDCP SDUs) transmitted for each 5QI over S1-U in uplink. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf pmGtpuEchoReqSent {
      description "Total number of sent GTP-U Echo Request messages..";
      type uint64;
      config false;
    }
    leaf-list pmPdcpPktRecDlDisc5qi {
      description "Total number of packets (PDCP SDUs) discarded for each 5QI over S1-U in downlink. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf pmGtpuEchoRespAccRcvd {
      description "Total number of received and accepted GTP-U Echo Response messages..";
      type uint64;
