      description "Number of successful SCell deconfigurations in serving PCell, including deconfiguration of last SCell. SCell release signaling to UE uses RRC Reconfiguration and RRC Connection Release procedures. SCell releases that use RRC Connection Release procedure are always successful in serving PCell. Deprecated: Since 25.Q2. Planned to be removed. Replaced by NRCellCU::pmCaSCellDeconfigSucc.; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf-list pmCaConfigUlSumSaDistr {
      description "Sum of UEs using this cell as PCell with configured uplink SCells for NR SA UEs. Ranges: Bin[0]: Number of NR SA UEs configured with one PCell and no uplink SCell. Bin[1]: Number of NR SA UEs configured with one PCell and one uplink SCell. Bin[2]: Number of NR SA UEs configured with one PCell and two uplink SCells. ... Bin[31]: Number of NR SA UEs configured with one PCell and thirty-one uplink SCells. Compressed: True.";
      type uint64;
      max-elements 32;
    }
    leaf pmEndcUeCapabilityGnssLocation {
      description "Number of UEs that support GNSS location capability for EN-DC..";
      type uint64;
      config false;
    }
    leaf pmNrdcPSCellChangeMnAttInterSgnb {
