      type string;
    }
  }
  grouping CaCellProfileUeCfg-attributes {
    leaf-list blockedSCellFreqList {
      description "List of arfcnValueNRDl values that are not allowed as SCells for Carrier Aggregation..";
      type eytypes:int32_range_0-3279165;
      ordered-by user;
      min-elements 0;
      max-elements 32;
    }
    leaf caCellProfileUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf effectiveBwImpactUl2Layer {
      description "Expected uplink throughput gain of having two layers compared with one. Only applicable to Low-Band and Mid-Band cells.; range 0..200; Default value: 180.";
      type int32 {
        range "0..200";
      }
      default "180";
    }
    leaf maxDlCcAllowed {
      description "Maximum number of downlink component carriers allowed.; range 1..32; Default value: 32.";
      type eytypes:int32_range_1-32;
      default "32";
    }
    leaf maxUlCcAllowed {
      description "Maximum number of uplink component carriers allowed.; range 1..32; Default value: 32.";
      type eytypes:int32_range_1-32;
      default "32";
    }
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf servingCellSelectionPolicy {
      description "Criteria for selecting serving cell set for UE connection. Used to prioritize between downlink and uplink throughput in serving cell selection algorithm. Value PRIO_DL_THP_THEN_PCELL_UL_THP is only applicable if license for Uplink-Aware Advanced Multi-Layer Coordination is present and feature is active, otherwise handled as default. Only applicable to Low-Band and Mid-Band cells..";
      type enumeration {
        enum PRIORITIZE_DL_THP;
        enum PRIORITIZE_UL_THP;
        enum PRIO_DL_THP_THEN_PCELL_UL_THP;
      }
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf ulCaConfigurationMode {
      description "Configuration mode for uplink aspect of SCell. In immediate configuration, uplink aspect of SCell is configured in first NR RRC Reconfiguration message. In delayed configuration, uplink aspect of SCell is configured in subsequent NR RRC Reconfiguration message after reception of PCell coverage measurement report from UE. Only applicable to Low-Band and Mid-Band cells..";
      type enumeration {
        enum IMMEDIATE;
        enum DELAYED_ALWAYS;
        enum DELAYED_CONDITIONAL;
      }
    }
    leaf ulSuMimoFr1Prevention {
      description "Type of cells for which Uplink Single-User MIMO is prevented for this MO instance. Only applicable to Low-Band and Mid-Band cells..";
      type enumeration {
        enum NONE;
        enum TDD;
        enum FDD;
        enum TDD_AND_FDD;
      }
    }
    leaf ulTxSwitchingAllowed {
      description "Whether uplink TX switching configuration is allowed for CaCellProfileUeCfg instance. Only applicable to Mid-Band cells.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping CaFreqRelMeasProfile-attributes {
    leaf caFreqRelMeasProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained CaFreqRelMeasProfileUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping CaFreqRelMeasProfileUeCfg-attributes {
    leaf caFreqRelMeasProfileUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf rsrpSCellCoverageThrOffset {
      description "RSRP A1 and A2 measurement event threshold offset for SCell coverage measurements. Used in combination with CaCellMeasProfileUeCfg::rsrpSCellCoverage. Only applicable to Low-Band and Mid-Band cells.; range -30..30; Default value: 0.";
      type eytypes:int32_range_-30-30;
      default "0";
      units "dB";
    }
    leaf rsrqSCellCoverageThrOffset {
      description "RSRQ A1 and A2 measurement event threshold offset for SCell coverage measurements. Used in combination with CaCellMeasProfileUeCfg::rsrqSCellCoverage. Only applicable to Low-Band and Mid-Band cells.; range -300..300; Default value: 0.";
      type int32 {
        range "-300..300";
      }
      default "0";
      units "dB";
    }
    leaf sinrSCellCoverageThrOffset {
      description "SINR A1 and A2 measurement event threshold offset for SCell coverage measurements. Used in combination with CaCellMeasProfileUeCfg::sinrSCellCoverage. Only applicable to Low-Band and Mid-Band cells.; range -100..100; Default value: 0.";
      type eytypes:int32_range_-100-100;
      default "0";
      units "dB";
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
    leaf waitForBetterSCellRep {
      description "Controls time gNodeB waits after reception of an A2 measurement report until SCell is deconfigured. If SCell A1 or A6 measurement report is received before timer expires, no SCell deconfiguration is attempted. Value -1 means waiting forever. Not applicable to High-Band cells.; range -1..32000; Default value: -1.";
      type eytypes:int32_range_-1-32000;
      default "-1";
      units "ms";
    }
  }
  grouping CapabilityHandling-attributes {
    leaf capabilityHandlingId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained CapabilityHandlingUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
  }
  grouping CapabilityHandlingUeCfg-attributes {
    leaf capabilityHandlingUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf gaplessFr2InterFreqMeasSupp {
      description "Whether UE is assumed to support gapless FR2 inter-frequency measurements. Only applicable to High-Band cells.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 32;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf ulRrcSegAllowedForUeCapInfo {
      description "Indicator of allowing UE to send RRC ULDedicatedMessageSegment message. Only applicable to segmented RRC UECapabilityInformation message transfer. Only applicable to CapabilityHandlingUeCfg=Base instance. Value in Base instance is applied in all UE groups.; Default value: true; Takes effect: New connection; Status info: Since 23.Q4. Planned to be removed..";
      type boolean;
      status deprecated;
      default "true";
      reference "Takes effect: New connection.";
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping CardinalityLimits-attributes {
    leaf cardinalityLimitsId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf maxNRCellCU {
      description "Maximum number of NRCellCU instances that can be created in current deployment..";
      type int32;
      config false;
    }
  }
  grouping CarrierAggregation-attributes {
    leaf carrierAggregationId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping CellGroupCategoryDefinition-attributes {
    leaf categoryCriteria {
      description "Cell group category criteria. <CategoryCriteria> ::= <ExpressionList> | \"\" <ExpressionList> ::= <ExpressionList> <AndOr> <ExpressionList> | <Not>? \"(\" <ExpressionList> \")\" | <Not>? <VariableExpression> <VariableExpression> ::= <Variable> <RelationalOperator> <Value> | <Variable> \"==\" \"{\" <ValueList> \"}\" <ValueList> ::= <Value> \",\" <ValueList> | <Value> <Variable> ::= \"PCellDlFreq\" | \"PCellUlFreq\" | \"PSCellDlFreq\" | \"PSCellUlFreq\" <AndOr> ::= \"&&\" | \"||\" <Not> ::= \"!\" <RelationalOperator> ::= \"==\" | \"!=\" | \"<\" | \"<=\" | \">=\" | \">\" A list of possible values can be specified in the form <Variable> == {<value1>, <value2>, ... , <valueN>}. This statement is equivalent to writing (<Variable> == <value1> || <Variable> == <value2> || ... || <Variable> == <valueN>). Whitespaces are allowed between every token in the syntax above. Question mark (?) means zero or one occurrence. For example, <Not>? makes <Not> optional. Syntax is case sensitive. Semantic: ======== Category criteria evaluation is defined by the following semantic rules. If empty or set to empty string \"\", selection criteria always evaluates to True. Operator Precedence Order: ======================= The logical and relation operators are evaluated according to the precedence order listed below. --------------------------------------------- 1 (highest precedence) < Less than <= Less than or equal > Greater than >= Greater than or equal == Equal != Not equal ------------------------------------------- 2 ! (Not) --------------------------------------------- 3 && (And) --------------------------------------------- 4 (lowest precedence) || (Or) --------------------------------------------- The NOT operator \"!\" negates the following <VariableExpression> or an <ExpressionList> encapsulated in parenthesis. Therefore, the expression !a==b && c==d is equivalent to (!(a==b) && (c==d)) and different from !(a==b && c==d). Expression !a==b and !(a==b) are equivalent. Since the AND operator \"&&\" has higher precedence than the OR operator \"||\", a<b || a<c && c<d is equivalent to (a<b || (a<c && c<d)). To change the order of operations, surround the expression with parentheses (...) as (a<b || a<c) && c<d to force the NOT operator \"||\" to be evaluated first. As an example, this attribute can be used like: Category criteria = PCellDlFreq> 2.5e9 && PCellDlFreq < 2.8e9 to check whether PCell downlink frequency is between 2.5 GHz and 2.8 GHz.; length 0..1000.";
      type string {
        length "0..1000";
      }
    }
    leaf cellGroupCategoryDefinitionId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf cgCategoryId {
      description "Cell group category identifier.; range 0..255.";
      type eytypes:int32_range_0-255;
      mandatory true;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping Chipsets-attributes {
    list chipsetList {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct sequence entry.";
      }
      min-elements 0;
      max-elements 128;
      uses Chipset-struct;
    }
    leaf chipsetsId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping CUCP5qi-attributes {
    leaf cUCP5qiId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf endcUlDataSplitRef {
      description "Reference to an instance of UlDataSplit MO. Automatically set to UlDataSplit=Default_endc instance, unless manually set to refer to another MO instance. Applicable to EN-DC if Service-Adaptive Uplink User Plane Profile feature is activated. UlDataSplit=Default_endc instance is applied if Service-Adaptive Uplink User Plane Profile feature is deactivated..";
      type string;
    }
    leaf nrdcSnTerminationRef {
      description "Reference to an instance of NrdcSnTermination MO. For 5QIs 1,5,65,66 and 69, if empty then SnTerminationProhibited instance of NrdcSnTermination is used. For all other 5QI, if empty then instance of NrdcSnTermination is used where defaultNrdcSnTerm is true. If empty, and no such MO exists, SN termination is not allowed for this 5QI..";
      type string;
    }
    leaf nrdcUlDataSplitRef {
      description "Reference to an instance of UlDataSplit MO. Automatically set to UlDataSplit=Default_nrdc instance, unless manually set to refer to another MO instance. Applicable to NR-DC if Service-Adaptive Uplink User Plane Profile feature is activated. UlDataSplit=Default_nrdc instance is applied if Service-Adaptive Uplink User Plane Profile feature is deactivated..";
      type string;
    }
    leaf pdcpSnSize {
      description "PDCP sequence number length. Following values are recommended: * 12 if profile5qi is 1, 2, 3, 4, 5, 6, 7, 65, 66, 67, 69, 70, 79, 80, 82, 83, 84 or 85. * 18 if profile5qi is 8 or 9.; Default value: 18.";
      type int32 {
        range "12 | 18";
      }
      default "18";
    }
    leaf profile5qi {
      description "5G QoS Identifier, unique within a table.; range 0..255.";
      type eytypes:int32_range_0-255;
      mandatory true;
    }
    leaf rlcMode {
      description "RLC mode for DRB. Recommended values for non-restricted 5QIs: UM if profile5qi is 2. AM if profile5qi is 6, 7, 8, 9 or 70..";
      type enumeration {
        enum AM;
        enum UM;
      }
    }
    leaf tPdcpDiscard {
      description "UL PDCP discard timer used in UE. Following values are recommended: * 150 if profile5qi is 1, 2, 65, 66 or 67. * 1500 if profile5qi is 8 or 9. * 2147483646 (infinity) if profile5qi is 5 or 69.; Default value: 1500.";
      type int32 {
        range "10 | 20 | 30 | 40 | 50 | 60 | 75 | 100 | 150 | 200 | 250 | 300 | 500 | 750 | 1500..2147483646";
      }
      default "1500";
      units "ms";
    }
    leaf tReorderingDl {
      description "Reordering downlink timer used by the receiving-end PDCP entity in the UE. Following values are recommended: * 40 if profile5qi is 1, 2, 65, 66 or 67. * 200 if profile5qi is 5, 8, 9 or 69.; Default value: 200.";
      type int32 {
        range "0..2 | 4..5 | 8 | 10 | 15 | 20 | 30 | 40 | 50 | 60 | 80 | 100 | 120 | 140 | 160 | 180 | 200 | 220 | 240 | 260 | 280 | 300 | 500 | 750 | 1000 | 1250 | 1500 | 1750 | 2000 | 2250 | 2500 | 2750 | 3000";
      }
      default "200";
      units "ms";
    }
    leaf tReorderingUl {
      description "Reordering uplink timer used by the receiving-end PDCP entity in the gNodeB. Following values are recommended: * 20 if profile5qi is 1, 2, 65, 66 or 67. * 50 is profile5qi is 8 or 9. * 200 if profile5qi is 5 or 69.; Default value: 20.";
      type int32 {
        range "0..2 | 4..5 | 8 | 10 | 15 | 20 | 30 | 40 | 50 | 60 | 80 | 100 | 120 | 140 | 160 | 180 | 200 | 220 | 240 | 260 | 280 | 300 | 500 | 750 | 1000 | 1250 | 1500 | 1750 | 2000 | 2250 | 2500 | 2750 | 3000";
      }
      default "20";
      units "ms";
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping CUCP5qiTable-attributes {
    leaf cUCP5qiTableId {
      description "The value component of the RDN..";
