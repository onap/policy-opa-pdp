      description "Number of normal EN-DC SCG radio resource releases..";
      type uint64;
      config false;
    }
    leaf pmNrdcSetupUeMnSuccHoInterGnb {
      description "Number of successful NR-DC UE setup attempts during inter-gNodeB handover. Counted on Master Node side..";
      type uint64;
      config false;
    }
    leaf pmEndcRelUeAbnormalMenbActT310Expiry {
      description "Number of abnormal EN-DC SCG radio resource releases triggered by MeNodeB with T310-Expiry SCG failure. UE is considered in session at time of release..";
      type uint64;
      config false;
    }
    leaf pmUeCtxtEstabAtt {
      description "Number of UE context establishment attempts..";
      type uint64;
      config false;
    }
