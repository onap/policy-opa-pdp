      type uint64;
      config false;
    }
    leaf pmCellBoosterCarrWakeUp {
      description "Number of times a decision is made to wake corresponding cell up because of traffic load. For more information, see NR Booster Carrier Sleep in CPI library..";
      type uint64;
      config false;
    }
    leaf-list pmCaConfigDlSumEndcDistr {
      description "Sum of UEs using this cell as PSCell with configured downlink (DL) SCells for EN-DC UEs. Ranges: Bin[0]: Number of EN-DC UEs configured with one PSCell only and no SCell. Bin[1]: Number of EN-DC UEs configured with one PSCell and one SCell. Bin[2]: Number of EN-DC UEs configured with one PSCell and two SCells. ... Bin[31]: Number of EN-DC UEs configured with one PSCell and thirty-one SCells. Compressed: True.";
      type uint64;
      max-elements 32;
    }
    leaf pmNrdcSetupUeMnAttInitBufUl {
