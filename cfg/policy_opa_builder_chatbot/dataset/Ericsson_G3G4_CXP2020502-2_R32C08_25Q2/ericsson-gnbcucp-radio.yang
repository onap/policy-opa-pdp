        description "Measurement Periodicity NR-AoA is used when having same value as Measurement Periodicity. E-CID MEASUREMENT INITIATION REQUEST is accepted if Information Element Measurement Periodicity NR-AoA (NR Angle of Arrival) has same value as Information Element Measurement Periodicity.";
      }
      enum AOA_PERIODICITY {
        description "Measurement Periodicity NR-AoA used. Information Element Measurement Periodicity NR-AoA (NR Angle of Arrival) in E-CID MEASUREMENT INITIATION REQUEST is used in case measurement quantity NR-AoA is requested.";
      }
    }
  }
  typedef UlCaConfigurationMode {
    description "Configuration mode for uplink aspect of SCell.";
    type enumeration {
      enum IMMEDIATE {
        description "Uplink aspect of SCell is configured in first NR RRC Reconfiguration. Uplink SCell configuration does not use PCell coverage measurement report from UE.";
      }
      enum DELAYED_ALWAYS {
        description "Uplink aspect of SCell is configured in subsequent NR RRC Reconfiguration. First NR RRC Reconfiguration configures downlink aspect of SCell and PCell coverage measurement report in UE. Upon reception of PCell coverage measurement report from UE, uplink aspect of SCell is configured in subsequent NR RRC Reconfiguration.";
      }
      enum DELAYED_CONDITIONAL {
        description "Uplink aspect of SCell is configured in subsequent NR RRC Reconfiguration. When UE-configured maximum output power for uplink carrier aggregation is less than UE-configured maximum output power for PCell, configuration of uplink aspect of SCell is delayed. See 3GPP TS 38.101-1, section 6.2.4 and section 6.2A.4. First NR RRC Reconfiguration configures downlink aspect of SCell and PCell coverage measurement report in UE. Upon reception of PCell coverage measurement report from UE, uplink aspect of SCell is configured in subsequent NR RRC Reconfiguration.";
      }
    }
  }
  typedef UlCompCellCandidate {
    description "Uplink coordinated multi-point reception cell partner status.";
    type enumeration {
      enum __UNDEFINED__ {
      }
    }
  }
  typedef UlCompStatusCause {
    description "Additional information on status of uplink coordinated multi-point reception.";
    type enumeration {
      enum __UNDEFINED__ {
      }
    }
  }
  typedef UlSuMimoFr1Prevention {
    description "Cell types where use of Uplink Single-User MIMO is prevented.";
    type enumeration {
      enum NONE {
        description "No prevention applied.";
      }
      enum TDD {
        description "Prevention applied to TDD cells.";
      }
      enum FDD {
        description "Prevention applied to FDD cells.";
      }
      enum TDD_AND_FDD {
        description "Prevention applied to both FDD and TDD cells.";
      }
    }
  }
  typedef UpdateAmfConnectionOption {
    description "Options on how to handle update of AMFs connections.";
    type enumeration {
      enum RETAIN_EXISTING {
        description "Retains all AMFs and connections that are included in DNS response. AMFs and connections that are not included in the response are removed. For AMFs domain names and IP addresses that are unknown for gNodeB, gNodeB establishes connections to those AMFs.";
      }
      enum RENEW_ALL {
        description "gNodeB releases all connections and AMFs. New DNS lookups are made and AMF termpoints and connections are created for AMFs that are included in DNS response. Traffic may be disturbed by this option.";
      }
    }
  }
