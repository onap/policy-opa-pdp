      description "Number of outgoing inter-RAT handover preparation attemps from NR to LTE in source NR cell..";
      type uint64;
      config false;
    }
    leaf pmEndcRelUeAbnormalMenbActRaProblem {
      description "Number of abnormal EN-DC SCG radio resource releases triggered by MeNodeB with randomAccessProblem SCG failure. UE is considered in session at time of release..";
      type uint64;
      config false;
    }
    leaf pmNgSigConnEstabAttEm {
      description "Number of NG signaling connection establishment attempts for connections with Emergency RRC establishment cause..";
      type uint64;
      config false;
    }
    leaf-list pmDrbRelNormal5qi {
      description "Number of normal DRB releases for each 5QI. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf pmRrcConnLevelMaxNrDc {
      description "Peak number of UEs configured with NR-DC, counted on Secondary Node Mode side..";
      type int64;
      config false;
    }
    leaf pmUeCtxtEstabAttMdtConsent {
      description "Number of times MDT is allowed in UE context establishment attempts..";
      type uint64;
      config false;
    }
    leaf pmEndcUeMeasurementReportPuem {
      description "Sum of periodic UE measurement reports for EN-DC..";
      type uint64;
      config false;
    }
    leaf pmHoPrepRejCellInvalid {
      description "Number of rejected Xn, NG, Inter-RAT handovers in NR SA because cell is barred or reserved..";
      type uint64;
      config false;
    }
    leaf pmNrdcRelUeSnAbnormalSnInit {
      description "Number of abnormal NR-DC UE releases initiated by Secondary Node. Counted on Secondary Node side. If counter is stepped due to a RESET message this can be seen in sn_nrdc_release_initiating_message..";
      type uint64;
      config false;
    }
    leaf pmDrbLevelSumEndc {
      description "Sum of all sample values recorded for number of NR EN-DC DRBs..";
      type uint64;
      config false;
    }
    leaf pmHoPrepSuccOutInterGnb {
      description "Number of successful outgoing NR inter-gNodeB NG or Xn handover preparations in source NR cell..";
      type uint64;
      config false;
    }
    leaf pmHoPrepRejInInterGnbUeAdmission {
      description "Number of failed incoming inter-gNodeB handovers in NR SA because of admission control. Deprecated: Since 23.Q4. Planned to be removed. Replaced by NRCellCU::pmHoPrepRejInInterGnbUeCapacityLimit.; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf pmHoExeAttOutInterGnbIntraF {
      description "Number of outgoing NR intra-frequency inter-gNodeB NG or Xn handover execution attempts in source NR cell..";
      type uint64;
      config false;
    }
    leaf pmNrdcSetupUeRejCellInvalid {
      description "Number of rejected NR-DC UE setup attempts counted on Secondary Node side and rejected inter-gNodeB PSCell change resource allocation requests for NR-DC in target NR cell because cell is barred or reserved..";
      type uint64;
      config false;
    }
    leaf pmNrdcPSCellChangeResAllocSnAttInterSgnb {
      description "Number of inter-gNodeB PSCell change resource allocation requests for NR-DC in target NR cell..";
      type uint64;
      config false;
    }
    leaf-list pmDrbEstabAttInit5qi {
      description "Number of initial DRB establishment attempts for each 5QI. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf pmHoPrepSuccOutIntraGnb {
      description "Number of successful NR intra-gNodeB handover preparations in source NR cell..";
      type uint64;
      config false;
    }
    leaf pmSaUeMeasurementReport {
      description "Sum of all UE measurement reports for NR SA..";
      type uint64;
      config false;
    }
    leaf pmUeCtxtRetrieveSuccRrcReest {
      description "Number of successfully completed Retrieve UE Context procedures triggered by RRC Connection Reestablishment procedure. See 3GPP TS 38.423, Retrieve UE Context Response..";
      type uint64;
      config false;
    }
    leaf pmEndcRelUeAbnormalMenbActRlcMaxRetx {
      description "Number of abnormal EN-DC SCG radio resource releases triggered by MeNodeB with Rlc-MaxNumRetx SCG failure. UE is considered in session at time of release..";
      type uint64;
      config false;
    }
    leaf pmHoPrepSuccOutEutranTs {
      description "Number of successful outgoing inter-RAT handover preparations for traffic steering reason from NR to LTE in source NR cell..";
      type uint64;
      config false;
    }
    leaf pmHoPrepSuccOutIntraGnbIntraF {
      description "Number of successful NR intra-frequency intra-gNodeB handover preparations in source NR cell..";
      type uint64;
      config false;
    }
    leaf-list pmDrbRelAbnormalAmfAct5qi {
      description "Number of abnormal active DRB releases triggered by AMF for each mapped 5QI. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf pmNgSigConnEstabSuccMos {
      description "Number of successful NG signaling connection establishments for connections with RRC establishmentCause mo-Signalling. See 3GPP TS 38.331, RRC Setup Request..";
      type uint64;
      config false;
    }
    leaf pmEndcCaConfigSucc {
      description "Number of successful SCell configurations in serving PSCell, including configuration of first SCell..";
      type uint64;
      config false;
    }
    leaf pmEndcPSCellChangeAttIntraSgnbIntraF {
      description "Number of intra-SgNodeB intra-frequency PSCell change attempts for EN-DC in source NR cell that are not interrupted by a MeNodeB-initiated procedure, for example, MN mobility. See 3GPP TS 37.340 for definition of PSCell..";
      type uint64;
      config false;
    }
    leaf pmCaConfigSucc {
      description "Number of successful SCell configurations in serving PCell, including configuration of first SCell. Deprecated: Since 25.Q2. Planned to be removed. Replaced by NRCellCU::pmCaSCellConfigSucc.; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf pmDrbLevelMaxSa {
      description "Peak number of NR standalone DRBs for UEs in RRC Connected mode. For NR-DC, only DRBs from Master Node are included..";
      type int64;
      config false;
    }
    leaf pmCaSCellReselectionSuccTs {
      description "Number of successful SCell Reselections in PCell triggered by Multi-Layer Coordination or Periodic Multi-Layer Coordination. At SCell Reselection PCell remains unchanged. One or more SCell can be changed to a new frequency. One or more of current SCells can be reused at SCell Reselection..";
      type uint64;
      config false;
    }
    leaf pmNrdcSetupUeSnSucc {
      description "Number of successful NR-DC UE setup attempts. Counted on Secondary Node side..";
      type uint64;
      config false;
    }
    leaf pmRrcConnEstabSuccMos {
      description "Successful RRC Connection Establishment procedure where establishmentCause is mo-Signalling. See 3GPP TS 38.331, RRC Setup Complete..";
      type uint64;
      config false;
    }
    leaf pmHoPrepAttOutInterGnb {
      description "Number of outgoing NR inter-gNodeB NG or Xn handover preparation attempts in source NR cell..";
      type uint64;
      config false;
    }
    leaf pmEndcPSCellChangeAttInterSgnbIntraF {
      description "Number of inter-SgNodeB intra-frequency PSCell change attempts for EN-DC in source NR cell that are not interrupted by a MeNodeB-initiated procedure, for example, MN mobility. See 3GPP TS 37.340 for definition of PSCell..";
      type uint64;
      config false;
    }
    leaf pmHoPrepRejInIntraGnbMpLoad {
      description "Number of rejected intra-gNodeB handovers in NR SA because Baseband MP load control indicates OVERLOAD or VERY HIGH state..";
      type uint64;
      config false;
    }
    leaf pmAnrNeighbRelAddNr {
