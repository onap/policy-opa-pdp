      description "Number of NR EN-DC DRBs at end of ROP..";
      type int64;
      config false;
    }
    leaf pmEndcRelUeAbnormalSgnb {
      description "Number of abnormal EN-DC SCG radio resource releases triggered by Secondary Node..";
      type uint64;
      config false;
    }
    leaf pmNrdcSetupUeMnAttHoIntraGnb {
      description "Number of successful NR-DC UE setup attempts during intra-gNodeB handover. Counted on Master Node side..";
      type uint64;
      config false;
    }
    leaf-list pmDrbRelAbnormalGnbArp {
      description "Number of abnormal DRB releases triggered by either local or external gNodeB for each Allocation and Retention Priority level. Compressed: True Deprecated: Since 24.Q4. Planned to be removed. Replaced by NRCellCU::pmDrbRelAbnormalGnb2Arp; MOM flags: noNotification.";
      type uint64;
      max-elements 16;
    }
    leaf pmHoExeAttOutIntraGnbTs {
      description "Number of NR intra-gNodeB handover execution attempts in source NR cell because of traffic steering..";
      type uint64;
      config false;
    }
    leaf pmRrcConnEstabSuccEm {
