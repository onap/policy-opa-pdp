        enum MS_1024;
        enum MS_2048;
        enum MS_5120;
        enum MS_10240;
        enum MS_20480;
        enum MS_40960;
        enum MIN_1;
        enum MIN_6;
        enum MIN_12;
        enum MIN_30;
      }
    }
    leaf reportQuantity {
      type enumeration {
        enum RSRP;
        enum RSRQ;
        enum SINR;
        enum RSRP_RSRQ;
        enum RSRP_SINR;
        enum RSRQ_SINR;
        enum RSRP_RSRQ_SINR;
      }
    }
  }
  grouping ReportQuantityCell-struct {
    description "Cell measurement quantities to be included in measurement report.";
    leaf rsrp {
      description "Default value: true.";
      type boolean;
      default "true";
    }
    leaf rsrq {
      description "Default value: true.";
      type boolean;
      default "true";
    }
    leaf sinr {
      description "Default value: false.";
      type boolean;
      default "false";
    }
  }
  grouping RfspSpidPair-struct {
    description "RAT Frequency Selection Priority (RFSP) and its mapped Subscriber Profile ID (SPID) value.";
    leaf rfsp {
      description "range 1..256.";
      type eytypes:int32_range_1-256;
    }
    leaf spid {
      description "range 1..256.";
      type eytypes:int32_range_1-256;
    }
  }
  grouping SliceSelectionAssistInfo-struct {
    description "Single Network Slice Selection Assistance Information (S-NSSAI).";
    leaf sd {
      description "range 0..16777215.";
      type eytypes:int32_range_0-16777215;
    }
    leaf sst {
      description "range 0..255.";
      type eytypes:int32_range_0-255;
    }
  }
  grouping SsRssiMeasurement-struct {
    description "Set of slots and symbols, within SMTC measurement duration, used for SS-RSSI measurement.";
    leaf endSymbol {
      type int32 {
        range "1 | 5 | 7 | 11";
      }
    }
    leaf measurementSlots {
      description "length 1..80.";
      type string {
        length "1..80";
        pattern "[0]*1[01]*";
      }
    }
  }
  grouping TimePeriod-struct {
    description "Time period for start and end time of week days which is not allowed for energy saving.";
    leaf endTime {
      description "length 5..5; Default value: 22:00.";
      type string {
        length "5";
        pattern "([0-1][0-9]|2[0-3]):([0-5][0-9])";
      }
      default "22:00";
    }
    leaf fri {
      description "Default value: true.";
      type boolean;
      default "true";
    }
    leaf mon {
      description "Default value: true.";
      type boolean;
      default "true";
    }
    leaf sat {
      description "Default value: true.";
      type boolean;
      default "true";
    }
    leaf startTime {
      description "length 5..5; Default value: 06:00.";
      type string {
        length "5";
        pattern "([0-1][0-9]|2[0-3]):([0-5][0-9])";
      }
      default "06:00";
    }
    leaf sun {
      description "Default value: true.";
      type boolean;
      default "true";
    }
    leaf thu {
      description "Default value: true.";
      type boolean;
      default "true";
    }
    leaf tue {
      description "Default value: true.";
      type boolean;
      default "true";
    }
    leaf wed {
      description "Default value: true.";
      type boolean;
      default "true";
    }
  }
