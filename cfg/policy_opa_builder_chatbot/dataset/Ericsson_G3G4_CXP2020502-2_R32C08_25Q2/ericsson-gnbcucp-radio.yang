    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
  }
  grouping DESManagementFunction-attributes {
    leaf dESManagementFunctionId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf desSwitch {
      description "Whether energy saving for cell is enabled.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf energySavingState {
      description "Energy saving state for cell..";
      type enumeration {
        enum IS_NOT_ENERGYSAVING;
        enum IS_ENERGYSAVING;
      }
      config false;
    }
    list esNotAllowedTimePeriod {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct sequence entry.";
      }
      min-elements 0;
      uses TimePeriod-struct;
    }
    list intraRatEsActivationOriginalCellLoadParameters {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "Enables energy saving in cell. If conditions in parameter set are met, cell initiates transition to energy saving state by using NR Booster Carrier Sleep feature..";
      uses LoadParameters-struct;
    }
    leaf periodicEsDuration {
      description "Duration for cell to periodic transition from IS_ENERGYSAVING back to IS_NOT_ENERGYSAVING state. Duration is only valid during time period when energy saving is allowed. When timer is expired: - If cell energySavingState is IS_ENERGYSAVING, transition to IS_NOT_ENERGYSAVING happens. - If cell is BARRED with value of NRCellDU::cellBarredReason equal to BOOSTER_CARRIER_SLEEP, transition to NOT_BARRED happens. If 0, energy saving has no periodic transition.; Default value: 120.";
      type int32 {
        range "0 | 5..1440";
      }
      default "120";
      units "minute";
    }
    leaf requiredWakeUpTime {
      description "Time for cell transition from OUT_OF_SERVICE to IN_SERVICE.; range 15..600; Default value: 180.";
      type int32 {
        range "15..600";
      }
      default "180";
      units "s";
    }
  }
  grouping EmCall-attributes {
    leaf-list arpPrioEm5qi1List {
      description "ARP level values used for emergency calls in QoS flow with 5qi = 1. If empty, no Allocation and Retention Priority (ARP) level is interpreted as emergency call..";
      type eytypes:int32_range_1-15-7;
      ordered-by user;
      min-elements 0;
      max-elements 15;
    }
    leaf-list arpPrioEm5qi5List {
      description "ARP level values used for emergency calls in QoS flow with 5qi = 5. If empty, no Allocation and Retention Priority (ARP) level is interpreted as emergency call..";
      type eytypes:int32_range_1-15-7;
      ordered-by user;
      min-elements 0;
      max-elements 15;
