    leaf ueMCCellProfileUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ulQualityThreshIncomingHo {
      description "Threshold value for uplink radio quality in target cell at inter-frequency incoming handover. Below this threshold, target cell uplink quality is considered critical for UE and incoming handover is rejected. Only applicable if checkUlQualityIncomingHo is true.; range -150..500; Default value: 70.";
      type int32 {
        range "-150..500";
      }
      default "70";
      units "dB";
    }
  }
  grouping UeMCEUtranFreqRelProfile-attributes {
    leaf blindRwrAllowed {
      description "Whether this frequency relation is used as blind release with redirect candidate. Applied at blind release with redirect triggered by poor coverage or when UE fails capability check. If true for more than one E-UTRAN frequency relation, frequency relation with lowest ARFCN is used. If false for all E-UTRAN frequency relations, UE will be released to idle without redirection..";
      type boolean;
    }
    leaf connModeAllowedPCell {
      description "Whether placing PCell on E-UTRAN frequency defined by E-UTRAN frequency relation is allowed. Applies to UEs that use cell as PCell for poor coverage triggered handover or blind release with redirect to this cell. Blind release with redirect can be triggered by poor coverage or when UE fails capability check..";
      type boolean;
    }
    leaf connModePrioPCell {
      description "Connected mode PCell priority for E-UTRAN frequency relation. Applies to UEs that use cell as PCell. Used to decide preference on which E-UTRAN frequency to place PCell in connected mode. 0 means frequency relation with lowest priority. 7 means frequency relation with highest priority. Applicable only when connModeAllowedPCell attribute is true.; range 0..7.";
      type eytypes:int32_range_0-7;
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained UeMCEUtranFreqRelProfileUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
    leaf ueMCEUtranFreqRelProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
