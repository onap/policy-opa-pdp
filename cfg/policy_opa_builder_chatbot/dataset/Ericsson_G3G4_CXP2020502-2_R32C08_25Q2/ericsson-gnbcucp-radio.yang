    }
    leaf uacProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping UaiProfile-attributes {
    leaf uaiProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained UaiProfileUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
  }
  grouping UaiProfileUeCfg-attributes {
    leaf overheatingAssistanceConfig {
      description "Whether UE is configured to provide overheating assistance information. If true, overheating assistance config is sent to UEs with overheating indication capabilities in RRCReconfiguration messages.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf overheatingIndProhibitTimer {
      description "Overheating indication prohibit timer for overheating assistance information reporting (T345).; Default value: 20.";
      type int32 {
        range "0 | 5 | 10 | 20 | 50 | 100 | 200 | 300 | 600 | 900 | 1200 | 3000 | 6000";
      }
      default "20";
      units "s";
    }
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf releasePrefConfig {
      description "Whether UE is configured to inform gNodeB about the UE preference to leave RRC_CONNECTED state. If true, release preference configuration is sent in RRCReconfiguration message, if UE has release preference indication capabilities.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf releasePrefOverride {
      description "Whether preference set by operator overrides preferredRRC-State in UEAssistanceInformation. If NO_PREFERENCE, preferredRRC-State in UE assistance information is not changed, otherwise preference set by operator overrides preferredRRC-State in UE assistance information..";
      type enumeration {
        enum IDLE;
        enum INACTIVE;
        enum NO_PREFERENCE;
      }
    }
    leaf releasePrefProhibitTimer {
      description "Prohibit timer for release preference assistance information reporting (T346f)..";
      type enumeration {
        enum S0;
        enum S0DOT5;
        enum S1;
        enum S2;
        enum S3;
        enum S4;
        enum S5;
        enum S6;
        enum S7;
        enum S8;
        enum S9;
        enum S10;
        enum S20;
        enum S30;
        enum INFINITY;
      }
    }
    leaf uaiProfileUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping UcmCellProfile-attributes {
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf ucmCellProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ucmCellTargetIntensity {
      description "Target intensity of UE coverage measurements per hour for cell.; range 1..100; Default value: 10.";
      type eytypes:int32_range_1-100-3;
      default "10";
    }
    leaf ucmEnabled {
      description "Whether UE coverage measurement is enabled in NR cell.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf ucmSelectionProbability {
      description "Probability for inactive UE to be selected for UE coverage measurements.; range 1..100; Default value: 100.";
      type eytypes:int32_range_1-100;
      default "100";
      units "percent";
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained UcmCellProfileUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping UcmCellProfileUeCfg-attributes {
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf ucmCellProfileUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ucmMaxFreqLayerToMeas {
      description "Maximum number of NR and E-UTRAN frequencies for concurrent UE coverage measurement per UE. If 0, no measurements are configured.; range 0..16; Default value: 7.";
      type eytypes:int32_range_0-16;
      default "7";
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 32;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping UcmEUtranFreqRelProfile-attributes {
    list reportConfigPeriodicalEutran {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "Report configuration setting for periodical UE coverage measurements..";
      uses ReportConfigPeriodicalEUtran-struct;
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf ucmEUtranFreqRelProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ucmTargetFactor {
      description "Multiplication factor to calculate target intensity of UE coverage measurements per hour. UE coverage measurement intensity is multiplied by this factor. If 0, no measurements are configured.; range 0..36; Default value: 1.";
      type int32 {
        range "0..36";
      }
      default "1";
    }
  }
  grouping UcmNrFreqRelProfile-attributes {
    list reportConfigPeriodical {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "Report configuration setting for periodical UE coverage measurements. Struct member reportInterval can only be MS_120, MS_240, MS_480 or MS_640. Struct member reportAmount can only be R1, R2 or R4..";
      uses ReportConfigPeriodical-struct;
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf ucmNrFreqRelProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ucmTargetFactor {
      description "Multiplication factor to calculate target intensity of UE coverage measurements per hour. UE coverage measurement intensity is multiplied with this factor. If 0, no measurements are configured.; range 0..36; Default value: 1.";
      type int32 {
        range "0..36";
      }
      default "1";
    }
  }
  grouping UeAdmissionGroupDefinition-attributes {
    leaf chipsetRef {
      description "Reference to an instance of Chipsets MO. Special <Value> \"ref\" for <Variable> chipset in selectionCriteria represents chipset <ValueList> defined via this reference. If empty, represented chipset <ValueList> is empty..";
      type string;
    }
    leaf imeiSvRef {
      description "Reference to an instance of ImeiSvs MO. Special <Value> \"ref\" for <Variable> imeisv in selectionCriteria represents imeisv <ValueList> defined via this reference. If empty, represented imeisv <ValueList> is empty..";
      type string;
    }
    leaf selectionCriteria {
      description "UE admission group selection criteria. Defines selection criteria that UE needs to fulfill to belong to UE admission group instance. If selection criteria evaluates to True, UE fulfills UE admission group instance. If selection criteria evaluates to False or Unknown, UE does not fulfill UE admission group instance. If selection criteria evaluates to True for more than one UE admission group instance, UE belongs to UE admission group instance with highest setting of ueAdmissionGroupPriority. Syntax: ====== The syntax of selection criteria is defined using Backus-Naur form. <SelectionCriteria> ::= <ParentExpressionList> | \"\" <ParentExpressionList> ::= <ParentExpressionList> <AndOr> < ParentExpressionList> | <Not>? \"(\" <ParentExpressionList> \")\" | <ExpressionList> | <FlowExpressionList> <FlowExpressionList> ::= <FlowExpressionList> <AndOr> <FlowExpressionList> | <Not>? <FlowExpression> <FlowExpression> ::= \"[\"<ExpressionList>\"]\" <ExpressionList> ::= <ExpressionList> <AndOr> <ExpressionList> | <Not>? \"(\" <ExpressionList> \")\" | <Not>? <VariableExpression> <VariableExpression> ::= <Variable> <RelationalOperator> <Value> | <Variable> \"==\" \"{\" <ValueList> \"}\" <ValueList> ::= <Value> \",\" <ValueList> | <Value> <Variable> ::= \"5qi\" | \"arp\" | \"cgrole\" | \"chipset\" | \"imeisv\" | \"imeisvn\" | \"imeitac\" | \"pagingPrio\" | \"pCellOnlyUe\" | \"plmn\" | \"qci\" | \"redCapUe\" | \"rfsp\" | \"rrcEstResCause\" | \"snssai\" | \"spid\" | \"voNrUe\" <AndOr> ::= \"&&\" | \"||\" <Not> ::= \"!\" <RelationalOperator> ::= \"==\" | \"!=\" | \"<\" | \"<=\" | \">=\" | \">\" A list of possible values can be specified in the form <Variable> == {<value1>, <value2>, ... , <valueN>}. This statement is equivalent to writing (<Variable> == <value1> || <Variable> == <value2> || ... || <Variable> == <valueN>). Up to 4 <FlowExpression> can be defined in <SelectionCriteria>. Whitespaces are allowed in the string for improved readability and are removed prior to evaluation. Question mark (?) means zero or one occurrence. For example, <Not>? makes <Not> optional. Syntax is case sensitive. Semantic: ======== Selection criteria evaluation is defined by the following semantic rules. If empty or set to empty string \"\", selection criteria always evaluates to True. Selection criteria evaluation is done per UE with the current applicable UE <Variable> values as input. List of UE <Variable> values that are applicable to NR standalone and EN-DC, respectively, is defined in Variable Definitions section below. Selection criteria for a UE is evaluated separately for each flow using applicable flow-dependent <Variable> together with rest of applicable UE <Variable>. For UE in NR standalone flow-dependent <Variable> 5qi, arp, and snssai are applicable. For UE in EN-DC flow-dependent <Variable> qci, and arp are applicable. Selection criteria evaluates to True if any of the flows evaluates to True. If UE does not have a flow, flow-dependent <Variable> values are evaluated as unknown variable values. If selection criteria shall match combination of flow-dependent <Variable>, then <FlowExpression> and <FlowExpressionList> must be used. Note: An <ExpressionList> defined as <VariableExpression> && <VariableExpression>, for which both <VariableExpression> relate to flow-dependent <Variable>, needs special attention. Example: <ExpressionList> = \"5qi==5 && 5qi==9\" always evaluate to False for UE in NR standalone even if UE has one flow with 5qi=5 and one flow with 5qi=9. Example: <ExpressionList> = \"5qi>=7 && 5qi<=11\" will evaluate to True for UE in NR standalone if UE has any flow with 5qi between 7 and 11. <FlowExpression> is defined as \"[\"<ExpressionList>\"]\" and indicates that an <ExpressionList> is evaluated per QoS flow independent of other <ExpressionList>. Example: <FlowExpressionList> = \"[5qi==1] && [5qi==5]\" evaluates to True for UE in NR standalone if UE has any flow with 5qi=1 and any flow with 5qi=5. In the example, [5qi==1] must match one flow, and [5qi==5] must match one flow. <VariableExpression> evaluates to Unknown if <Variable> is not known or if the <Variable> value is not valid. <VariableExpression> evaluates to True or False if <Variable> value is known and valid. <Value> \"ref\" is a special <Value> of <Variable> representing <ValueList> defined via corresponding reference attribute. For <Variable> chipset, and imeisv, corresponding reference attribute is chipsetRef, and imeiSvRef respectively. If reference attribute is empty, represented <ValueList> is empty. The logical operators <AndOr> and <Not> apply three way logic as defined below: F=False; T=True; U=Unknown A=Evaluation result of <ExpressionList> or <VariableExpression> B=Evaluation result of <ExpressionList> or <VariableExpression> NOT operator: A !A ----------------- F T U U T F AND operator: A B A && B ------------------- F F F F T F F U F T F F T T T T U U U F F U T U U U U OR operator: A B A || B ------------------ F F F F T T F U U T F T T T T T U T U F U U T T U U U Variable Definitions: ================= Allowed <Value> and <RelationalOperator> depend on <Variable> with limitations given below. 5qi: 5G QoS Identifier (3GPP TS 23.501). Applicable to NR standalone. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 0..255 given in decimal. arp: Priority Level part of the Allocation and Retention Priority (3GPP TS 38.413, 3GPP TS 36.423). Applicable to both NR standalone and EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 1..15 given in decimal. cgrole: Cell group role. Applicable to both NR standalone and EN-DC. Operator: ==, and !=. Value: mcg or scg, where mcg is only applicable to NR standalone. chipset: Chipset identifier. Applicable to both NR standalone and EN-DC. Operator: ==, and !=. Value: String in format \"<vendor>.<variant>.<version>\" matched by regular expression \"(1[0-6]|[0-9])\\\\.(6[0-4]|[1-5]?[0-9])\\\\.(12[0-8]|1[01][0-9]|[1-9]?[0-9])\", or a string constant \"ref\". Description: Chipset identifier composed of three distinct elements: - vendor: 1-2 digit decimal number in range 0..16 - variant: 1-2 digit decimal number in range 0..64 - version: 1-3 digit decimal number in range 0..128 UEs that do not support chipset identifier reporting are represented internally as 0.0.0. Example values: 0.0.0, 1.1.1, 1.2.3, 16.10.100, 16.64.128, ref. imeisv: International Mobile Station Equipment Identity Software Version. Applicable to both NR standalone and EN-DC. Operator: ==, and !=. Value: String in format \"<TAC><SNR><SVN>\" matched by regular expression \"[0-9]{10}[0-9fF]{4}[0-9]{2}\", or string constant \"ref\". Description: IMEISV composed of three distinct elements: - TAC (Type Allocation Code): 8 digit decimal number - SNR (or SN, Serial Number): 2 digit decimal number + 4 digit hexa-decimal number, last four digits are automatically masked with 0xFFFF to match with masked IMEISV - SVN (Software Version Number): 2 digit decimal number Example values: 1234567890123456, 1234567890FFFF12, 1234567890ffff12, ref. imeitac: Type Allocation Code (TAC) part of imeisv. Applicable to both NR standalone and EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: 8 digit decimal number. imeisvn: Software Version Number (SVN) part of imeisv. Applicable to both NR standalone and EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: 2 digit decimal number. pagingPrio: Paging Priority (3GPP TS 23.501). Applicable to NR standalone. Operator: ==, !=, <=, >=, <, and > Value: Integer in range 1..8 given in decimal. Description: Paging priority value received in NGAP Paging message. The received value is valid in UE grouping framework when performing UE group evaluation during time specified by UeGroupSelection::validityTimePagingPrio. pCellOnlyUe: Low-Band and Mid-Band PCell-only capability. Indicates whether the UE is not capable of carrier aggregation in Low-Band or Mid-Band. Only applicable when performing UE group evaluation in NR standalone Master Node. Operator: ==, and !=. Value: Integer in range 0..1 given in decimal, where 0 means false and 1 means true. Only applicable if license for Flexible UE Grouping for Limited Capability UEs is present and feature is active. plmn: Public Land and Mobile Network identifier. Applicable to both NR standalone and EN-DC. Operator: ==, and !=. Value: A string matched by regular expression \"[02-79][0-9][0-9]-[0-9][0-9][0-9]?\". Example values: 070-007, 070-07, 234-56. qci: QoSClass Identifier (3GPP TS 23.401). Applicable to EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 0..255 given in decimal. redCapUe: Reduced Capabilities UE indicator. Applicable to NR standalone. Operator: ==, and !=. Value: Integer in range 0..1 given in decimal, where 0 means false and 1 means true. Description: RedCap UE identification received via LCID in MSG3 (see 3GPP TS 38.331). rfsp: Index to RAT/Frequency Selection Priority (3GPP TS 23.501). Applicable to NR standalone. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 1..256 given in decimal. rrcEstResCause: RRC establishment cause or RRC resume cause. Applicable to NR standalone. Operator: ==, and !=. Value: One of emergency, highPriorityAccess, mt-Access, mo-Signaling, mo-Data, mo-VoiceCall, mo-VideoCall, mo-SMS, mps-PriorityAccess, or mcs-PriorityAccess. Description: Establishment cause value received in RRC Setup Request message or resume cause received in RRC Resume Request message (see 3GPP TS 38.331). The received establishment cause or resume cause is valid in UE grouping framework when performing UE group evaluation during time specified by corresponding validity time attribute value in MO class UeGroupSelection. snssai: Single Network Slice Selection Assistance Information (3GPP TS 23.003). Applicable to NR standalone. Operator: ==, !=, <=, >=, <, and >. Value: input option 1: String in format \"<SST><SD>\" matched by regular expression [0][x][0-9a-fA-F]{8} (8 digit hexa-decimal number). Value: input option 2: Integer in range 0x0..0xffffffff given in hexadecimal. Description: S-NSSAI is composed of two distinct elements: - SST (Slice/Service Type): 2 digit hexa-decimal number - SD (Slice Differentiator): 6 digit hexa-decimal number The SD field has a reserved value \"no SD value associated with the SST\" defined as hexadecimal FFFFFF/ffffff. Example values, input option 1: - 0x050000EE (SST=0x05,SD=0x0000EE) - 0x2effffff (SST=0x2e,SD=0xffffff // no SD associated with the SST) Example values, input option 2: - 0x1 (SST=0x00,SD=0x000001) - 0x50000EE (SST=0x05,SD=0x0000EE) - 0x150000EE (SST=0x15,SD=0x0000EE) spid: Subscriber Profile ID for RAT/Frequency Priority (3GPP TS 36.300). Applicable to EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 1..256 given in decimal. voNrUe: Low-Band and Mid-Band VoNR capability. Only applicable when performing UE group evaluation in NR standalone Master Node. Operator: ==, and !=. Value: Integer in range 0..1 given in decimal, where 0 means false and 1 means true. Operator Precedence Order: ======================= The logical and relation operators are evaluated according to the precedence order listed below. --------------------------------------------- 1 (highest precedence) < Less than <= Less than or equal > Greater than >= Greater than or equal == Equal != Not equal ------------------------------------------- 2 ! (Not) --------------------------------------------- 3 && (And) --------------------------------------------- 4 (lowest precedence) || (Or) --------------------------------------------- The NOT operator \"!\" negates the following <ParentExpressionList>, <VariableExpression>, <FlowExpression> or an <ExpressionList> encapsulated in parenthesis. Therefore, expression !a==b && c==d is equivalent to ((!(a==b)) && (c==d)) and different from !(a==b && c==d). Expression !a==b and !(a==b) are equivalent. Since AND operator \"&&\" has higher precedence than OR operator \"||\", a<b || a<c && c<d is equivalent to (a<b || (a<c && c<d)). Surround expression list including OR operator with parenthesis to force OR operator to be evaluated before AND operators outside of the expression list, for example (a<b || a<c) && c<d. Examples: ========= Simple one valued expressions: plmn == 234-56 spid == 1 cgrole == mcg arp > 3 snssai == 0xfedcba98 rrcEstResCause == mo-VoiceCall imeisv == 1234567890FFFF12 imeisv == ref //Special <value> ref represents <ValueList> defined via imeiSvRef. chipset == ref chipset == 1.1.1 //Matches all UEs with chipset identifier: vendor = 1, variant = 1 and version = 1. chipset == 0.0.0 //Matches all UEs that do not support chipset identifier reporting. Value list expressions: spid == {8,9,10,1,155} !plmn == {234-56, 434-567} chipset == {1.1.1, 1.1.2, 1.1.3, ref} //Matches all UEs with chipset identifier: vendor = 1, variant = 1 and version = 1, 2 or 3, or the corresponding vendor, variant and version defined via chipsetRef. imeisv == {1234567890FFFF12, ref, 1234567890FFFF13} //Matches all UEs with imeisv: TAC = 12345678, SNR = 90FFFF and SVN = 12 or 13, or the corresponding TAC, SN and SVN defined via imeiSvRef. Equivalent expressions using ||: (spid == 8 || spid == 9 || spid == 10 || spid == 1 || spid == 155) //Equals to spid == {8, 9, 10, 1, 155}. !(plmn == 234-56 || plmn == 434-567) //Equals to !plmn == {234-56, 434-567}. imeisv == ref || imeisv == 1234567890FFFF12|| imeisv == 1234567890FFFF13 //Equals to imeisv == {ref, 1234567890FFFF12, 1234567890FFFF13}. chipset == 1.1.1 || chipset == ref || chipset == 1.1.2 // Equals to chipset == {1.1.1, ref, 1.1.2}. Negative expressions: !5qi==1 //Matches flows with 5qi not equal to 1. 5qi!=1 //Matches flows with 5qi not equal to 1. Negative <FlowExpressions> that produce same result: [!5qi==1] //Matches flows with 5qi not equal to 1. [5qi!=1] //Matches flows with 5qi not equal to 1. <FlowExpressionList> negative expressions: !([5qi==1]) //Matches UEs that do not have flows with 5qi 1. ![5qi==1] //Matches UEs that do not have flows with 5qi 1. Mixed examples: spid == 1 && cgrole == mcg !(spid != 1 || cgrole != mcg) (spid == 8 || spid == 9 || spid == 10 || spid == 1 || spid == 155) && (plmn == 234-56 || plmn == 434-567) Precedence given by \"()\" and sequence alter the evaluation order and result: [5qi==1] && chipset==ref || imeisv==ref && [5qi==5] //Equals to ([5qi==1] && chipset==ref) || (imeisv==ref && [5qi==5]) [5qi==1] && (chipset==ref || imeisv==ref) && [5qi==5] ([5qi==1] && chipset==ref || imeisv==ref) && [5qi==5] [5qi==1] && (chipset==ref || imeisv==ref && [5qi==5]) chipset==ref || [5qi==1] && [5qi==5] && imeisv==ref Examples of selection criteria that shall be avoided since they will always be evaluated to False. <FlowExpression> can be used in these cases. 5qi==5 && 5qi==9 snssai==0x15000000 && snssai==0x17000000 arp==5 && arp==10 qci==5 && qci==9 Example of selection criteria for UE variable snssai: snssai>=15000000 && snssai<=15FFFFFF //Matches UE which has a flow with S-NSSAI SST part equal to 15 regardless of value of S-NSSAI SD part. snssai==15FFFFFF //Matches UE which has a flow with S-NSSAI SST part equal to 15 and S-NSSAI SD part value equal to FFFFFF, meaning no SD value associated with the SST. Flow expressions combined with UE variables: plmn == 234-56 && [5qi==1] && [5qi==9] //Matches UE which has plmn equal to 234-56, any QoS flow with 5qi equal to 1, and any QoS flow with 5qi equal to 9. chipset==1.5.32 && [5qi==9] && ![5qi==1] //Matches UE which has chipset identifier equal to 1.5.32, any QoS flow with 5qi equal to 9, and no QoS flow with 5qi equal to 1. [5qi==1 && snssai == 0xfedcba98] || ([5qi==2] && [snssai == 0xfedcba77]) //Matches UE which has any QoS flow with 5qi equal to 1 and snssai equal to 0xfedcba98, or has any QoS flow with 5qi equal to 2 and snssai equal to 0xfedcba77. voNrUe==1 && chipset==1.1.1 && [5qi==1] //Matches UEs with Low-Band and Mid-Band VoNR capability using chipset 1.1.1, and have an ongoing flow 5qi.; length 1..1000.";
      type string {
        length "1..1000";
      }
    }
    leaf ueAdmissionGroupDefinitionId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ueAdmissionGroupId {
      description "UE admission group identifier. Must be unique among UE admission groups.; range 1..255.";
      type eytypes:int32_range_1-255;
      mandatory true;
    }
    leaf ueAdmissionGroupPriority {
      description "Relative priority among UE admission groups. Must be unique among UE admission groups. If UE fulfills selection criteria for more than one UE admission group, UE admission group with the highest priority is selected. Higher value gives higher priority.; range 1..65535.";
      type eytypes:int32_range_1-65535;
      mandatory true;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping UeCC-attributes {
    leaf ueCCId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping UeCovMeas-attributes {
    leaf ueCovMeasId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping UeGroupSelection-attributes {
    leaf ueGroupSelectionId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf validityTimeEmergencyCause {
      description "Validity time of RRC establishment cause or resume cause emergency. Defines for how long time the IE establishmentCause with value emergency, received in RRCSetupRequest message, or the IE resumeCause with value emergency, received in RRCResumeRequest message, is valid when performing UE group evaluation.; range 1..36000; Default value: 6.";
      type int32 {
        range "1..36000";
      }
      default "6";
      units "s";
    }
    leaf validityTimeHighPrioAccCause {
      description "Validity time of RRC establishment cause or resume cause high priority access. Defines for how long time the IE establishmentCause with value high priority access, received in RRCSetupRequest message, or the IE resumeCause with value high priority access, received in RRCResumeRequest message, is valid when performing UE group evaluation.; range 1..15; Default value: 6.";
      type eytypes:int32_range_1-15;
      default "6";
      units "s";
    }
    leaf validityTimeMcsPrioAccCause {
      description "Validity time of RRC establishment cause or resume cause MCS priority access. Defines for how long time the IE establishmentCause with value mission critical services priority access, received in RRCSetupRequest message, or the IE resumeCause with value mission critical services priority access, received in RRCResumeRequest message, is valid when performing UE group evaluation.; range 1..15; Default value: 6.";
      type eytypes:int32_range_1-15;
      default "6";
      units "s";
    }
    leaf validityTimeMoDataCause {
      description "Validity time of RRC establishment cause or resume cause mobile originating data. Defines for how long time the IE establishmentCause with value mobile originating data, received in RRCSetupRequest message, or the IE resumeCause with value mobile originating data, received in RRCResumeRequest message, is valid when performing UE group evaluation.; range 1..15; Default value: 6.";
      type eytypes:int32_range_1-15;
      default "6";
      units "s";
    }
    leaf validityTimeMoSignallingCause {
      description "Validity time of RRC establishment cause or resume cause mobile originating signaling. Defines for how long time the IE establishmentCause with value mobile originating signaling, received in RRCSetupRequest message, or the IE resumeCause with value mobile originating signaling, received in RRCResumeRequest message, is valid when performing UE group evaluation.; range 1..15; Default value: 6.";
      type eytypes:int32_range_1-15;
      default "6";
      units "s";
    }
    leaf validityTimeMoSmsCause {
      description "Validity time of RRC establishment cause or resume cause mobile originating SMS. Defines for how long time the IE establishmentCause with value mobile originating short message service, received in RRCSetupRequest message, or the IE resumeCause with value mobile originating short message service, received in RRCResumeRequest message, is valid when performing UE group evaluation.; range 1..15; Default value: 6.";
      type eytypes:int32_range_1-15;
      default "6";
      units "s";
    }
    leaf validityTimeMoVideoCallCause {
      description "Validity time of RRC establishment cause or resume cause mobile originating video call. Defines for how long time the IE establishmentCause with value mobile originating video call, received in RRCSetupRequest message, or the IE resumeCause with value mobile originating video call, received in RRCResumeRequest message, is valid when performing UE group evaluation.; range 1..15; Default value: 6.";
      type eytypes:int32_range_1-15;
      default "6";
      units "s";
    }
    leaf validityTimeMoVoiceCallCause {
      description "Validity time of RRC establishment cause or resume cause mobile originating voice call. Defines for how long time the IE establishmentCause with value mobile originating voice call, received in RRCSetupRequest message, or the IE resumeCause with value mobile originating voice call, received in RRCResumeRequest message, is valid when performing UE group evaluation.; range 1..15; Default value: 6.";
      type eytypes:int32_range_1-15;
      default "6";
      units "s";
    }
    leaf validityTimeMpsPrioAccCause {
      description "Validity time of RRC establishment cause or resume cause MPS priority access. Defines for how long time the IE establishmentCause with value multimedia priority service priority access, received in RRCSetupRequest message, or the IE resumeCause with value multimedia priority service priority access, received in RRCResumeRequest message, is valid when performing UE group evaluation.; range 1..15; Default value: 6.";
      type eytypes:int32_range_1-15;
      default "6";
      units "s";
    }
    leaf validityTimeMtAccessCause {
      description "Validity time of RRC establishment cause or resume cause mobile terminating access. Defines for how long time the IE establishmentCause with value mobile terminating access, received in RRCSetupRequest message, or the IE resumeCause with value mobile terminating access, received in RRCResumeRequest message, is valid when performing UE group evaluation.; range 1..15; Default value: 6.";
      type eytypes:int32_range_1-15;
      default "6";
      units "s";
    }
    leaf validityTimePagingPrio {
      description "Validity time of Paging Priority. Defines how long IE Paging Priority, received in NGAP paging message, is valid when performing UE group evaluation.; range 1..15; Default value: 6.";
      type eytypes:int32_range_1-15;
      default "6";
      units "s";
    }
  }
  grouping UeGroupSelectionProfile-attributes {
    leaf chipsetRef {
      description "Reference to an instance of Chipsets MO. Special <Value> \"ref\" for <Variable> chipset in selectionCriteria represents chipset <ValueList> defined via this reference. If empty, represented chipset <ValueList> is empty..";
      type string;
    }
    leaf imeiSvRef {
      description "Reference to an instance of ImeiSvs MO. Special <Value> \"ref\" for <Variable> imeisv in selectionCriteria represents imeisv <ValueList> defined via this reference. If empty, represented imeisv <ValueList> is empty..";
      type string;
    }
    leaf selectionCriteria {
      description "UE group selection criteria. Defines selection criteria that UE needs to fulfill to belong to UE group instance. If selection criteria evaluates to True, UE fulfills UE group instance. If selection criteria evaluates to False or Unknown, UE does not fulfill UE group instance. If selection criteria evaluates to True for more than one UE group instance, UE belongs to UE group instance with highest setting of ueGroupPriority. Syntax: ====== The syntax of selection criteria is defined using Backus-Naur form. <SelectionCriteria> ::= <ParentExpressionList> | \"\" <ParentExpressionList> ::= <ParentExpressionList> <AndOr> < ParentExpressionList> | <Not>? \"(\" <ParentExpressionList> \")\" | <ExpressionList> | <FlowExpressionList> <FlowExpressionList> ::= <FlowExpressionList> <AndOr> <FlowExpressionList> | <Not>? <FlowExpression> <FlowExpression> ::= \"[\"<ExpressionList>\"]\" <ExpressionList> ::= <ExpressionList> <AndOr> <ExpressionList> | <Not>? \"(\" <ExpressionList> \")\" | <Not>? <VariableExpression> <VariableExpression> ::= <Variable> <RelationalOperator> <Value> | <Variable> \"==\" \"{\" <ValueList> \"}\" <ValueList> ::= <Value> \",\" <ValueList> | <Value> <Variable> ::= \"5qi\" | \"arp\" | \"cgrole\" | \"chipset\" | \"imeisv\" | \"imeisvn\" | \"imeitac\" | \"pagingPrio\" | \"pCellOnlyUe\" | \"plmn\" | \"qci\" | \"redCapUe\" | \"rfsp\" | \"rrcEstResCause\" | \"snssai\" | \"spid\" | \"voNrUe\" <AndOr> ::= \"&&\" | \"||\" <Not> ::= \"!\" <RelationalOperator> ::= \"==\" | \"!=\" | \"<\" | \"<=\" | \">=\" | \">\" A list of possible values can be specified in the form <Variable> == {<value1>, <value2>, ... , <valueN>}. This statement is equivalent to writing (<Variable> == <value1> || <Variable> == <value2> || ... || <Variable> == <valueN>). Up to 4 <FlowExpression> can be defined in <SelectionCriteria>. Whitespaces are allowed in the string for improved readability and are removed prior to evaluation. Question mark (?) means zero or one occurrence. For example, <Not>? makes <Not> optional. Syntax is case sensitive. Semantic: ======== Selection criteria evaluation is defined by the following semantic rules. If empty or set to empty string \"\", selection criteria always evaluates to True. Selection criteria evaluation is done per UE with the current applicable UE <Variable> values as input. List of UE <Variable> values that are applicable to NR standalone and EN-DC, respectively, is defined in Variable Definitions section below. Selection criteria for a UE is evaluated separately for each flow using applicable flow-dependent <Variable> together with rest of applicable UE <Variable>. For UE in NR standalone flow-dependent <Variable> 5qi, arp, and snssai are applicable. For UE in EN-DC flow-dependent <Variable> qci, and arp are applicable. Selection criteria evaluates to True if any of the flows evaluates to True. If UE does not have a flow, flow-dependent <Variable> values are evaluated as unknown variable values. If selection criteria shall match combination of flow-dependent <Variable>, then <FlowExpression> and <FlowExpressionList> must be used. Note: An <ExpressionList> defined as <VariableExpression> && <VariableExpression>, for which both <VariableExpression> relate to flow-dependent <Variable>, needs special attention. Example: <ExpressionList> = \"5qi==5 && 5qi==9\" always evaluate to False for UE in NR standalone even if UE has one flow with 5qi=5 and one flow with 5qi=9. Example: <ExpressionList> = \"5qi>=7 && 5qi<=11\" will evaluate to True for UE in NR standalone if UE has any flow with 5qi between 7 and 11. <FlowExpression> is defined as \"[\"<ExpressionList>\"]\" and indicates that an <ExpressionList> is evaluated per QoS flow independent of other <ExpressionList>. Example: <FlowExpressionList> = \"[5qi==1] && [5qi==5]\" evaluates to True for UE in NR standalone if UE has any flow with 5qi=1 and any flow with 5qi=5. In the example, [5qi==1] must match one flow, and [5qi==5] must match one flow. <VariableExpression> evaluates to Unknown if <Variable> is not known or if the <Variable> value is not valid. <VariableExpression> evaluates to True or False if <Variable> value is known and valid. <Value> \"ref\" is a special <Value> of <Variable> representing <ValueList> defined via corresponding reference attribute. For <Variable> chipset, and imeisv, corresponding reference attribute is chipsetRef, and imeiSvRef respectively. If reference attribute is empty, represented <ValueList> is empty. The logical operators <AndOr> and <Not> apply three way logic as defined below: F=False; T=True; U=Unknown A=Evaluation result of <ExpressionList> or <VariableExpression> B=Evaluation result of <ExpressionList> or <VariableExpression> NOT operator: A !A ----------------- F T U U T F AND operator: A B A && B ------------------- F F F F T F F U F T F F T T T T U U U F F U T U U U U OR operator: A B A || B ------------------ F F F F T T F U U T F T T T T T U T U F U U T T U U U Variable Definitions: ================= Allowed <Value> and <RelationalOperator> depend on <Variable> with limitations given below. 5qi: 5G QoS Identifier (3GPP TS 23.501). Applicable to NR standalone. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 0..255 given in decimal. arp: Priority Level part of the Allocation and Retention Priority (3GPP TS 38.413, 3GPP TS 36.423). Applicable to both NR standalone and EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 1..15 given in decimal. cgrole: Cell group role. Applicable to both NR standalone and EN-DC. Operator: ==, and !=. Value: mcg or scg, where mcg is only applicable to NR standalone. chipset: Chipset identifier. Applicable to both NR standalone and EN-DC. Operator: ==, and !=. Value: String in format \"<vendor>.<variant>.<version>\" matched by regular expression \"(1[0-6]|[0-9])\\\\.(6[0-4]|[1-5]?[0-9])\\\\.(12[0-8]|1[01][0-9]|[1-9]?[0-9])\", or a string constant \"ref\". Description: Chipset identifier composed of three distinct elements: - vendor: 1-2 digit decimal number in range 0..16 - variant: 1-2 digit decimal number in range 0..64 - version: 1-3 digit decimal number in range 0..128 UEs that do not support chipset identifier reporting are represented internally as 0.0.0. Example values: 0.0.0, 1.1.1, 1.2.3, 16.10.100, 16.64.128, ref. imeisv: International Mobile Station Equipment Identity Software Version. Applicable to both NR standalone and EN-DC. Operator: ==, and !=. Value: String in format \"<TAC><SNR><SVN>\" matched by regular expression \"[0-9]{10}[0-9fF]{4}[0-9]{2}\", or string constant \"ref\". Description: IMEISV composed of three distinct elements: - TAC (Type Allocation Code): 8 digit decimal number - SNR (or SN, Serial Number): 2 digit decimal number + 4 digit hexa-decimal number, last four digits are automatically masked with 0xFFFF to match with masked IMEISV - SVN (Software Version Number): 2 digit decimal number Example values: 1234567890123456, 1234567890FFFF12, 1234567890ffff12, ref. imeitac: Type Allocation Code (TAC) part of imeisv. Applicable to both NR standalone and EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: 8 digit decimal number. imeisvn: Software Version Number (SVN) part of imeisv. Applicable to both NR standalone and EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: 2 digit decimal number. pagingPrio: Paging Priority (3GPP TS 23.501). Applicable to NR standalone. Operator: ==, !=, <=, >=, <, and > Value: Integer in range 1..8 given in decimal. Description: Paging priority value received in NGAP Paging message. The received value is valid in UE grouping framework when performing UE group evaluation during time specified by UeGroupSelection::validityTimePagingPrio. pCellOnlyUe: Low-Band and Mid-Band PCell-only capability. Indicates whether the UE is not capable of carrier aggregation in Low-Band or Mid-Band. Only applicable when performing UE group evaluation in NR standalone Master Node. Operator: ==, and !=. Value: Integer in range 0..1 given in decimal, where 0 means false and 1 means true. Only applicable if license for Flexible UE Grouping for Limited Capability UEs is present and feature is active. plmn: Public Land and Mobile Network identifier. Applicable to both NR standalone and EN-DC. Operator: ==, and !=. Value: A string matched by regular expression \"[02-79][0-9][0-9]-[0-9][0-9][0-9]?\". Example values: 070-007, 070-07, 234-56. qci: QoSClass Identifier (3GPP TS 23.401). Applicable to EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 0..255 given in decimal. redCapUe: Reduced Capabilities UE indicator. Applicable to NR standalone. Operator: ==, and !=. Value: Integer in range 0..1 given in decimal, where 0 means false and 1 means true. Description: RedCap UE identification received via LCID in MSG3 (see 3GPP TS 38.331). rfsp: Index to RAT/Frequency Selection Priority (3GPP TS 23.501). Applicable to NR standalone. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 1..256 given in decimal. rrcEstResCause: RRC establishment cause or RRC resume cause. Applicable to NR standalone. Operator: ==, and !=. Value: One of emergency, highPriorityAccess, mt-Access, mo-Signaling, mo-Data, mo-VoiceCall, mo-VideoCall, mo-SMS, mps-PriorityAccess, or mcs-PriorityAccess. Description: Establishment cause value received in RRC Setup Request message or resume cause received in RRC Resume Request message (see 3GPP TS 38.331). The received establishment cause or resume cause is valid in UE grouping framework when performing UE group evaluation during time specified by corresponding validity time attribute value in MO class UeGroupSelection. snssai: Single Network Slice Selection Assistance Information (3GPP TS 23.003). Applicable to NR standalone. Operator: ==, !=, <=, >=, <, and >. Value: input option 1: String in format \"<SST><SD>\" matched by regular expression [0][x][0-9a-fA-F]{8} (8 digit hexa-decimal number). Value: input option 2: Integer in range 0x0..0xffffffff given in hexadecimal. Description: S-NSSAI is composed of two distinct elements: - SST (Slice/Service Type): 2 digit hexa-decimal number - SD (Slice Differentiator): 6 digit hexa-decimal number The SD field has a reserved value \"no SD value associated with the SST\" defined as hexadecimal FFFFFF/ffffff. Example values, input option 1: - 0x050000EE (SST=0x05,SD=0x0000EE) - 0x2effffff (SST=0x2e,SD=0xffffff // no SD associated with the SST) Example values, input option 2: - 0x1 (SST=0x00,SD=0x000001) - 0x50000EE (SST=0x05,SD=0x0000EE) - 0x150000EE (SST=0x15,SD=0x0000EE) spid: Subscriber Profile ID for RAT/Frequency Priority (3GPP TS 36.300). Applicable to EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 1..256 given in decimal. voNrUe: Low-Band and Mid-Band VoNR capability. Only applicable when performing UE group evaluation in NR standalone Master Node. Operator: ==, and !=. Value: Integer in range 0..1 given in decimal, where 0 means false and 1 means true. Operator Precedence Order: ======================= The logical and relation operators are evaluated according to the precedence order listed below. --------------------------------------------- 1 (highest precedence) < Less than <= Less than or equal > Greater than >= Greater than or equal == Equal != Not equal ------------------------------------------- 2 ! (Not) --------------------------------------------- 3 && (And) --------------------------------------------- 4 (lowest precedence) || (Or) --------------------------------------------- The NOT operator \"!\" negates the following <ParentExpressionList>, <VariableExpression>, <FlowExpression> or an <ExpressionList> encapsulated in parenthesis. Therefore, expression !a==b && c==d is equivalent to ((!(a==b)) && (c==d)) and different from !(a==b && c==d). Expression !a==b and !(a==b) are equivalent. Since AND operator \"&&\" has higher precedence than OR operator \"||\", a<b || a<c && c<d is equivalent to (a<b || (a<c && c<d)). Surround expression list including OR operator with parenthesis to force OR operator to be evaluated before AND operators outside of the expression list, for example (a<b || a<c) && c<d. Examples: ========= Simple one valued expressions: plmn == 234-56 spid == 1 cgrole == mcg arp > 3 snssai == 0xfedcba98 rrcEstResCause == mo-VoiceCall imeisv == 1234567890FFFF12 imeisv == ref //Special <value> ref represents <ValueList> defined via imeiSvRef. chipset == ref chipset == 1.1.1 //Matches all UEs with chipset identifier: vendor = 1, variant = 1 and version = 1. chipset == 0.0.0 //Matches all UEs that do not support chipset identifier reporting. Value list expressions: spid == {8,9,10,1,155} !plmn == {234-56, 434-567} chipset == {1.1.1, 1.1.2, 1.1.3, ref} //Matches all UEs with chipset identifier: vendor = 1, variant = 1 and version = 1, 2 or 3, or the corresponding vendor, variant and version defined via chipsetRef. imeisv == {1234567890FFFF12, ref, 1234567890FFFF13} //Matches all UEs with imeisv: TAC = 12345678, SNR = 90FFFF and SVN = 12 or 13, or the corresponding TAC, SN and SVN defined via imeiSvRef. Equivalent expressions using ||: (spid == 8 || spid == 9 || spid == 10 || spid == 1 || spid == 155) //Equals to spid == {8, 9, 10, 1, 155}. !(plmn == 234-56 || plmn == 434-567) //Equals to !plmn == {234-56, 434-567}. imeisv == ref || imeisv == 1234567890FFFF12|| imeisv == 1234567890FFFF13 //Equals to imeisv == {ref, 1234567890FFFF12, 1234567890FFFF13}. chipset == 1.1.1 || chipset == ref || chipset == 1.1.2 // Equals to chipset == {1.1.1, ref, 1.1.2}. Negative expressions: !5qi==1 //Matches flows with 5qi not equal to 1. 5qi!=1 //Matches flows with 5qi not equal to 1. Negative <FlowExpressions> that produce same result: [!5qi==1] //Matches flows with 5qi not equal to 1. [5qi!=1] //Matches flows with 5qi not equal to 1. <FlowExpressionList> negative expressions: !([5qi==1]) //Matches UEs that do not have flows with 5qi 1. ![5qi==1] //Matches UEs that do not have flows with 5qi 1. Mixed examples: spid == 1 && cgrole == mcg !(spid != 1 || cgrole != mcg) (spid == 8 || spid == 9 || spid == 10 || spid == 1 || spid == 155) && (plmn == 234-56 || plmn == 434-567) Precedence given by \"()\" and sequence alter the evaluation order and result: [5qi==1] && chipset==ref || imeisv==ref && [5qi==5] //Equals to ([5qi==1] && chipset==ref) || (imeisv==ref && [5qi==5]) [5qi==1] && (chipset==ref || imeisv==ref) && [5qi==5] ([5qi==1] && chipset==ref || imeisv==ref) && [5qi==5] [5qi==1] && (chipset==ref || imeisv==ref && [5qi==5]) chipset==ref || [5qi==1] && [5qi==5] && imeisv==ref Examples of selection criteria that shall be avoided since they will always be evaluated to False. <FlowExpression> can be used in these cases. 5qi==5 && 5qi==9 snssai==0x15000000 && snssai==0x17000000 arp==5 && arp==10 qci==5 && qci==9 Example of selection criteria for UE variable snssai: snssai>=15000000 && snssai<=15FFFFFF //Matches UE which has a flow with S-NSSAI SST part equal to 15 regardless of value of S-NSSAI SD part. snssai==15FFFFFF //Matches UE which has a flow with S-NSSAI SST part equal to 15 and S-NSSAI SD part value equal to FFFFFF, meaning no SD value associated with the SST. Flow expressions combined with UE variables: plmn == 234-56 && [5qi==1] && [5qi==9] //Matches UE which has plmn equal to 234-56, any QoS flow with 5qi equal to 1, and any QoS flow with 5qi equal to 9. chipset==1.5.32 && [5qi==9] && ![5qi==1] //Matches UE which has chipset identifier equal to 1.5.32, any QoS flow with 5qi equal to 9, and no QoS flow with 5qi equal to 1. [5qi==1 && snssai == 0xfedcba98] || ([5qi==2] && [snssai == 0xfedcba77]) //Matches UE which has any QoS flow with 5qi equal to 1 and snssai equal to 0xfedcba98, or has any QoS flow with 5qi equal to 2 and snssai equal to 0xfedcba77. voNrUe==1 && chipset==1.1.1 && [5qi==1] //Matches UEs with Low-Band and Mid-Band VoNR capability using chipset 1.1.1, and have an ongoing flow 5qi.; length 1..1000.";
      type string {
        length "1..1000";
      }
    }
    leaf selectionProbability {
      description "Selection probability for AB testing. Probability for UE to be selected into this UeGroup after fulfilling all selection conditions according to the configured selectionCriteria.; range 0..100; Default value: 100.";
      type eytypes:int32_range_0-100;
      default "100";
      units "percent";
    }
    leaf ueGroupId {
      description "UE group identifier.; range 1..255.";
      type eytypes:int32_range_1-255;
      mandatory true;
    }
    leaf ueGroupPriority {
      description "Relative priority among UE groups. If UE fulfills more than one UeGroupSelectionProfile, UeGroupSelectionProfile with the highest relative priority is applied. Higher value gives higher priority.; range 1..65535.";
      type eytypes:int32_range_1-65535;
      mandatory true;
    }
    leaf ueGroupSelectionProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping UeMC-attributes {
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained UeMCUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
    leaf ueMCId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping UeMCCellProfile-attributes {
    leaf connModeUeAllowedToBarredCell {
      description "Whether UE in RRC Connected Mode is allowed to access cell in BARRED state. If true, UE in RRC Connected Mode can access cell in BARRED state, also valid for EN-DC UE.; Default value: true.";
      type boolean;
      default "true";
    }
    leaf filterCoefficientEUtraRsrp {
      description "Layer 3 average filter coefficient for RSRP measurements on E-UTRA frequencies. Layer 3 average filter coefficient that is applied in UE performing RSRP measurements on E-UTRA frequencies.; Default value: 4.";
      type int32 {
        range "0..9 | 11 | 13 | 15 | 17 | 19";
      }
      default "4";
    }
    leaf filterCoefficientEUtraRsrq {
      description "Layer 3 average filter coefficient for RSRQ measurements on E-UTRA frequencies. Layer 3 average filter coefficient that is applied in UE performing RSRQ measurements on E-UTRA frequencies.; Default value: 11.";
      type int32 {
        range "0..9 | 11 | 13 | 15 | 17 | 19";
      }
      default "11";
    }
    leaf filterCoefficientEUtraSinr {
      description "Layer 3 average filter coefficient for SINR measurements on E-UTRA frequencies. Layer 3 average filter coefficient that is applied in UE performing SINR measurements on E-UTRA frequencies.; Default value: 4.";
      type int32 {
        range "0..9 | 11 | 13 | 15 | 17 | 19";
      }
      default "4";
    }
    leaf filterCoefficientNrRsrpHigh {
      description "Layer 3 average filter coefficient for RSRP measurements on NR frequencies. Layer 3 average filter coefficient that is applied in UE performing RSRP measurements on NR frequencies. Filter coefficient for measurement of NR frequencies with ARFCN-ValueNR value higher than ARFCN-ValueNR defined by freqClassificationThreshold.; Default value: 4.";
      type int32 {
        range "0..9 | 11 | 13 | 15 | 17 | 19";
      }
      default "4";
    }
    leaf filterCoefficientNrRsrpLow {
      description "Layer 3 average filter coefficient for RSRP measurements on NR frequencies. Layer 3 average filter coefficient that is applied in UE performing RSRP measurements on NR frequencies. Filter coefficient for measurement of NR frequencies with ARFCN-ValueNR value lower than or equal to ARFCN-ValueNR defined by freqClassificationThreshold.; Default value: 4.";
      type int32 {
        range "0..9 | 11 | 13 | 15 | 17 | 19";
      }
      default "4";
    }
    leaf filterCoefficientNrRsrqHigh {
      description "Layer 3 average filter coefficient for RSRQ measurements on NR frequencies. Layer 3 average filter coefficient that is applied in UE performing RSRQ measurements on NR frequencies. Filter coefficient for measurement of NR frequencies with ARFCN-ValueNR value higher than ARFCN-ValueNR defined by freqClassificationThreshold.; Default value: 11.";
      type int32 {
        range "0..9 | 11 | 13 | 15 | 17 | 19";
      }
      default "11";
    }
    leaf filterCoefficientNrRsrqLow {
      description "Layer 3 average filter coefficient for RSRQ measurements on NR frequencies. Layer 3 average filter coefficient that is applied in UE performing RSRQ measurements on NR frequencies. Filter coefficient for measurement of NR frequencies with ARFCN-ValueNR value lower than or equal to ARFCN-ValueNR defined by freqClassificationThreshold.; Default value: 11.";
      type int32 {
        range "0..9 | 11 | 13 | 15 | 17 | 19";
      }
      default "11";
    }
    leaf filterCoefficientNrSinrHigh {
      description "Layer 3 average filter coefficient for SINR measurements on NR frequencies. Layer 3 average filter coefficient that is applied in UE performing SINR measurements on NR frequencies. Filter coefficient for measurement of NR frequencies with ARFCN-ValueNR value higher than ARFCN-ValueNR defined by freqClassificationThreshold.; Default value: 4.";
      type int32 {
        range "0..9 | 11 | 13 | 15 | 17 | 19";
      }
      default "4";
    }
    leaf filterCoefficientNrSinrLow {
      description "Layer 3 average filter coefficient for SINR measurements on NR frequencies. Layer 3 average filter coefficient that is applied in UE performing SINR measurements on NR frequencies. Filter coefficient for measurement of NR frequencies with ARFCN-ValueNR value lower than or equal to ARFCN-ValueNR defined by freqClassificationThreshold.; Default value: 4.";
      type int32 {
        range "0..9 | 11 | 13 | 15 | 17 | 19";
      }
      default "4";
    }
    leaf freqClassificationThreshold {
      description "Frequency classification threshold. Threshold is provided as ARFCN-ValueNR value and defines which filter coefficients that are used by UE when measuring on NR frequencies.; range 0..3279164; Default value: 3279163.";
      type int32 {
        range "0..3279164";
      }
      default "3279163";
    }
    leaf noOfInvIntraFreqTrigPCSearch {
      description "Number of invalid mobility targets needed to trigger PCell candidates search. Configuration of number of better intra-frequency PCell measurement reports for invalid mobility targets needed to trigger PCell candidates search outside PCell search zone.; range 1..3; Default value: 1.";
      type int32 {
        range "1..3";
      }
      default "1";
    }
    leaf prohibitCellTrigMob {
      description "Whether prohibited cell triggered mobility is enabled. If not DISABLED, configure measurements for searching PCell candidates on other frequencies in following cases: - UE is outside of PCell search zone and number of reported better intra-frequency PCell measurements for invalid mobility targets has reached noOfInvIntraFTrigPCSearch. - Inter-gNB intra-frequency handover is rejected by target cell. For ENABLED_EUTRAN_ONLY, E-UTRAN frequency measurements are configured for PCell candidates search. For ENABLED_ALL, both NR and E-UTRAN frequency measurements are configured for PCell candidates search..";
      type enumeration {
        enum DISABLED;
        enum ENABLED_EUTRAN_ONLY;
        enum ENABLED_ALL;
      }
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf sMeasure {
      description "RSRP measurement threshold when UE is required to perform measurements on non-serving cells. Corresponds to RRC parameter s-MeasureConfig and choice ssb-RSRP. If empty or 1000, threshold is not used. Value -29 corresponds to special value of ssb-RSRP = infinity.; Default value: -29.";
      type int32 {
        range "-156..-29 | 1000";
      }
      default "-29";
      units "dBm";
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained UeMCCellProfileUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
    leaf ueMCCellProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping UeMCCellProfileUeCfg-attributes {
    leaf checkUlQualityIncomingHo {
      description "Whether uplink quality evaluation is enabled at inter-frequency incoming handover.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf connModeUeAllowedToResCell {
      description "Whether UE in RRC Connected Mode is allowed to access cell in RESERVED state. If true, UE in RRC Connected Mode can access cell in RESERVED state, also valid for EN-DC UE.; Default value: true.";
      type boolean;
      default "true";
    }
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
