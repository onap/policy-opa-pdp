      type uint64;
      config false;
    }
    leaf pmCaSCellReselectionAttTs {
      description "Number of SCell Reselection attempts in PCell triggered by Multi-Layer Coordination or Periodic Multi-Layer Coordination. At SCell Reselection PCell remains unchanged. One or more SCell can be changed to a new frequency. One or more of current SCells can be reused at SCell Reselection..";
