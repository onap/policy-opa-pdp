      type int32 {
        range "0 | 40 | 64 | 80 | 100 | 128 | 160 | 256 | 320 | 480 | 512 | 640 | 1024 | 1280 | 2560 | 5120";
      }
      default "160";
      units "ms";
    }
    leaf timeToTriggerA1 {
      description "Default value: -1.";
      type int32 {
        range "-1..0 | 40 | 64 | 80 | 100 | 128 | 160 | 256 | 320 | 480 | 512 | 640 | 1024 | 1280 | 2560 | 5120";
      }
      default "-1";
      units "ms";
    }
  }
  grouping AdditionalPLMNInfo-attributes {
    leaf additionalPLMNInfoId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf nRTAC {
      description "NR Tracking Area Code (TAC). If empty, NR standalone is not supported for PLMN IDs in pLMNIdList..";
      type int32;
      config false;
    }
    list pLMNIdList {
      config false;
      min-elements 1;
      max-elements 12;
      uses PLMNId-struct;
    }
  }
  grouping AdmissionControl-attributes {
    leaf admissionControlId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping AdmissionLimit-attributes {
    leaf admissionLimitId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf maxConnectedUe {
      description "Upper limit for connected users. When number of connected users exceeds this limit, admission and preemption mechanisms of Priority-Based Admission Control affect accessibility and retainability of traffic based on priority of configured users. Limit is also used in NR Unified Access Control to calculate cell load. If 0, UE admission and preemption mechanisms of Priority-Based Admission Control are disabled. Load measure based on number of UEs in NR Unified Access Control is also disabled.; range 0..10000; Default value: 0.";
      type int32 {
        range "0..10000";
      }
      default "0";
    }
    leaf maxConnectedUeOffloadISHo {
      description "Maximum number of connected UEs for offload-triggered inter-system handover. Used together with OffloadCellProfileUeCfg::ueOffloadISHoRatio.; range 0..10000; Default value: 10000.";
      type int32 {
        range "0..10000";
      }
      default "10000";
    }
    leaf preemptionRate {
      description "Intensity of UE preemption. Defines how intensively the preemption mechanisms of Priority-Based Admission Control are triggered to ensure that number of connected users does not exceed configured capacity. If 0, UE preemption mechanisms of Priority-Based Admission Control are disabled.; range 0..100; Default value: 80.";
      type eytypes:int32_range_0-100;
      default "80";
      units "percent";
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
  }
  grouping AdmissionPriority-attributes {
    leaf admissionPriorityId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained AdmissionPriorityUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
  }
  grouping AdmissionPriorityUeCfg-attributes {
    leaf admissionPriorityUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf uePriority {
      description "Priority of UE. Used by the admission and preemption mechanisms of Priority-Based Admission Control to prioritize and then admit or preempt users when AdmissionLimit::maxConnectedUe is reached or exceeded. Lower value means higher UE priority.; range 1..255; Default value: 255.";
      type eytypes:int32_range_1-255;
      default "255";
    }
  }
  grouping AnrFunction-attributes {
    leaf anrFunctionId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf demoteCellRelMobAttThresh {
      description "ANR criteria for cell relation MO instance to be demoted to lightweight cell relation object. A neighbor cell relation MO instance is periodically evaluated and demoted when average mobility attempts number per day is less than or equal to this attribute. Neighbor cell relation MO instance having mobility attempts collected during at least 7 days is considered for demotion based on this attribute. If empty, threshold based automatic demotion is disabled.; range 1..1000.";
      type eytypes:int32_range_1-1000-6;
    }
    leaf lwCellRelationRatio {
      description "Number of lightweight cell relations in proportion of maximum number.; range 0..100.";
      type eytypes:int32_range_0-100;
      config false;
      units "percent";
    }
    leaf promoteCellRelMobAttThresh {
      description "ANR criteria for lightweight neighbor object to be promoted to visible MO instance. A lightweight neighbor object is internally evaluated before it is created as MO instance if number of average mobility attempts per day is higher than or equal to this attribute. If empty, automatic promotion and saturation handling are not enabled.; range 1..1000.";
      type eytypes:int32_range_1-1000-6;
    }
    leaf removeEnbTime {
      description "Time while neighbor eNodeB can be disconnected from gNodeB before being considered for removal. Value 1000 means no automatic removal is performed.; range 1..1000; Default value: 7.";
      type eytypes:int32_range_1-1000;
      default "7";
      units "day";
    }
    leaf removeEUtranFreqRelTime {
      description "Time before removing EUtranFreqRelation instance that refers to a frequency without external cell. If EUtranFreqRelation instance that refers to an EUtranFrequency instance that is configured for LTE CBRS band and unreferenced by any other ExternalEUtranCell instance during this period, it can be removed. If EUtranFrequency instance is configured for LTE CBRS band and unreferenced by ExternalEUtranCell instance and EUtranFreqRelation instance, it can be removed. If 10000, automatic removal is not performed.; range 10..10000; Default value: 10000.";
      type int32 {
        range "10..10000";
      }
      default "10000";
      units "minute";
    }
    leaf removeFreqRelTime {
      description "Maximum time an NRFreqRelation instance can be unreferenced before being considered for removal. If 10000, no automatic removal is performed.; range 10..10000; Default value: 15.";
      type int32 {
        range "10..10000";
      }
      default "15";
      units "minute";
    }
    leaf removeGnbTime {
      description "Time a neighbor gNodeB can be without a relation to this gNodeB before being considered for removal. 1000 means no automatic removal is performed.; range 1..1000; Default value: 7.";
      type eytypes:int32_range_1-1000;
      default "7";
      units "day";
    }
    leaf removeNrelTime {
      description "Maximum time while unused NR cell or E-UTRAN cell remains in RBS. Value 1000 means no automatic removal is performed.; range 1..1000; Default value: 7.";
      type eytypes:int32_range_1-1000;
      default "7";
      units "day";
    }
  }
  grouping AnrFunctionEUtran-attributes {
    leaf anrCgiMeasEUtranEnabled {
      description "Whether ANR with CGI measurement for E-UTRAN is enabled.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf anrFunctionEUtranId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping AnrFunctionEUtranUeCfg-attributes {
    leaf anrFunctionEUtranUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ecgiDuringEpsFbEnabled {
      description "Whether ECGI measurement during EPS fallback is enabled. ECGI measurement is triggered when B1 measurement report is received and E-UTRAN cell PCI is not known. Only applicable to EPS fallback of non-emergency voice call.; Default value: true.";
      type boolean;
      default "true";
    }
  }
  grouping AnrFunctionNR-attributes {
    leaf anrAutoCreateXnForEndc {
      description "Whether NR Automated Neighbor Relations feature can create Xn for NR neighbor relation for EN-DC. If true, Xn is created automatically for lightweight NR neighbor relations created by NR Automated Neighbor Relations feature for EN-DC over X2.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf anrCgiMeasInterFreqMode {
      description "ANR with CGI measurement for inter-frequency for RBS..";
      type enumeration {
        enum DISABLED;
        enum FR1;
      }
    }
    leaf anrCgiMeasIntraFreqEnabled {
      description "Whether ANR with CGI measurement for intra frequency is enabled for RBS.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf anrEndcX2Enabled {
      description "Whether ANR for EN-DC over X2 is enabled for NR for one RBS. Only takes effect when ANR feature is enabled.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf anrFunctionNRId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping AnrFunctionNRUeCfg-attributes {
    leaf adjustedAnrRsrpThreshold {
      description "Adjusted ANR-specific threshold RSRP value. If non-empty, system has reset lightweight cell relations and applied offsetAdjustAnrRsrpThreshold to anrRsrpThreshold. If empty, system has not applied offsetAdjustAnrRsrpThreshold.; range -156..-29.";
      type eytypes:int32_range_-156--29;
      config false;
      units "dBm";
    }
    leaf anrFunctionNRUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf anrRsrpThreshold {
      description "ANR-specific threshold RSRP value for the received Measurement Report Event A3. If received Measurement Report A3 trigger quantity is RSRP and neighbor RSRP value is higher than or equal to this threshold value, ANR action is triggered.; range -156..-29; Default value: -156.";
      type eytypes:int32_range_-156--29;
      default "-156";
      units "dBm";
    }
    leaf anrRsrqThreshold {
      description "ANR-specific threshold RSRQ value for the received Measurement Report Event A3. If received Measurement Report A3 trigger quantity is RSRQ and neighbor RSRQ value is higher than or equal to this threshold value, ANR action is triggered.; range -435..200; Default value: -435.";
      type eytypes:int32_range_-435-200;
      default "-435";
      units "dB";
    }
    leaf anrSinrThreshold {
      description "ANR-specific threshold SINR value for the received event A3 measurement report. If received A3 measurement report trigger quantity is SINR, and neighbor SINR value is higher than or equal to this threshold value, ANR action is triggered.; range -230..405; Default value: -230.";
      type int32 {
        range "-230..405";
      }
      default "-230";
      units "dB";
    }
    leaf offsetAdjustAnrRsrpThreshold {
      description "Offset to adjust ANR-specific RSRP value. If not 0, when maximum number of lightweight cell relations is reached, system resets lightweight cell relations and adds this offset to anrRsrpThreshold. Attribute adjustedAnrRsrpThreshold shows adjusted value. If 0, no adjustment is applied, and lightweight cell relations are not reset.; range 0..127; Default value: 10.";
      type int32 {
        range "0..127";
      }
      default "10";
      units "dB";
    }
  }
  grouping AnrPLMNTable-attributes {
    leaf anrPLMNTableId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf gNBIdLength {
      description "Length of gNBId bit string representation when ANR extracts gNBId from NCGI. Value is used by ANR when node containing newly found cell belongs to a PLMN that is listed in pLMNIdList in same AnrPLMNTable instance.; range 22..32.";
      type eytypes:int32_range_22-32;
      mandatory true;
    }
    list pLMNIdList {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct sequence entry.";
      }
      min-elements 1;
      max-elements 11;
      uses PLMNId-struct;
    }
  }
  grouping BarringGroup-attributes {
    leaf-list accessCategoryList {
      description "List of access categories. Access category defines which type of access a UE is attempting to perform. If empty, barring does not occur, regardless if load or rejection conditions are met for sending out barring info. Under each UacProfile instance, one specific access category is only allowed to be specified in one BarringGroup instance if it affects the same PLMN. Note: Explicitly defined access categories in one BarringGroup instance, take precedence over empty access categories defined in other BarringGroup instances if it affects the same PLMN..";
      type eytypes:int32_range_1-10;
      ordered-by user;
      min-elements 0;
      max-elements 10;
    }
    leaf barringGroupId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf barringTime {
      description "Time during which UE refrains from re-evaluating the possibility of an access attempt.; Default value: 16.";
      type int32 {
        range "4 | 8 | 16 | 32 | 64 | 128 | 256 | 512";
      }
      default "16";
      units "s";
    }
    leaf bgCounterId {
      description "Counter identity. Identity of counter representing this barring group. Set automatically during MO creation.; range 1..8.";
      type eytypes:int32_range_1-8;
      config false;
    }
    leaf cellUsageBarringMax {
      description "Threshold at which maximum probability that a UE is barred occurs. The amount of UEs that are barred is given by maxBarringProbability. If cell usage is above this threshold, maxBarringProbability is broadcast in SIB1. Cell usage is defined as number RRC connected UEs to a cell divided by AdmissionLimit::maxConnectedUe. If AdmissionLimit::maxConnectedUe is 0, this means that cell usage, based on number RRC connected UEs, is not used in unified access control calculations.; range 0..100; Default value: 100.";
      type eytypes:int32_range_0-100;
      default "100";
      units "percent";
    }
    leaf cellUsageBarringStart {
      description "Threshold at which 5 % of UEs are barred. If cell usage is above this threshold, barring information is broadcast in SIB1. Cell usage is defined as number of RRC-connected UEs in a cell divided by AdmissionLimit::maxConnectedUe. If AdmissionLimit::maxConnectedUe is 0, cell usage, based on number RRC connected UEs, is not used in unified access control calculations. Note: If equal to cellUsageBarringMax, amount of barred UEs is defined by maxBarringProbability.; range 0..100; Default value: 100.";
      type eytypes:int32_range_0-100;
      default "100";
      units "percent";
    }
    leaf maxBarringProbability {
      description "Maximum barring probability due to high cell usage. If cell usage is greater than or equal to value specified in cellUsageBarringMax, maximum barring probability is broadcast in SIB1. Cell usage is defined as number RRC connected UEs to a cell, divided by AdmissionLimit::maxConnectedUe. If AdmissionLimit::maxConnectedUe is set to zero, this means that cell usage, based on number RRC connected UEs, is not used in unified access control calculations.; Default value: 0.";
      type int32 {
        range "0 | 5 | 10 | 15 | 20 | 25 | 30 | 40 | 50 | 60 | 70 | 75 | 80 | 85 | 90 | 95 | 100";
      }
      default "0";
      units "percent";
    }
    list pLMNIdList {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct sequence entry.";
      }
      min-elements 0;
      max-elements 12;
      uses PLMNId-struct;
    }
    leaf rejRatioBarringMax {
      description "Rejection ratio at which 100 % of UEs are barred. Rejection ratio is defined as the number of rejected UEs divided by total number of access attempts.; range 0..100; Default value: 100.";
      type eytypes:int32_range_0-100;
      default "100";
      units "percent";
    }
    leaf rejRatioBarringStart {
      description "Rejection ratio at which 5 % of UEs are barred. This is the lowest rejection ratio at which barring information is broadcast in SIB1. Rejection ratio is defined as number of rejected UEs divided by total number of access attempts.; range 0..100; Default value: 100.";
      type eytypes:int32_range_0-100;
      default "100";
      units "percent";
    }
    leaf startBarringAi1 {
      description "Threshold at which UEs of access identity 1 can be barred. If barring probability is greater than or equal to threshold, UEs of access identity 1 are barred to the same degree as UEs of access identity 0. If 100, barring never occurs. Barring probability is the outcome from calculations made by unified access control. It is defined by settings of following attributes: - cellUsageBarringStart - cellUsageBarringMax - maxBarringProbability - rejRatioBarringStart - rejRatioBarringMax Access identity 1 corresponds to UEs running multimedia priority service traffic.; Default value: 100.";
      type int32 {
        range "0 | 5 | 10 | 15 | 20 | 25 | 30 | 40 | 50 | 60 | 70 | 75 | 80 | 85 | 90 | 95 | 100";
      }
      default "100";
      units "percent";
    }
    leaf startBarringAi11 {
      description "Threshold at which UEs of access identity 11 can be barred. If barring probability is greater than or equal to threshold, UEs of access identity 11 are barred to the same degree as UEs of access identity 0. If 100, barring never occurs. Barring probability is the outcome from calculations made by unified access control. It is defined by settings of following attributes: - cellUsageBarringStart - cellUsageBarringMax - maxBarringProbability - rejRatioBarringStart - rejRatioBarringMax Access identity 11 correspond to LTE Access Classes 11.; Default value: 100.";
      type int32 {
        range "0 | 5 | 10 | 15 | 20 | 25 | 30 | 40 | 50 | 60 | 70 | 75 | 80 | 85 | 90 | 95 | 100";
      }
      default "100";
      units "percent";
    }
    leaf startBarringAi12 {
      description "Threshold at which UEs of access identity 12 can be barred. If barring probability is greater than or equal to threshold, UEs of access identity 12 are barred to the same degree as UEs of access identity 0. If 100, barring never occurs. Barring probability is the outcome from calculations made by unified access control. It is defined by settings of following attributes: - cellUsageBarringStart - cellUsageBarringMax - maxBarringProbability - rejRatioBarringStart - rejRatioBarringMax Access identity 12 correspond to LTE Access Classes 12.; Default value: 100.";
      type int32 {
        range "0 | 5 | 10 | 15 | 20 | 25 | 30 | 40 | 50 | 60 | 70 | 75 | 80 | 85 | 90 | 95 | 100";
      }
      default "100";
      units "percent";
    }
    leaf startBarringAi13 {
      description "Threshold at which UEs of access identity 13 can be barred. If barring probability is greater than or equal to threshold, UEs of access identity 13 are barred to the same degree as UEs of access identity 0. If 100, barring never occurs. Barring probability is the outcome from calculations made by unified access control. It is defined by settings of following attributes: - cellUsageBarringStart - cellUsageBarringMax - maxBarringProbability - rejRatioBarringStart - rejRatioBarringMax Access identity 13 correspond to LTE Access Classes 13; Default value: 100.";
      type int32 {
        range "0 | 5 | 10 | 15 | 20 | 25 | 30 | 40 | 50 | 60 | 70 | 75 | 80 | 85 | 90 | 95 | 100";
      }
      default "100";
      units "percent";
    }
    leaf startBarringAi14 {
      description "Threshold at which UEs of access identity 14 can be barred. If barring probability is greater than or equal to threshold, UEs of access identity 14 are barred to the same degree as UEs of access identity 0. If 100, barring never occurs. Barring probability is the outcome from calculations made by unified access control. It is defined by settings of following attributes: - cellUsageBarringStart - cellUsageBarringMax - maxBarringProbability - rejRatioBarringStart - rejRatioBarringMax Access identity 14 correspond to LTE Access Classes 14.; Default value: 100.";
      type int32 {
        range "0 | 5 | 10 | 15 | 20 | 25 | 30 | 40 | 50 | 60 | 70 | 75 | 80 | 85 | 90 | 95 | 100";
      }
      default "100";
      units "percent";
    }
    leaf startBarringAi15 {
      description "Threshold at which UEs of access identity 15 can be barred. If barring probability is greater than or equal to threshold, UEs of access identity 15 are barred to the same degree as UEs of access identity 0. If 100, barring never occurs. Barring probability is the outcome from calculations made by unified access control. It is defined by settings of following attributes: - cellUsageBarringStart - cellUsageBarringMax - maxBarringProbability - rejRatioBarringStart - rejRatioBarringMax Access identity 15 correspond to LTE Access Classes 15.; Default value: 100.";
      type int32 {
        range "0 | 5 | 10 | 15 | 20 | 25 | 30 | 40 | 50 | 60 | 70 | 75 | 80 | 85 | 90 | 95 | 100";
      }
      default "100";
      units "percent";
    }
    leaf startBarringAi2 {
      description "Threshold at which UEs of access identity 2 can be barred. If barring probability is greater than or equal to threshold, UEs of access identity 2 are barred to the same degree as UEs of access identity 0. If 100, barring never occurs. Barring probability is the outcome from calculations made by unified access control. It is defined by settings of following attributes: - cellUsageBarringStart - cellUsageBarringMax - maxBarringProbability - rejRatioBarringStart - rejRatioBarringMax Access identity 2 corresponds to UEs running mission critical traffic. Only applicable if license for NR Unified Access Control for Mission-Critical Services is present and feature is active.; Default value: 100.";
      type int32 {
        range "0 | 5 | 10 | 15 | 20 | 25 | 30 | 40 | 50 | 60 | 70 | 75 | 80 | 85 | 90 | 95 | 100";
      }
      default "100";
      units "percent";
    }
  }
  grouping BlockedGNodeB-attributes {
    leaf blockedGNodeBId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf directPacketForwarding {
      description "Whether direct packet forwarding is enabled. Direct packet forwarding is part of NR Mobility feature..";
      type boolean;
    }
    leaf gNBId {
      description "Identity of gNodeB. If -1, all gNBs with specified PLMN are blocked.; range -1..4294967295.";
      type int64 {
        range "-1..4294967295";
      }
    }
    leaf mcc {
      description "Mobile Country Code (MCC) identifies uniquely domicile country of mobile subscriber. If -1, all gNBs with specified gNBId regardless of PLMN are blocked.; range -1..999.";
      type int32 {
        range "-1..999";
      }
    }
    leaf mnc {
      description "Mobile Network Code (MNC) identifies home PLMN of mobile subscription.; range 0..999.";
      type int32 {
        range "0..999";
      }
    }
    leaf mncLength {
      description "Length of Mobile Network Code (MNC).; range 2..3.";
      type int32 {
        range "2..3";
      }
    }
  }
  grouping CaCellMeasProfile-attributes {
    leaf caCellMeasProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained CaCellMeasProfileUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping CaCellMeasProfileUeCfg-attributes {
    leaf betterSCellReportConfigMode {
      description "Condition for better SCell A6 measurement report. Cell referring to parent of this MO instance is used as a PCell or PSCell for UE. Not applicable to High-Band cells..";
      type enumeration {
        enum ALWAYS;
        enum CONDITIONAL;
      }
    }
    leaf betterSCellTriggerQuantity {
      description "Measurement trigger quantity used when detecting neighboring SCells with better downlink coverage. Only applicable to Low-Band and Mid-Band cells..";
      type enumeration {
        enum RSRP;
        enum RSRQ;
        enum SINR_FALLBACK_RSRP;
        enum SINR_FALLBACK_RSRQ;
      }
    }
    leaf caCellMeasProfileUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf maxReportCells {
      description "Maximum number of non-serving cells included in measurement report. Only applicable to event A6.; range 1..8; Default value: 1.";
      type eytypes:int32_range_1-8;
      default "1";
    }
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    list rsrpBetterSCell {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "RSRP measurement report criteria to detect neighboring SCells with better downlink coverage. Used when betterSCellTriggerQuantity is RSRP. Only applicable to Low-Band and Mid-Band cells..";
      uses ReportConfigA6Rsrp-struct;
    }
    list rsrpSCellCoverage {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "RSRP measurement report criteria to detect poor or good downlink coverage in SCell. Used when sCellCoverageTriggerQuantity is RSRP. Only applicable to Low-Band and Mid-Band cells..";
      uses ReportConfigA1A2Rsrp-struct;
    }
    list rsrqBetterSCell {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "RSRQ measurement report criteria to detect neighboring SCells with better downlink coverage. Used when betterSCellTriggerQuantity is RSRQ. Only applicable to Low-Band and Mid-Band cells..";
      uses ReportConfigA6Rsrq-struct;
    }
    list rsrqSCellCoverage {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "RSRQ measurement report criteria to detect poor or good downlink coverage in SCell. Used when sCellCoverageTriggerQuantity is RSRQ. Only applicable to Low-Band and Mid-Band cells..";
      uses ReportConfigA1A2Rsrq-struct;
    }
    leaf sCellCoverageTriggerQuantity {
      description "Measurement trigger quantity used for SCell downlink coverage measurements. Only applicable to Low-Band and Mid-Band cells..";
      type enumeration {
        enum RSRP;
        enum RSRQ;
        enum SINR_FALLBACK_RSRP;
        enum SINR_FALLBACK_RSRQ;
      }
    }
    list sinrBetterSCell {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "SINR measurement report criteria to detect neighboring SCells with better downlink coverage. Used when betterSCellTriggerQuantity is SINR. Applicable for UE that support SS-SINR (Synchronization Signal Signal-To-Noise and interference Ratio) measurements. Only applicable to Low-Band and Mid-Band cells..";
      uses ReportConfigA6Sinr-struct;
    }
    list sinrSCellCoverage {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "SINR measurement report criteria to detect poor or good downlink coverage in SCell. Used when sCellCoverageTriggerQuantity is SINR. Applicable for UE that support SS-SINR (Synchronization Signal Signal-To-Noise and interference Ratio) measurements. Only applicable to Low-Band and Mid-Band cells..";
      uses ReportConfigA1A2Sinr-struct;
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping CaCellProfile-attributes {
    leaf caCellProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
