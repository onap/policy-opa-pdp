  grouping PuemReportConfigPeriodical-struct {
    description "Periodical report configuration for UE measurement.";
    leaf includeBeamMeas {
      description "Default value: true.";
      type boolean;
      default "true";
    }
    leaf maxNoOfRsIndexesToReport {
      description "range 0..32; Default value: 1.";
      type eytypes:int32_range_0-32;
      default "1";
    }
    leaf maxReportCells {
      description "range 1..8; Default value: 8.";
      type eytypes:int32_range_1-8;
      default "8";
    }
    leaf reportAddNeighMeas {
      description "Default value: true.";
      type boolean;
      default "true";
    }
    leaf reportAmount {
      type enumeration {
        enum R1;
        enum R2;
        enum R4;
        enum R8;
        enum R16;
        enum R32;
        enum R64;
        enum INFINITY;
      }
    }
    leaf reportInterval {
      type enumeration {
        enum MS_120;
        enum MS_240;
        enum MS_480;
        enum MS_640;
        enum MS_1024;
        enum MS_2048;
        enum MS_5120;
        enum MS_10240;
        enum MS_20480;
        enum MS_40960;
        enum MIN_1;
        enum MIN_6;
        enum MIN_12;
        enum MIN_30;
      }
    }
    leaf reportQuantityCell {
      type enumeration {
        enum RSRP;
        enum RSRQ;
        enum SINR;
        enum RSRP_RSRQ;
        enum RSRP_SINR;
        enum RSRQ_SINR;
        enum RSRP_RSRQ_SINR;
        enum NO_QUANTITY;
      }
    }
    leaf reportQuantityRsIndex {
      type enumeration {
        enum RSRP;
        enum RSRQ;
        enum SINR;
        enum RSRP_RSRQ;
        enum RSRP_SINR;
        enum RSRQ_SINR;
        enum RSRP_RSRQ_SINR;
        enum NO_QUANTITY;
      }
    }
  }
