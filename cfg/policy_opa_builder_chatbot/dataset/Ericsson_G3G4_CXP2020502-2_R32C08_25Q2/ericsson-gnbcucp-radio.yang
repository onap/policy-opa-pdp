  augment "/emael:ManagedElement/gnbcucp:GNBCUCPFunction/gnbcucp:UeCC/gnbcucp:Rohc" {
    list RohcUeCfg {
      description "Additional definitions from MOM:min/max-elements:0/8; Configuration of Robust Header Compression feature for UE groups. Instance RohcUeCfg=Base is created automatically when parent MO instance is created, unless created manually in same transaction. Each UE configuration group identifier can only be defined in one ueConfGroupList among RohcUeCfg instances contained under parent Rohc instance. Any combination of one UE group identifier in ueGroupList and one preference UE group identifier in prefUeGroupList must be unique among RohcUeCfg instances contained under parent Rohc instance. Attributes prefUeGroupList, ueGroupList, and ueConfGroupList must be empty in instance RohcUeCfg=Base but cannot all be empty in any other instance of RohcUeCfg. Precondition: Instance RohcUeCfg=Base can only be created in same transaction as parent MO instance and cannot be deleted unless parent MO instance is deleted. Other instances can be created and deleted at any time. Maximum 7 RohcUeCfg instances, with RDN different from Base, can be created under parent MO instance.";
      key "rohcUeCfgId";
      leaf rohcUeCfgId {
        type leafref {
          path "../attributes/rohcUeCfgId";
        }
      }
      container attributes {
      uses RohcUeCfg-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbcucp:GNBCUCPFunction/gnbcucp:UeCC/gnbcucp:Rrc" {
    list RrcUeCfg {
      description "Additional definitions from MOM:min/max-elements:0/8; Configuration of RRC UE groups. Instance RrcUeCfg=Base is created automatically when parent MO instance is created, unless created manually in same transaction. Attributes prefUeGroupList, ueGroupList and ueConfGroupList must be empty in instance RrcUeCfg=Base but cannot all be empty in any other instance of RrcUeCfg under same parent RrcInactiveProfile instance. Precondition: Instance RrcUeCfg=Base can only be created in same transaction as parent MO instance and cannot be deleted unless parent MO instance is deleted. Other instances can be created and deleted at any time. Maximum 7 RrcUeCfg instances, with RDN different from Base, can be created under parent MO instance.";
      key "rrcUeCfgId";
      leaf rrcUeCfgId {
        type leafref {
          path "../attributes/rrcUeCfgId";
        }
      }
      container attributes {
      uses RrcUeCfg-attributes;
      }
    }
  }

