  grouping PmUeMeas-attributes {
    leaf pmUeMeasId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping PrefUeGroupSelectionProfile-attributes {
    leaf chipsetRef {
      description "Reference to an instance of Chipsets MO. Special <Value> \"ref\" for <Variable> chipset in selectionCriteria represents chipset <ValueList> defined via this reference. If empty, represented chipset <ValueList> is empty..";
      type string;
    }
    leaf imeiSvRef {
      description "Reference to an instance of ImeiSvs MO. Special <Value> \"ref\" for <Variable> imeisv in selectionCriteria represents imeisv <ValueList> defined via this reference. If empty, represented imeisv <ValueList> is empty..";
      type string;
    }
    leaf prefUeGroupId {
      description "Preference UE group identifier.; range 1..255.";
      type eytypes:int32_range_1-255;
      mandatory true;
    }
    leaf prefUeGroupPriority {
      description "Relative priority among preference UE groups. If UE fulfills more than one PrefUeGroupSelectionProfile, PrefUeGroupSelectionProfile with the highest relative priority is applied. Higher value gives higher priority.; range 1..65535.";
      type eytypes:int32_range_1-65535;
      mandatory true;
    }
    leaf prefUeGroupSelectionProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf selectionCriteria {
      description "Preference UE group selection criteria. Defines selection criteria that UE needs to fulfill to belong to the Preference UE group instance. If selection criteria evaluates to True, UE fulfills Preference UE group instance. If selection criteria evaluates to False or Unknown, UE does not fulfill Preference UE group instance. If selection criteria evaluates to True for more than one Preference UE group instance, UE belongs to the Preference UE group instance with highest setting of prefUeGroupPriority. Syntax: ====== The syntax of selection criteria is defined using Backus-Naur form. <SelectionCriteria> ::= <ParentExpressionList> | \"\" <ParentExpressionList> ::= <ParentExpressionList> <AndOr> < ParentExpressionList> | <Not>? \"(\" <ParentExpressionList> \")\" | <ExpressionList> | <FlowExpressionList> <FlowExpressionList> ::= <FlowExpressionList> <AndOr> <FlowExpressionList> | <Not>? <FlowExpression> <FlowExpression> ::= \"[\"<ExpressionList>\"]\" <ExpressionList> ::= <ExpressionList> <AndOr> <ExpressionList> | <Not>? \"(\" <ExpressionList> \")\" | <Not>? <VariableExpression> <VariableExpression> ::= <Variable> <RelationalOperator> <Value> | <Variable> \"==\" \"{\" <ValueList> \"}\" <ValueList> ::= <Value> \",\" <ValueList> | <Value> <Variable> ::= \"5qi\" | \"arp\" | \"cgrole\" | \"chipset\" | \"imeisv\" | \"imeisvn\" | \"imeitac\" | \"pagingPrio\" | \"pCellOnlyUe\" | \"plmn\" | \"qci\" | \"redCapUe\" | \"rfsp\" | \"rrcEstResCause\" | \"snssai\" | \"spid\" | \"voNrUe\" <AndOr> ::= \"&&\" | \"||\" <Not> ::= \"!\" <RelationalOperator> ::= \"==\" | \"!=\" | \"<\" | \"<=\" | \">=\" | \">\" A list of possible values can be specified in the form <Variable> == {<value1>, <value2>, ... , <valueN>}. This statement is equivalent to writing (<Variable> == <value1> || <Variable> == <value2> || ... || <Variable> == <valueN>). Up to 4 <FlowExpression> can be defined in <SelectionCriteria>. Whitespaces are allowed in the string for improved readability and are removed prior to evaluation. Question mark (?) means zero or one occurrence. For example, <Not>? makes <Not> optional. Syntax is case sensitive. Semantic: ======== Selection criteria evaluation is defined by the following semantic rules. If empty or set to empty string \"\", selection criteria always evaluates to True. Selection criteria evaluation is done per UE with the current applicable UE <Variable> values as input. List of UE <Variable> values that are applicable to NR standalone and EN-DC, respectively, is defined in Variable Definitions section below. Selection criteria for a UE is evaluated separately for each flow using applicable flow-dependent <Variable> together with rest of applicable UE <Variable>. For UE in NR standalone flow-dependent <Variable> 5qi, arp, and snssai are applicable. For UE in EN-DC flow-dependent <Variable> qci, and arp are applicable. Selection criteria evaluates to True if any of the flows evaluates to True. If UE does not have a flow, flow-dependent <Variable> values are evaluated as unknown variable values. If selection criteria shall match combination of flow-dependent <Variable>, then <FlowExpression> and <FlowExpressionList> must be used. Note: An <ExpressionList> defined as <VariableExpression> && <VariableExpression>, for which both <VariableExpression> relate to flow-dependent <Variable>, needs special attention. Example: <ExpressionList> = \"5qi==5 && 5qi==9\" always evaluate to False for UE in NR standalone even if UE has one flow with 5qi=5 and one flow with 5qi=9. Example: <ExpressionList> = \"5qi>=7 && 5qi<=11\" will evaluate to True for UE in NR standalone if UE has any flow with 5qi between 7 and 11. <FlowExpression> is defined as \"[\"<ExpressionList>\"]\" and indicates that an <ExpressionList> is evaluated per QoS flow independent of other <ExpressionList>. Example: <FlowExpressionList> = \"[5qi==1] && [5qi==5]\" evaluates to True for UE in NR standalone if UE has any flow with 5qi=1 and any flow with 5qi=5. In the example, [5qi==1] must match one flow, and [5qi==5] must match one flow. <VariableExpression> evaluates to Unknown if <Variable> is not known or if the <Variable> value is not valid. <VariableExpression> evaluates to True or False if <Variable> value is known and valid. <Value> \"ref\" is a special <Value> of <Variable> representing <ValueList> defined via corresponding reference attribute. For <Variable> chipset, and imeisv, corresponding reference attribute is chipsetRef, and imeiSvRef respectively. If reference attribute is empty, represented <ValueList> is empty. The logical operators <AndOr> and <Not> apply three way logic as defined below: F=False; T=True; U=Unknown A=Evaluation result of <ExpressionList> or <VariableExpression> B=Evaluation result of <ExpressionList> or <VariableExpression> NOT operator: A !A ----------------- F T U U T F AND operator: A B A && B ------------------- F F F F T F F U F T F F T T T T U U U F F U T U U U U OR operator: A B A || B ------------------ F F F F T T F U U T F T T T T T U T U F U U T T U U U Variable Definitions: ================= Allowed <Value> and <RelationalOperator> depend on <Variable> with limitations given below. 5qi: 5G QoS Identifier (3GPP TS 23.501). Applicable to NR standalone. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 0..255 given in decimal. arp: Priority Level part of the Allocation and Retention Priority (3GPP TS 38.413, 3GPP TS 36.423). Applicable to both NR standalone and EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 1..15 given in decimal. cgrole: Cell group role. Applicable to both NR standalone and EN-DC. Operator: ==, and !=. Value: mcg or scg, where mcg is only applicable to NR standalone. chipset: Chipset identifier. Applicable to both NR standalone and EN-DC. Operator: ==, and !=. Value: String in format \"<vendor>.<variant>.<version>\" matched by regular expression \"(1[0-6]|[0-9])\\\\.(6[0-4]|[1-5]?[0-9])\\\\.(12[0-8]|1[01][0-9]|[1-9]?[0-9])\", or a string constant \"ref\". Description: Chipset identifier composed of three distinct elements: - vendor: 1-2 digit decimal number in range 0..16 - variant: 1-2 digit decimal number in range 0..64 - version: 1-3 digit decimal number in range 0..128 UEs that do not support chipset identifier reporting are represented internally as 0.0.0. Example values: 0.0.0, 1.1.1, 1.2.3, 16.10.100, 16.64.128, ref. imeisv: International Mobile Station Equipment Identity Software Version. Applicable to both NR standalone and EN-DC. Operator: ==, and !=. Value: String in format \"<TAC><SNR><SVN>\" matched by regular expression \"[0-9]{10}[0-9fF]{4}[0-9]{2}\", or string constant \"ref\". Description: IMEISV composed of three distinct elements: - TAC (Type Allocation Code): 8 digit decimal number - SNR (or SN, Serial Number): 2 digit decimal number + 4 digit hexa-decimal number, last four digits are automatically masked with 0xFFFF to match with masked IMEISV - SVN (Software Version Number): 2 digit decimal number Example values: 1234567890123456, 1234567890FFFF12, 1234567890ffff12, ref. imeitac: Type Allocation Code (TAC) part of imeisv. Applicable to both NR standalone and EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: 8 digit decimal number. imeisvn: Software Version Number (SVN) part of imeisv. Applicable to both NR standalone and EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: 2 digit decimal number. pagingPrio: Paging Priority (3GPP TS 23.501). Applicable to NR standalone. Operator: ==, !=, <=, >=, <, and > Value: Integer in range 1..8 given in decimal. Description: Paging priority value received in NGAP Paging message. The received value is valid in UE grouping framework when performing UE group evaluation during time specified by UeGroupSelection::validityTimePagingPrio. pCellOnlyUe: Low-Band and Mid-Band PCell-only capability. Indicates whether the UE is not capable of carrier aggregation in Low-Band or Mid-Band. Only applicable when performing UE group evaluation in NR standalone Master Node. Operator: ==, and !=. Value: Integer in range 0..1 given in decimal, where 0 means false and 1 means true. Only applicable if license for Flexible UE Grouping for Limited Capability UEs is present and feature is active. plmn: Public Land and Mobile Network identifier. Applicable to both NR standalone and EN-DC. Operator: ==, and !=. Value: A string matched by regular expression \"[02-79][0-9][0-9]-[0-9][0-9][0-9]?\". Example values: 070-007, 070-07, 234-56. qci: QoSClass Identifier (3GPP TS 23.401). Applicable to EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 0..255 given in decimal. redCapUe: Reduced Capabilities UE indicator. Applicable to NR standalone. Operator: ==, and !=. Value: Integer in range 0..1 given in decimal, where 0 means false and 1 means true. Description: RedCap UE identification received via LCID in MSG3 (see 3GPP TS 38.331). rfsp: Index to RAT/Frequency Selection Priority (3GPP TS 23.501). Applicable to NR standalone. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 1..256 given in decimal. rrcEstResCause: RRC establishment cause or RRC resume cause. Applicable to NR standalone. Operator: ==, and !=. Value: One of emergency, highPriorityAccess, mt-Access, mo-Signaling, mo-Data, mo-VoiceCall, mo-VideoCall, mo-SMS, mps-PriorityAccess, or mcs-PriorityAccess. Description: Establishment cause value received in RRC Setup Request message or resume cause received in RRC Resume Request message (see 3GPP TS 38.331). The received establishment cause or resume cause is valid in UE grouping framework when performing UE group evaluation during time specified by corresponding validity time attribute value in MO class UeGroupSelection. snssai: Single Network Slice Selection Assistance Information (3GPP TS 23.003). Applicable to NR standalone. Operator: ==, !=, <=, >=, <, and >. Value: input option 1: String in format \"<SST><SD>\" matched by regular expression [0][x][0-9a-fA-F]{8} (8 digit hexa-decimal number). Value: input option 2: Integer in range 0x0..0xffffffff given in hexadecimal. Description: S-NSSAI is composed of two distinct elements: - SST (Slice/Service Type): 2 digit hexa-decimal number - SD (Slice Differentiator): 6 digit hexa-decimal number The SD field has a reserved value \"no SD value associated with the SST\" defined as hexadecimal FFFFFF/ffffff. Example values, input option 1: - 0x050000EE (SST=0x05,SD=0x0000EE) - 0x2effffff (SST=0x2e,SD=0xffffff // no SD associated with the SST) Example values, input option 2: - 0x1 (SST=0x00,SD=0x000001) - 0x50000EE (SST=0x05,SD=0x0000EE) - 0x150000EE (SST=0x15,SD=0x0000EE) spid: Subscriber Profile ID for RAT/Frequency Priority (3GPP TS 36.300). Applicable to EN-DC. Operator: ==, !=, <=, >=, <, and >. Value: Integer in range 1..256 given in decimal. voNrUe: Low-Band and Mid-Band VoNR capability. Only applicable when performing UE group evaluation in NR standalone Master Node. Operator: ==, and !=. Value: Integer in range 0..1 given in decimal, where 0 means false and 1 means true. Operator Precedence Order: ======================= The logical and relation operators are evaluated according to the precedence order listed below. --------------------------------------------- 1 (highest precedence) < Less than <= Less than or equal > Greater than >= Greater than or equal == Equal != Not equal ------------------------------------------- 2 ! (Not) --------------------------------------------- 3 && (And) --------------------------------------------- 4 (lowest precedence) || (Or) --------------------------------------------- The NOT operator \"!\" negates the following <ParentExpressionList>, <VariableExpression>, <FlowExpression> or an <ExpressionList> encapsulated in parenthesis. Therefore, expression !a==b && c==d is equivalent to ((!(a==b)) && (c==d)) and different from !(a==b && c==d). Expression !a==b and !(a==b) are equivalent. Since AND operator \"&&\" has higher precedence than OR operator \"||\", a<b || a<c && c<d is equivalent to (a<b || (a<c && c<d)). Surround expression list including OR operator with parenthesis to force OR operator to be evaluated before AND operators outside of the expression list, for example (a<b || a<c) && c<d. Examples: ========= Simple one valued expressions: plmn == 234-56 spid == 1 cgrole == mcg arp > 3 snssai == 0xfedcba98 rrcEstResCause == mo-VoiceCall imeisv == 1234567890FFFF12 imeisv == ref //Special <value> ref represents <ValueList> defined via imeiSvRef. chipset == ref chipset == 1.1.1 //Matches all UEs with chipset identifier: vendor = 1, variant = 1 and version = 1. chipset == 0.0.0 //Matches all UEs that do not support chipset identifier reporting. Value list expressions: spid == {8,9,10,1,155} !plmn == {234-56, 434-567} chipset == {1.1.1, 1.1.2, 1.1.3, ref} //Matches all UEs with chipset identifier: vendor = 1, variant = 1 and version = 1, 2 or 3, or the corresponding vendor, variant and version defined via chipsetRef. imeisv == {1234567890FFFF12, ref, 1234567890FFFF13} //Matches all UEs with imeisv: TAC = 12345678, SNR = 90FFFF and SVN = 12 or 13, or the corresponding TAC, SN and SVN defined via imeiSvRef. Equivalent expressions using ||: (spid == 8 || spid == 9 || spid == 10 || spid == 1 || spid == 155) //Equals to spid == {8, 9, 10, 1, 155}. !(plmn == 234-56 || plmn == 434-567) //Equals to !plmn == {234-56, 434-567}. imeisv == ref || imeisv == 1234567890FFFF12|| imeisv == 1234567890FFFF13 //Equals to imeisv == {ref, 1234567890FFFF12, 1234567890FFFF13}. chipset == 1.1.1 || chipset == ref || chipset == 1.1.2 // Equals to chipset == {1.1.1, ref, 1.1.2}. Negative expressions: !5qi==1 //Matches flows with 5qi not equal to 1. 5qi!=1 //Matches flows with 5qi not equal to 1. Negative <FlowExpressions> that produce same result: [!5qi==1] //Matches flows with 5qi not equal to 1. [5qi!=1] //Matches flows with 5qi not equal to 1. <FlowExpressionList> negative expressions: !([5qi==1]) //Matches UEs that do not have flows with 5qi 1. ![5qi==1] //Matches UEs that do not have flows with 5qi 1. Mixed examples: spid == 1 && cgrole == mcg !(spid != 1 || cgrole != mcg) (spid == 8 || spid == 9 || spid == 10 || spid == 1 || spid == 155) && (plmn == 234-56 || plmn == 434-567) Precedence given by \"()\" and sequence alter the evaluation order and result: [5qi==1] && chipset==ref || imeisv==ref && [5qi==5] //Equals to ([5qi==1] && chipset==ref) || (imeisv==ref && [5qi==5]) [5qi==1] && (chipset==ref || imeisv==ref) && [5qi==5] ([5qi==1] && chipset==ref || imeisv==ref) && [5qi==5] [5qi==1] && (chipset==ref || imeisv==ref && [5qi==5]) chipset==ref || [5qi==1] && [5qi==5] && imeisv==ref Examples of selection criteria that shall be avoided since they will always be evaluated to False. <FlowExpression> can be used in these cases. 5qi==5 && 5qi==9 snssai==0x15000000 && snssai==0x17000000 arp==5 && arp==10 qci==5 && qci==9 Example of selection criteria for UE variable snssai: snssai>=15000000 && snssai<=15FFFFFF //Matches UE which has a flow with S-NSSAI SST part equal to 15 regardless of value of S-NSSAI SD part. snssai==15FFFFFF //Matches UE which has a flow with S-NSSAI SST part equal to 15 and S-NSSAI SD part value equal to FFFFFF, meaning no SD value associated with the SST. Flow expressions combined with UE variables: plmn == 234-56 && [5qi==1] && [5qi==9] //Matches UE which has plmn equal to 234-56, any QoS flow with 5qi equal to 1, and any QoS flow with 5qi equal to 9. chipset==1.5.32 && [5qi==9] && ![5qi==1] //Matches UE which has chipset identifier equal to 1.5.32, any QoS flow with 5qi equal to 9, and no QoS flow with 5qi equal to 1. [5qi==1 && snssai == 0xfedcba98] || ([5qi==2] && [snssai == 0xfedcba77]) //Matches UE which has any QoS flow with 5qi equal to 1 and snssai equal to 0xfedcba98, or has any QoS flow with 5qi equal to 2 and snssai equal to 0xfedcba77. voNrUe==1 && chipset==1.1.1 && [5qi==1] //Matches UEs with Low-Band and Mid-Band VoNR capability using chipset 1.1.1, and have an ongoing flow 5qi.; length 1..1000.";
      type string {
        length "1..1000";
      }
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping PriorityService-attributes {
    list arp5qiPairList {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct sequence entry.";
      }
      min-elements 0;
      max-elements 8;
      uses Arp5qiPair-struct;
    }
    leaf mpsPriorityForRwr {
      description "Whether MPS priority indication is supported in release with redirect. If true, following applies: If Multimedia Priority Services (MPS) user is identified, then in RRCRelease message in release with redirect procedure, the MPS priority indication flag is set.; Default value: false.";
      type boolean;
      default "false";
    }
    list pLMNIdList {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct sequence entry.";
      }
      min-elements 0;
      max-elements 12;
      uses PLMNId-struct;
    }
    leaf priorityServiceId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping PuemCellProfile-attributes {
    leaf puemCellProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf puemCellTargetIntensity {
      description "Target intensity of periodic UE measurements for each hour for cell. If 0, no measurements are configured.; Default value: 360.";
      type int32 {
        range "0..720 | 1440 | 2160 | 2880 | 3600";
      }
      default "360";
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained PuemCellProfileUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping PuemCellProfileUeCfg-attributes {
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf puemCellProfileUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    list puemReportConfigPeriodical {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "Report configuration setting for periodical UE measurements..";
      uses PuemReportConfigPeriodical-struct;
    }
    leaf puemUeGroupEnabled {
      description "Whether periodic UE measurements are enabled for UE group.; Default value: true.";
      type boolean;
      default "true";
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 32;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping QciProfileEndcConfigExt-attributes {
    leaf initialUplinkConf {
      description "Initial uplink configuration for EN-DC and NR-DC. Whether to use MCG or SCG leg for uplink at initial state. Set when dual connectivity is configured.; Default value: MCG; Takes effect: New connection; Status info: Since 25.Q1. Replaced by UlDataSplitUeCfg::initialUlPrimaryPathMode. Planned to be removed..";
      type enumeration {
        enum MCG;
        enum SCG;
      }
      status deprecated;
      default "MCG";
      reference "Takes effect: New connection.";
    }
    leaf qciProfileEndcConfigExtId {
      description "The value component of the RDN.; MOM flags: restricted, noNotification; Status info: Since 25.Q1. Planned to be removed..";
      type string;
      mandatory true;
      status deprecated;
    }
    leaf ulDataSplitThreshold {
      description "Buffer threshold for uplink PDCP split for capable UE instances. Specifies buffer level where capable UE instances can split data on both main and secondary leg when primary path is SCG. A capable UE is a UE with dual connectivity supporting split DRB with uplink on both MCG and SCG. This UE can submit uplink PDCP PDUs to both primary RLC entity and secondary RLC entity if total amount of PDCP and RLC data volume for initial transmission in two associated RLC entities is equal or larger than used threshold. If 0, uplink PDCP split is always active for capable UE instances. If -1, used threshold is infinity meaning that PDCP split is not allowed even for capable UE instances. The attribute is common for EN-DC and NR-DC. If empty, used threshold will be automatically controlled for EN-DC users and set to infinity for NR-DC users. Without license for LTE-NR Uplink Aggregation a value of infinity is used for EN-DC and NR-DC users.; Takes effect: New connection; MOM flags: isNillable=true; Status info: Since 25.Q1. Replaced by UlDataSplitUeCfg::ulDataSplitThreshScg. Planned to be removed.; Specification: 3GPP TS 38.463, 3GPP TS 38.331, 3GPP TS 38.323.";
      type int32 {
        range "-1..0 | 100 | 200 | 400 | 800 | 1600 | 3200 | 6400 | 12800 | 25600 | 51200 | 102400 | 204800 | 409600 | 819200 | 1228800 | 1638400 | 2457600 | 3276800 | 4096000 | 4915200 | 5734400 | 6553600";
      }
      status deprecated;
      units "byte";
      reference "Takes effect: New connection.";
    }
    leaf ulDataSplitThresholdMcg {
      description "Buffer threshold for uplink PDCP split for capable UE instances when primary path is MCG. This attribute is only applicable to EN-DC UEs. For NR-DC UEs used threshold is infinity meaning that PDCP split is not allowed when primary path is MCG. Only applicable if license for LTE-NR Uplink Aggregation is present and feature is active. Following settings are possible: - If empty and value for ulDataSplitThreshold is also empty, threshold is 51200. - If empty and value for ulDataSplitThreshold is non-empty, value according to ulDataSplitThreshold is used. - If -1, threshold is infinity meaning that PDCP split is not allowed. - If 0, UL PDCP split is always active. - Value -1 is recommended when NRCellDU::endcUlLegSwitchEnabled is true and a low value is set for NRCellDU::endcUlNrLowQualThresh. - Values 0 to 1600 are only recommended for operators for temporary testing purposes.; Takes effect: New connection; MOM flags: isNillable=true; Status info: Since 25.Q1. Replaced by UlDataSplitUeCfg::ulDataSplitThreshMcg. Planned to be removed.; Specification: 3GPP TS 38.463, 3GPP TS 38.331, 3GPP TS 38.323.";
      type int32 {
        range "-1..0 | 100 | 200 | 400 | 800 | 1600 | 3200 | 6400 | 12800 | 25600 | 51200 | 102400 | 204800 | 409600 | 819200 | 1228800 | 1638400 | 2457600 | 3276800 | 4096000 | 4915200 | 5734400 | 6553600";
      }
      status deprecated;
      units "byte";
      reference "Takes effect: New connection.";
    }
  }
  grouping RelaxedRrmMeas-attributes {
    leaf relaxedRrmMeasId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping RelaxedRrmMeasCellProfile-attributes {
    leaf combineRelaxedMeasCondition {
      description "Whether UE must fulfill both low mobility and cell edge criteria for relaxed measurements. Only applicable when sSearchDeltaP, tSearchDeltaP and sSearchThresholdP are non-empty.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf combineRelaxedMeasCondition2 {
      description "Whether UE must fulfill both stationary and cell edge criteria for relaxed measurements. Only applicable when sSearchDeltaPStationary, tSearchDeltaPStationary and sSearchThresholdP2 are non-empty. Only applicable to RedCap devices.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf highPriorityMeasRelax {
      description "Whether low mobility is sufficient for higher priority frequency measurements to be relaxed. Only applicable when sSearchDeltaP and tSearchDeltaP are non-empty.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf relaxedRrmMeasCellProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf sSearchDeltaP {
      description "Threshold for Srxlev variation in low mobility criterion for relaxed measurements. If empty, value is not broadcast in SIB2, and UE is not configured for low mobility evaluation. Only applicable when tSearchDeltaP is non-empty..";
      type int32 {
        range "3 | 6 | 9 | 12 | 15";
      }
      units "dB";
    }
    leaf sSearchDeltaPStationary {
      description "Threshold for Srxlev variation in stationary criterion for relaxed measurements. If empty, value is not broadcast in SIB2, and UE is not configured for stationary evaluation. Only applicable when tSearchDeltaPStationary is non-empty. Only applicable to RedCap devices..";
      type int32 {
        range "2..3 | 6 | 9 | 12 | 15";
      }
      units "dB";
    }
    leaf sSearchThresholdP {
      description "Threshold for Srxlev in not-at-cell-edge criterion for relaxed measurements. If empty, value is not broadcast in SIB2, and UE is not configured for evaluation of not-at-cell-edge.; range 0..62.";
      type eytypes:int32_range_0-62;
      units "dB";
    }
    leaf sSearchThresholdP2 {
      description "Threshold for Srxlev in not-at-cell-edge while stationary criterion for relaxed measurements. If empty, value is not broadcast in SIB2, and UE is not configured for evaluation of not-at-cell-edge while stationary. Only applicable when sSearchDeltaPStationary and tSearchDeltaPStationary are non-empty. Only applicable to RedCap devices.; range 0..62.";
      type eytypes:int32_range_0-62;
      units "dB";
    }
    leaf sSearchThresholdQ {
      description "Threshold for Squal in not-at-cell-edge criterion for relaxed measurements. If empty, value is not broadcast in SIB2. Only applicable when sSearchThresholdP is non-empty.; range 0..31.";
      type eytypes:int32_range_0-31;
      units "dB";
    }
    leaf sSearchThresholdQ2 {
      description "Threshold for Squal in not-at-cell-edge while stationary criterion for relaxed measurements. If empty, value is not broadcast in SIB2. Only applicable when sSearchThresholdP2 is non-empty. Only applicable to RedCap devices.; range 0..31.";
      type eytypes:int32_range_0-31;
      units "dB";
    }
    leaf tSearchDeltaP {
      description "Duration of Srxlev variation measurement in low mobility criterion for relaxed measurements. If empty, value is not broadcast in SIB2, and UE is not configured for low mobility evaluation. Only applicable when sSearchDeltaP is non-empty..";
      type int32 {
        range "5 | 10 | 20 | 30 | 60 | 120 | 180 | 240 | 300";
      }
      units "s";
    }
    leaf tSearchDeltaPStationary {
      description "Duration of Srxlev variation measurement in stationary criterion for relaxed measurements. If empty, value is not broadcast in SIB2, and UE is not configured for stationary evaluation. Only applicable when sSearchDeltaPStationary is non-empty. Only applicable to RedCap devices..";
      type int32 {
        range "5 | 10 | 20 | 30 | 60 | 120 | 180 | 240 | 300";
      }
      units "s";
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping ResourcePartition-attributes {
    leaf related5qiTableRef {
      description "Reference to an instance of CUCP5qiTable MO..";
      type string;
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance. Currently not used..";
      type string;
      min-elements 0;
    }
    leaf resourcePartitionId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf resourcePartitionName {
      description "Name of a resource partition.; length 1..255.";
      type string {
        length "1..255";
      }
    }
  }
  grouping ResourcePartitionMember-attributes {
    leaf endpointResourceRef {
      description "Reference to an instance of EndpointResource MO. Defines transport network configuration for specific PLMN or NSSAI. If empty, GNBCUCPFunction::endpointResourceRef is used. Cannot refer to EndpointResource MO which has LocalSctpEndpoint::interfaceUsed set to F1. F1 SctpEndpoint can only be referenced from GNBCUCPFunction::endpointResourceRef..";
      type string;
    }
    list pLMNIdList {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct sequence entry.";
      }
      min-elements 0;
      max-elements 12;
      uses PLMNId-struct;
    }
    leaf resourcePartitionMemberId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    list sNSSAIList {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct sequence entry.";
      }
      min-elements 0;
      max-elements 1024;
      uses SliceSelectionAssistInfo-struct;
    }
  }
  grouping ResourcePartitions-attributes {
    leaf resourcePartitionsId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping RibTmRelation-attributes {
    leaf additionalInfo {
      description "Information about any Radio Interface-Based Time Monitoring error..";
      type enumeration {
        enum FEATURE_DEACTIVATED;
        enum PEER_FEATURE_DEACTIVATED;
        enum UNSUPP_HW_CONF;
        enum PEER_UNSUPP_HW_CONF;
        enum MAX_PAIRS;
        enum PEER_MAX_PAIRS;
        enum NO_RESP_FROM_PEER;
        enum PCI_CONFLICT;
        enum INCOMPATIBLE_CELLS;
        enum CELL_DISABLED;
        enum PEER_CELL_DISABLED;
      }
      config false;
    }
    leaf administrativeState {
      description "The administrative state. If set to SHUTTINGDOWN, the state is immediately brought to LOCKED..";
      type enumeration {
        enum LOCKED;
        enum UNLOCKED;
        enum SHUTTINGDOWN;
      }
    }
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operationalState..";
      type AvailStatus;
      min-elements 0;
    }
    leaf isRemoveAllowed {
      description "Whether Radio Interface-Based Time Monitoring (RIB-TM) autoconfiguration can remove this instance. This setting does not restrict operator removal of object. Objects created by RIB-TM autoconfiguration have this attribute set to true initially.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf measurementQuality {
      description "Quality of Radio Interface-Based Time Monitoring measurements..";
      type enumeration {
        enum NO_MEASUREMENTS;
        enum UNKNOWN;
        enum RELIABLE;
        enum UNRELIABLE;
      }
      config false;
    }
    leaf operationalState {
      description "The operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf peerCellRef {
      description "Reference to the assisting cell. Can be an instance of ExternalNRCellCU MO..";
      type string;
      mandatory true;
    }
    leaf ribTmRelationId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list pmRibtmTimeErrorDistr {
      description "Node time alignment error measured on radio interface-based time monitoring relation by Radio Interface-Based Time Monitoring feature. Covers all sector carrier pairs valid for radio interface-based time monitoring relation. Unit: N/A Ranges: Bin[0]: [..-3000[ nanoseconds Bin[1]: [-3000..-2500[ nanoseconds Bin[2]: [-2500..-2000[ nanoseconds Bin[3]: [-2000..-1500[ nanoseconds Bin[4]: [-1500..-1000[ nanoseconds Bin[5]: [-1000..-500[ nanoseconds Bin[6]: [-500..0[ nanoseconds Bin[7]: [0..500] nanoseconds Bin[8]: ]500..1000] nanoseconds Bin[9]: ]1000..1500] nanoseconds Bin[10]: ]1500..2000] nanoseconds Bin[11]: ]2000..2500] nanoseconds Bin[12]: ]2500..3000] nanoseconds Bin[13]: ]3000..] nanoseconds.";
      type uint64;
      max-elements 14;
    }
  }
  grouping Rohc-attributes {
    leaf rohcId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained RohcUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
  }
  grouping RohcUeCfg-attributes {
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf-list rohc5qiList {
      description "Rohc5qi list. List of 5QIs for which Robust Header Compression is enabled.; Default values sequence: 1.";
      type int32 {
        range "1 | 65..66";
      }
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf rohcUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 32;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping Rrc-attributes {
    leaf rrcId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf t312 {
      description "Timer t312. Waiting time for fast radio link failure recovery. Recommended to be less than t310 under GNBDUFunction instance for fast radio link failure recovery. Otherwise, there is no benefit.; Default value: 1000.";
      type int32 {
        range "0 | 50 | 100 | 200 | 300 | 400 | 500 | 1000";
      }
      default "1000";
      units "ms";
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained RrcUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
  }
  grouping RrcInactiveProfile-attributes {
    leaf rrcInactiveProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained RrcInactiveProfileUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
  }
  grouping RrcInactiveProfileUeCfg-attributes {
    leaf periodicRnaUpdateCount {
      description "Indicates the amount of periodic RNA update procedure before UE becomes RRC_IDLE. If 0, UE becomes RRC_INACTIVE when RRCResumeRequest message is received. If n, and n is greater than 0, - UE becomes RRC_IDLE when nth RRCResumeRequest message is received. - UE becomes RRC_INACTIVE every time an RRCResumeRequests message is received, except for nth one.; range 0..5; Default value: 1.";
      type eytypes:int32_range_0-5;
      default "1";
    }
    leaf periodicRnaUpdateTimer {
      description "Configuration of t380. Value of t380 for UE is calculated based on this attribute and Periodic Registration Update timer provided by Core Network.; Default value: 60.";
      type int32 {
        range "5 | 10 | 20 | 30 | 60 | 120 | 360 | 720";
      }
      default "60";
      units "minute";
    }
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf rrcInactiveProfileUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf rrcInactiveStateSupport {
      description "Whether RRC Inactive state is supported. Applies to RRC Release procedure triggered by user plane and control plane inactivity.; Default value: true.";
      type boolean;
      default "true";
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 32;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping RrcUeCfg-attributes {
    leaf dedicatedSib1AtHo {
      description "Whether dedicatedSIB1-Delivery IE is included in RRCReconfiguration message at handover.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf rrcReestForcedFallback {
      description "Whether forced fallback to RRC connection establishment is enabled. If true, fallback to RRC connection establishment is performed regardless of other conditions when RRC reestablishment procedure is triggered.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf rrcUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf tWaitForRrcReestRequest {
      description "Waiting time for the RRC Reestablishment Request message upon detecting Radio Link Failure. Used by RBS.; range 1..20; Default value: 6.";
      type eytypes:int32_range_1-20;
      default "6";
      units "s";
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 32;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping SecurityHandling-attributes {
    leaf-list cipheringAlgoPrio {
      description "Array of allowed ciphering algorithms with priority order. Minimum length of 1, maximum length of 4. Algorithm in index zero has highest priority. Each algorithm written only once in array..";
      type CipheringAlgorithmID;
      min-elements 1;
      max-elements 4;
    }
    leaf featCtrlIntegProtUserPlane {
      description "Whether the feature Integrity Protection of User Plane is on or off..";
      type enumeration {
        enum OFF;
        enum ON;
      }
    }
    leaf integProtUserPlaneLowRate {
      description "Whether a low rate Integrity Protection is handled by reject or no Integrity Protection..";
      type enumeration {
        enum REJECT;
        enum NO_INTEGRITY_PROTECTION;
      }
    }
    leaf-list integrityProtectAlgoPrio {
      description "Array of allowed integrity algorithms with priority order. Minimum length of 1, maximum length of 3. Algorithm in index zero has highest priority. Each algorithm written only once in array..";
      type IntegrityAlgorithmID;
      min-elements 1;
      max-elements 3;
    }
    leaf personalDataProtectionEnabled {
      description "Whether personal data protection is enabled. When personal data protection is enabled, subscriber personal data is not logged. If protection is disabled, there are rare traffic occasions when subscriber personal data is revealed and can be logged in PM events and other short-lived on-demand troubleshooting logs. Alert is raised when personal data protection is set to be disabled.; Default value: true.";
      type boolean;
      default "true";
    }
    leaf securityHandlingId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping TermPointToAmf-attributes {
    list additionalOperatorPlmnIdList {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct sequence entry.";
      }
      min-elements 0;
      max-elements 11;
      uses PLMNId-struct;
    }
    leaf administrativeState {
      description "The administrative state. If set to SHUTTINGDOWN, the state is immediately brought to LOCKED..";
      type enumeration {
        enum LOCKED;
        enum UNLOCKED;
        enum SHUTTINGDOWN;
      }
    }
    leaf amfName {
      description "AMF name used by ENM to identify an AMF. Set by RBS at NG-SETUP or AMF CONFIGURATION UPDATE..";
      type string;
      config false;
    }
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operationalState..";
      type AvailStatus;
      min-elements 0;
    }
    leaf defaultAmf {
      description "Whether TermPointToAmf instance is a default AMF.; Default value: true.";
      type boolean;
      default "true";
    }
    leaf domainName {
      description "Fully qualified domain name of AMF. Consists of one or more labels, separated by dots (.). Valid characters for labels are limited to letters a - z, A - Z, digits 0 - 9, and character - (dash). Character case is preserved. Length of labels cannot exceed 255 characters. NOTE: First and last character in domain name cannot be the character - (dash). For more information, see RFC 952, 1101 and 1123.; length 1..255.";
      type string {
        length "1..255";
        pattern "(((([a-zA-Z0-9]([a-zA-Z0-9\\-]){0,255})?[a-zA-Z0-9]\\.)*([a-zA-Z0-9]([a-zA-Z0-9\\-]){0,255})?[a-zA-Z0-9]\\.?)|\\.)";
      }
    }
    leaf ipv4Address1 {
      description "Primary IPv4 address of AMF for NG-C interface. The input format is four fields of digits, separated by dots. Each field consists of three digits. The value of each field must be in the range 0..255.; length 7..15; Default value: 0.0.0.0.";
      type string {
        length "7..15";
        pattern "((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\\.){3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])";
      }
      default "0.0.0.0";
    }
    leaf ipv4Address2 {
      description "Secondary IPv4 address of AMF for NG-C interface. The input format is four fields of digits, separated by dots. Each field consists of three digits. The value of each field must be in the range 0..255.; length 7..15; Default value: 0.0.0.0.";
      type string {
        length "7..15";
        pattern "((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\\.){3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])";
      }
      default "0.0.0.0";
    }
    leaf ipv6Address1 {
      description "Primary IPv6 address of AMF for NG-C interface. The input format is eight fields, separated by colons. Each field consists of four hexadecimal characters. The value of each field must be in the range 0..FFFF. Leading zeroes can be omitted in a field, and multiple groups of 16 bits of zeroes can be compressed to ::. The :: can be used only once in an address.; length 2..39; Default value: ::.";
      type string {
        length "2..39";
        pattern "(::|((([0-9A-Fa-f]{1,4}):){7}(([0-9A-Fa-f]{1,4})|:))|((([0-9A-Fa-f]{1,4}):){6}(:([0-9A-Fa-f]{1,4})|:))|((([0-9A-Fa-f]{1,4}):){5}(((:([0-9A-Fa-f]{1,4})){1,2})|:))|((([0-9A-Fa-f]{1,4}):){4}(((:([0-9A-Fa-f]{1,4})){1,3})|:))|((([0-9A-Fa-f]{1,4}):){3}(((:([0-9A-Fa-f]{1,4})){1,4})|:))|((([0-9A-Fa-f]{1,4}):){2}(((:([0-9A-Fa-f]{1,4})){1,5})|:))|((([0-9A-Fa-f]{1,4}):)(((:([0-9A-Fa-f]{1,4})){1,6})|:))|(:(:([0-9A-Fa-f]{1,4})){1,7}))";
      }
      default "::";
    }
    leaf ipv6Address2 {
      description "Secondary IPv6 address of AMF for NG-C interface. The input format is eight fields, separated by colons. Each field consists of four hexadecimal characters. The value of each field must be in the range 0..FFFF. Leading zeroes can be omitted in a field, and multiple groups of 16 bits of zeroes can be compressed to ::. The :: can be used only once in an address.; length 2..39; Default value: ::.";
      type string {
        length "2..39";
        pattern "(::|((([0-9A-Fa-f]{1,4}):){7}(([0-9A-Fa-f]{1,4})|:))|((([0-9A-Fa-f]{1,4}):){6}(:([0-9A-Fa-f]{1,4})|:))|((([0-9A-Fa-f]{1,4}):){5}(((:([0-9A-Fa-f]{1,4})){1,2})|:))|((([0-9A-Fa-f]{1,4}):){4}(((:([0-9A-Fa-f]{1,4})){1,3})|:))|((([0-9A-Fa-f]{1,4}):){3}(((:([0-9A-Fa-f]{1,4})){1,4})|:))|((([0-9A-Fa-f]{1,4}):){2}(((:([0-9A-Fa-f]{1,4})){1,5})|:))|((([0-9A-Fa-f]{1,4}):)(((:([0-9A-Fa-f]{1,4})){1,6})|:))|(:(:([0-9A-Fa-f]{1,4})){1,7}))";
      }
      default "::";
    }
    leaf isRemoveAllowed {
      description "Whether Discovery of AMFs via DNS function can remove this instance. If false, Discovery of AMFs via DNS function also does not modify this object. Setting does not restrict operator removal of object. Objects created by Discovery of AMFs via DNS function have this attribute set to true initially.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf operationalState {
      description "The operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    list operatorPLMNId {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "PLMN identifier used to select transport configuration for NG-C interface. PLMN identifier is also used for alarm filtering purposes. If empty, GNBCUCPFunction::pLMNId is used..";
      uses PLMNId-struct;
    }
    list pLMNIdList {
      config false;
      min-elements 0;
      max-elements 12;
      uses PLMNId-struct;
    }
    leaf pwsRestartHandling {
      description "Whether the NG-C link is used to send restart and failure messages related to PWS. Note: If ENABLED but no connection exists between AMF and CBC function, the PWS restart and failure messages are lost..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
    }
    leaf relativeCapacity {
      description "Relative processing capacity of an AMF to other AMFs in pool. Capacity is used to balance the load between AMFs in a pool.; range 0..255.";
      type eytypes:int32_range_0-255;
      config false;
    }
    list servedGuamiList {
      config false;
      min-elements 0;
      max-elements 256;
      uses GlobalUniqueAmfId-struct;
    }
    list sNSSAIList {
      config false;
      min-elements 0;
      max-elements 1024;
      uses SliceSelectionAssistInfo-struct;
    }
    leaf termPointToAmfId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    list unavailableGuamiList {
      config false;
      min-elements 0;
      max-elements 256;
      uses GlobalUniqueAmfId-struct;
    }
    leaf usedIpAddress {
      description "The destination address used for initialization of underlying SCTP association. Contains the address of the latest successful NGAP Setup. The IP address can be an IPv4 or an IPv6 address.; length 2..39.";
      type string {
        length "2..39";
      }
      config false;
    }
  }
  grouping TermPointToENodeB-attributes {
    leaf administrativeState {
      description "The administrative state. If set to SHUTTINGDOWN, the state is immediately brought to LOCKED..";
      type enumeration {
        enum LOCKED;
        enum UNLOCKED;
        enum SHUTTINGDOWN;
      }
    }
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operational state..";
      type AvailStatus;
      min-elements 0;
    }
    leaf ipsecEpAddress {
      description "Outer IP address of X2 eNodeB neighbor in EN-DC case. Manual configuration is only applicable if peer node is not upgraded to support automatic direct X2 IPsec configuration. Outer IP address received from X2 neighbor node overwrites manual configuration by operator. If empty, no direct IPsec VPN connection is to be established. Can be IPv4 or IPv6 address. For IPv4, input format is four fields of digits, separated by dots. Each field can consist of three digits. Value of each field is in range 0..255. For IPv6, input format is eight fields, separated by colons. Each field consists of four hexadecimal characters. Value of each field is in range 0..FFFF. Leading zeroes can be omitted in a field. Multiple groups of 16 bits of zeroes can be compressed to :: and can appear once in address.; length 2..39.";
      type string {
        length "2..39";
        pattern "(::|((([0-9A-Fa-f]{1,4}):){7}(([0-9A-Fa-f]{1,4})|:))|((([0-9A-Fa-f]{1,4}):){6}(:([0-9A-Fa-f]{1,4})|:))|((([0-9A-Fa-f]{1,4}):){5}(((:([0-9A-Fa-f]{1,4})){1,2})|:))|((([0-9A-Fa-f]{1,4}):){4}(((:([0-9A-Fa-f]{1,4})){1,3})|:))|((([0-9A-Fa-f]{1,4}):){3}(((:([0-9A-Fa-f]{1,4})){1,4})|:))|((([0-9A-Fa-f]{1,4}):){2}(((:([0-9A-Fa-f]{1,4})){1,5})|:))|((([0-9A-Fa-f]{1,4}):)(((:([0-9A-Fa-f]{1,4})){1,6})|:))|(:(:([0-9A-Fa-f]{1,4})){1,7})|((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\\.){3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9]))";
      }
    }
    leaf operationalState {
      description "The operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf termPointToENodeBId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf upIpAddress {
      description "User plane address of X2 eNodeB neighbor in EN-DC case. Manual configuration is only applicable if peer node is not upgraded to support automatic direct X2 IPsec configuration. User plan address received from X2 neighbor node overwrites manual configuration by operator. If empty, no direct IPsec VPN connection is to be established. Can be IPv4 or IPv6 address. For IPv4, input format is four fields of digits, separated by dots. Each field can consist of three digits. Value of each field is in range 0..255. For IPv6, input format is eight fields, separated by colons. Each field consists of four hexadecimal characters. Value of each field is in range 0..FFFF. Leading zeroes can be omitted in a field. Multiple groups of 16 bits of zeroes can be compressed to :: and can appear once in address. Multiple groups of 16 bits of zeroes can be compressed to :: and can appear once in address.; length 2..39.";
      type string {
        length "2..39";
        pattern "(::|((([0-9A-Fa-f]{1,4}):){7}(([0-9A-Fa-f]{1,4})|:))|((([0-9A-Fa-f]{1,4}):){6}(:([0-9A-Fa-f]{1,4})|:))|((([0-9A-Fa-f]{1,4}):){5}(((:([0-9A-Fa-f]{1,4})){1,2})|:))|((([0-9A-Fa-f]{1,4}):){4}(((:([0-9A-Fa-f]{1,4})){1,3})|:))|((([0-9A-Fa-f]{1,4}):){3}(((:([0-9A-Fa-f]{1,4})){1,4})|:))|((([0-9A-Fa-f]{1,4}):){2}(((:([0-9A-Fa-f]{1,4})){1,5})|:))|((([0-9A-Fa-f]{1,4}):)(((:([0-9A-Fa-f]{1,4})){1,6})|:))|(:(:([0-9A-Fa-f]{1,4})){1,7})|((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\\.){3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9]))";
      }
    }
  }
  grouping TermPointToGNBCUUP-attributes {
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operationalState..";
      type AvailStatus;
      min-elements 0;
    }
    leaf gNBCUUPId {
      description "Central Unit User Plane (CUUP) identity within gNodeB..";
      type int64;
      config false;
    }
    leaf gNBCUUPName {
      description "Central Unit User Plane (CUUP) name..";
      type string;
      config false;
    }
    leaf operationalState {
      description "The operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf termPointToGNBCUUPId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf usedIpAddress {
      description "Destination address used in underlying connection. Contains address of latest successful E1 setup. IP address can be an IPv4 or an IPv6 address..";
      type string;
      config false;
    }
  }
  grouping TermPointToGNBDU-attributes {
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operational state..";
      type AvailStatus;
      min-elements 0;
    }
    leaf gNBDUId {
      description "Distributed Unit (DU) Identity within the gNodeB.; range 0..68719476735.";
      type eytypes:int64_range_0-68719476735;
      config false;
    }
    leaf gNBDUName {
      description "Distributed Unit (DU) name.; length 1..150.";
      type string {
        length "1..150";
      }
      config false;
    }
    leaf operationalState {
      description "The operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf pwsBroadcastStarted {
      description "Whether PWS service is started toward gNodeB-DU instance based on requested time. This attribute considers possible multiple messages and all cells in DU. NRCellDU::pwsBroadcastOngoing defines exact value for each cell..";
      type boolean;
      config false;
    }
    leaf termPointToGNBDUId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf usedIpAddress {
      description "Destination address used in underlying SCTP association. Contains address of latest successful F1-C setup. IP address can be an IPv4 or an IPv6 address..";
      type string;
      config false;
    }
  }
  grouping TermPointToGNodeB-attributes {
    leaf administrativeState {
      description "The administrative state. If set to SHUTTINGDOWN, the state is immediately brought to LOCKED..";
      type enumeration {
        enum LOCKED;
        enum UNLOCKED;
        enum SHUTTINGDOWN;
      }
    }
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operationalState..";
      type AvailStatus;
      min-elements 0;
    }
    leaf ipsecEpAddress {
      description "Outer IP address of Xn neighbor. Non-empty if direct IPsec VPN connection is to be established.; length 2..39.";
      type string {
        length "2..39";
      }
      config false;
    }
    leaf ipv4Address {
      description "IPv4 address of peer gNodeB. Four fields, separated by dots. Each field consists of up to three digits. Value of each field is in range 0..255. This attribute can be overridden by system if GNBCUCPFunction::xnIpAddrViaNgActive is true.; length 7..15; Default value: 0.0.0.0.";
      type ietfinet:ipv4-address;
      default "0.0.0.0";
    }
    leaf ipv6Address {
      description "IPv6 address of peer gNodeB. Eight fields, separated by colons. Each field consists of up to four hexadecimal characters. Value of each field is in range 0..FFFF. Leading zeroes can be omitted in a field, and multiple groups of 16 bits of zeroes can be compressed to :: The :: can appear only once in an address. This attribute can be overridden by system if GNBCUCPFunction::xnIpAddrViaNgActive is true.; length 2..39; Default value: ::.";
      type ietfinet:ipv6-address;
      default "::";
    }
    leaf operationalState {
      description "The operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf termPointToGNodeBId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf upIpAddress {
      description "Inner IP address of Xn neighbor. Non-empty if direct IPsec VPN connection is to be established.; length 2..39.";
      type string {
        length "2..39";
      }
      config false;
    }
    leaf usedIpAddress {
      description "Destination address used in underlying SCTP association..";
      type string;
      config false;
    }
    list usedPLMNId {
      config false;
      description "PLMNId used in underlying SCTP association. Used to select SctpEndPoint of Xn-C in local IP address selection for SCTP association..";
      uses PLMNId-struct;
    }
  }
  grouping TimeSchedulingGroup-attributes {
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf timeSchedulingGroupId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping TimeSchedulingWindow-attributes {
    leaf-list daysOfWeek {
      description "Days when time window is applicable..";
      type DayOfWeekOnly;
      min-elements 1;
      max-elements 7;
    }
    leaf epBoosterCellProfileRef {
      description "Reference to an instance of EpBoosterCellProfile MO. If empty, no Booster Carrier Sleep is used for this MO instance..";
      type string;
    }
    leaf startTime {
      description "Time of day when time window starts. Value ranges from 00:00 to 23:58.; length 5..5; Default value: 00:00.";
      type string {
        length "5";
        pattern "([01][0-9]|2[0-3]):([0-5][0-9])";
      }
      default "00:00";
    }
    leaf stopTime {
      description "Time of day when time window ends. Value ranges from 00:01 to 23:59.; length 5..5; Default value: 06:00.";
      type string {
        length "5";
        pattern "([01][0-9]|2[0-3]):([0-5][0-9])";
      }
      default "06:00";
    }
    leaf timeSchedulingWindowId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping TnlAssociation-attributes {
    leaf activeForNonUe {
      description "Whether this TNL association is preferred for non-UE associated signaling from gNodeB..";
      type boolean;
      config false;
    }
    leaf operationalState {
      description "The operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf-list remoteIpAddress {
      description "List of AMF IP addresses of this TNL association..";
      type string {
        length "2..39";
      }
      min-elements 1;
      max-elements 2;
    }
    leaf remotePortNumber {
      description "AMF port number of this TNL association.; range 1..65535.";
      type ietfinet:port-number;
      config false;
    }
    leaf tnlAssociationId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf usage {
      description "Usage of this TNL association. TNL association can be used for UE-associated signaling, for non-UE associated signaling or for both UE-associated and non-UE associated signaling..";
      type enumeration {
        enum BOTH;
        enum UE;
        enum NON_UE;
      }
      config false;
    }
    leaf weightFactor {
      description "Weight factor for TNL association, as set by AMF. Weight factor is used for selecting a TNL association for UE initial NGAP message.; range 0..255.";
      type eytypes:int32_range_0-255;
      config false;
    }
  }
  grouping TrafficOffload-attributes {
    leaf trafficOffloadId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
  }
  grouping TrafficSteering-attributes {
    leaf bwtishoB1ToB2DepHEnabled {
      description "Whether deprecation handling for rsrpPCellCandidateB1 in TrStSaCellProfileUeCfg is enabled. Whether deprecation handling for rsrpPCellCandidateB1 in TrStSaCellProfileUeCfg and for rsrpPCellCandidateB1Offset in TrStSaEUtranFreqRelProfileUeCfg is enabled. If true, deprecation handling as below apply: - At create of TrStSaCellProfileUeCfg instance: Set rsrpPCellCandidateB2.threshold1 to -29 Copy rsrpPCellCandidateB1.hysteresis to rsrpPCellCandidateB2.hysteresis Copy rsrpPCellCandidateB1.threshold to rsrpPCellCandidateB2.threshold2EUtra Copy rsrpPCellCandidateB1.timeToTrigger to rsrpPCellCandidateB2.timeToTrigger - At update of rsrpPCellCandidateB1 corresponding update of replacing rsrpPCellCandidateB2 is done as described below: Copy rsrpPCellCandidateB1.hysteresis to rsrpPCellCandidateB2.hysteresis Copy rsrpPCellCandidateB1.threshold to rsrpPCellCandidateB2.threshold2EUtra Copy rsrpPCellCandidateB1.timeToTrigger to rsrpPCellCandidateB2.timeToTrigger - At create of TrStSaEUtranFreqRelProfileUeCfg instance: Copy rsrpPCellCandidateB1Offset to rsrpPCellCandidateB2Offsets.threshold2EUtraOffset Set rsrpPCellCandidateB2Offsets.threshold1Offset to 0 - At update of rsrpPCellCandidateB1Offset corresponding update of replacing rsrpPCellCandidateB2Offsets is done as described below: Copy rsrpPCellCandidateB1Offset to rsrpPCellCandidateB2Offsets.threshold2EUtraOffset If false, no deprecation handling is applied for rsrpPCellCandidateB1 and rsrpPCellCandidateB1Offset. Node always uses rsrpPCellCandidateB2 configured in TrStSaCellProfileUeCfg instance. Updating rsrpPCellCandidateB2 never updates deprecated rsrpPCellCandidateB1. Node always uses rsrpPCellCandidateB2Offsets configured in TrStSaEUtranFreqRelProfileUeCfg instance. Updating rsrpPCellCandidateB2Offsets never updates deprecated rsrpPCellCandidateB1Offset. Disabling deprecation handling prevents rsrpPCellCandidateB2 in TrStSaEUtranFreqRelPro MO class from being overwritten by deprecation handling for rsrpPCellCandidateB1. Disabling deprecation handling prevents rsrpPCellCandidateB2Offsets in TrStSaEUtranFreqRelProfileUeCfg MO class from being overwritten by deprecation handling for rsrpPCellCandidateB1Offset. Set to false when using management system where rsrpPCellCandidateB2 in TrStSaCellProfileUeCfg MO class and rsrpPCellCandidateB2Offsets in TrStSaEUtranFreqRelProfileUeCfg MO class are visible.; Default value: true.";
      type boolean;
      default "true";
    }
    leaf dlCellLoadAware {
      description "Whether downlink cell load is considered when selecting cells. Only applicable if license for NR Advanced Multi-Layer Coordination is present and feature is active. Only applicable to Low-Band and Mid-Band cells.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf trafficSteeringId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ulCellLoadAwareEnabled {
      description "Whether uplink cell load is considered when selecting cells. Only applicable if licenses for both following features are present and features are active: - Uplink-Aware Advanced Multi-Layer Coordination - NR Advanced Multi-Layer Coordination Only applicable to Low-Band and Mid-Band cells.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping TrStPSCellNrFreqRelProfile-attributes {
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf trStPSCellNrFreqRelProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained TrStPSCellNrFreqRelProfileUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping TrStPSCellNrFreqRelProfileUeCfg-attributes {
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf rsrpCandidateA5Thr2Offset {
      description "RSRP A5 measurement threshold2 offset when searching for higher priority PSCell candidate. Used in PSCell Change to Higher Priority feature.; range -100..100; Default value: 0.";
      type eytypes:int32_range_-100-100;
      default "0";
      units "dB";
    }
    leaf rsrqCandidateA5Thr2Offset {
      description "RSRQ A5 measurement threshold2 offset when searching for higher priority PSCell candidate. Used in PSCell Change to Higher Priority feature.; range -100..100; Default value: 0.";
      type eytypes:int32_range_-100-100;
      default "0";
      units "dB";
    }
    leaf sinrCandidateA5Thr2Offset {
      description "SINR A5 measurement threshold2 offset when searching for higher priority PSCell candidate. Used in PSCell Change to Higher Priority feature.; range -100..100; Default value: 0.";
      type eytypes:int32_range_-100-100;
      default "0";
      units "dB";
    }
    leaf trStPSCellNrFreqRelProfileUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 32;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping TrStPSCellProfile-attributes {
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf trStPSCellProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained TrStPSCellProfileUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping TrStPSCellProfileUeCfg-attributes {
    leaf candidateA5TriggerQuantity {
      description "Measurement trigger quantity used when searching for higher priority PSCell candidate..";
      type enumeration {
        enum RSRP;
        enum RSRQ;
        enum SINR_FALLBACK_RSRP;
        enum SINR_FALLBACK_RSRQ;
      }
    }
    leaf hiPrioAllowedForDistUeEnabled {
      description "Whether PSCell Change to Higher Priority is allowed when EN-DC distribution model is applied. If true, PSCell Change to Higher Priority is allowed.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf hiPrioDetInactiveTime {
      description "Time period between periods of active measurements on higher priority cells.; range 500..300000; Default value: 30000.";
      type int32 {
        range "500..300000";
      }
      default "30000";
      units "ms";
    }
    leaf hiPrioDetMeasurementTime {
      description "Time period when measurements on higher priority cells are active.; range 500..120000; Default value: 5000.";
      type int32 {
        range "500..120000";
      }
      default "5000";
      units "ms";
    }
    leaf hiPrioDetStartTime {
      description "Initial delay before starting A5 measurements for higher priority cells.; range 10..10000; Default value: 2000.";
      type int32 {
        range "10..10000";
      }
      default "2000";
      units "ms";
    }
    leaf maxReportCells {
      description "Maximum number of non-serving cells included in measurement report. Only applicable to event A5.; range 1..8; Default value: 1.";
      type eytypes:int32_range_1-8;
      default "1";
    }
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    list rsrpCandidateA5 {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "RSRP A5 measurement report criteria when searching for higher priority PSCell candidate..";
      uses ReportConfigA5NoThr1Rsrp-struct;
    }
    leaf rsrpCandidateA5AddTargEval {
      description "Additional target evaluation of other reported quantity. Applicable when searching for for higher priority PSCell candidate with trigger quantity RSRP. Other reported quantity SINR is evaluated towards threshold value defined by following formula: threshold2 in sinrCandidateA5 + hysteresis in sinrCandidateA5 + TrStPSCellNrFreqRelProfileUeCfg::sinrCandidateA5Thr2Offset Other reported quantity RSRQ is evaluated towards threshold value defined by following formula: threshold2 in rsrqCandidateA5 + hysteresis in rsrqCandidateA5 + TrStPSCellNrFreqRelProfileUeCfg::rsrqCandidateA5Thr2Offset.";
      type enumeration {
        enum NONE;
        enum RSRQ;
        enum SINR_FALLBACK_RSRQ;
        enum SINR_NO_FALLBACK_RSRQ;
      }
    }
    list rsrqCandidateA5 {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "RSRQ A5 measurement report criteria when searching for higher priority PSCell candidate..";
      uses ReportConfigA5NoThr1Rsrq-struct;
    }
    leaf rsrqCandidateA5AddTargEval {
      description "Additional target evaluation of other reported quantity. Applicable when searching for for higher priority PSCell candidate with trigger quantity RSRQ. Other reported quantity RSRP is evaluated towards threshold value defined by following formula: threshold2 in rsrpCandidateA5 + hysteresis in rsrpCandidateA5 + TrStPSCellNrFreqRelProfileUeCfg::rsrpCandidateA5Thr2Offset - NRCellRelation::cellIndividualOffsetNR.";
      type enumeration {
        enum NONE;
        enum RSRP;
      }
    }
    list sinrCandidateA5 {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "SINR A5 measurement report criteria when searching for higher priority PSCell candidate..";
      uses ReportConfigA5NoThr1Sinr-struct;
    }
    leaf sinrCandidateA5AddTargEval {
      description "Additional target evaluation of other reported quantity. Applicable when searching for for higher priority PSCell candidate with trigger quantity SINR. Other reported quantity RSRP is evaluated towards threshold value defined by following formula: threshold2 in rsrpCandidateA5 + hysteresis in rsrpCandidateA5 + TrStPSCellNrFreqRelProfileUeCfg::rsrpCandidateA5Thr2Offset - NRCellRelation::cellIndividualOffsetNR Other reported quantity RSRQ is evaluated towards threshold value defined by following formula: threshold2 in rsrqCandidateA5 + hysteresis in rsrqCandidateA5 + TrStPSCellNrFreqRelProfileUeCfg::rsrqCandidateA5Thr2Offset.";
      type enumeration {
        enum NONE;
        enum RSRP;
        enum RSRQ;
        enum RSRP_AND_RSRQ;
      }
    }
    leaf trStPSCellProfileUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping TrStSaCellProfile-attributes {
    leaf dataAwareMobDlLowThpDuration {
      description "Minimum duration for UE to experience low downlink throughput. Used for throughput monitoring in NR Data-Aware Mobility feature.; range 1..10; Default value: 1.";
      type int32 {
        range "1..10";
      }
      default "1";
      units "s";
    }
    leaf dataAwareMobDlThpFilterCoeff {
      description "Filter coefficient used for downlink throughput monitoring. Used for throughput monitoring in NR Data-Aware Mobility feature.; range 0..95; Default value: 60.";
      type eytypes:int32_range_0-95;
      default "60";
    }
    leaf dataAwareMobDlThpFilterTime {
      description "Minimum valid time of downlink throughput samples. Used for throughput monitoring in NR Data-Aware Mobility feature.; range 0..1000; Default value: 200.";
      type eytypes:int32_range_0-1000;
      default "200";
      units "ms";
    }
    leaf dataAwareMobUlLowThpDuration {
      description "Minimum duration for UE to experience low uplink throughput. Used for throughput monitoring in NR Data-Aware Mobility feature.; range 1..10; Default value: 1.";
      type int32 {
        range "1..10";
      }
      default "1";
      units "s";
    }
    leaf dataAwareMobUlThpFilterCoeff {
      description "Filter coefficient used for uplink throughput monitoring. Used for throughput monitoring in NR Data-Aware Mobility feature.; range 0..95; Default value: 60.";
      type eytypes:int32_range_0-95;
      default "60";
    }
    leaf dataAwareMobUlThpFilterTime {
      description "Minimum valid time of uplink throughput samples. Used for throughput monitoring in NR Data-Aware Mobility feature.; range 0..1000; Default value: 200.";
      type eytypes:int32_range_0-1000;
      default "200";
      units "ms";
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf trStSaCellProfileId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained TrStSaCellProfileUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping TrStSaCellProfileUeCfg-attributes {
    leaf actionAtRelease {
      description "Traffic steering action at UE release. If mlcEnabled is false, value CA_CONF does not take effect. It is handled as DISABLED. Value RANDOM_REDIRECT is applicable to High-Band cells. Not supported for Low-Band or Mid-Band cells..";
      type enumeration {
        enum DISABLED;
        enum CA_CONF;
        enum PRIORITY_LIST;
        enum CRP_MLC_CONDITIONAL;
        enum RANDOM_REDIRECT;
      }
    }
    leaf aggregatedBwThreshold {
      description "Aggregated bandwidth threshold. Used in bandwidth-triggered inter-system handover function to decide if inter-system handover to E-UTRAN shall be triggered. If aggregated downlink bandwidth (MHz) of current serving NR cell(s) in coverage is lower than or equal to threshold inter-system handover to E-UTRAN might be triggereded. Downlink bandwidth per serving cell corresponds to value of NRSectorCarrier::bSChannelBwDL under GNBDUFunction instance.; range 1..1000; Default value: 10.";
      type int32 {
        range "1..1000";
      }
      default "10";
      units "MHz";
    }
    leaf bwTrigISHoEnabled {
      description "Whether bandwidth-triggered inter-system handover is enabled for NR cell.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf bwTrigISHoTriggerQuantity {
      description "Measurement trigger quantity used when searching for E-UTRAN PCell candidate. Used in function Bandwidth-Triggered Inter-System Handover and in feature NR Data-Aware Mobility..";
      type enumeration {
        enum RSRP;
        enum RSRQ;
        enum SINR_FALLBACK_RSRP;
        enum SINR_FALLBACK_RSRQ;
      }
    }
    leaf capAwarePCellSelEnabled {
      description "Whether multi-layer coordination is enabled for NR cell.; Default value: false; Takes effect: Next usage; Status info: Since 23.Q2. Replaced by mlcEnabled. Planned to be removed..";
      type boolean;
      status deprecated;
      default "false";
      reference "Takes effect: Next usage.";
    }
    leaf criterionBetterUeConfig {
      description "Criterion for better UE configuration. Defines a better UE configuration candidate relative to the current UE configuration. Expressed as percentage better estimated throughput based on the configured bandwidth of respective UE configuration. For NR Advanced Multi-Layer Coordination feature and Uplink-Aware Advanced Multi-Layer Coordination feature, cell load is also used when calculating estimated throughput.; range 1..100; Default value: 100.";
      type eytypes:int32_range_1-100;
      default "100";
      units "percent";
    }
    leaf criterionDlAbsoluteOffset {
      description "Absolute offset criterion in downlink for better UE configuration. Defines a better UE configuration candidate than current UE configuration. Expressed as an absolute offset above current estimated downlink cell weight for current UE configuration.; Default value: 5.";
      type int32 {
        range "0 | 5..100";
      }
      default "5";
      units "Mbps";
    }
    leaf criterionUlAbsoluteOffset {
      description "Absolute offset criterion in uplink for better UE configuration. Defines a better UE configuration candidate than current UE configuration. Expressed as an absolute offset above current estimated uplink cell weight for current UE configuration.; range 0..100; Default value: 2.";
      type int32 {
        range "0..100";
      }
      default "2";
      units "Mbps";
    }
    leaf dataAwareMobDlPktAgeThr {
      description "Threshold for age of packets in RLC SDU buffer. Used for buffer monitoring in NR Data-Aware Mobility feature. If 0, age buffer monitoring is disabled.; Default value: 0.";
      type int32 {
        range "0 | 10..500";
      }
      default "0";
      units "ms";
    }
    leaf dataAwareMobDlPktVolThr {
      description "Threshold for volume of packets in RLC SDU buffer. Used for buffer monitoring in NR Data-Aware Mobility feature. If 0, volume buffer monitoring is disabled.; Default value: 0.";
      type int32 {
        range "0 | 10..30000";
      }
      default "0";
      units "kB";
    }
    leaf dataAwareMobLowDlThpThr {
      description "Threshold for low downlink throughput. Used for throughput monitoring in NR Data-Aware Mobility feature. If 0, downlink throughput monitoring is disabled.; Default value: 0.";
      type int32 {
        range "0 | 500..10000";
      }
      default "0";
      units "kbps";
    }
    leaf dataAwareMobLowUlThpThr {
      description "Threshold for low uplink throughput. Used for throughput monitoring in NR Data-Aware Mobility feature. If 0, uplink throughput monitoring is disabled.; Default value: 0.";
      type int32 {
        range "0 | 500..3000";
      }
      default "0";
      units "kbps";
    }
    leaf dlCellLoadAware {
      description "Whether downlink cell load is considered when selecting cells. Only applicable if license for Advanced Multi-Layer Coordination is present and feature is active. Only applicable to Low-Band and Mid-Band cells..";
      type boolean;
    }
    list freqPrioListEUtran {
      key "id";
      leaf id {
