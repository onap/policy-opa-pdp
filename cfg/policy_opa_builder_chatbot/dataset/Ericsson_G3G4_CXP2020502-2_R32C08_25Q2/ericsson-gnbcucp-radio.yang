  augment "/emael:ManagedElement/gnbcucp:GNBCUCPFunction/gnbcucp:NRCellCU" {
    list DESManagementFunction {
      description "Additional definitions from MOM:min/max-elements:0/1; Distributed SON energy saving settings for cell. Instance DESManagementFunction=1 is created automatically when parent MO instance is created, unless created manually in same transaction. The RDN of this MO must be DESManagementFunction=1. Precondition: Instance DESManagementFunction=1 can only be created in same transaction as parent MO instance and cannot be deleted unless parent MO instance is deleted.";
      key "dESManagementFunctionId";
      leaf dESManagementFunctionId {
        type leafref {
          path "../attributes/dESManagementFunctionId";
        }
      }
      container attributes {
      uses DESManagementFunction-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbcucp:GNBCUCPFunction/gnbcucp:NRCellCU" {
    list EUtranCellRelation {
      description "Additional definitions from MOM:min/max-elements:0/128; Handover relationship between NR cell and a neighboring E-UTRAN cell. Can be created by action promoteLwEUtranCellRelation in NRCellCU instance. RDN is the same as for automatically created instance. When created automatically, the RDN of this MO is EUtranCellRelation=auto<ECI>, where ECI = <eNBid>*256 + <cellLocalId>. Length of RDN value is up to 13 characters for automatically created instance. Instance can be created without a preceding user-initiated transaction.";
      key "eUtranCellRelationId";
      leaf eUtranCellRelationId {
        type leafref {
          path "../attributes/eUtranCellRelationId";
        }
      }
      container attributes {
      uses EUtranCellRelation-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbcucp:GNBCUCPFunction/gnbcucp:NRCellCU" {
    list EUtranFreqRelation {
      description "Additional definitions from MOM:min/max-elements:0/16; Mobility relation between NR cell and an E-UTRAN frequency.";
      key "eUtranFreqRelationId";
      leaf eUtranFreqRelationId {
        type leafref {
          path "../attributes/eUtranFreqRelationId";
        }
      }
      container attributes {
      uses EUtranFreqRelation-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbcucp:GNBCUCPFunction/gnbcucp:NRCellCU" {
    list NRCellRelation {
      description "Additional definitions from MOM:min/max-elements:0/512; Handover relationship between NR cell and a neighboring NR cell. This MO is updated or deleted automatically when configuration message over F1, Xn or X2 interface is received, with changed frequency of neighbor cell. If matching NRFreqRelation instance exists, then nRFreqRelationRef is updated. Otherwise, NRCellRelation instance is deleted. See dependencies of nRFreqRelationRef. Can be created by action promoteLwNRCellRelation in NRCellCU instance. RDN is the same as for automatically created instance. When created automatically, the RDN of this MO is NRCellRelation=auto<NCI>, where NCI = <gNBId>*2^(36-<gNBIdLength>) + <cellLocalId>. Length of RDN value is up to 15 characters for automatically created instance. Instance can be created without a preceding user-initiated transaction.";
      key "nRCellRelationId";
      leaf nRCellRelationId {
        type leafref {
          path "../attributes/nRCellRelationId";
        }
      }
      container attributes {
      uses NRCellRelation-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbcucp:GNBCUCPFunction/gnbcucp:NRCellCU" {
    list NRFreqRelation {
      description "Additional definitions from MOM:min/max-elements:0/16; Mobility relation between NR cell and an NR frequency. Must use an NRFrequency on the Global Synchronization Channel Raster (indicated in NRFrequency::gscn) for Standalone operation. Frequency relation not on the GSCN are not included in SIB4, nor used for PCell mobility. Created automatically when F1 or Xn message is received and cell frequency is in frequency range defined in NRFreqRelationTemplate. Can also be created and deleted manually. When created automatically, the RDN of this MO is NRFreqRelation=auto<arfcn>_<scs>. Length of RDN value is up to 15 characters for automatically created instance. Instance can be created without a preceding user-initiated transaction.";
      key "nRFreqRelationId";
      leaf nRFreqRelationId {
        type leafref {
          path "../attributes/nRFreqRelationId";
        }
      }
      container attributes {
      uses NRFreqRelation-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbcucp:GNBCUCPFunction/gnbcucp:NRCellCU" {
    list NRFreqRelationTemplate {
      description "Additional definitions from MOM:min/max-elements:0/4; Frequency range of automatically created or deleted NRFreqRelation instances. Can be used, for example, for CBRS. Contains reference to default NRFreqRelation instance used as template for automatically created NRFreqRelation instances within this range. Note: Only NRFreqRelation instances within this range are automatically deleted. Changing the range or deleting an NRFreqRelationTemplate instance may require manual deletion of NRFreqRelation instances. NRFreqRelationTemplate instances cannot have overlapping nRFrequencyRange values under same NRCellCU instance.";
      key "nRFreqRelationTemplateId";
      leaf nRFreqRelationTemplateId {
        type leafref {
          path "../attributes/nRFreqRelationTemplateId";
        }
      }
      container attributes {
      uses NRFreqRelationTemplate-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbcucp:GNBCUCPFunction/gnbcucp:NRCellCU" {
    list RibTmRelation {
      description "Additional definitions from MOM:min/max-elements:0/unbounded; Radio interface-based time monitoring relation between a monitoring and an assisting NR cell. Created automatically when GNBCUCPFunction::ribTmAutoMax is higher than 0, a suitable NRCellRelation instance exists and there is enough capacity. Runs periodically every 5 minutes. Deleted automatically when GNBCUCPFunction::ribTmAutoMax is set to 0 or number of automatically created RibTmRelation instances exceeded GNBCUCPFunction::ribTmAutoMax limit (after setting new GNBCUCPFunction::ribTmAutoMax). Runs periodically every 5 minutes. Can also be created and deleted manually. When created automatically, the RDN of this MO is RibTmRelation=auto<NCI>, where remote NCI = <gNBId>*2^(36-<gNBIdLength>) + <cellLocalId>. Length of RDN value is up to 15 characters for automatically created instance. Instance can be created without a preceding user-initiated transaction.";
      key "ribTmRelationId";
      leaf ribTmRelationId {
        type leafref {
          path "../attributes/ribTmRelationId";
        }
      }
      container attributes {
      uses RibTmRelation-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbcucp:GNBCUCPFunction/gnbcucp:NRNetwork/gnbcucp:NRFrequency" {
    list NRFrequencyUeCfg {
      description "Additional definitions from MOM:min/max-elements:0/32; NRFrequency parameters for UE groups. Instance NRFrequencyUeCfg=Base is created automatically when parent MO instance is created, unless created manually in same transaction. Attributes prefUeGroupList, ueGroupList and ueConfGroupList must be empty in instance NRFrequencyUeCfg=Base but cannot all be empty in any other instance of NRFrequencyUeCfg under same parent NRFrequency instance. Precondition: Instance NRFrequencyUeCfg=Base can only be created in same transaction as parent MO instance and cannot be deleted unless parent MO instance is deleted. Other instances can be created and deleted at any time. Maximum 31 NRFrequencyUeCfg instances, with RDN different from Base, can be created under parent MO instance.";
      key "nRFrequencyUeCfgId";
      leaf nRFrequencyUeCfgId {
        type leafref {
          path "../attributes/nRFrequencyUeCfgId";
        }
      }
      container attributes {
      uses NRFrequencyUeCfg-attributes;
      }
    }
  }

