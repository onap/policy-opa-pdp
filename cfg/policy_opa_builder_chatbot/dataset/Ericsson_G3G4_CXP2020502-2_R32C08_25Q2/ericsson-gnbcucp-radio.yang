      config false;
    }
    leaf pmAnrNeighbRelRemEutran {
      description "Number of E-UTRAN neighbor relations removed by ANR function..";
      type uint64;
      config false;
    }
    leaf pmCaConfigDelaySamp {
      description "Number of times NRCellCU.pmCaConfigDelaySum PM counter accumulates new sample..";
      type uint64;
      config false;
    }
    leaf-list pmDrbRelAbnormalAmfArp {
      description "Number of abnormal DRB releases triggered by AMF for each Allocation and Retention Priority level. Compressed: True.";
      type uint64;
      max-elements 16;
    }
    leaf pmRrcResumeSuccRnaUpdate {
      description "Number of successful RRC connection resumptions for resumeCause rna-Update..";
      type uint64;
      config false;
    }
    leaf pmX2DowntimeInterfaceSupervision {
