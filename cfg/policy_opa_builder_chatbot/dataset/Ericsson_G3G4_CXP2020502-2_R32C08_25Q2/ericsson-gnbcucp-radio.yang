      description "Number of NR-DC UE setup attempts during intra-gNodeB, intra-cell handover. Counted on Master Node side..";
      type uint64;
      config false;
    }
    leaf pmEndcSetupScgUeAtt {
      description "Number of EN-DC SCG setup attempts initiated by by MeNodeB, excluding EN-DC setups performed after LTE handover if the SCG resource could be kept, and after gNB PSCell change..";
      type uint64;
      config false;
    }
    leaf pmNrdcSetupUeMnSuccHoIntraCell {
      description "Number of successful NR-DC UE setup attempts during intra-gNodeB, intra-cell handover. Counted on Master Node side..";
