      description "Number of PDU sessions released by AMF when cause is considered abnormal..";
      type uint64;
      config false;
    }
    leaf pmEndcPSCellChangeSuccInterSgnb {
      description "Number of successful inter-SgNodeB PSCell changes for EN-DC in source NR cell. For definition of PSCell, see 3GPP TS 37.340..";
      type uint64;
      config false;
    }
    leaf pmHoPrepSuccOutInterGnbPciHandling {
      description "Number of successful outgoing NR inter-gNodeB NG or Xn handover preparations in source NR cell triggered by PCI conflict handling..";
      type uint64;
      config false;
    }
    leaf pmHoPrepRejInCellBarred {
      description "Number of rejected Xn, NG, Inter-RAT handovers in NR SA because cell is barred. Deprecated: Since 24.Q3. Planned to be removed. Replaced by NRCellCU.pmHoPrepRejCellInvalid.; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf pmHoPrepAttInNg {
      description "Number of NG Handover request attempts..";
      type uint64;
      config false;
    }
    leaf-list pmSessionTimeDrb5qi {
      description "Aggregated session time of released DRBs for each mapped 5QI in milliseconds. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf pmRrcInitAccessRejUeCapacityLimit {
      description "Number of RRCSetupRequest, RRCResumeRequest, and RRCReestablishmentRequest messages not permitted because of UE capacity limit..";
      type uint64;
      config false;
    }
