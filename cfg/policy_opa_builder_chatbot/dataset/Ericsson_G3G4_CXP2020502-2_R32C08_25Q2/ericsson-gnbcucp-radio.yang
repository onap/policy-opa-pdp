        type leafref {
          path "../attributes/ulDataSplitUeCfgId";
        }
      }
      container attributes {
      uses UlDataSplitUeCfg-attributes;
      }
    }
  }
  typedef AcaOperationMode {
    description "Operational mode of Automated Carrier Aggregation.";
    type enumeration {
      enum AUTO {
        description "NRCellRelation::sCellCandidate is operated by Automated Carrier Aggregation. NRCellRelation::sCellCandidate can be configured for both uplink and downlink CA.";
      }
      enum MANUAL {
        description "NRCellRelation::sCellCandidate is managed manually by operator.";
      }
    }
  }
  typedef ActionAtRelease {
    description "Traffic steering action at UE release.";
    type enumeration {
      enum DISABLED {
        description "Traffic steering at release is disabled.";
      }
      enum CA_CONF {
        description "Cell reselection steering based on current carrier aggregation configuration. Cell reselection steering affects UEs both in RRC IDLE state and RRC INACTIVE state. Cell reselection priorities are included in 38.331 RRCRelease message if UE is configured with carrier aggregation at release occasion and if TrStSaCellProfileUeCfg::mlcEnabled is true. Cell reselection priorities are set in RRCRelease message as follows: - Priority for current PCell frequency is set to 7.8. - Priorities for current SCell frequencies are set to 6.8, 6.6, 6.4, 6.2 or 6 in order of decreasing ARFCN. - Priorities for remaining NR cell frequencies are set to 5.8, 5.6, 5.4, 5.2 or 5 in order of decreasing ARFCN. - Priorities for E-UTRAN frequencies are set between 4.8 and 0 in such a way that the priority order between E-UTRAN frequencies, as defined by EUtranFreqRelation::cellReselectionPriority and EUtranFreqRelation::cellReselectionSubPriority settings, is preserved.";
      }
      enum PRIORITY_LIST {
        description "Cell reselection steering based on frequency priority lists. Cell reselection steering affects UEs both in RRC IDLE state and RRC INACTIVE state. Cell reselection priorities are included in 38.331 RRCRelease message according to freqPrioListNR and freqPrioListEUtran.";
      }
      enum CRP_MLC_CONDITIONAL {
        description "Cell reselection steering conditional on multi-layer coordination evaluation. Cell reselection steering affects UEs both in RRC IDLE state and RRC INACTIVE state. Cell reselection priorities are included in 38.331 RRC release message if a multi-layer coordination evaluation has been performed at least once for UE. Cell reselection priorities are set in RRCRelease message as follows: - Priority for current PCell frequency is set to 7.8. - Priorities for current SCell frequencies are set to 6.8, 6.6, 6.4, 6.2 or 6 in order of decreasing ARFCN. - Priorities for remaining NR cell frequencies are set to 5.8, 5.6, 5.4, 5.2 or 5 in order of decreasing ARFCN. - Priorities for E-UTRAN frequencies are set between 4.8 and 0 in such a way that the priority order between E-UTRAN frequencies, as defined by EUtranFreqRelation::cellReselectionPriority and EUtranFreqRelation::cellReselectionSubPriority settings, is preserved.";
      }
      enum RANDOM_REDIRECT {
        description "Randomized redirection steering. Randomized redirection steering affects UEs in RRC IDLE state. Redirected carrier info is included in 38.331 RRCRelease message according to randomly selected frequency among allowed PCells frequencies.";
      }
    }
  }
