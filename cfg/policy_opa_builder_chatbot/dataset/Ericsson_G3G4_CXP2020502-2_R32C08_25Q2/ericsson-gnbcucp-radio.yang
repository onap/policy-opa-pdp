      mandatory true;
    }
    leaf default5qiTable {
      description "Indicates that CUCP5qiTable instance is a default 5QI table. The default 5QI table is used when no CUCP5qiTable has been configured for a resource partition.; Default value: false.";
      type boolean;
      default "false";
