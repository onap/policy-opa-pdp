      type int64;
      max-elements 15;
    }
    leaf-list ipdvRevAvg {
      description "Average IPDV measured in responder to initiator direction. Calculates according to RFC 5481 chapter 4.1. Only zero to positive values is presented. Unit: 1 microsecond Specification: RFC 5481.";
      type int64;
      max-elements 15;
    }
    leaf-list ipdvRevP95 {
      description "95th percentile value of IPDV measured in responder to initiator direction. Calculates according to RFC 5481 chapter 4.1. Only zero to positive values is presented. Unit: 1 microsecond Specification: RFC 5481.";
      type int64;
      max-elements 15;
    }
    leaf-list reorderPktFwd {
      description "Reordered packets in initiator to responder direction. Specification: RFC 4737, chapter 1.";
      type int64;
      max-elements 15;
    }
    leaf-list lostPeriodsFwd {
      description "Number of periods with lost packets in initiator to responder direction..";
      type int64;
      max-elements 15;
    }
    leaf-list duplicPktRev {
      description "Duplicated packets in responder to initiator direction. Specification: RFC 5560.";
      type int64;
      max-elements 15;
    }
    leaf-list ipdvFwdMin {
      description "Minimum IPDV measured in initiator to responder direction. Calculates according to RFC 5481 chapter 4.1. Only zero to positive values is presented. Unit: 1 microsecond Specification: RFC 5481.";
      type int64;
      max-elements 15;
    }
    leaf-list delayRtMax {
      description "Maximum round trip delay between TWAMP initiator and TWAMP responder, where Round trip delay is (T4-T1)-(T3-T2). Unit: 1 microsecond.";
      type int64;
      max-elements 15;
    }
    leaf-list dscpRecMax {
      description "Maximum received Differentiated Services Code Point (DSCP) value..";
      type int64;
      max-elements 15;
    }
    leaf-list ttlMaxFwd {
      description "Maximum Time To Live (TTL) for IPv4 or Hop Limit for IPv6 value in initiator to responder direction..";
      type int64;
      max-elements 15;
    }
    leaf-list rxPkts {
      description "Number of packets received by TWAMP initiator including duplicated packets..";
      type int64;
      max-elements 15;
    }
    leaf-list lostPeriodsRev {
      description "Number of periods with lost packets in responder to initiator direction..";
      type int64;
      max-elements 15;
    }
    leaf-list lostPeriodMaxFwd {
      description "Maximum lost period in millisecond in initiator to responder direction. Example: Three consecutive packet is lost when frequency is 10pps=300ms..";
      type int64;
      max-elements 15;
    }
    leaf-list ttlMinFwd {
      description "Minimum TTL for IPv4 or Hop Limit for IPv6 value in initiator to responder direction..";
      type int64;
      max-elements 15;
    }
    leaf-list delayRtP99 {
      description "99th percentile value of round trip delay between TWAMP initiator and TWAMP responder, where Round trip delay is (T4-T1)-(T3-T2). Unit: 1 microsecond.";
      type int64;
      max-elements 15;
    }
    leaf-list delayRtMin {
      description "Minimum round trip delay between TWAMP initiator and TWAMP responder, where Round trip delay is (T4-T1)-(T3-T2). Unit: 1 microsecond.";
      type int64;
      max-elements 15;
    }
    leaf-list ipdvFwdAvg {
      description "Average Inter Packet Delay Variation (IPDV) measured in initiator to responder direction. Calculates according to RFC 5481 chapter 4.1. Only zero to positive values is presented. Unit: 1 microsecond Specification: RFC 5481.";
      type int64;
      max-elements 15;
    }
    leaf-list lostPeriodMaxRev {
      description "Maximum lost period in milliseconds in responder to initiator direction. Example: Three consecutive packet is lost when frequency is 10pps=300ms..";
      type int64;
      max-elements 15;
    }
    leaf-list ipdvRevMin {
      description "Minimum IPDV measured in responder to initiator direction. Calculates according to RFC 5481 chapter 4.1. Only zero to positive values is presented. Unit: 1 microsecond Specification: RFC 5481.";
