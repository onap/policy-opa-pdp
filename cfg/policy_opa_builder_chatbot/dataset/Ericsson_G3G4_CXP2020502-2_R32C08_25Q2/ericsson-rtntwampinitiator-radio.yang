    }
    leaf-list ipdvRevP98 {
      description "98th percentile value of IPDV measured in responder to initiator direction. Calculates according to RFC 5481 chapter 4.1. Only zero to positive values is presented. Unit: 1 microsecond Specification: RFC 5481.";
      type int64;
      max-elements 15;
    }
    leaf-list ipdvFwdMax {
      description "Maximum IPDV measured in initiator to responder direction. Calculates according to RFC 5481 chapter 4.1. Only zero to positive values is presented. Unit: 1 microsecond Specification: RFC 5481.";
      type int64;
      max-elements 15;
    }
    leaf-list lostPktsFwd {
