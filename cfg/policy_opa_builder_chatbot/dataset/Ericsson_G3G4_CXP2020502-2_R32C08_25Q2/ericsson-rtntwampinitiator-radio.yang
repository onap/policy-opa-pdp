      type int64;
      max-elements 15;
    }
    leaf-list delayRtP95 {
      description "95th percentile value of round trip delay between TWAMP initiator and TWAMP responder, where Round trip delay is (T4-T1)-(T3-T2). Unit: 1 microsecond.";
      type int64;
