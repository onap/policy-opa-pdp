    leaf-list schedulingWeight {
      description "Scheduling weight..";
      type uint32;
      ordered-by user;
      min-elements 0;
    }
    leaf userLabel {
      description "Label for free use.; length 1..128.";
      type string {
        length "1..128";
      }
    }
  }
  grouping SchedulerSp-attributes {
    leaf order {
      description "If parent is SchedulerDwrr MO or SchedulerSP MO, this attribute indicates unique index amongst its children. If parent is SchedulerSP MO, this index denotes scheduling priority.; Default value: 0.";
      type uint16;
      default "0";
    }
    leaf schedulerSpId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf userLabel {
      description "Label for free use.; length 1..128.";
      type string {
        length "1..128";
      }
    }
  }
  grouping Shaper-attributes {
    list committedBurstSize {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      min-elements 1;
      description "Committed burst size. If set to less than 4000 bytes, shaper still allows 4000 bytes bursting. If set to more than 64000 bytes, shaper still allows maximum 64000 bytes bursting. Unit: 1 bytes.";
      uses CbsInShaper-struct;
    }
    list committedInformationRate {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      min-elements 1;
      description "Committed information rate. If set to less than 1000 kbps, shaper still allows 1000 kbps sending. Only applicable to RAN Compute Group 4 and higher. Unit: 1 kbps.";
      uses CirInShaper-struct;
    }
    leaf order {
      description "If parent is SchedulerDwrr MO or SchedulerSP MO, this attribute indicates unique index amongst its children. If parent is SchedulerSP MO, this index denotes scheduling priority.; Default value: 0.";
      type uint16;
      default "0";
    }
    leaf shaperId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf userLabel {
      description "Label for free use.; length 1..128.";
      type string {
        length "1..128";
      }
    }
  }
}
