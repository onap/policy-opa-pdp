  grouping QueueRed-attributes {
    leaf exponentWeight {
      description "The averaging weight factor used by the RED drop mechanism. The weight factor is used when calculating the average queue length and it is represented as the parameter n in the following formula: average_queue_length = old_average_queue_length * (1 - 2^-n) + current_queue_length * 2^-n, where 2^-n means: 2 raised to the power of –n. The averaging weight factor controls the sensitivity to bursts and rapid changes in the current queue length. Setting the averaging weight factor too high causes the average queue length to respond too slowly to changes in the current queue size, thus not reacting to congestion. Setting the averaging weight factor too low causes the average queue length to respond too fast to changes in the actual queue size, thus overreacting to bursts and dropping packets unnecessarily. Guideline: The egress bandwidth and the average packet size should influence the choice of this attribute value..";
      type string;
    }
    list maxThreshold {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      min-elements 1;
      description "The maximum threshold for RED. When the average queue length is above the minimum threshold, RED starts dropping packets. The rate of packet drop increases linearly as the average queue length increases until the average queue length reaches the maximum threshold. When the average queue length is above the maximum threshold, all packets are dropped..";
      uses MaxThresholdForRed-struct;
    }
    list minThreshold {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      min-elements 1;
      description "The minimum threshold for RED. When the average queue length is above the minimum threshold, RED starts dropping packets. The rate of packet drop increases linearly as the average queue length increases until the average queue length reaches the maximum threshold. When the average queue length is above the maximum threshold, all packets are dropped..";
      uses MinThresholdForRed-struct;
    }
    leaf order {
      description "If parent is SchedulerDwrr MO or SchedulerSP MO, this attribute indicates unique index amongst its children. If parent is SchedulerSP MO, this index denotes scheduling priority.; Default value: 0.";
      type uint16;
      default "0";
    }
    leaf queueRedId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    list queueSize {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      min-elements 1;
      description "Maximum queue length..";
      uses QueueSizeForRed-struct;
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf userLabel {
      description "Label for free use.; length 1..128.";
      type string {
        length "1..128";
      }
    }
    leaf queueHCInPkts {
      description "The number (64-bit) of packets transmitted into the queue. Unit: Packets.";
      type uint64;
      config false;
    }
    leaf filledUpperThreshold {
      description "The number (64-bit) of samples, taken a 1000 times per ROP, when a queue is filled more than 80% of its size..";
      type uint64;
      config false;
    }
    leaf queueHCDroppedOctets {
      description "The number (64-bit) of octets discarded by the queue. Ethernet header, payload and FCS are counted. Unit: Octets.";
      type uint64;
      config false;
    }
    leaf queueHCOutPkts {
      description "The number (64-bit) of packets transmitted by the queue. Ethernet header, payload and FCS are counted. Unit: Octets.";
      type uint64;
      config false;
    }
    leaf filledLowerThreshold {
      description "The number (64-bit) of samples, taken a 1000 times per ROP, when a queue is filled more than 20% of its size..";
      type uint64;
      config false;
    }
    leaf queueHCDroppedPkts {
      description "The number (64-bit) of packets discarded by the queue. Unit: Packets; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf queueHCOutOctets {
      description "The number (64-bit) of octets transmitted by the queue. Ethernet header, payload and FCS are counted. Unit: Octets.";
      type uint64;
      config false;
    }
    leaf queueHCInOctets {
      description "The number (64-bit) of octets transmitted into the queue. Ethernet header, payload and FCS are counted. Unit: Octets.";
      type uint64;
      config false;
    }
  }
