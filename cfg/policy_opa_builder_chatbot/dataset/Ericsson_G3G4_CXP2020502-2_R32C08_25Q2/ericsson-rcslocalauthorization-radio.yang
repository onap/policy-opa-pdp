    list CustomRule {
      description "Additional definitions from MOM:min/max-elements:0/unbounded; The rules created by the MS that define the access control to objects. The CustomRule MO instances are associated with CustomRole MO instances, which may be then applied to users.";
      key "customRuleId";
      leaf customRuleId {
        type leafref {
          path "../attributes/customRuleId";
        }
      }
      container attributes {
      uses CustomRule-attributes;
      }
    }
  }

