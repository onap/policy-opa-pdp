      type enumeration {
        enum LOCKED;
        enum UNLOCKED;
      }
      mandatory true;
    }
    leaf userLabel {
      description "An additional descriptive text..";
      type string;
    }
  }
  grouping Role-attributes {
    leaf roleId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf roleName {
      description "The role name a user may have. The name is matched against role names retrieved from the user information store..";
      type string;
      config false;
    }
    leaf userLabel {
      description "An additional descriptive text..";
      type string;
    }
  }
  grouping Rule-attributes {
    leaf ruleId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ruleName {
      description "The rule name. The rule name is a string of '<FunctionName>_<RuleNumber>' <FunctionName> is a unique name for a system, transport, equipment, or application function. <RuleNumber> is a numerical ID of the Rule MO within a <FunctionName>. Examples: BackupAndRestoreManagement_1 FileManagement_2 SecurityManagement_2 SystemManagement_1.";
      type string;
      config false;
    }
    leaf permission {
      description "Permission is the access right the rule provides on a target specified by the ruleData attribute..";
      type enumeration {
        enum R;
        enum RW;
        enum X;
        enum RX;
        enum RWX;
        enum NO_ACCESS;
      }
      config false;
    }
    leaf ruleData {
      description "Defines the model elements for which the permission is applicable..";
      type string;
      config false;
    }
    leaf userLabel {
      description "An additional descriptive text..";
      type string;
    }
  }
