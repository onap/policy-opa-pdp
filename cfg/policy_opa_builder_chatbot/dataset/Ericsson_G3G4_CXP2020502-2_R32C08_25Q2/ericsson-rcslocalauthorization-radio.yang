    list LocalAuthorizationMethod {
      description "Additional definitions from MOM:min/max-elements:1/1;root;systemCreated; The Root MOC of the Local Authorization method. Roles and authorization rules are defined to build a Role Based Access Control (RBAC) model for controlling access to Managed Element resources such as Managed Objects, attributes, actions and CLI commands.";
      key "localAuthorizationMethodId";
      leaf localAuthorizationMethodId {
        type leafref {
          path "../attributes/localAuthorizationMethodId";
        }
      }
      container attributes {
      uses LocalAuthorizationMethod-attributes;
      }
    }
  }
  typedef BasicAdmState {
    description "Basic administrative states for a resource.";
    type enumeration {
      enum LOCKED {
        description "The resource is administratively prohibited from performing services for its users.";
      }
      enum UNLOCKED {
        description "The resource is administratively permitted to perform services for its users. This is independent of its inherent operability.";
      }
    }
  }
  typedef PermissionType {
    description "Permission is the access right a role has on a target object specified by the ruleData attribute. Current permission types follow UNIX/Linux permission enumeration values as follows: 0 = NO_ACCESS 1 = X (EXECUTE) 4 = R (READ) 5 = RX (READ and EXECUTE) 6 = RW (READ and WRITE) 7 = RWX (READ, WRITE and EXECUTE) Reserved values that are not included here are as follows and if required, may be introduced at a later date: 2 = W (WRITE) 3 = WX (WRITE and EXECUTE).";
    type enumeration {
      enum R {
        description "Read only access right. The user can read MOs and can get attribute values.";
      }
      enum RW {
        description "Read and write access right. The user can create and delete MOs and set and get attribute values.";
      }
      enum X {
        description "Execute access right. This is valid only for actions and specific commands.";
      }
      enum RX {
        description "Read and execute access rights. The user can read MOs, get attribute values, and execute any actions.";
      }
      enum RWX {
        description "Read, write, and execute access rights. The user can create and delete MOs, and set and get attribute values, and execute any actions.";
      }
      enum NO_ACCESS {
        description "No access. The user has no read, write or execute rights to the MO, attribute, or action.";
      }
    }
  }
