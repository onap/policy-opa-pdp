      type int32;
      config false;
      units "kWh";
    }
    leaf-list energyMeterListRef {
      description "List with references to which energy meter can be included in the calculation. Reference can be MO FieldReplaceableUnit representing a PSU, EMU or PDU of type ECM..";
      type string;
      ordered-by user;
      min-elements 1;
      max-elements 32;
    }
    leaf operationalState {
