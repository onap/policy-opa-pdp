      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf powerConsumption {
      description "The present power consumption of the units listed in the energyMeterListRef attribute. An undefined value indicates that it is not possible to calculate a measurement for the present power consumption..";
      type int32;
      config false;
      units "W";
    }
    leaf startTime {
      description "From when the energy consumption is calculated. If the field is left empty/undefined the system will start the measurements immediately at the creation of the MO. Format: YYYYMMDD hh:mm; length 14..14.";
      type string {
        length "14";
      }
    }
    leaf stopTime {
      description "When the measurement shall stop counting. An attribute to let the operator keep the measurement even when the calculating has stopped. If an empty/undefined value is set it means the measurement shall continue forever, i.e. until MO is deleted. Format: YYYYMMDD hh:mm; length 14..14.";
      type string {
        length "14";
      }
    }
    leaf userLabel {
      description "Label for free use.; length 1..128.";
      type string {
        length "1..128";
      }
    }
    leaf pmMaxPowerConsumption {
      description "Maximum power consumption during each ROP. Unit: 1 W.";
      type int32;
      config false;
    }
    leaf-list pmPowerConsumption {
      description "Average power consumption in 6 second periods averaged from one sample for each second. Unit: 1 W.";
      type int32;
      max-elements 150;
    }
    leaf pmAccumulatedEnergyConsumption {
      description "Accumulated energy consumption from start of EnergyMeasurement. Unit: 0.1 kWh.";
      type uint32;
      config false;
    }
    leaf pmEnergyConsumption {
      description "Energy consumed during each ROP. Unit: 0.1 kWh.";
      type uint32;
      config false;
    }
    leaf pmMinPowerConsumption {
      description "Minimum power consumption during each ROP. Unit: 1 W.";
      type int32;
      config false;
    }
