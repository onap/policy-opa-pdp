    leaf bridgeId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf lowLatencySwitching {
      description "Provides low latency switching over member ports.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf macAddress {
      description "MAC address of Bridged Virtual Interface (BVI), when BVI is associated with this Bridge MO..";
