      default "true";
    }
    leaf autoCreateExternalNodes {
      description "Whether or not detection of unconfigured external nodes results in auto-creation of corresponding ExternalNode MOs.; Default value: true.";
      type boolean;
      default "true";
    }
    leaf supportFunction {
      description "A read-only attribute boolean supportFunction, default true, always set to true. For use by management systems to distinguish supportFunction implementations..";
