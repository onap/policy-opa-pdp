    }
    leaf supportSystemControl {
      description "Indicates if the node controls and supervises the climate, power, and external alarm hardware in the cabinet. Only one node in the cabinet can control and supervise climate and power.; Default value: true.";
      type boolean;
      default "true";
    }
    leaf-list reservedBy {
      description "Contains a reference to the EcBus MO that reserve this MO instance..";
      type string;
      min-elements 0;
    }
