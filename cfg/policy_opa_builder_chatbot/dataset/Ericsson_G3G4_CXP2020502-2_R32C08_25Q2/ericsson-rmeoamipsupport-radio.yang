      description "Used to acknowledge successful setting of OaM IP address in management system. Set to value eriChangeIPAddressAckAttributeValue sent in SNMP trap eriChangeIPAddressEvent to acknowledge setting of OaM IP address in management system..";
      type int32;
    }
  }
