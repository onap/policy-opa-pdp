  }

  augment "/emael:ManagedElement/emael:Transport" {
    list SctpEndpoint {
      description "Additional definitions from MOM:min/max-elements:0/unbounded;root; Represents logical sender and receiver of SCTP packets. Maximum number of SctpEndpoint MO in node is limited to 128. Each SctpEndpoint is served by SCTP server assigned to one Router MO. Maximum number of SCTP servers running in parallel is limited to: - For Baseband in RAN Compute Group 1, 2, or 3: 8, - For Baseband in RAN Compute Group 4 or higher: 12.";
      key "sctpEndpointId";
      leaf sctpEndpointId {
        type leafref {
          path "../attributes/sctpEndpointId";
        }
      }
      container attributes {
      uses SctpEndpoint-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/emael:Transport/sctprdo:SctpEndpoint" {
    list SctpAssociation {
      description "Additional definitions from MOM:min/max-elements:0/unbounded;systemCreated; Represents protocol relationship between two SCTP Endpoints. It is composed of two SCTP Endpoints and protocol state information.";
      key "sctpAssociationId";
      leaf sctpAssociationId {
        type leafref {
          path "../attributes/sctpAssociationId";
        }
      }
      container attributes {
      uses SctpAssociation-attributes;
      }
    }
  }
  typedef AssociationSecurityState {
    description "SCTP association security status.";
    type enumeration {
      enum UNSECURED {
        description "SCTP association is not secured.";
      }
      enum SECURED {
        description "SCTP association is secured.";
      }
    }
  }
  typedef AssociationState {
    description "SCTP association state.";
    type enumeration {
      enum CLOSED {
        description "SCTP association is closed.";
      }
      enum ESTABLISHED {
        description "SCTP association is established.";
      }
    }
  }
  typedef AvailStatus {
    description "The availability status is used to qualify the operational state. It indicates why the operational state has changed its value.";
    type enumeration {
      enum IN_TEST {
        description "The resource is undergoing a test procedure. If the administrative state is locked or shutting down then normal users are precluded from using the resource.";
      }
      enum FAILED {
        description "The resource has an internal fault that prevents it from operating.";
      }
      enum POWER_OFF {
        description "The resource requires power to be applied and is not powered on.";
      }
      enum OFF_LINE {
        description "The resource requires a routine operation to be performed. This routine operation is to place the resource online and make it available for use. The operation may be manual or automatic, or both. The operational state is disabled.";
      }
      enum OFF_DUTY {
        description "The resource has been made inactive by an internal control process.";
      }
      enum DEPENDENCY {
        description "The resource cannot operate because some other resource on which it depends is unavailable.";
      }
      enum DEGRADED {
        description "The service available from the resource is degraded in some respect.";
      }
      enum NOT_INSTALLED {
        description "The resource represented by the managed object is not present, or is incomplete.";
      }
      enum LOG_FULL {
        description "This indicates a log full condition.";
      }
      enum DEPENDENCY_LOCKED {
        description "The administrative state of a resource that this resource depends on is locked. or the availability status of the other resource is dependency locked.";
      }
      enum DEPENDENCY_FAILED {
        description "The availability status of a resource that this resource depends on is failed or dependency failed.";
      }
      enum DEPENDENCY_SHUTTINGDOWN {
        description "The administrative state of a resource that this resource depends on is shutting down. or the availability status of the other resource is dependency shutting down.";
      }
    }
  }
  typedef OperState {
    description "The operational states of a resource.";
    type enumeration {
      enum DISABLED {
        description "The resource is totally inoperable.";
      }
      enum ENABLED {
        description "The resource is partially or fully operable.";
      }
    }
  }
  typedef RedundancyStatus {
    description "SCTP redundancy status.";
    type enumeration {
      enum UNDEFINED {
        description "SCTP redundancy is undefined, SCTP association is closed.";
      }
      enum DORMANT {
        description "All remote IP addresses are inactive.";
      }
      enum NOT_REDUNDANT {
        description "Redundancy addresses are unreachable. All remote IP addresses except primary are inactive.";
      }
      enum REDUNDANT {
        description "At least one remote IP address except primary is active.";
      }
      enum REDUNDANCY_NOT_POSSIBLE {
        description "SCTP association has only one remote IP address.";
      }
    }
  }
  typedef SctpSecurityMode {
    description "SCTP security mode.";
    type enumeration {
      enum DISABLED {
        description "No protection available.";
      }
      enum FORCED {
        description "DTLS protection is forced.";
      }
      enum PREFERRED {
        description "DTLS protection is preferred.";
      }
    }
  }
  grouping SctpAssociation-attributes {
    leaf associationSecurityState {
      description "SCTP association security state..";
      type enumeration {
        enum UNSECURED;
        enum SECURED;
      }
      config false;
    }
