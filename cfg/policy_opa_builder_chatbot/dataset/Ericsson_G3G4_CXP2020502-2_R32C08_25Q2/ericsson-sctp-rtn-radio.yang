      description "Remote IP address normally used for outgoing traffic..";
      type string;
      config false;
    }
    leaf sctpAssociationId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf sctpAssocInAbnormalControlChunks {
      description "Number of received control chunks which were chosen to be discarded due to errors in the chunk format or in the chunk content..";
      type uint64;
      config false;
    }
    leaf sctpAssocInControlChunks {
      description "Number of received control chunks. The counter does not include abnormal or discarded chunks..";
      type uint64;
      config false;
    }
    leaf sctpAssocTimeCongested {
      description "Number of seconds that the local transmission buffer for the association is congested..";
      type uint64;
      config false;
    }
    leaf sctpAssocOutDataChunks {
      description "Number of transmitted DATA chunks (excluding retransmissions)..";
      type uint64;
      config false;
    }
    leaf sctpAssocInAbnormalDataChunks {
      description "Number of received DATA chunks with errors in the chunk format or in the chunk contents preventing them from being delivered to the SCTP user..";
      type uint64;
      config false;
    }
    leaf sctpAssocOutPacks {
      description "Number of transmitted packets..";
      type uint64;
      config false;
    }
    leaf sctpAssocUnavailRtx {
      description "Number of times that the association has become unavailable to the SCTP user because all paths forming part of this association became inactive for one of the following reasons: - Retransmission limit was reached - an ICMP message is received and is treated as if the retransmission limit was reached.";
      type uint64;
      config false;
    }
    leaf sctpAssocAborteds {
      description "Number of times that the association has become unavailable to the SCTP user due to ungraceful termination by the local or the remote side, using the chunk ABORT.Ungraceful termination during association establishment does not increment this counter..";
      type uint64;
      config false;
    }
    leaf sctpAssocOutOctets {
      description "Number of octets in transmitted packets..";
      type uint64;
      config false;
    }
    leaf sctpAssocOutControlChunks {
      description "Number of transmitted control chunks..";
      type uint64;
      config false;
    }
    leaf sctpAssocShutdowns {
      description "Number of times that the association has become unavailable to the SCTP user due to graceful shutdown by the local or the remote side..";
      type uint64;
      config false;
    }
    leaf sctpAssocOutDiscardedDataChunks {
      description "Number of outgoing DATA chunks for this association for which no problems were encountered to prevent their transmission but were discarded. DATA chunks are discarded due to ungraceful closing of the association..";
      type uint64;
      config false;
    }
    leaf sctpAssocCongestions {
      description "Number of times that the local transmission buffer for the association is congested..";
      type uint64;
      config false;
    }
    leaf sctpAssocPeerZeroWindows {
      description "Number of times that the association has started the zero window supervision procedure..";
      type uint64;
      config false;
    }
    leaf sctpAssocTimeUnavail {
      description "Number of seconds the association has been unavailable to the SCTP user. Unit: 1 s.";
      type uint64;
      config false;
    }
    leaf sctpAssocDelayRTTMax {
      description "Maximum Round Trip Time value observed from all valid one minute intervals within ROP..";
      type int64;
      config false;
    }
    leaf sctpAssocInDiscardedDataChunks {
      description "Number of received DATA chunks that were discarded due to lack of space in the receive buffer..";
      type uint64;
      config false;
    }
    leaf sctpAssocOutDiscardedUserMsgs {
      description "Number of outgoing user data messages, which were discarded even though no problems were encountered to prevent their transmission. User messages are discarded due to lack of space in the transmission buffer..";
      type uint64;
      config false;
    }
    leaf sctpAssocInPacks {
      description "Number of received packets for this association, including duplicates and those received in error..";
      type uint64;
      config false;
    }
    leaf sctpAssocRtxChunks {
      description "Number of retransmitted DATA chunks..";
      type uint64;
      config false;
    }
    leaf sctpAssocDelayRTTAvg {
      description "Average Round Trip Time value from all valid one minute intervals within ROP..";
      type int64;
      config false;
    }
    leaf sctpAssocDelayRTTMin {
      description "Minimum Round Trip Time value observed from all valid one minute intervals within ROP.";
      type int64;
      config false;
    }
    leaf sctpAssocInOctets {
      description "Number of octets in received packets for this association, including duplicates and those received in error..";
      type uint64;
      config false;
    }
    leaf sctpAssocInDiscardedControlChunks {
      description "Number of received control chunks which were discarded even though no errors were detected. Chunks can be discarded for the following reasons: - unsupported chunk type. - wrong association state..";
      type uint64;
      config false;
    }
    leaf sctpAssocTimePeerZeroWindow {
      description "Number of seconds that the remote peer has claimed to have zero window for its receive buffer..";
      type uint64;
      config false;
    }
    leaf sctpAssocInDataChunks {
      description "Number of received DATA chunks. The counter does NOT include abnormal or discarded chunks..";
      type uint64;
      config false;
    }
    leaf sctpAssocDelayRTTPeriods {
      description "Number of valid one minute intervals within ROP, delayRTT values is based on. If retransmit occurs in one minute interval, specific interval will be excluded from result. If retransmit occurs in all 15 one minute intervals no delayRTT values will be presented..";
      type int64;
      config false;
    }
