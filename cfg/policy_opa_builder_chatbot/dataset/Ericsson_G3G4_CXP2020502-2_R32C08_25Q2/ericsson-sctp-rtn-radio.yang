      description "SCTP redundancy status indicates if there are redundant remote IP addresses available for SCTP traffic..";
      type enumeration {
        enum UNDEFINED;
        enum DORMANT;
        enum NOT_REDUNDANT;
        enum REDUNDANT;
        enum REDUNDANCY_NOT_POSSIBLE;
      }
      config false;
    }
    leaf-list remoteIpAddress {
      description "One or several remote IP addresses used by association..";
      type string;
      min-elements 0;
    }
