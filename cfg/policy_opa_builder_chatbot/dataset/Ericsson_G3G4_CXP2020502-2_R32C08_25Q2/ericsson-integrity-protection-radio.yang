        type leafref {
          path "../attributes/integrityProtectionId";
        }
      }
      container attributes {
      uses IntegrityProtection-attributes;
      }
    }
  }
  typedef IntegProtUpSupport {
    description "Status for supporting Integrity Protection of User Plane support on Baseband unit.";
    type enumeration {
      enum NOT_SUPPORTED {
        description "Integrity Protection of User Plane feature on Baseband is not supported.";
      }
      enum SUPPORTED {
        description "Integrity Protection of User Plane feature on Baseband is supported.";
      }
    }
  }
  grouping IntegrityProtection-attributes {
    leaf integrityProtectionId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf integProtUserPlaneCapability {
      description "Whether Baseband hardware has capability to support Integrity Protection of User Plane. Setting this attribute to SUPPORTED enables capability..";
      type enumeration {
        enum NOT_SUPPORTED;
        enum SUPPORTED;
      }
    }
  }
}
