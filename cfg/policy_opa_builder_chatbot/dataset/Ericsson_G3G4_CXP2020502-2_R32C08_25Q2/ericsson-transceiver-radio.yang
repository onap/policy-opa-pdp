      default "false";
    }
    leaf-list pmTxOffRatio2 {
      description "Relative time transmission power off in highest or next ascending supported band displayed in dlFrequencyRanges, recorded in regular periodic intervals during one ROP. Unit: %. Bins: [0] Transmission power off in [0..5] seconds in ROP. [1] Transmission power off in [6..11] seconds in ROP. ... [148] Transmission power off in [888..893] seconds in ROP. [149] Transmission power off in [894..899] seconds in ROP..";
      type int32;
      max-elements 150;
