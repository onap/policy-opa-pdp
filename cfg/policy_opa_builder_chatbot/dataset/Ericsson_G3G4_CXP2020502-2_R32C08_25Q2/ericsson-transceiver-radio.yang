    leaf mechanicalAntennaTilt {
      description "Fixed antenna tilt of installation, defined as inclination of antenna element axis with respect to vertical plane. A signed value. Positive indicates downtilt, negative indicates uptilt.; range -900..900; Default value: 0.";
      type eytypes:int32_range_-900-900-42;
      default "0";
      units "°";
    }
    leaf maxTotalTilt {
      description "Maximum antenna elevation including installed tilt and tilt applied by Remote Electrical Tilt (RET). Described by inclination of antenna main beam maximum with respect to horizontal plane. A signed value. Positive indicates downtilt, negative indicates uptilt. Sets a limitation on total tilt which is given by following formula: TotalTilt = Transceiver.mechanicalAntennaTilt + RetSubunit.electricalTilt If RET not installed, this value does not account for inclination that antenna beam can have by default, with respect to orthogonal direction to antenna element axis.; range -900..900; Default value: 900.";
      type eytypes:int32_range_-900-900-42;
      default "900";
      units "°";
    }
    leaf minTotalTilt {
      description "Minimum antenna elevation including installed tilt and tilt applied by Remote Electrical Tilt (RET). Described by inclination of antenna main beam maximum with respect to horizontal plane. A signed value. Positive indicates downtilt, negative indicates uptilt. Limitation on total tilt is found by following equation: TotalTilt = Transceiver.mechanicalAntennaTilt + RetSubunit.electricalTilt If RET not installed, total tilt value does not necessarily account for inclination the antenna beam can have by default, with respect to orthogonal direction to antenna element axis.; range -900..900; Default value: -900.";
      type eytypes:int32_range_-900-900-42;
      default "-900";
      units "°";
    }
    leaf totalTilt {
      description "Total antenna elevation including installed tilt and tilt applied by Remote Electrical Tilt (RET). Total tilt is defined as inclination of antenna main beam maximum with respect to horizontal plane. Tilt is a signed value. Positive indicates downtilt, negative indicates uptilt. Can be found by following equation: TotalTilt = Transceiver.mechanicalAntennaTilt + RetSubunit.electricalTilt If RET not installed, this value does not account for inclination that antenna beam can have by default, with respect to orthogonal direction to antenna element axis.; range -900..900.";
      type eytypes:int32_range_-900-900-42;
      config false;
      units "°";
    }
