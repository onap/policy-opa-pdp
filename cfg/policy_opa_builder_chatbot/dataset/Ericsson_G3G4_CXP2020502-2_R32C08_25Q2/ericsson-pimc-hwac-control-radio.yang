  }
  grouping PimcHwacControl-attributes {
    leaf pimcHwacControlId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf pimcEnabled {
      description "Whether PIMC is enabled on radio unit. Triggers PIMC HWAC allocation and release on radio unit. true: PIMC is enabled. Setting value to true allocates PIMC HWAC for PIMC capable radio unit. false: PIMC is disabled.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf pimcHwacAllocated {
      description "Whether PIMC HWAC is allocated for current radio unit. Default value is false..";
      type boolean;
