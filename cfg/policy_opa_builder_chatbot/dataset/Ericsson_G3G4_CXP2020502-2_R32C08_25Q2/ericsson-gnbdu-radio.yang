    leaf-list pmRadioBranchDeltaSinr0Distr {
      description "Value is SINR difference of PUSCH channel between antenna branch 1 and antenna branch 0 in antenna branch pair 0. Unit: N/A Ranges: Bin[0]: [..-29] dB Bin[1]: ]-29..-28] dB Bin[2]: ]-28..-27] dB Bin[3]: ]-27..-26] dB Bin[4]: ]-26..-25] dB Bin[5]: ]-25..-24] dB Bin[6]: ]-24..-23] dB Bin[7]: ]-23..-22] dB Bin[8]: ]-22..-21] dB Bin[9]: ]-21..-20] dB Bin[10]: ]-20..-19] dB Bin[11]: ]-19..-18] dB Bin[12]: ]-18..-17] dB Bin[13]: ]-17..-16] dB Bin[14]: ]-16..-15] dB Bin[15]: ]-15..-14] dB Bin[16]: ]-14..-13] dB Bin[17]: ]-13..-12] dB Bin[18]: ]-12..-11] dB Bin[19]: ]-11..-10] dB Bin[20]: ]-10..-9] dB Bin[21]: ]-9..-8] dB Bin[22]: ]-8..-7] dB Bin[23]: ]-7..-6] dB Bin[24]: ]-6..-5] dB Bin[25]: ]-5..-4] dB Bin[26]: ]-4..-3] dB Bin[27]: ]-3..-2] dB Bin[28]: ]-2..-1] dB Bin[29]: ]-1..0] dB Bin[30]: ]0..1] dB Bin[31]: ]1..2] dB Bin[32]: ]2..3] dB Bin[33]: ]3..4] dB Bin[34]: ]4..5] dB Bin[35]: ]5..6] dB Bin[36]: ]6..7] dB Bin[37]: ]7..8] dB Bin[38]: ]8..9] dB Bin[39]: ]9..10] dB Bin[40]: ]10..11] dB Bin[41]: ]11..12] dB Bin[42]: ]12..13] dB Bin[43]: ]13..14] dB Bin[44]: ]14..15] dB Bin[45]: ]15..16] dB Bin[46]: ]16..17] dB Bin[47]: ]17..18] dB Bin[48]: ]18..19] dB Bin[49]: ]19..20] dB Bin[50]: ]20..21] dB Bin[51]: ]21..22] dB Bin[52]: ]22..23] dB Bin[53]: ]23..24] dB Bin[54]: ]24..25] dB Bin[55]: ]25..26] dB Bin[56]: ]26..27] dB Bin[57]: ]27..28] dB Bin[58]: ]28..29] dB Bin[59]: ]29..] dB Compressed: True.";
