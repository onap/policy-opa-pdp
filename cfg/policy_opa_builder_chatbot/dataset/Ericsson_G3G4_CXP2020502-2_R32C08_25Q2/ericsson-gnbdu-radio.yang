      description "Total number of times when no HARQ is received in gNodeB uplink when the following conditions apply: - UL grant is meant for HARQ transmission of transport block that uses 256-QAM modulation. - DTX is considered the reason for no reception. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
