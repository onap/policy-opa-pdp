      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacTimeDlCaDrbActivity {
      description "Aggregated time for HARQ initial transmission scheduling activity of downlink DRB for data volume classified as carrier aggregation bursts. Scheduling activity refers to time interval from first scheduling occasion of a burst until all data in DRB buffer is drained. Unit: 125 microseconds.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmRimPdschActionSpecialSlotDistr {
      description "Histogram of applied RIM mitigation actions on PDSCH transmissions. Considers mitigation actions taken in special slot. Unit: N/A Ranges: Bin[0]: UE not scheduled due to blanking Bin[1]: UE not scheduled due to low load Bin[2]: UE not scheduled due to low SINR Bin[3]: UE is backed off with low power value Bin[4]: UE is backed off with high power value.";
      type uint64;
      max-elements 5;
    }
    leaf-list pmRadioPreambleSinrMsg3DtxAllTxDistr {
      description "Total number of occurances when all attempts of Msg3 transimissions resulted in DTX for a preamble SINR bin. Ranges: Bin[0]: [..-15] dB Bin[1]: ]-15..-12] dB Bin[2]: ]-12..-9] dB Bin[3]: ]-9..-6] dB Bin[4]: ]-6..-3] dB Bin[5]: ]-3..] dB.";
