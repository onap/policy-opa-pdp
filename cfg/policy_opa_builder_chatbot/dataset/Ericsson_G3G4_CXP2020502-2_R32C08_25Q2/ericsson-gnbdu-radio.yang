    }
  }
  grouping ResourceAllocationPolicy-attributes {
    leaf demotedRrpSchedulingPriority {
      description "Scheduling domain to be used by RRP when resource usage is above configured share..";
      type enumeration {
        enum DEMOTED_NORMAL;
        enum DEMOTED_LOW;
      }
    }
    leaf overAllocationAllowed {
      description "Whether over-allocation of partition shares is allowed.; Default value: true.";
      type boolean;
      default "true";
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf resourceAllocationPolicyId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf resourceShareLimitRef {
      description "Reference to an instance of ResourceShareLimit MO. If empty, none of following features is operable for partition: - Load-based Automated Radio Resource Partitioning. - Automated Radio Resource Partitioning..";
      type string;
    }
    leaf rrpControllerRef {
      description "Reference to an instance of RrpController MO. Automatically set to RrpController=NO_AUTO_CONTROL instance, unless manually set to refer to another MO instance..";
      type string;
    }
    leaf rrpOperationModeDl {
      description "Operation mode of RRP in downlink for a resource allocation policy. This can favor accuracy in share fulfillment over time or low impact on latency..";
      type enumeration {
        enum BALANCED;
        enum FAIRNESS_FAVORED;
      }
    }
    leaf rrpOperationModeUl {
      description "Operation mode of RRP in uplink for a resource allocation policy. This can favor accuracy in share fulfillment over time or low impact on latency..";
      type enumeration {
        enum BALANCED;
        enum FAIRNESS_FAVORED;
      }
    }
    leaf shareAdjustmentModeDl {
      description "Mode of RRP share adjustment. Applied when updating downlink usage share for partition..";
      type enumeration {
        enum ABSOLUTE;
        enum GENERAL_COMPENSATION;
      }
    }
    leaf shareAdjustmentModeUl {
      description "Mode of RRP share adjustment. Applied when updating uplink usage share for partition..";
      type enumeration {
        enum ABSOLUTE;
        enum GENERAL_COMPENSATION;
      }
    }
    leaf spectrumShareDl {
      description "Share of downlink spectrum resources for which resource partition has priority. Partitions can use more than their share if free resources remain in cell.; range 0..100.";
      type eytypes:int32_range_0-100;
      mandatory true;
      units "percent";
    }
    leaf spectrumShareUl {
      description "Share of uplink spectrum resources for which resource partition has priority. Partitions can use more than their share as long as free resources remain in cell.; range 0..100.";
      type eytypes:int32_range_0-100;
      mandatory true;
      units "percent";
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping ResourceAllocTypeDl-attributes {
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf resourceAllocTypeDlId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf ueConfGroupType {
      description "UE configuration group type. UE configuration group type that is applied in contained ResourceAllocTypeDlUeCfg instances..";
      type enumeration {
        enum UE_MOBILITY_GROUP;
        enum UE_SERVICE_GROUP;
        enum UE_ADMISSION_GROUP;
      }
    }
