      type ietfyang:mac-address;
      max-elements 8;
    }
    leaf pmMacRBSymUsedPdschTypeA {
      description "Aggregated number of resource block symbols used for PDSCH mapping type A during complete ROP. DMRS and PTRS embedded in PDSCH resources are included. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
