      type eytypes:int32_range_0-256;
      ordered-by user;
      min-elements 0;
      max-elements 20;
    }
    leaf trafficCategory {
      description "Traffic category of configured traffic group member. Set to ENDC in TrafficGroupMember=Default_ENDC instance.; Default value: SA; Status info: Since 25.Q2. Replaced by TrafficSetMember::trafficCategory. Planned to be removed..";
      type enumeration {
        enum SA;
        enum ENDC;
      }
      status deprecated;
      default "SA";
    }
    leaf trafficGroupMemberId {
      description "The value component of the RDN.; MOM flags: restricted, noNotification; Status info: Since 25.Q2. Planned to be removed..";
      type string;
      mandatory true;
      status deprecated;
    }
