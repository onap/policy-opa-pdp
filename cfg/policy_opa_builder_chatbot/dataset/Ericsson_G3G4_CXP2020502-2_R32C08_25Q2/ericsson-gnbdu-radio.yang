  augment "/emael:ManagedElement/gnbdu:GNBDUFunction/gnbdu:NRCellDU" {
    list CellPortionRd {
      description "Additional definitions from MOM:min/max-elements:0/192;systemCreated; Represents a Radio Dot and coverage area of a Radio Dot in a cell. Created when cell is unlocked and precondition is true. Deleted at next cell unlock if precondition no longer is true. Only applicable to Mid-Band cells. The RDNs of these MOs are CellPortionRd=1 to CellPortionRd=192. Length of RDN value is up to 3 characters. Instance can be created without a preceding user-initiated transaction. Precondition: License for Advanced RDS Location Support for Private 5G is present and feature is active. NRCellDU::rdsUeAdvancedPosEnabled is true.";
      key "cellPortionRdId";
      leaf cellPortionRdId {
        type leafref {
          path "../attributes/cellPortionRdId";
        }
      }
      container attributes {
      uses CellPortionRd-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbdu:GNBDUFunction/gnbdu:NRCellDU" {
    list DlOuterLoop {
      description "Additional definitions from MOM:min/max-elements:1/1;systemCreated; Configuration of downlink outer loops. Only applicable to Low-Band cells. The RDN of this MO is DlOuterLoop=1.";
      key "dlOuterLoopId";
      leaf dlOuterLoopId {
        type leafref {
          path "../attributes/dlOuterLoopId";
        }
      }
      container attributes {
      uses DlOuterLoop-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbdu:GNBDUFunction/gnbdu:NRSectorCarrier" {
    list AesMMimoSleep {
      description "Additional definitions from MOM:min/max-elements:0/1;systemCreated; Threshold information for NR Massive MIMO Sleep Mode feature updated by Automated Energy Saver. Created when all following conditions are fulfilled: - Aes::aesEnabled is true. - NRSectorCarrier::massiveMimoSleepEnabled is ENABLED or DETECTION. - License for Automated Energy Saver is present and feature is active. Deleted when Aes::aesEnabled is false or NRSectorCarrier::massiveMimoSleepEnabled is DISABLED. Only applicable to Mid-Band sector carriers. The RDN of this MO is AesMMimoSleep is 1. Length of RDN value is 1 character. Instance can be created without a preceding user-initiated transaction.";
      key "aesMMimoSleepId";
      leaf aesMMimoSleepId {
        type leafref {
          path "../attributes/aesMMimoSleepId";
        }
      }
      container attributes {
      uses AesMMimoSleep-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbdu:GNBDUFunction/gnbdu:NRSectorCarrier" {
    list CommonBeamforming {
      description "Additional definitions from MOM:min/max-elements:0/1; Configuration parameters related to common beamforming. Created automatically when administrativeState under parent MO instance is changed to UNLOCKED. Can also be created and deleted manually. When created automatically, the RDN of this MO is CommonBeamforming=1. Length of RDN value is 1 character for automatically created instance. Instance can be created without a preceding user-initiated transaction. Precondition: Can only be deleted when parent NRSectorCarrier::administrativeState is LOCKED.";
      key "commonBeamformingId";
      leaf commonBeamformingId {
        type leafref {
          path "../attributes/commonBeamformingId";
        }
      }
      container attributes {
      uses CommonBeamforming-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbdu:GNBDUFunction/gnbdu:NRSectorCarrier" {
    list NRPimCancellationConfig {
      description "Additional definitions from MOM:min/max-elements:0/72; Configuration data for PIM cancellation of NRSectorCarrier attribute. Only one NRPimCancellationConfig instance can refer to same PimCancellationFunction instance. Among NRPimCancellationConfig instances that have same createdBy value, only one NRPimCancellationConfig instance can have ulPimCancellationMode value that is not EXCLUDED. When createdBy is SYSTEM, operator is not allowed to modify attributes. Only takes effect for CPRI-based radio equipment that does not support AAS functions. Not applicable to High-Band sector carriers. High-Band only supports AAS functions. Automatic configuration is active when GNBDUFunction::pimCancAutoConfigEnabled is true. Then instance is - created automatically when PIM victim is identified. - deleted automatically when PIM victim is no longer valid. Automatically created instances are deleted when GNBDUFunction::pimCancAutoConfigEnabled is false. Can also be created and deleted manually. When created automatically, the RDNs of these MOs are NRPimCancellationConfig=auto1, auto2 and so on. RDN value matches RDN value of PimCancellationFunction instance that this NRPimCancellationConfig instance refers to. Length of RDN value is up to 6 characters for automatically created instance. Instance can be created without a preceding user-initiated transaction. When created manually, RDN value must not start with 'auto'.";
      key "nRPimCancellationConfigId";
      leaf nRPimCancellationConfigId {
        type leafref {
          path "../attributes/nRPimCancellationConfigId";
        }
      }
      container attributes {
      uses NRPimCancellationConfig-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbdu:GNBDUFunction/gnbdu:NRSectorCarrier" {
    list PowerBackoff {
      description "Additional definitions from MOM:min/max-elements:0/1; Configuration parameters for EMF Power Lock Mid-Band feature. The feature intends to reduce radio safety distance in massive MIMO products. Power backoff is sector carrier-wide, same in all directions. Only applicable to Mid-Band sector carriers. Precondition: Parent MO must be locked when this MO is created or deleted. Cannot be created if PowerBackoffDir instance exists.";
      key "powerBackoffId";
      leaf powerBackoffId {
        type leafref {
          path "../attributes/powerBackoffId";
        }
      }
      container attributes {
      uses PowerBackoff-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbdu:GNBDUFunction/gnbdu:NRSectorCarrier" {
    list PowerBackoffDir {
      description "Additional definitions from MOM:min/max-elements:0/1; Configuration parameters related to NR Directional Control for EMF Power Lock Mid-Band feature. Only applicable to Mid-Band sector carriers. Creating this MO on NRSectorCarrier instance with non-C2 sector carrier type or non-AAS capable radios will result in an alarm. Precondition: Parent MO must be locked when this MO is created or deleted. Cannot be created if PowerBackoff MO exists or radio is not TDD.";
      key "powerBackoffDirId";
      leaf powerBackoffDirId {
        type leafref {
          path "../attributes/powerBackoffDirId";
        }
      }
      container attributes {
      uses PowerBackoffDir-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbdu:GNBDUFunction/gnbdu:UeCC/gnbdu:OutOfCov" {
    list OutOfCovUeCfg {
      description "Additional definitions from MOM:min/max-elements:0/3; Out of coverage (OOC) profile used for current UE. Instance OutOfCovUeCfg=Base is created automatically when parent MO instance is created, unless created manually in same transaction as parent MO. UeBbProfileUeCfg::outOfCovUeCfgRef is automatically set to OutOfCovUeCfg=Base instance, unless manually set to refer to another MO instance. Precondition: Instance OutOfCovUeCfg=Base can only be created in same transaction as parent MO instance and cannot be deleted unless parent MO instance is deleted. Other instances can be created and deleted at any time. Maximum 2 OutOfCovUeCfg instances, with RDN different from Base, can be created under parent MO instance.";
      key "outOfCovUeCfgId";
      leaf outOfCovUeCfgId {
        type leafref {
          path "../attributes/outOfCovUeCfgId";
        }
      }
      container attributes {
      uses OutOfCovUeCfg-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/gnbdu:GNBDUFunction/gnbdu:UeCC/gnbdu:PdcchReuseForPdsch" {
    list PdcchReuseForPdschUeCfg {
      description "Additional definitions from MOM:min/max-elements:0/8; Configuration of PDCCH and PDSCH Frequency Division Multiplexing profile for UE groups. Instance PdcchReuseForPdschUeCfg=Base is created automatically when parent MO instance is created, unless created manually in same transaction. Attributes prefUeGroupList, ueGroupList and ueConfGroupList must be empty in instance PdcchReuseForPdschUeCfg=Base but cannot all be empty in any other instance of PdcchReuseForPdschUeCfg under same parent PdcchReuseForPdsch instance. A combination of an element of ueGroupList and an element of prefUeGroupList in PdcchReuseForPdschUeCfg instance must be unique under PdcchReuseForPdsch instance. Precondition: Instance PdcchReuseForPdschUeCfg=Base can only be created in same transaction as parent MO instance and cannot be deleted unless parent MO instance is deleted. Other instances can be created and deleted at any time. Maximum 7 PdcchReuseForPdschUeCfg instances, with RDN different from Base, can be created under parent MO instance.";
      key "pdcchReuseForPdschUeCfgId";
      leaf pdcchReuseForPdschUeCfgId {
