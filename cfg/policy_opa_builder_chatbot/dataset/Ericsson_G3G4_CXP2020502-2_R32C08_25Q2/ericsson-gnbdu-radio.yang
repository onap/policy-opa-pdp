      }
      enum HIGHRISE_1 {
        description "Coverage shape with larger beam space ratio in elevation plane than in azimuth plane. Beam space ratio for HIGHRISE is product specific. Only applicable to Low-Band and Mid-Band cells.";
      }
      enum HOTSPOT_1 {
        description "Coverage shape with full beam space in both azimuth plane and elevation plane. Full beam space range is product specific. Only applicable to Low-Band and Mid-Band cells.";
      }
      enum MACRO_120_20 {
        description "Coverage shape with larger service area ratio in azimuth plane than in elevation plane. 120 degrees in azimuth and 20 degrees in elevation. Only applicable to High-Band cells.";
      }
      enum HOTSPOT_120_30 {
        description "Coverage shape with full service area in both azimuth plane and elevation plane. 120 degrees in azimuth and 30 degrees in elevation. Only applicable to High-Band cells.";
      }
      enum MACRO_120_15 {
        description "Coverage shape with larger service area ratio in azimuth plane than in elevation plane. 120 degrees in azimuth and 15 degrees in elevation. Only applicable to High-Band cells.";
      }
      enum STREET_COVERAGE_1 {
        description "Coverage shape with normal service area in azimuth plane and narrow in elevation plane. Beam space range is product specific. Only applicable to Mid-Band cells.";
      }
      enum STREET_HOTSPOT_1 {
        description "Coverage shape with normal service area in azimuth plane and elevation plane. Beam space range is product specific. Only applicable to Mid-Band cells.";
      }
      enum STREET_HOTSPOT_WIDE_1 {
        description "Coverage shape with wide service area in azimuth plane and normal in elevation plane. Beam space range is product specific. Only applicable to Mid-Band cells.";
      }
      enum FLEXIBLE_COVERAGE_1 {
        description "Coverage shape with flexible service area used with azimuth and elevation coverage width.";
      }
