      type ietfyang:mac-address;
      config false;
    }
    leaf pmRimDetectedVictimSetIDsMax {
      description "Number of unique setIDs reported by aggressor cells with RS1 detection..";
      type int64;
      config false;
    }
    leaf pmMacVolDlAdvEis {
      description "Aggregated volume of successfully transmitted downlink MAC PDUs for all reciprocity-based Ericsson Interference Sensing (EIS) transmissions. Unit: bytes.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacVolUlSCellExt {
      description "Data volume in MAC SDUs successfully received in uplink when cell is used as external inter-gNodeB SCell and inter-capacity module SCell. Unit: byte.";
      type ietfyang:mac-address;
      config false;
    }
