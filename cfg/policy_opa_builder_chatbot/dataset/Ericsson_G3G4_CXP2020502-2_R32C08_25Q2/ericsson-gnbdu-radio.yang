    }
    leaf pmMacHarqDlDtxQpskInit {
      description "Total number of occasions when downlink HARQ feedback for initial HARQ transmission using QPSK modulation could not be detected from UE. Initial transmission is first transmission on HARQ process. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacTimeDlDrbLastSlotSamp {
      description "Aggregated number of samples for measuring time for last slot of burst scheduling of downlink DRB since last scheduled DRB (delta time between scheduling occasions). It is considered last slot if all data in DRB buffer is drained. It is considered part of a burst if there is at least one previous DL scheduling occasion that does not fully empty buffer. HARQ initial transmission is measured. HARQ retransmission is excluded. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmUeEffDopplerSpeedDistr {
      description "Distribution of measured effective speed values from all measured effective speeds. Ranges Bin[0]: Number of speed measurements within [0..20] km/h. Bin[1]: Number of speed measurements within ]20..40] km/h. Bin[2]: Number of speed measurements within ]40..60] km/h. Bin[3]: Number of speed measurements within ]60..80] km/h. Bin[4]: Number of speed measurements within ]80..100] km/h. Bin[5]: Number of speed measurements within ]100..120] km/h. Bin[6]: Number of speed measurements within ]120..140] km/h. Bin[7]: Number of speed measurements within ]140..160] km/h. Bin[8]: Number of speed measurements within ]160..180] km/h. Bin[9]: Number of speed measurements within ]180..200] km/h. Bin[10]: Number of speed measurements within ]200..220] km/h. Bin[11]: Number of speed measurements within ]220..240] km/h. Bin[12]: Number of speed measurements within ]240..260] km/h. Bin[13]: Number of speed measurements within ]260..280] km/h. Bin[14]: Number of speed measurements within ]280..300] km/h. Bin[15]: Number of speed measurements within ]300..] km/h..";
      type uint64;
      max-elements 16;
    }
    leaf pmMacPdcchBlockingPuschOccasions {
      description "Number of scheduling occasions when PDCCH limits number of sessions served by PUSCH. Scheduling occasion is when any number of requests are allocated PDCCH, PDSCH and PUSCH. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacRBSymUsedPdcchTypeBAggrLvl2 {
      description "Number of resource block symbols used by PDCCH with aggregation level 2 for scheduling of PDSCH or PUSCH using mapping type B. This includes DMRS and PTRS embedded in resources scheduling. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmRrcAccessFailMpLoad {
      description "Number of rejected RRC Connection procedures in NR SA because Baseband MP load control indicates OVERLOAD or VERY HIGH state. RRC Connection procedures can be one of the following options: - RRC Setup Request - RRC Resume Request - RRC Reestablishment Request.";
      type uint64;
      config false;
    }
    leaf pmMacVolUlOffloadSCell {
      description "MAC SDU volume successfully received through SCells when cell is used as PCell. Unit: bytes Deprecated: Since 23.Q4. Planned to be removed. Replaced by NRCellDU::pmMacOffloadVolUlSCell; MOM flags: noNotification.";
      type ietfyang:mac-address;
      config false;
      status deprecated;
    }
    leaf pmMacTimeDlCaConfigDrbActivity {
      description "Aggregated time for HARQ initial transmission scheduling activity of downlink DRB associated with carrier aggregation-configured UEs. Scheduling activity refers to time interval from first scheduling occasion of a burst until all data in DRB buffer is drained. Unit: 125 microseconds.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacTimeUlResDrbMaxQos {
      description "Maximum time in restricted uplink for each QoS. Unit: 125 microseconds Compressed: True.";
      type ietfyang:mac-address;
      max-elements 256;
    }
    leaf-list pmMacTimeDlDrbLastSlotSampQos {
      description "Aggregated number of samples for measuring time for last slot of burst scheduling of downlink DRB since last scheduled DRB (delta time between scheduling occasions). It is considered last slot if all data in DRB buffer is drained. It is considered part of a burst if there is at least one previous DL scheduling occasion that does not fully empty buffer. HARQ initial transmission is measured. HARQ retransmission is excluded. Samples from all DRBs with same QoS are accumulated. Unit: N/A Compressed: True.";
      type ietfyang:mac-address;
      max-elements 256;
    }
    leaf pmRadioMacTransUl2Layers {
      description "Total number of dual-layer uplink transmissions in each cell. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacVolPdschAdvMimoSinrThresUserDistr {
      description "Shows accumulated sum of data volume for first downlink transmission by a variable number of users that meet preset SINR thresholding conditions as a result of advanced beamforming. This PM counter can be used together with NRCellDU.pmMacRBSymUsedPdschAdvMimoSinrThresUserDistr PM counter to calculate SRS reciprocity resource block spectral efficiency. Unit: byte Ranges: Bin[0]: Accumulated sum of data volume for first downlink transmission for one user. Bin[1]: Accumulated sum of data volume for first downlink transmission for two users. Bin[2]: Accumulated sum of data volume for first downlink transmission for three users. Bin[3]: Accumulated sum of data volume for first downlink transmission for four users. Bin[4]: Accumulated sum of data volume for first downlink transmission for five users. Bin[5]: Accumulated sum of data volume for first downlink transmission for six users. Bin[6]: Accumulated sum of data volume for first downlink transmission for seven users. Bin[7]: Accumulated sum of data volume for first downlink transmission for eight users. Bin[8]: Reserved for future MU-MIMO. Bin[9]: Reserved for future MU-MIMO. Bin[10]: Reserved for future MU-MIMO. Bin[11]: Reserved for future MU-MIMO. Bin[12]: Reserved for future MU-MIMO. Bin[13]: Reserved for future MU-MIMO. Bin[14]: Reserved for future MU-MIMO. Bin[15]: Reserved for future MU-MIMO..";
      type ietfyang:mac-address;
      max-elements 16;
    }
    leaf pmMacHarqUlAck256QamInit {
      description "Total number of successful initial HARQ transmissions with 256-QAM uplink. Initial transmission is first transmission on HARQ process, where New Data Indicator (NDI) bit in DCI message is toggled. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacHarqUlAck16Qam {
      description "Total number of successful HARQ transmissions in uplink using 16-QAM modulation. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmRadioPuschPhrDistr {
      description "Distribution of UL Power Headroom reported by UE. Unit: N/A Ranges: Bin[0]: [0..3] PHR index Bin[1]: [4..7] PHR index Bin[2]: [8..11] PHR index Bin[3]: [12..15] PHR index Bin[4]: [16..19] PHR index Bin[5]: [20..23] PHR index Bin[6]: [24..27] PHR index Bin[7]: [28..31] PHR index Bin[8]: [32..35] PHR index Bin[9]: [36..39] PHR index Bin[10]: [40..43] PHR index Bin[11]: [44..47] PHR index Bin[12]: [48..51] PHR index Bin[13]: [52..55] PHR index Bin[14]: [56..59] PHR index Bin[15]: [60..63] PHR index.";
      type uint64;
      max-elements 16;
    }
    leaf-list pmMacSchedSlotDlTempAlarmSCellDistr {
      description "Aggregated number of scheduled downlink slots when SCells are active and UE temperature alarm is detected. Measured when this cell is used as PSCell. Unit: N/A Ranges: Bin[0]: Scheduled DL slots when UE temperature alarm is detected with 0 SCells activated. Bin[1]: Scheduled DL slots when UE temperature alarm is detected with 1 SCells activated. Bin[2]: Scheduled DL slots when UE temperature alarm is detected with 2 SCells activated. Bin[3]: Scheduled DL slots when UE temperature alarm is detected with 3 SCells activated. Bin[4]: Scheduled DL slots when UE temperature alarm is detected with 4 SCells activated. Bin[5]: Scheduled DL slots when UE temperature alarm is detected with 5 SCells activated. Bin[6]: Scheduled DL slots when UE temperature alarm is detected with 6 SCells activated. Bin[7]: Scheduled DL slots when UE temperature alarm is detected with 7 SCells activated..";
      type ietfyang:mac-address;
      max-elements 8;
    }
    leaf-list pmSessionTimeUeSssgSumDistr {
      description "Accumulated time sessions of UEs. PDF ranges: Bin[0]: Accumulated time sessions of UEs not configured with search space set group switching. Bin[1]: Accumulated time sessions of UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a dense search space set group. Bin[2]: Accumulated time sessions of UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a sparse search space set group. Bin[3]: Accumulated time sessions of UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 2 for UEs configured with a dense search space set group. ... Bin[15]: Accumulated time sessions of UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a dense search space set group. Bin[16]: Accumulated time sessions of UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a sparse search space set group..";
      type uint64;
      max-elements 17;
    }
    leaf pmMacHarqDlNackQpsk {
      description "Total number of unsuccessful downlink HARQ transmissions using QPSK modulation. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacHarqUlAckQpskInit {
      description "Total number of successful initial HARQ transmissions in uplink using QPSK modulation. Initial transmission is first transmission on HARQ process, where NDI bit in DCI message is toggled. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmRadioSinrPuschDtxDistr {
      description "Total number of PUSCH DTX counts pegged at SINR values for each PUSCH transmission. Ranges: Bin[0]: [..-11] dB Bin[1]: ]-11..-8] dB Bin[2]: ]-8..-5] dB Bin[3]: ]-5..-2] dB Bin[4]: ]-2..1] dB Bin[5]: ]1..4] dB Bin[6]: ]4..7] dB Bin[7]: ]7..10] dB Bin[8]: ]10..13] dB Bin[9]: ]13..16] dB Bin[10]: ]16..] dB.";
      type uint64;
      max-elements 11;
    }
    leaf pmMacHarqUlNackQpskInit {
      description "Total number of unsuccessful initial HARQ transmissions in uplink using QPSK modulation. Initial transmission is first transmission on HARQ process, where NDI bit in DCI message is toggled. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmPdschSchedActivityBwp {
      description "Total duration of slots with downlink PDSCH scheduling activity in downlink BWP. For uplink BWP value is always zero. PDF ranges: Bin[0]: Total duration of slots with downlink PDSCH scheduling activity in the first BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Bin[1]: Total duration of slots with downlink PDSCH scheduling activity in the second BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Bin[2]: Total duration of slots with downlink PDSCH scheduling activity in the third BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute ... Bin[15]: Total duration of slots with downlink PDSCH scheduling activity in the sixteenth BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Unit: 125 microseconds.";
      type uint64;
      max-elements 16;
    }
    leaf-list pmMacRBSymUsedPdcchOfdmSymDistr {
      description "Number of resource block symbols used for PDCCH for scheduling of PDSCH or PUSCH using mapping type A or Type B in OFDM-symbols. This includes DMRS and PTRS embedded in resources. Unit: N/A Ranges: Bin[0]: Accumulated downlink resource block symbols used by PDCCH in the 1st OFDM-symbol Bin[1]: Accumulated downlink resource block symbols used by PDCCH in the 2nd OFDM-symbol Bin[2]: Accumulated downlink resource block symbols used by PDCCH in the 3rd OFDM-symbol Bin[3]: Accumulated downlink resource block symbols used by PDCCH in the 4th OFDM-symbol Bin[4]: Accumulated downlink resource block symbols used by PDCCH in the 5th OFDM-symbol Bin[5]: Accumulated downlink resource block symbols used by PDCCH in the 6th OFDM-symbol Bin[6]: Accumulated downlink resource block symbols used by PDCCH in the 7th OFDM-symbol Bin[7]: Accumulated downlink resource block symbols used by PDCCH in the 8th OFDM-symbol Bin[8]: Accumulated downlink resource block symbols used by PDCCH in the 9th OFDM-symbol Bin[9]: Accumulated downlink resource block symbols used by PDCCH in the 10th OFDM-symbol Bin[10]: Accumulated downlink resource block symbols used by PDCCH in the 11th OFDM-symbol Bin[11]: Accumulated downlink resource block symbols used by PDCCH in the 12th OFDM-symbol Bin[12]: Accumulated downlink resource block symbols used by PDCCH in the 13th OFDM-symbol Bin[13]: Accumulated downlink resource block symbols used by PDCCH in the 14th OFDM-symbol.";
      type ietfyang:mac-address;
      max-elements 14;
    }
    leaf pmMacHarqUlDtx256QamInit {
      description "Number of DTX detections for initial HARQ transmissions with 256-QAM uplink. Initial transmission is first transmission on HARQ process, where NDI bit in DCI message is toggled. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacVolDlDrbOverlapLastSlot {
      description "Aggregated volume of downlink MAC SDUs transmitted for HARQ initial transmission in last slot of burst that overlaps with subsequent burst when buffer is emptied. HARQ retransmission is excluded. Unit: bytes.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacRBSymUsedPdschMimoLayerDistr {
      description "Distribution of aggregated number of resource block symbols used for PDSCH by different number of coscheduled layers as a result of SU-MIMO or MU-MIMO. DMRS and PTRS embedded in PDSCH resources are included. Unit: N/A Ranges: Bin[0]: Number of resource block symbols scheduled with 1 layer. Bin[1]: Number of resource block symbols scheduled with 2 layers. Bin[2]: Number of resource block symbols scheduled with 3 layers. Bin[3]: Number of resource block symbols scheduled with 4 layers. Bin[4]: Number of resource block symbols scheduled with 5 layers. Bin[5]: Number of resource block symbols scheduled with 6 layers. Bin[6]: Number of resource block symbols scheduled with 7 layers. Bin[7]: Number of resource block symbols scheduled with 8 layers. Bin[8]: Number of resource block symbols scheduled with 9 layers. Bin[9]: Number of resource block symbols scheduled with 10 layers. Bin[10]: Number of resource block symbols scheduled with 11 layers. Bin[11]: Number of resource block symbols scheduled with 12 layers. Bin[12]: Number of resource block symbols scheduled with 13 layers. Bin[13]: Number of resource block symbols scheduled with 14 layers. Bin[14]: Number of resource block symbols scheduled with 15 layers. Bin[15]: Number of resource block symbols scheduled with 16 layers..";
      type ietfyang:mac-address;
      max-elements 16;
    }
    leaf-list pmRadioRecInterferencePwrSpecialSlot1Distr {
      description "Absolute power value of SRS comb offsets in each uplink symbol of special slot 1. The absolute power value is expressed in units of 0.1 dBm. Bins correspond to SRS comb offsets in each uplink symbol. This ensures compatibility between the lengths of uplink symbols in a special slot. To extract average interference power for each bin across a ROP, divide by pmRadioRecInterferencePwrSlotSamp. Number of bins corresponds to maximum six uplink symbols in a special slot and four comb offsets in each uplink symbol. Bins support the following symbol number and comb offset combinations: Bin[0]: First comb offset in last uplink symbol of special slot Bin[1]: Second comb offset in last uplink symbol of special slot Bin[2]: Third comb offset in last uplink symbol of special slot Bin[3]: Fourth comb offset in last uplink symbol of special slot Bin[4]: First comb offset in second uplink symbol from last of special slot Bin[5]: Second comb offset in second uplink symbol from last of special slot .... Bin[22]: Third comb offset in sixth uplink symbol from last of special slot Bin[23]: Fourth comb offset in sixth uplink symbol from last of special slot Note: For TDD UL-DL pattern 'DDSSUUDDDD DDSSUUDDDD', there's no ul symbol in the first and the third S slot. Only the second and the fourth S slot will be pegged. So, only pmRadioRecInterferencePwrSpecialSlot1Distr and pmRadioRecInterferencePwrSpecialSlot2Distr will be used..";
      type uint64;
      max-elements 24;
    }
    leaf-list pmRadioPreambleSinrMsg3AckDistr {
      description "Total number of Msg3 ACKs for a preamble SINR range. Ranges: Bin[0]: [..-15] dB Bin[1]: ]-15..-12] dB Bin[2]: ]-12..-9] dB Bin[3]: ]-9..-6] dB Bin[4]: ]-6..-3] dB Bin[5]: ]-3..] dB.";
      type uint64;
      max-elements 6;
    }
    leaf-list pmPimAvoidPowerExcessDistr {
      description "Distribution of PIM power excess measured after PIM avoidance. Unit: N/A Ranges: Bin[0]: [..-10] dB Bin[1]: ]-10..-8] dB Bin[2]: ]-8..-6] dB Bin[3]: ]-6..-4] dB Bin[4]: ]-4..-2] dB Bin[5]: ]-2..0] dB Bin[6]: ]0..2] dB Bin[7]: ]2..4] dB Bin[8]: ]4..6] dB Bin[9]: ]6..8] dB Bin[10]: ]8..10] dB Bin[11]: ]10..12] dB Bin[12]: ]12..14] dB Bin[13]: ]14..16] dB Bin[14]: ]16..18] dB Bin[15]: ]18..20] dB Bin[16]: ]20..22] dB Bin[17]: ]22..24] dB Bin[18]: ]24..26] dB Bin[19]: ]26..28] dB Bin[20]: ]28..30] dB Bin[21]: ]30..] dB.";
      type uint64;
      max-elements 22;
    }
    leaf pmMacRBSymUsedPdcchCss {
      description "Aggregated number of resource block symbols used for common search space PDCCH allocation. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacTimeDlDrbQos {
      description "Aggregated time for HARQ initial transmission scheduling of downlink DRB, while there is data in buffer. Accumulates measured time from all DRBs with same QoS. Unit: 125 microseconds Compressed: True.";
      type ietfyang:mac-address;
      max-elements 256;
    }
    leaf-list pmMacRBSymUsedPdcchTypeAAggrLvl8Bwp {
      description "Number of resource block symbols used by PDCCH with aggregation level 8 for scheduling of PDSCH or PUSCH using mapping type A in BWP. This includes DMRS and PTRS embedded in resources. PDF ranges: Bin[0]: Accumulated downlink resource block symbols used by PDCCH with aggregation level 8 in the first BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Bin[1]: Accumulated downlink resource block symbols used by PDCCH with aggregation level 8 in the second BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Bin[2]: Accumulated downlink resource block symbols used by PDCCH with aggregation level 8 in the third BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute ... Bin[15]: Accumulated downlink resource block symbols used by PDCCH with aggregation level 8 in the sixteenth BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Unit: N/A.";
      type ietfyang:mac-address;
      max-elements 16;
    }
    leaf pmRadioRaCfFailMsg2Disc {
      description "Number of CFRA preambles for which no random access Msg2 is sent due to expiry of random access response window. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf-list pmMacRBSymUsedPdcchTypeAAggrLvl2Sssg {
      description "Number of resource block symbols used by PDCCH with aggregation level 2 for scheduling of PDSCH or PUSCH using mapping type A in search space set group. Includes DMRS and PTRS embedded in resources. PDF ranges: Bin[0]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 2 for UEs that are not configured with search space set group switching. Bin[1]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 2 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a dense search space set group. Bin[2]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 2 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a sparse search space set group. Bin[3]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 2 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 2 for UEs configured with a dense search space set group. ... Bin[15]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 2 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a dense search space set group. Bin[16]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 2 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a sparse search space set group. Unit: N/A.";
      type ietfyang:mac-address;
      max-elements 17;
    }
    leaf pmMacVolDlRat {
      description "Aggregated volume of successfully transmitted downlink MAC PDUs for DRB or SRB using cell as PCell for RAT(Reciprocity assistant transmission) UE. Unit: bytes.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmDuCellDownLockAuto {
      description "Number of times cell is locked due to system-initiated action..";
      type uint64;
      config false;
    }
    leaf pmMacRBSymUsedPuschTypeA {
      description "Aggregated number of resource block symbols used for PUSCH mapping type A during complete ROP. DMRS and PTRS embedded in PUSCH resources are included. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmRadioUeRepPmiPrimaryCsiRsRank4Distr {
      description "Distribution of precoding weights reported by UE for rank 4 codebook associated with primary CSI-RS. Indicates spatial distribution of UEs using cell as PCell. Type 1 single-panel codebooks are defined in 3GPP TS 38.214. Represents distribution of requested departure angles from AAS-capable radio unit as estimated from UE CSI feedback, specifically main and diversity direction of PMI values. It is not recommended to use this PM counter for Remote radio units. For more information, see Massive MIMO Mid-Band and Manage Massive MIMO NR in CPI library. Unit: N/A Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf pmMacRBSymAvailRach {
      description "Aggregated number of resource block symbols configured for RACH during complete ROP. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacHarqUlDtx16Qam {
      description "Total number of occasions when no HARQ is received in gNodeB uplink when the following conditions apply: - Uplink grant is meant for HARQ transmission of transport block that uses 16-QAM modulation. - DTX is considered the reason for no reception. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacRBSymUsedPuschTypeB {
      description "Aggregated number of resource block symbols used for PUSCH mapping type B during complete ROP. DMRS and PTRS that are embedded in PUSCH resources are included. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacHarqUlNack256QamInit {
      description "Total number of unsuccessful initial HARQ transmissions with 256-QAM UL. Initial transmission is first transmission on HARQ process, where New Data Indicator (NDI) bit in DCI message is toggled. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmActiveUeDlSamp {
      description "Number of times corresponding pmActiveUeDlSum counter is incremented. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf-list pmDrbAdmissionPreemptQos {
      description "Number of DRBs required to be released by NR Service-Adaptive Preemption feature for each QoS value. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf pmMacHarqUlDtxQpskInit {
      description "Number of DTX detections for initial HARQ transmissions in uplink using QPSK modulation. Initial transmission is first transmission on HARQ process, where NDI bit in DCI message is toggled. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmRadioRecInterferencePwrUlSlot7Distr {
      description "Absolute power for each symbol in uplink slot 7 in one radio frame. Bins correspond to uplink symbol 2 and uplink symbol 11 respectively. To get average interference power for each bin across a Result Output Period (ROP), divide by NRCellDU.pmRadioRecInterferencePwrSlotSamp. Unit: 0.1 dBm/PRB.";
      type uint64;
      max-elements 2;
    }
    leaf-list pmRadioPreambleSinrMsg3HarqFailDistr {
      description "Total number of HARQ failures on Msg3 transmission counts due to DTX or NACK for a preamble SINR range. Ranges: Bin[0]: [..-15] dB Bin[1]: ]-15..-12] dB Bin[2]: ]-12..-9] dB Bin[3]: ]-9..-6] dB Bin[4]: ]-6..-3] dB Bin[5]: ]-3..] dB.";
      type uint64;
      max-elements 6;
    }
