      description "Total number of occasions when no HARQ is received in gNodeB uplink when the following conditions apply: - Uplink grant is meant for HARQ transmission of transport block that uses QPSK modulation. - DTX is considered the reason for no reception. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacHarqDlNack256Qam {
      description "Total number of unsuccessful downlink HARQ transmissions using 256-QAM modulation. Unit: N/A.";
