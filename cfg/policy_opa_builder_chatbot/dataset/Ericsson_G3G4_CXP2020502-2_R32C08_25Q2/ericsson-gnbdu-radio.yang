      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf srbPriority {
      description "SRB priority. Value 1 indicates lowest priority. Only applicable if license for Adaptive SRB Priority is present and feature is active.; range 1..16; Default value: 1.";
      type eytypes:int32_range_1-16;
      default "1";
    }
    leaf srbPriorityUeCfgId {
      description "The value component of the RDN..";
      type string;
