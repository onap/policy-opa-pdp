        enum SR_PERIODICITY_SL640;
      }
    }
    leaf srPeriodicityPoolSetId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf subCarrierSpacing {
      description "Sub-carrier spacing for common elements at cell level.; Default value: 120.";
      type int32 {
        range "15 | 30 | 120";
      }
      default "120";
      units "kHz";
    }
  }
  grouping SrPeriodicityUeCfg-attributes {
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf prefUeSrPeriodicityPool {
      description "Preferred SR periodicity pool for corresponding UE. Applicable to Low-Band and Mid-Band cells if license NR Service-Adaptive SR Periodicity is present and feature is active. Not applicable to High-Band cells..";
      type enumeration {
        enum SR_PERIODICITY_POOL_1;
        enum SR_PERIODICITY_POOL_2;
        enum SR_PERIODICITY_POOL_3;
        enum SR_PERIODICITY_POOL_4;
        enum SR_PERIODICITY_POOL_5;
      }
    }
    leaf prefUeSrPeriodicityPoolFr2 {
      description "Preferred SR periodicity pool for corresponding UE. Applicable to High-Band cells if license Service-Adaptive SR Periodicity High-Band for Dedicated RAN or license Service-Adaptive SR Periodicity High-Band for Public RAN is present and feature is active. Not applicable to Low-Band and Mid-Band cells..";
      type enumeration {
        enum SR_PERIODICITY_POOL_1;
        enum SR_PERIODICITY_POOL_2;
        enum SR_PERIODICITY_POOL_3;
        enum SR_PERIODICITY_POOL_4;
        enum SR_PERIODICITY_POOL_5;
      }
    }
    leaf srPeriodicityUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 32;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
