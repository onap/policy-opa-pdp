  grouping SrPeriodicityCovAdaptUeCfg-attributes {
    leaf covAdaptSrPEnabled {
      description "Whether coverage adaptive scheduling request periodicity is enabled. Only applicable to High-Band cells.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf covAdaptSrPNrLowQualThresh {
      description "NR radio quality threshold. Used for configuring SR periodicity on PUCCH. Below this threshold, uplink channel quality is assumed limited hence SR Periodicity on PUCCH is configured to longer duration. Uplink SINR is used for estimating uplink coverage. Recommended to be set to a value 3 dB higher than endcUlNrLowQualThresh. Only applicable if covAdaptSrPEnabled is True. Only applicable to High-Band cells.; range -40..145; Default value: 20.";
      type int32 {
        range "-40..145";
      }
      default "20";
      units "dB";
    }
    leaf covAdaptSrPNrQualHyst {
      description "NR radio quality hysteresis. Used for configuring SR periodicity on PUCCH. Quality needs to be hysteresis better than covAdaptSrPNrLowQualThresh to configure SR periodicity on PUCCH back to shorter duration. Uplink SINR is used for estimating uplink coverage. Only applicable if covAdaptSrPEnabled is True. Only applicable to High-Band cells.; range 0..60; Default value: 5.";
      type eytypes:int32_range_0-60;
      default "5";
      units "dB";
    }
    leaf covAdaptSrPStartRsrpThresh {
      description "RSRP threshold. SR periodicity is configured to longer duration if reported RSRP value is below RSRP threshold. RSRP is reported in 3GPP TS 38.331 CG-ConfigInfo. Applicable at PSCell setup and PSCell change in the Secondary Node (for NR-DC and EN-DC). Recommended to be set to a value 3 dB lower than dftSOfdmPuschStartRsrpThresh. Only applicable if covAdaptSrPEnabled is True. Only applicable to High-Band cells.; range -156..-29; Default value: -107.";
      type eytypes:int32_range_-156--29;
      default "-107";
      units "dBm";
    }
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf srPeriodicityCovAdaptUeCfgId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list ueConfGroupList {
      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 32;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
  }
