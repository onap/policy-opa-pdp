      config false;
    }
    leaf pmMacVolUlUeLastSlot {
      description "Data volume in MAC SDUs successfully received in uplink while not restricted by air interface. Received in last slot of burst. Unit: byte.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacTimeDlCaDrb {
      description "Aggregated time for HARQ initial transmission scheduling of downlink DRB for data volume classified as carrier aggregation bursts, with data in buffer. Unit: 125 microseconds.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmDrbEstabFailAdmissionRejQos {
      description "Number of DRB establishments rejected by Service Admission Control feature per QoS. DRB is rejected because of limit configured in FlowLimit.maxNoOfFlows attribute. For more information, check Feature Description for Service Admission Control feature. Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf pmRlcArqUlNack {
      description "Total number of unsuccessful RLC SDU and RLC SDU segment transmissions (NACKs) in uplink (UL). Only applicable to RLC AM bearers. In NR, RLC SN is associated with RLC SDUs and not RLC PDUs. The arq_ul_ack and arq_ul_nack are related to RLC SDUs and RLC PDU or RLC SDU segments NACKed. When carrier aggregation is used, total number of unsuccessful RLC SDU and RLC SDU segment transmissions (NACKs) in UL is registered on PCell of UE..";
      type uint64;
      config false;
    }
    leaf-list pmRadioMacShortPsrSinrDistr {
      description "Distribution of SINR values as measured at time of decision to switch scheduling request on PUCCH periodicity to shorter periodicity. Ranges: Bin[0]: [..13] dB Bin[1]: ]13..15] dB Bin[2]: ]15..17] dB Bin[3]: ]17..19] dB Bin[4]: ]19..21] dB Bin[5]: ]21..23] dB Bin[6]: ]23..25] dB Bin[7]: ]25..27] dB Bin[8]: ]27..29] dB Bin[9]: ]29..31] dB Bin[10]: ]31..33] dB Bin[11]: ]33..35] dB Bin[12]: ]35..37] dB Bin[13]: ]37..39] dB Bin[14]: ]39..] dB Unit: N/A.";
      type ietfyang:mac-address;
      max-elements 15;
    }
    leaf pmSssgSwitchDciDropped {
      description "Number of dropped search space set group switch DCIs in a cell because only one switch DCI can be sent in each slot. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf pmPdschAvailTime {
      description "Total duration of slots where gNodeB scheduler can schedule on PDSCH. Unit: 125 microseconds.";
      type uint64;
      config false;
    }
    leaf-list pmBwpUeConfSumDistr {
      description "Shows distribution of UEs configured with BWP for PCell in NRCellDU MO by BWPSet.allBWPRegularRef attribute PDF ranges: Bin[0]: Number of UEs configured with first BWP for PCell referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Bin[1]: Number of UEs configured with second BWP for PCell referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Bin[2]: Number of UEs configured with third BWP for PCell referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute ... Bin[15]: Number of UEs configured with sixteenth BWP for PCell referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute.";
      type uint64;
      max-elements 16;
    }
    leaf-list pmRadioRecInterferencePwrUlSlot4Distr {
      description "Absolute power for each symbol in uplink slot 4 in one radio frame. Bins correspond to uplink symbol 2 and uplink symbol 11 respectively. To get average interference power for each bin across a Result Output Period (ROP), divide by NRCellDU.pmRadioRecInterferencePwrSlotSamp. Unit: 0.1 dBm/PRB.";
      type uint64;
      max-elements 2;
    }
    leaf pmMassiveMimoSleepTimeTxMute {
      description "Accumulates actual amount of time a cell is set to TXMUTE state. Unit: seconds.";
      type uint64;
      config false;
    }
    leaf-list pmRadioPreambleSinrMsg3SuccTx3Distr {
      description "Total number of successful Msg3 counts for third transmission attempt for a preamble SINR bin. Ranges: Bin[0]: [..-15] dB Bin[1]: ]-15..-12] dB Bin[2]: ]-12..-9] dB Bin[3]: ]-9..-6] dB Bin[4]: ]-6..-3] dB Bin[5]: ]-3..] dB.";
      type uint64;
      max-elements 6;
    }
    leaf pmPagReceivedRan {
      description "Number of requests for RAN paging routed to cell. Counter is a subset of NRCellDU.pmPagReceived PM counter. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf pmRrcAccessFailBbIntens {
      description "Number of failed RRC Connection procedures because of connection intensity control. RRC connection procedures can be one of the following options: - RRC Setup Request - RRC Resume Request - RRC Reestablishment Request.";
      type uint64;
      config false;
    }
    leaf pmMacPdcchBlockingPuschOccasionsExclPresched {
      description "Number of scheduling occasions when PDCCH limits number of sessions served by PUSCH, excluding uplink prescheduling scheduling requests. Scheduling occasion is when any number of requests are allocated PDCCH, PDSCH and PUSCH. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacTempAlarmSCellDistr {
      description "Aggregated number of unique UE temperature alarms when SCells are active. Measured when this cell is used as PSCell. Unit: N/A Ranges: Bin[0]: Unique UE temperature alarms with 0 SCells activated. Bin[1]: Unique UE temperature alarms with 1 SCells activated. Bin[2]: Unique UE temperature alarms with 2 SCells activated. Bin[3]: Unique UE temperature alarms with 3 SCells activated. Bin[4]: Unique UE temperature alarms with 4 SCells activated. Bin[5]: Unique UE temperature alarms with 5 SCells activated. Bin[6]: Unique UE temperature alarms with 6 SCells activated. Bin[7]: Unique UE temperature alarms with 7 SCells activated..";
      type ietfyang:mac-address;
      max-elements 8;
    }
    leaf-list pmMacPucchSrPuschGrantLatDistr {
      description "Distribution of latency between reception of PUCCH scheduling request from UE and grant on PDCCH for transmission on PUSCH for that UE. Unit: N/A Ranges: Bin[0]: [0..0.5[ ms Bin[1]: [0.5..1[ ms Bin[2]: [1..2[ ms Bin[3]: [2..3[ ms Bin[4]: [3..4[ ms Bin[5]: [4..5[ ms Bin[6]: [5..6[ ms Bin[7]: [6..7[ ms Bin[8]: [7..8[ ms Bin[9]: [8..9[ ms Bin[10]: [9..10[ ms Bin[11]: [10..20[ ms Bin[12]: [20..40[ ms Bin[13]: [40..60[ ms Bin[14]: [60..80[ ms Bin[15]: [80..100[ ms Bin[16]: [100..200[ ms Bin[17]: [200..300[ ms Bin[18]: [300..400[ ms Bin[19]: [400..500[ ms Bin[20]: [500..] ms.";
      type ietfyang:mac-address;
      max-elements 21;
    }
    leaf-list pmRadioUeRepCqi64QamLowSeRank2Distr {
      description "Distribution of UE-reported CQI values with low Spectral Efficiency related to rank 2 transmissions when highest modulation order supported in downlink (DL) in NR cell is 64-QAM. CQI values and interpretations correspond to entries in Table 5.2.2.1-4 in 3GPP 38.214 for reporting CQI based on QPSK, 16-QAM, and 64-QAM. Unit: N/A Ranges: Bin[0]: CQI = 0 Bin[1]: CQI = 1 Bin[2]: CQI = 2 Bin[3]: CQI = 3 Bin[4]: CQI = 4 Bin[5]: CQI = 5 Bin[6]: CQI = 6 Bin[7]: CQI = 7 Bin[8]: CQI = 8 Bin[9]: CQI = 9 Bin[10]: CQI = 10 Bin[11]: CQI = 11 Bin[12]: CQI = 12 Bin[13]: CQI = 13 Bin[14]: CQI = 14 Bin[15]: CQI = 15.";
      type uint64;
      max-elements 16;
    }
    leaf-list pmRlcDelayTimeDlQos {
      description "Aggregated RLC delay time for each QoS. For each DRB packet, measures time in milliseconds from packet arrival in gNodeB RLC layer to when last byte of this packet is scheduled and drained from RLC layer for transmission over air. Also PDCP SDU queue time (if any) is included on RAN Compute group 5 and earlier. Unit: milliseconds Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf pmMacHarqDlAck64Qam {
      description "Total number of successful downlink HARQ transmissions using 64-QAM modulation. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacVolUl {
      description "Aggregated volume of successfully received uplink MAC SDUs for DRB or SRB using cell as PCell, SCell, or PSCell. Unit: byte.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmRadioBeamSwitchTargetNotAvailable {
      description "Number of times when beam is not available as target for beam switch. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf pmMacHarqUlAck256Qam {
      description "Total number of successful HARQ transmissions with 256-QAM uplink. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacHarqUlNackQpsk {
      description "Total number of unsuccessful HARQ transmissions in uplink using QPSK modulation. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacVolUlPCellCa {
      description "Aggregated volume of successfully received uplink MAC SDUs for DRB or SRB using cell as PCell. Only includes volume from carrier aggregation UEs using cell as PCell, including uplink carrier aggregation and uplink Tx Switching UEs. Unit: byte.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmPdcchDciSwitchSssg {
      description "Accumulated number of outgoing DCI switches by search space set group for NRCellDU MO. PDF ranges: Bin[0]: Accumulated number of outgoing DCI switches for UEs that are not configured with search space set group switching. Bin[1]: Accumulated number of outgoing DCI switches for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a dense search space set group. Bin[2]: Accumulated number of outgoing DCI switches for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a sparse search space set group. Bin[3]: Accumulated number of outgoing DCI switches for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 2 for UEs configured with a dense search space set group. ... Bin[15]: Accumulated number of outgoing DCI switches for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a dense search space set group. Bin[16]: Accumulated number of outgoing DCI switches for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a sparse search space set group..";
      type uint64;
      max-elements 17;
    }
    leaf-list pmMacRBSymUsedPdcchTypeAAggrLvl16Sssg {
      description "Number of resource block symbols used by PDCCH with aggregation level 16 for scheduling of PDSCH or PUSCH using mapping type A in search space set group. Includes DMRS and PTRS embedded in resources. PDF ranges: Bin[0]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 16 for UEs that are not configured with search space set group switching. Bin[1]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 16 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a dense search space set group. Bin[2]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 16 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a sparse search space set group. Bin[3]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 16 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 2 for UEs configured with a dense search space set group. ... Bin[15]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 16 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a dense search space set group. Bin[16]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 16 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a sparse search space set group. Unit: N/A.";
      type ietfyang:mac-address;
      max-elements 17;
    }
    leaf-list pmPdschSchedActivitySssg {
      description "Total duration of slots with downlink PDSCH scheduling activity. PDF ranges: Bin[0]: Total duration of slots with downlink PDSCH scheduling activity for UEs that are not configured with search space set group switching. Bin[1]: Total duration of slots with downlink PDSCH scheduling activity for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a dense search space set group. Bin[2]: Total duration of slots with downlink PDSCH scheduling activity for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a sparse search space set group. Bin[3]: Total duration of slots with downlink PDSCH scheduling activity for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 2 for UEs configured with a dense search space set group. ... Bin[15]: Total duration of slots with downlink PDSCH scheduling activity for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a dense search space set group. Bin[16]: Total duration of slots with downlink PDSCH scheduling activity for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a sparse search space set group. Unit: 125 microseconds.";
      type uint64;
      max-elements 17;
    }
    leaf pmMacRBSymUtilDlMax {
      description "Maximum utilization of downlink resource block symbols in ROP sampled every 1 second. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmRadioRecInterferencePwrSpecialSlot3Distr {
      description "Absolute power value of SRS comb offsets in each uplink symbol of special slot 3. The absolute power value is expressed in units of 0.1 dBm. Bins correspond to SRS comb offsets in each uplink symbol. This ensures compatibility between the lengths of uplink symbols in a special slot. To extract average interference power for each bin across a ROP, divide by pmRadioRecInterferencePwrSlotSamp. Number of bins corresponds to maximum six uplink symbols in a special slot and four comb offsets in each uplink symbol. Bins support the following symbol number and comb offset combinations: Bin[0]: First comb offset in last uplink symbol of special slot Bin[1]: Second comb offset in last uplink symbol of special slot Bin[2]: Third comb offset in last uplink symbol of special slot Bin[3]: Fourth comb offset in last uplink symbol of special slot Bin[4]: First comb offset in second uplink symbol from last of special slot Bin[5]: Second comb offset in second uplink symbol from last of special slot .... Bin[22]: Third comb offset in sixth uplink symbol from last of special slot Bin[23]: Fourth comb offset in sixth uplink symbol from last of special slot Note: For TDD UL-DL pattern 'DDSSUUDDDD DDSSUUDDDD', there's no ul symbol in the first and the third S slot. Only the second and the fourth S slot will be pegged. So, only pmRadioRecInterferencePwrSpecialSlot1Distr and pmRadioRecInterferencePwrSpecialSlot2Distr will be used..";
      type uint64;
      max-elements 24;
    }
    leaf-list pmMacSchedSlotUlSCellActivatedDistr {
      description "Aggregated number of scheduled uplink slots when uplink-configured SCells are active. Measured when cell is used as PSCell. Pre-scheduling is not included. Unit: N/A Ranges: Bin[0]: Scheduled uplink slots with 0 SCells activated. Bin[1]: Scheduled uplink slots with 1 SCells activated. Bin[2]: Scheduled uplink slots with 2 SCells activated. Bin[3]: Scheduled uplink slots with 3 SCells activated. Bin[4]: Scheduled uplink slots with 4 SCells activated. Bin[5]: Scheduled uplink slots with 5 SCells activated. Bin[6]: Scheduled uplink slots with 6 SCells activated. Bin[7]: Scheduled uplink slots with 7 SCells activated..";
      type ietfyang:mac-address;
      max-elements 8;
    }
    leaf-list pmMacHarqDlNackQpskInitSlotDistr {
      description "For each downlink slot, bin that corresponds to number of unsuccessful initial HARQ PDSCH transmissions using QPSK modulation in slot is incremented. HARQ transmissions used for BWP DCI switch Scheduling Request (SR) are not pegged. Unit: N/A Ranges: Bin[0]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 0. Bin[1]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 1. Bin[2]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 2. Bin[3]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 3. Bin[4]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 4. Bin[5]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 5. Bin[6]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 6. Bin[7]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 7. Bin[8]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 8. Bin[9]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 9. Bin[10]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 10. Bin[11]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 11. Bin[12]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 12. Bin[13]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 13. Bin[14]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 14. Bin[15]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 15. Bin[16]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 16. Bin[17]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 17. Bin[18]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 18. Bin[19]: Total number of unsuccessful initial downlink HARQ transmissions using QPSK on slot 19..";
      type ietfyang:mac-address;
      max-elements 20;
    }
    leaf pmCellSleepTimeEnergySaving {
      description "Time cell is disabled due to energy saving mode. NRCellDU.OperationalState is set to disabled and NRCellDU.AvailabilityStatus is set to OFF_DUTY by system Unit: seconds.";
      type uint64;
      config false;
    }
    leaf-list pmMacInitSchedDelayUlMaxQos {
      description "Maximum initial scheduling delay in uplink for each QoS. Unit: 125 microseconds Compressed: True.";
      type ietfyang:mac-address;
      max-elements 256;
    }
    leaf pmMacVolUlUnresUePucchSrGrant {
      description "Data volume in MAC SDUs successfully received in uplink and not restricted by air interface. Sent using one grant given by gNodeB to answer PUCCH scheduling request. Unit: byte.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacRBSymUsedPdschAdvMuMimoTxRankDistr {
      description "Distribution of aggregated number of resource block symbols used for PDSCH by sounding antennas and downlink rank as a result of reciprocity-based MU-MIMO. DMRS and PTRS embedded in PDSCH resources are included. Unit: N/A Ranges: Bin[0]: Number of resource block symbols scheduled with 1TX/4RX R1 in MU-MIMO. Bin[1]: Number of resource block symbols scheduled with 1TX/4RX R2 in MU-MIMO. Bin[2]: Number of resource block symbols scheduled with 1TX/4RX R3 in MU-MIMO. Bin[3]: Number of resource block symbols scheduled with 1TX/4RX R4 in MU-MIMO. Bin[4]: Number of resource block symbols scheduled with 2TX/4RX R1 in MU-MIMO. Bin[5]: Number of resource block symbols scheduled with 2TX/4RX R2 in MU-MIMO. Bin[6]: Number of resource block symbols scheduled with 2TX/4RX R3 in MU-MIMO. Bin[7]: Number of resource block symbols scheduled with 2TX/4RX R4 in MU-MIMO. Bin[8]: Number of resource block symbols scheduled with 4TX/4RX R1 in MU-MIMO. Bin[9]: Number of resource block symbols scheduled with 4TX/4RX R2 in MU-MIMO. Bin[10]: Number of resource block symbols scheduled with 4TX/4RX R3 in MU-MIMO. Bin[11]: Number of resource block symbols scheduled with 4TX/4RX R4 in MU-MIMO. Bin[12]: Number of resource block symbols scheduled with 1TX/2RX R1 in MU-MIMO. Bin[13]: Number of resource block symbols scheduled with 1TX/2RX R2 in MU-MIMO. Bin[14]: Number of resource block symbols scheduled with 2TX/2RX R1 in MU-MIMO. Bin[15]: Number of resource block symbols scheduled with 2TX/2RX R2 in MU-MIMO. Bin[16]: Number of resource block symbols scheduled with 1TX/1RX R1..";
      type ietfyang:mac-address;
      max-elements 17;
    }
    leaf pmMacRBSymUtilUlMax {
      description "Maximum utilization of uplink resource block symbols in ROP sampled every 1 second. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacRBSymPowerBackoffDistr {
      description "Represents mapping of all resource block symbols for UEs that were included in backoff calculations for appropriate backoff ranges. Unit: N/A Ranges: Bin[0]: 0 resource block symbol Bin[1]: 1 resource block symbol Bin[2]: 2 resource block symbol Bin[3]: 3 resource block symbol Bin[4]: 4 resource block symbol Bin[5]: 5 resource block symbol Bin[6]: 6 resource block symbol Bin[7]: 7 resource block symbol Bin[8]: 8 resource block symbol Bin[9]: 9 resource block symbol.";
      type ietfyang:mac-address;
      max-elements 10;
    }
    leaf pmMacHarqUlDtx16QamInit {
      description "Number of DTX detections for initial HARQ transmissions in uplink using 16-QAM modulation. Initial transmission is first transmission on HARQ process, where NDI bit in DCI message is toggled. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmRadioRaSuccTaRelDistr {
      description "Distribution of measured timing advance (TA) values at successful random access. TA values are expressed as a percentage of TAs that correspond to configured cell range. Unit: N/A Ranges: Bin[0]: [0..4] % Bin[1]: [5..9] % Bin[2]: [10..14] % Bin[3]: [15..19] % Bin[4]: [20..24] % Bin[5]: [25..29] % Bin[6]: [30..34] % Bin[7]: [35..39] % Bin[8]: [40..44] % Bin[9]: [45..49] % Bin[10]: [50..54] % Bin[11]: [55..59] % Bin[12]: [60..64] % Bin[13]: [65..69] % Bin[14]: [70..74] % Bin[15]: [75..79] % Bin[16]: [80..84] % Bin[17]: [85..89] % Bin[18]: [90..94] % Bin[19]: [95..99] % Bin[20]: [100..104] % Bin[21]: [105..109] % Bin[22]: [110..] %.";
      type uint64;
      max-elements 23;
    }
    leaf-list pmRadioPdschTable2MbsfnMcsDistr {
      description "Distribution of MCS used for PDSCH transmissions in MBSFN subframes where MCS index table 2 is applied, and UE instances are enabled with up to 256-QAM. For more information, see 3GPP TS 38.214, Table 5.1.3.1-2. Each bin represents a specific MCS. Unit: N/A Ranges: Bin[0]: MCS = 0 Bin[1]: MCS = 1 Bin[2]: MCS = 2 Bin[3]: MCS = 3 Bin[4]: MCS = 4 Bin[5]: MCS = 5 Bin[6]: MCS = 6 Bin[7]: MCS = 7 Bin[8]: MCS = 8 Bin[9]: MCS = 9 Bin[10]: MCS = 10 Bin[11]: MCS = 11 Bin[12]: MCS = 12 Bin[13]: MCS = 13 Bin[14]: MCS = 14 Bin[15]: MCS = 15 Bin[16]: MCS = 16 Bin[17]: MCS = 17 Bin[18]: MCS = 18 Bin[19]: MCS = 19 Bin[20]: MCS = 20 Bin[21]: MCS = 21 Bin[22]: MCS = 22 Bin[23]: MCS = 23 Bin[24]: MCS = 24 Bin[25]: MCS = 25 Bin[26]: MCS = 26 Bin[27]: MCS = 27 Bin[28]: MCS = 28 Bin[29]: MCS = 29 Bin[30]: MCS = 30 Bin[31]: MCS = 31.";
      type uint64;
      max-elements 32;
    }
    leaf pmMacRBSymUsedPdcchTypeAAggrLvl1 {
      description "Number of resource block symbols used by PDCCH with aggregation level 1 for scheduling of PDSCH or PUSCH using mapping type A. This includes DMRS and PTRS embedded in resources. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacLatTimeDlNoDrxSyncSampQos {
      description "Aggregated number of samples for downlink MAC latency measurements for each QoS without DRX and out-of-sync impact. DL MAC latency measures MAC scheduling latency between reception of packet in empty DL buffer and transmission of first packet. Unit: N/A Compressed: True.";
      type ietfyang:mac-address;
      max-elements 256;
    }
    leaf-list pmMacRBSymUsedPuschMimoUserDistr {
      description "Distribution of aggregated number of resource block symbols used for PUSCH by different number of users as a result of SU-MIMO or MU-MIMO. DMRS and PTRS embedded in PUSCH resources are included. Unit: N/A Ranges: Bin[0]: Number of resource block symbols scheduled with 1 user. Bin[1]: Number of resource block symbols scheduled with 2 users. Bin[2]: Number of resource block symbols scheduled with 3 users. Bin[3]: Number of resource block symbols scheduled with 4 users. Bin[4]: Number of resource block symbols scheduled with 5 users. Bin[5]: Number of resource block symbols scheduled with 6 users. Bin[6]: Number of resource block symbols scheduled with 7 users. Bin[7]: Number of resource block symbols scheduled with 8 users..";
      type ietfyang:mac-address;
      max-elements 8;
    }
    leaf-list pmMacRBSymUsedPdcchTypeADciSwitchSssg {
      description "Aggregated number of resource block symbols used by PDCCH for scheduling of PDSCH or PUSCH using mapping type A in search space set group for DCI switches. Includes DMRS and PTRS embedded in resources. PDF ranges: Bin[0]: Aggregated number of resource block symbols used by PDCCH for scheduling of PDSCH or PUSCH using mapping type A for DCI switches for UEs that are not configured with search space set group switching. Bin[1]: Aggregated number of resource block symbols used by PDCCH for scheduling of PDSCH or PUSCH using mapping type A for DCI switches for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a dense search space set group. Bin[2]: Aggregated number of resource block symbols used by PDCCH for scheduling of PDSCH or PUSCH using mapping type A for DCI switches for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a sparse search space set group. Bin[3]: Aggregated number of resource block symbols used by PDCCH for scheduling of PDSCH or PUSCH using mapping type A for DCI switches for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 2 for UEs configured with a dense search space set group. ... Bin[15]: Aggregated number of resource block symbols used by PDCCH for scheduling of PDSCH or PUSCH using mapping type A for DCI switches for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a dense search space set group. Bin[16]: Aggregated number of resource block symbols used by PDCCH for scheduling of PDSCH or PUSCH using mapping type A for DCI switches for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a sparse search space set group. Unit: N/A.";
      type ietfyang:mac-address;
      max-elements 17;
    }
    leaf pmMacHarqDlAckQpskInit {
      description "Total number of successful initial downlink HARQ transmissions using QPSK modulation. Initial transmission is first transmission on HARQ process. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmRadioBeamSwitchSuccMacCe {
      description "Number of successful wide beam switch commands. Beam switch command is sent to UE in MAC Control Element. Measured when this cell is used as PSCell. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacServingDelayUlUeDistr {
      description "The delay between consecutive occurrences of following events: - Uplink grant for data transmission - PUCCH scheduling request received from UE is 0 Unit: N/A Ranges: Bin[0]: [0..1] ms Bin[1]: ]1..2] ms Bin[2]: ]2..5] ms Bin[3]: ]5..10] ms Bin[4]: ]10..20] ms Bin[5]: ]20..40] ms Bin[6]: ]40..80] ms Bin[7]: ]80..160] ms Bin[8]: ]160..320] ms Bin[9]: ]320..] ms.";
      type ietfyang:mac-address;
      max-elements 10;
    }
    leaf pmMacHarqDlNackQpskInit {
      description "Total number of unsuccessful initial downlink HARQ transmissions using QPSK modulation. Initial transmission is first transmission on HARQ process. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmRadioUeRepPmiPrimaryCsiRsRank3Distr {
      description "Distribution of precoding weights reported by UE for rank 3 codebook associated with primary CSI-RS. Indicates spatial distribution of UEs using cell as PCell. Type 1 single-panel codebooks are defined in 3GPP TS 38.214. Represents distribution of requested departure angles from AAS-capable radio unit as estimated from UE CSI feedback, specifically main and diversity direction of PMI values. It is not recommended to use this PM counter for Remote radio units. For more information, see Massive MIMO Mid-Band and Manage Massive MIMO NR in CPI library. Unit: N/A Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf pmMacVolDlDrbSingleSlotShortBurst {
      description "Aggregated volume of downlink MAC SDUs for single slot short burst cases that are transmitted for HARQ initial transmission for each DRB. Single slot short burst case is when new packet arrives to empty buffer and buffer is drained by single scheduling occasion on each active component carrier. HARQ retransmission is excluded. Unit: bytes.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmUeCtxtRelAbnormalGnbDuPnr {
      description "Total number of abnormal UE context releases triggered by gNodeB-DU because of partial node restart, that is, NR baseband reset. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf-list pmRadioPdschTable1McsDistr {
      description "Distribution of MCS used for PDSCH transmissions where MCS index table 1 is applied and UE instances are enabled with up to 64-QAM. For more information, see 3GPP TS 38.214, Table 5.1.3.1-1. Each bin represents a specific MCS. Unit: N/A Ranges: Bin[0]: MCS = 0 Bin[1]: MCS = 1 Bin[2]: MCS = 2 Bin[3]: MCS = 3 Bin[4]: MCS = 4 Bin[5]: MCS = 5 Bin[6]: MCS = 6 Bin[7]: MCS = 7 Bin[8]: MCS = 8 Bin[9]: MCS = 9 Bin[10]: MCS = 10 Bin[11]: MCS = 11 Bin[12]: MCS = 12 Bin[13]: MCS = 13 Bin[14]: MCS = 14 Bin[15]: MCS = 15 Bin[16]: MCS = 16 Bin[17]: MCS = 17 Bin[18]: MCS = 18 Bin[19]: MCS = 19 Bin[20]: MCS = 20 Bin[21]: MCS = 21 Bin[22]: MCS = 22 Bin[23]: MCS = 23 Bin[24]: MCS = 24 Bin[25]: MCS = 25 Bin[26]: MCS = 26 Bin[27]: MCS = 27 Bin[28]: MCS = 28 Bin[29]: MCS = 29 Bin[30]: MCS = 30 Bin[31]: MCS = 31.";
      type uint64;
      max-elements 32;
    }
    leaf-list pmRadioRecInterferencePwrUlSlot3Distr {
      description "Absolute power for each symbol in uplink slot 3 in one radio frame. Bins correspond to uplink symbol 2 and uplink symbol 11 respectively. To get average interference power for each bin across a Result Output Period (ROP), divide by NRCellDU.pmRadioRecInterferencePwrSlotSamp. Unit: 0.1 dBm/PRB.";
      type uint64;
      max-elements 2;
    }
    leaf pmMacHarqDlFail {
      description "Number of complete downlink HARQ failures. When HARQ transmission reaches maximum number of retransmissions, it is not retransmitted again and is regarded as scheduling activity complete HARQ failure. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmRadioUeRepPmiPrimaryCsiRsRank1Distr {
      description "Distribution of precoding weights reported by UE for rank 1 codebook associated with primary CSI-RS. Indicates spatial distribution of UEs using cell as PCell. Type 1 single-panel codebooks are defined in 3GPP TS 38.214. Represents distribution of requested departure angles from AAS-capable radio unit as estimated from UE CSI feedback, specifically main and diversity direction of PMI values. It is not recommended to use this PM counter for Remote radio units. For more information, see Massive MIMO Mid-Band and Manage Massive MIMO NR in CPI library. Unit: N/A Compressed: True.";
      type uint64;
      max-elements 256;
    }
    leaf-list pmMacVolUlSssg {
      description "Aggregated volume of successfully received uplink MAC SDUs for DRB or SRB using cell as PCell or PSCell. PDF ranges: Bin[0]: Aggregated volume of successfully received uplink MAC SDUs for UEs that are not configured with search space set group switching. Bin[1]: Aggregated volume of successfully received uplink MAC SDUs for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a dense search space set group. Bin[2]: Aggregated volume of successfully received uplink MAC SDUs for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a sparse search space set group. Bin[3]: Aggregated volume of successfully received uplink MAC SDUs for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 2 for UEs configured with a dense search space set group. ... Bin[15]: Aggregated volume of successfully received uplink MAC SDUs for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a dense search space set group. Bin[16]: Aggregated volume of successfully received uplink MAC SDUs for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a sparse search space set group. Unit: 100 bytes.";
      type ietfyang:mac-address;
      max-elements 17;
    }
    leaf-list pmMacRBSymReservedPdcchCapacityBoostOfdmSymDistr {
      description "Distribution of aggregated number of resource block symbols reserved for PDCCH Capacity Boost feature. Ranges Bin[0]: Accumulated downlink resource block symbols reserved by PDCCH Capacity Boost feature on OFDM symbol 0. Bin[1]: Accumulated downlink resource block symbols reserved by PDCCH Capacity Boost feature on OFDM symbol 1. ... Bin[12]: Accumulated downlink resource block symbols reserved by PDCCH Capacity Boost feature on OFDM symbol 12. Bin[13]: Accumulated downlink resource block symbols reserved by PDCCH Capacity Boost feature on OFDM symbol 13. Unit: N/A.";
      type ietfyang:mac-address;
      max-elements 14;
    }
    leaf-list pmPuschSchedEntityDistr {
      description "For each uplink slot, bin that corresponds to number of PUSCH scheduled entities is incremented. Includes Msg3 but excludes prescheduling. For High-Band, only uplink-capable cells, where value of NRSectorCarrier.txDirection attribute is DL_AND_UL, are incremented. Unit: N/A Ranges: Bin[0]: Zero PUSCH scheduled entities in uplink slot. Bin[1]: One PUSCH scheduled entity in uplink slot. Bin[2]: Two PUSCH scheduled entities in uplink slot. Bin[3]: Three PUSCH scheduled entities in uplink slot. Bin[4]: Four PUSCH scheduled entities in uplink slot. Bin[5]: Five PUSCH scheduled entities in uplink slot. Bin[6]: Six PUSCH scheduled entities in uplink slot. Bin[7]: Seven PUSCH scheduled entities in uplink slot. Bin[8]: Eight PUSCH scheduled entities in uplink slot. Bin[9]: Nine PUSCH scheduled entities in uplink slot. Bin[10]: 10 PUSCH scheduled entities in uplink slot. Bin[11]: 11 PUSCH scheduled entities in uplink slot. Bin[12]: 12 PUSCH scheduled entities in uplink slot. Bin[13]: 13 PUSCH scheduled entities in uplink slot. Bin[14]: 14 PUSCH scheduled entities in uplink slot. Bin[15]: 15 PUSCH scheduled entities in uplink slot. Bin[16]: 16 PUSCH scheduled entities in uplink slot. Bin[17]: 17 PUSCH scheduled entities in uplink slot. Bin[18]: 18 PUSCH scheduled entities in uplink slot. Bin[19]: 19 PUSCH scheduled entities in uplink slot. Bin[20]: 20 PUSCH scheduled entities in uplink slot. Bin[21]: 21 PUSCH scheduled entities in uplink slot. Bin[22]: 22 PUSCH scheduled entities in uplink slot. Bin[23]: 23 PUSCH scheduled entities in uplink slot. Bin[24]: 24 PUSCH scheduled entities in uplink slot. Bin[25]: 25 PUSCH scheduled entities in uplink slot. Bin[26]: 26 PUSCH scheduled entities in uplink slot. Bin[27]: 27 PUSCH scheduled entities in uplink slot. Bin[28]: 28 PUSCH scheduled entities in uplink slot. Bin[29]: 29 PUSCH scheduled entities in uplink slot. Bin[30]: 30 PUSCH scheduled entities in uplink slot. Bin[31]: 31 PUSCH scheduled entities in uplink slot. Bin[32]: 32 PUSCH scheduled entities in uplink slot. Bin[33]: 33 PUSCH scheduled entities in uplink slot. Bin[34]: 34 PUSCH scheduled entities in uplink slot. Bin[35]: 35 PUSCH scheduled entities in uplink slot. Bin[36]: 36 PUSCH scheduled entities in uplink slot..";
      type uint64;
      max-elements 37;
    }
    leaf pmPduSessionEstabFailAdmissionRej {
      description "Number of PDU Session establishments rejected by Service Admission Control feature. PDU Session is rejected because of limit configured in SessionLimit.maxNoOfSessions attribute. For more information, check Feature Description for Service Admission Control feature..";
      type uint64;
      config false;
    }
    leaf pmMacVolUlResCaUe {
      description "Data volume in MAC SDUs successfully received in uplink as part of a carrier aggregation burst while being restricted by air interface, excluding data volume received in last slot in burst. Unit: byte.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMeasGapUeMnSumDistr {
      description "Sum of active UEs that have measurement gap configured by MN which impacts SN during dual connectivity. Sample is taken every 5 seconds. Unit: N/A Ranges: Bin[0]: Gap pattern 0 Bin[1]: Gap pattern 1 Bin[2]: Gap pattern 2 Bin[3]: Gap pattern 3 Bin[4]: Not used Bin[5]: Not used Bin[6]: Not used Bin[7]: Not used Bin[8]: Not used Bin[9]: Not used Bin[10]: Not used Bin[11]: Not used Bin[12]: Not used Bin[13]: Not used Bin[14]: Gap pattern 14 Bin[15]: Not used Bin[16]: Not used Bin[17]: Not used Bin[18]: Not used Bin[19]: Not used Bin[20]: Not used Bin[21]: Not used Bin[22]: Not used Bin[23]: Not used Compressed: True.";
      type uint64;
      max-elements 24;
    }
    leaf pmActiveUeUlTrueSamp {
      description "Number of times corresponding pmActiveUeUlSum counter is updated, regardless if there are any active UEs, that is, once every slot. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf pmMacRBSymUsedPdcchTypeBAggrLvl16 {
      description "Number of resource block symbols used by PDCCH with aggregation level 16 for scheduling of PDSCH or PUSCH using mapping type B. This includes DMRS and PTRS embedded in resources scheduling. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmActiveUeDlMax {
      description "Peak number of active UE instances that have DRB data in UE dedicated downlink buffer. Value is maximum of a set of samples, where following conditions apply: . Throughout measurement period, each sample is an average of active UE instances. Rounding method can cause counter to show one less than the real number of UE instances. . Sample is taken every second. Unit: N/A.";
      type int64;
      config false;
    }
    leaf-list pmRimPdschAction2LastDlSlotDistr {
      description "Histogram of applied RIM mitigation actions on PDSCH transmissions. Considers mitigation actions taken in second downlink slot before special slot. Unit: N/A Ranges: Bin[0]: UE not scheduled due to blanking Bin[1]: UE not scheduled due to low load Bin[2]: UE not scheduled due to low SINR Bin[3]: UE is backed off with low power value Bin[4]: UE is backed off with high power value.";
      type uint64;
      max-elements 5;
    }
    leaf-list pmMacSchedSlotUlCellSchedDistr {
      description "Aggregated number of scheduled uplink slots when uplink-configured cells are scheduled. Measured when cell is used as PSCell. Pre-scheduling is not included. Unit: N/A Ranges: Bin[0]: Scheduled uplink slots with 1 cell scheduled. Bin[1]: Scheduled uplink slots with 2 cells scheduled. Bin[2]: Scheduled uplink slots with 3 cells scheduled. Bin[3]: Scheduled uplink slots with 4 cells scheduled. Bin[4]: Scheduled uplink slots with 5 cells scheduled. Bin[5]: Scheduled uplink slots with 6 cells scheduled. Bin[6]: Scheduled uplink slots with 7 cells scheduled. Bin[7]: Scheduled uplink slots with 8 cells scheduled..";
      type ietfyang:mac-address;
      max-elements 8;
    }
    leaf-list pmRadioSinrPdschDistr {
      description "Distribution of SINR values calculated for PDSCH transmissions. Unit: N/A Ranges: Bin[0]: [..-5] dB Bin[1]: ]-5..-2] dB Bin[2]: ]-2..1] dB Bin[3]: ]1..4] dB Bin[4]: ]4..7] dB Bin[5]: ]7..10] dB Bin[6]: ]10..13] dB Bin[7]: ]13..16] dB Bin[8]: ]16..19] dB Bin[9]: ]19..22] dB Bin[10]: ]22..25] dB Bin[11]: ]25..] dB.";
      type uint64;
      max-elements 12;
    }
    leaf pmMacRBSymUsedPdcchTypeAAggrLvl2 {
      description "Number of resource block symbols used by PDCCH with aggregation level 2 for scheduling of PDSCH or PUSCH using mapping type A. This includes DMRS and PTRS embedded in resources. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacHarqUlAckQpsk {
      description "Total number of successful HARQ transmissions in uplink using QPSK modulation. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacTimeUlResCaUe {
      description "Transfer time of restricted uplink data volume of carrier aggregation burst records. Unit: 125 microseconds.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacRBSymUsedPdschAilg {
      description "Total number of resource blocks symbols generated by artificial load generator for PDSCH for artificial load. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacRBSymUtilUlDistr {
      description "Distribution of utilization for uplink resource block symbols averaged over 1 second. Unit: N/A Ranges: Bin[0]: [0..5] % Bin[1]: [6..10] % Bin[2]: [11..15] % Bin[3]: [16..20] % Bin[4]: [21..25] % Bin[5]: [26..30] % Bin[6]: [31..35] % Bin[7]: [36..40] % Bin[8]: [41..45] % Bin[9]: [46..50] % Bin[10]: [51..55] % Bin[11]: [56..60] % Bin[12]: [61..65] % Bin[13]: [66..70] % Bin[14]: [71..75] % Bin[15]: [76..80] % Bin[16]: [81..85] % Bin[17]: [86..90] % Bin[18]: [91..95] % Bin[19]: [96..100] %.";
      type ietfyang:mac-address;
      max-elements 20;
    }
    leaf pmRadioPdschEmptySlotsForced {
      description "Number of PDSCH slots (shown by NRCellDU.pmRadioPdschEmptySlots PM counter) forced to be empty to fulfill maximum PDSCH use ratio set by radio units of cell. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf pmMacHarqUlNack64QamInit {
      description "Total number of unsuccessful initial HARQ transmissions in uplink using 64-QAM modulation. Initial transmission is first transmission on HARQ process, where NDI bit in DCI message is toggled. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacPdcchCongestionDlDistr {
      description "Distribution of downlink PDCCH congestion rate averaged over one second. Ranges Bin[0]: [0..5] % Bin[1]: [6..10] % Bin[2]: [11..15] % Bin[3]: [16..20] % Bin[4]: [21..25] % Bin[5]: [26..30] % Bin[6]: [31..35] % Bin[7]: [36..40] % Bin[8]: [41..45] % Bin[9]: [46..50] % Bin[10]: [51..55] % Bin[11]: [56..60] % Bin[12]: [61..65] % Bin[13]: [66..70] % Bin[14]: [71..75] % Bin[15]: [76..80] % Bin[16]: [81..85] % Bin[17]: [86..90] % Bin[18]: [91..95] % Bin[19]: [96..100] % Unit: N/A.";
      type ietfyang:mac-address;
      max-elements 20;
    }
    leaf pmMacHarqDlResAllocType1Dci11 {
      description "Aggregated number of HARQ transmissions and retransmissions scheduled with resource allocation Type 1 with DCI format 1_1. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacRBSymUsedPdschAdvMuMimoLayersDistr {
      description "Distribution of aggregated number of resource block symbols used for PDSCH by different number of co-scheduled layers as a result of reciprocity-based MU-MIMO. DMRS and PTRS embedded in PDSCH resources are included. Unit: N/A Ranges: Bin[0]: Reserved - Not Used. Bin[1]: Number of resource block symbols scheduled with 2 layers. Bin[2]: Number of resource block symbols scheduled with 3 layers. Bin[3]: Number of resource block symbols scheduled with 4 layers. Bin[4]: Number of resource block symbols scheduled with 5 layers. Bin[5]: Number of resource block symbols scheduled with 6 layers. Bin[6]: Number of resource block symbols scheduled with 7 layers. Bin[7]: Number of resource block symbols scheduled with 8 layers. Bin[8]: Number of resource block symbols scheduled with 9 layers. Bin[9]: Number of resource block symbols scheduled with 10 layers. Bin[10]: Number of resource block symbols scheduled with 11 layers. Bin[11]: Number of resource block symbols scheduled with 12 layers. Bin[12]: Number of resource block symbols scheduled with 13 layers. Bin[13]: Number of resource block symbols scheduled with 14 layers. Bin[14]: Number of resource block symbols scheduled with 15 layers. Bin[15]: Number of resource block symbols scheduled with 16 layers..";
      type ietfyang:mac-address;
      max-elements 16;
    }
    leaf pmMacHarqDlAck16QamInit {
      description "Total number of successful initial downlink HARQ transmissions using 16-QAM modulation. Initial transmission is first transmission on HARQ process. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacRBSymUsedPdschAdvEisSuMimoLayerDistr {
      description "Distribution of aggregated number of resource block symbols used for PDSCH by different number of coscheduled layers as a result of reciprocity-based Ericsson Interference Sensing (EIS) SU-MIMO. DMRS and PTRS embedded in PDSCH resources are included. Unit: N/A Ranges: Bin[0]: Number of resource block symbols scheduled with 1 layer. Bin[1]: Number of resource block symbols scheduled with 2 layers. Bin[2]: Number of resource block symbols scheduled with 3 layers. Bin[3]: Number of resource block symbols scheduled with 4 layers. Bin[4]: Number of resource block symbols scheduled with 5 layers. Bin[5]: Number of resource block symbols scheduled with 6 layers. Bin[6]: Number of resource block symbols scheduled with 7 layers. Bin[7]: Number of resource block symbols scheduled with 8 layers..";
      type ietfyang:mac-address;
      max-elements 8;
    }
    leaf pmMacTimeUlResUe {
      description "Transfer time of restricted uplink data volume. Unit: 125 microseconds.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmRadioMacSrPeriodicitySwitchLimitedCoverage {
      description "Indicates number of scheduling request on PUCCH periodicity reconfigurations to longer duration. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmRadioUeRepCqi256QamRank1Distr {
      description "Distribution of UE-reported CQI values related to rank 1 transmissions when highest modulation order supported in downlink (DL) in NR cell is configured to be 256-QAM. CQI values and interpretations correspond to entries in Table 5.2.2.1-3 in 3GPP 38.214 for reporting CQI based on QPSK, 16-QAM, 64-QAM, and 256-QAM. Unit: N/A Ranges: Bin[0]: CQI = 0 Bin[1]: CQI = 1 Bin[2]: CQI = 2 Bin[3]: CQI = 3 Bin[4]: CQI = 4 Bin[5]: CQI = 5 Bin[6]: CQI = 6 Bin[7]: CQI = 7 Bin[8]: CQI = 8 Bin[9]: CQI = 9 Bin[10]: CQI = 10 Bin[11]: CQI = 11 Bin[12]: CQI = 12 Bin[13]: CQI = 13 Bin[14]: CQI = 14 Bin[15]: CQI = 15.";
      type uint64;
      max-elements 16;
    }
    leaf pmMacRBSymPucchSchedPusch {
      description "Number of resource block symbols in uplink slots where PSCell is configured for PUCCH but the symbols are used for scheduling on PUSCH. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacRBSymUsedPdcchTypeAAggrLvl2Bwp {
      description "Number of resource block symbols used by PDCCH with aggregation level 2 for scheduling of PDSCH or PUSCH using mapping type A in BWP. This includes DMRS and PTRS embedded in resources. PDF ranges: Bin[0]: Accumulated downlink resource block symbols used by PDCCH with aggregation level 2 in the first BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Bin[1]: Accumulated downlink resource block symbols used by PDCCH with aggregation level 2 in the second BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Bin[2]: Accumulated downlink resource block symbols used by PDCCH with aggregation level 2 in the third BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute ... Bin[15]: Accumulated downlink resource block symbols used by PDCCH with aggregation level 2 in the sixteenth BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Unit: N/A.";
      type ietfyang:mac-address;
      max-elements 16;
    }
    leaf-list pmPuschSchedActivitySssg {
      description "Total duration of slots where at least one MAC SDU is received on PUSCH. PDF ranges: Bin[0]: Duration of slots where at least one MAC SDU is received on PUSCH for UEs that are not configured with search space set group switching. Bin[1]: Duration of slots where at least one MAC SDU is received on PUSCH for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a dense search space set group. Bin[2]: Duration of slots where at least one MAC SDU is received on PUSCH for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a sparse search space set group. Bin[3]: Duration of slots where at least one MAC SDU is received on PUSCH for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 2 for UEs configured with a dense search space set group. ... Bin[15]: Duration of slots where at least one MAC SDU is received on PUSCH for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a dense search space set group. Bin[16]: Duration of slots where at least one MAC SDU is received on PUSCH for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a sparse search space set group. Unit: 125 microseconds.";
      type uint64;
      max-elements 17;
    }
    leaf pmRadioMacTransUl1LayerSinrDelta {
      description "Total number of single-layer uplink transmissions due to high difference in SINR between two layers. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacContentionDelayUlDistr {
      description "Distribution of MAC contention delay in uplink data bursts when volume is restricted by air interface. Unit: N/A Ranges: Bin[0]: [ 0..125[ us Bin[1]: [125..250[ us Bin[2]: [250..375[ us Bin[3]: [375..500[ us Bin[4]: [500..625[ us Bin[5]: [625..750[ us Bin[6]: [750..875[ us Bin[7]: [875..1000[ us Bin[8]: [1000..1125[ us Bin[9]: [1125..1250[ us Bin[10]: [1250..1375[ us Bin[11]: [1375..1500[ us Bin[12]: [1500..1625[ us Bin[13]: [1625..1750[ us Bin[14]: [1750..1875[ us Bin[15]: [1875..2000[ us Bin[16]: [2000..3000[ us Bin[17]: [3000..4000[ us Bin[18]: [4000..5000[ us Bin[19]: [5000..10000[ us Bin[20]: [10000..] us.";
      type ietfyang:mac-address;
      max-elements 21;
    }
    leaf-list pmMacRBSymUtilDlDistr {
      description "Distribution of utilization for downlink resource block symbols averaged over 1 second. Unit: N/A Ranges: Bin[0]: [0..5] % Bin[1]: [6..10] % Bin[2]: [11..15] % Bin[3]: [16..20] % Bin[4]: [21..25] % Bin[5]: [26..30] % Bin[6]: [31..35] % Bin[7]: [36..40] % Bin[8]: [41..45] % Bin[9]: [46..50] % Bin[10]: [51..55] % Bin[11]: [56..60] % Bin[12]: [61..65] % Bin[13]: [66..70] % Bin[14]: [71..75] % Bin[15]: [76..80] % Bin[16]: [81..85] % Bin[17]: [86..90] % Bin[18]: [91..95] % Bin[19]: [96..100] %.";
      type ietfyang:mac-address;
      max-elements 20;
    }
    leaf pmMacHarqUlNack16QamInit {
      description "Total number of unsuccessful initial HARQ transmissions in uplink using 16-QAM modulation. Initial transmission is first transmission on HARQ process, where NDI bit in DCI message is toggled. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmRadioRaAttTaDistr {
      description "Distribution of measured Timing Advance (TA) values from all detected random access attempts. TA values are expressed as percentage of maximum possible TA value in cell. Unit: N/A Ranges: Bin[0]: [0..9] % Bin[1]: [10..19] % Bin[2]: [20..29] % Bin[3]: [30..39] % Bin[4]: [40..49] % Bin[5]: [50..59] % Bin[6]: [60..69] % Bin[7]: [70..79] % Bin[8]: [80..89] % Bin[9]: [90..99] % Bin[10]: [100..109] % Bin[11]: [110..] %.";
      type uint64;
      max-elements 12;
    }
    leaf pmRadioRaCbFailMsg1Ooc {
      description "Number of CBRA preambles discarded because timing offset corresponds to a greater distance than the configured cell range. Unit: messages.";
      type uint64;
      config false;
    }
    leaf pmRadioSrsResUsedAntSwitching {
      description "Accumulates number of SRS resources used for SRS antenna switching from every SRS slot. Each SRS resource is a combination of symbol, comb, and cyclic shift. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf pmMacRBSymReservedPdcchCapacityBoost {
      description "Aggregated number of resource block symbols reserved for PDCCH Capacity Boost feature. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacRBSymUsedPdschAdvMuMimoLayerDistr {
      description "Distribution of aggregated number of resource block symbols used for PDSCH by different number of co-scheduled layers as a result of reciprocity-based MU-MIMO. DMRS and PTRS embedded in PDSCH resources are included. Unit: N/A Ranges: Bin[0]: Reserved - Not Used. Bin[1]: Number of resource block symbols scheduled with 2 layers. Bin[2]: Number of resource block symbols scheduled with 3 layers. Bin[3]: Number of resource block symbols scheduled with 4 layers. Bin[4]: Number of resource block symbols scheduled with 5 layers. Bin[5]: Number of resource block symbols scheduled with 6 layers. Bin[6]: Number of resource block symbols scheduled with 7 layers. Bin[7]: Number of resource block symbols scheduled with 8 layers. Deprecated: Since 23.Q2. Planned to be removed. Replaced by NRCellDU::pmMacRBSymUsedPdschAdvMuMimoLayersDistr.; MOM flags: noNotification.";
      type ietfyang:mac-address;
      max-elements 8;
    }
    leaf pmMacTimeDlDrbLastSlot {
      description "Aggregated time for last slot of burst scheduling of downlink DRB since last scheduled DRB (delta time between scheduling occasions). It is considered last slot if all data in DRB buffer is drained. It is considered part of a burst if there is at least one previous DL scheduling occasion that does not fully empty buffer. HARQ initial transmission is measured. HARQ retransmission is excluded. Unit: 125 microseconds.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacVolDlSCellBwp {
      description "Aggregated volume of successfully transmitted downlink MAC PDUs for DRB or SRB using cell as SCell. BWP value is always zero for uplink. PDF ranges: Bin[0]: Aggregated volume of successfully transmitted downlink MAC PDUs for DRB or SRB in first BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute. Bin[1]: Aggregated volume of successfully transmitted downlink MAC PDUs for DRB or SRB in second BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute. Bin[2]: Aggregated volume of successfully transmitted downlink MAC PDUs for DRB or SRB in third BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute. ... Bin[15]: Aggregated volume of successfully transmitted downlink MAC PDUs for DRB or SRB in sixteenth BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute. Unit: Bytes.";
      type ietfyang:mac-address;
      max-elements 16;
    }
    leaf pmMassiveMimoSleepTimeEcoPending {
      description "Amount of time a cell is in EcoPending state. Timer starts when EcoPending indication is received and stops when sleep confirmation, for example TxMute or wake-up is received. Unit: seconds.";
      type uint64;
      config false;
    }
    leaf-list pmRadioRecInterferenceNoOfEventsPrbDistr {
      description "Number of events that are summed in each bin of pmRadioRecInterferencePwrSumPrbDistr. Unit: N/A.";
      type uint64;
      max-elements 273;
    }
    leaf pmRlcArqDlNack {
      description "Total number of unsuccessful RLC SDU and RLC SDU segment transmissions (NACKs) in downlink (DL). Only applicable to RLC AM bearers. In NR, the RLC SN is associated with RLC SDUs and not RLC PDUs. The arq_dl_ack and arq_dl_nack are related to RLC SDUs and RLC PDU or RLC SDU segments NACKed. When carrier aggregation is used, total number of unsuccessful RLC SDU and RLC SDU segment transmissions (NACKs) in DL is registered on PCell of UE..";
      type uint64;
      config false;
    }
    leaf-list pmDrbModFailAdmissionRejQos {
