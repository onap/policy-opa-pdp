      description "Estimated average power distribution over time relative to maximum TX power in each control step for SectorCarrier for direction 4. Unit: N/A Ranges: Bin[0]: [0..2.5] % Bin[1]: ]2.5..5] % Bin[2]: ]5..7.5] % Bin[3]: ]7.5..10] % Bin[4]: ]10..12.5] % Bin[5]: ]12.5..15] % Bin[6]: ]15..17.5] % Bin[7]: ]17.5..20] % Bin[8]: ]20..22.5] % Bin[9]: ]22.5..25] % Bin[10]: ]25..27.5] % Bin[11]: ]27.5..30] % Bin[12]: ]30..32.5] % Bin[13]: ]32.5..35] % Bin[14]: ]35..37.5] % Bin[15]: ]37.5..40] % Bin[16]: ]40..42.5] % Bin[17]: ]42.5..45] % Bin[18]: ]45..47.5] % Bin[19]: ]47.5..50] % Bin[20]: ]50..52.5] % Bin[21]: ]52.5..55] % Bin[22]: ]55..57.5] % Bin[23]: ]57.5..60] % Bin[24]: ]60..62.5] % Bin[25]: ]62.5..65] % Bin[26]: ]65..67.5] % Bin[27]: ]67.5..70] % Bin[28]: ]70..72.5] % Bin[29]: ]72.5..75] % Bin[30]: ]75..77.5] % Bin[31]: ]77.5..80] % Bin[32]: ]80..82.5] % Bin[33]: ]82.5..85] % Bin[34]: ]85..87.5] % Bin[35]: ]87.5..90] % Bin[36]: ]90..92.5] % Bin[37]: ]92.5..95] % Bin[38]: ]95..97.5] % Bin[39]: ]97.5..100] %.";
      type uint64;
      max-elements 40;
    }
    leaf pmSectorCarrierDowntimeAutoCbrs {
      description "Length of time CBRS-enabled sector carrier is automatically disabled because grant period from Spectrum Access System is expired. Unit: seconds.";
      type uint64;
      config false;
    }
    leaf-list pmEmfPwrBackoffStepPwrDir3Distr {
      description "Estimated average power distribution over time relative to maximum TX power in each control step for SectorCarrier for direction 3. Unit: N/A Ranges: Bin[0]: [0..2.5] % Bin[1]: ]2.5..5] % Bin[2]: ]5..7.5] % Bin[3]: ]7.5..10] % Bin[4]: ]10..12.5] % Bin[5]: ]12.5..15] % Bin[6]: ]15..17.5] % Bin[7]: ]17.5..20] % Bin[8]: ]20..22.5] % Bin[9]: ]22.5..25] % Bin[10]: ]25..27.5] % Bin[11]: ]27.5..30] % Bin[12]: ]30..32.5] % Bin[13]: ]32.5..35] % Bin[14]: ]35..37.5] % Bin[15]: ]37.5..40] % Bin[16]: ]40..42.5] % Bin[17]: ]42.5..45] % Bin[18]: ]45..47.5] % Bin[19]: ]47.5..50] % Bin[20]: ]50..52.5] % Bin[21]: ]52.5..55] % Bin[22]: ]55..57.5] % Bin[23]: ]57.5..60] % Bin[24]: ]60..62.5] % Bin[25]: ]62.5..65] % Bin[26]: ]65..67.5] % Bin[27]: ]67.5..70] % Bin[28]: ]70..72.5] % Bin[29]: ]72.5..75] % Bin[30]: ]75..77.5] % Bin[31]: ]77.5..80] % Bin[32]: ]80..82.5] % Bin[33]: ]82.5..85] % Bin[34]: ]85..87.5] % Bin[35]: ]87.5..90] % Bin[36]: ]90..92.5] % Bin[37]: ]92.5..95] % Bin[38]: ]95..97.5] % Bin[39]: ]97.5..100] %.";
      type uint64;
      max-elements 40;
    }
    leaf pmUeAssistedPrecodingOptCalibratedUpdating {
      description "Number of NR UE-Assisted Precoding Optimization calibrations with result ACTIVE-CALIBRATED-UPDATING. This counter is used for the feature NR UE-Assisted Precoding Optimization (applicable for 4Tx radio only). Calibration result ACTIVE-CALIBRATED-UPDATING means that the feature is active and calibrated, and the AC-event finished with estimated phase and/or time delay values outside preset limits. For more information, see Feature Description NR UE-Assisted Precoding Optimization in CPI library..";
      type uint64;
      config false;
    }
    leaf-list pmEmfPwrBackoffPwrDir8Distr {
      description "Estimated average power distribution over time relative to maximum TX power for sectorcarrier for direction 8. Only backoff related to Directional EMF feature is reflected in this counter. Power Spectral Density limitation related to other features is not shown. Unit: N/A Ranges: Bin[0]: [0..2.5] % Bin[1]: ]2.5..5] % Bin[2]: ]5..7.5] % Bin[3]: ]7.5..10] % Bin[4]: ]10..12.5] % Bin[5]: ]12.5..15] % Bin[6]: ]15..17.5] % Bin[7]: ]17.5..20] % Bin[8]: ]20..22.5] % Bin[9]: ]22.5..25] % Bin[10]: ]25..27.5] % Bin[11]: ]27.5..30] % Bin[12]: ]30..32.5] % Bin[13]: ]32.5..35] % Bin[14]: ]35..37.5] % Bin[15]: ]37.5..40] % Bin[16]: ]40..42.5] % Bin[17]: ]42.5..45] % Bin[18]: ]45..47.5] % Bin[19]: ]47.5..50] % Bin[20]: ]50..52.5] % Bin[21]: ]52.5..55] % Bin[22]: ]55..57.5] % Bin[23]: ]57.5..60] % Bin[24]: ]60..62.5] % Bin[25]: ]62.5..65] % Bin[26]: ]65..67.5] % Bin[27]: ]67.5..70] % Bin[28]: ]70..72.5] % Bin[29]: ]72.5..75] % Bin[30]: ]75..77.5] % Bin[31]: ]77.5..80] % Bin[32]: ]80..82.5] % Bin[33]: ]82.5..85] % Bin[34]: ]85..87.5] % Bin[35]: ]87.5..90] % Bin[36]: ]90..92.5] % Bin[37]: ]92.5..95] % Bin[38]: ]95..97.5] % Bin[39]: ]97.5..100] %.";
      type uint64;
