    leaf-list pmEmfPrbSclPowerDeboostPdschDirDistr {
      description "Distribution of PRB scale used to increase upper limit on PRB calculated by worst-case EMF controller with minimum number of allowed PRBs among all directions. Counter stepped on each power backoff control step. Unit: N/A Ranges: Bin[0]: 1 Bin[1]: 2 Bin[2]: 3 Bin[3]: 4.";
      type uint64;
      max-elements 4;
