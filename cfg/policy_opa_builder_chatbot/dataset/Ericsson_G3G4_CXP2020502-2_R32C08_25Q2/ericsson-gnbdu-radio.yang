      description "UE configuration group list. List of UE configuration group identifiers. If empty, MO instance matches all UE configuration group identifiers. UE configuration group type is defined by ueConfGroupType in parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 32;
    }
    leaf-list ueGroupList {
      description "UE group list. List of UE group identifiers. If empty, MO instance matches all UE group identifiers..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping TermPointToGNBCUCP-attributes {
    leaf administrativeState {
      description "The administrative state. Can be set to LOCKED only if there is no NRCellDU instance with administrativeState UNLOCKED in GNBDUFunction instance. If set to SHUTTINGDOWN, the state is immediately brought to LOCKED..";
      type enumeration {
        enum LOCKED;
        enum UNLOCKED;
        enum SHUTTINGDOWN;
      }
    }
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operational state..";
      type AvailStatus;
      min-elements 0;
    }
    leaf gNBCUName {
      description "Central Unit (CU) name.; length 1..150.";
      type string {
        length "1..150";
      }
      config false;
    }
    leaf ipv4Address {
      description "IPv4 address of the gNodeB-CU-CP. The input format is four fields of digits, separated by dots. Each field may consist of three digits. The value of each field is in the range 0..255.; length 7..15; Default value: 0.0.0.0.";
      type ietfinet:ipv4-address;
      default "0.0.0.0";
    }
    leaf ipv6Address {
      description "IPv6 address of gNodeB-CU-CP. Format is eight fields, separated by colons. Each field consists of four hexadecimal characters. Value of each field is in range 0..FFFF. Leading zeroes can be omitted in a field, and multiple groups of 16 bits of zeroes can be compressed to ::. The :: can appear only once in an address.; length 2..39; Default value: ::.";
      type ietfinet:ipv6-address;
      default "::";
    }
    leaf operationalState {
      description "The operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf termPointToGNBCUCPId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf usedIpAddress {
      description "Destination address used for initialization of underlying SCTP association. Contains address of latest successful F1-C setup. IP address can be an IPv4 or an IPv6 address..";
      type string;
      config false;
    }
  }
