      }
      enum PORT_SWITCHED_INIT_2_PORT {
        description "Uplink port number is switched. If UE has two ports, uplink two ports is used for power classes PC1_5, PC2, and PC3 from the start. Uplink port switching is allowed between one port and two ports for power classes PC1_5, PC2, and PC3.";
      }
    }
  }
  typedef UlWfSwitchFr1Mode {
    description "Uplink waveform switch mode.";
    type enumeration {
      enum CP_OFDM_NOSWITCH {
        description "Uplink waveform is CP-OFDM. Waveform switch is not allowed.";
      }
      enum DFTS_OFDM_NOSWITCH {
        description "Uplink waveform is DFT-s-OFDM. Waveform switch is not allowed.";
      }
      enum WAVEFORM_SWITCH {
        description "Waveform switch is allowed between DFT-s-OFDM and CP-OFDM.";
      }
    }
  }
  typedef WeightOffset {
    description "Initial domain weight.";
    type enumeration {
      enum ZERO {
        description "No weight offset.";
      }
      enum LOW {
        description "Low weight offset.";
      }
      enum MEDIUM {
        description "Medium weight offset.";
      }
      enum HIGH {
        description "High weight offset.";
      }
    }
  }
  grouping AzimuthNull-struct {
    description "Characteristics of spatial null in azimuth.";
    leaf frequency {
      description "range 0..6000000; Default value: 0.";
