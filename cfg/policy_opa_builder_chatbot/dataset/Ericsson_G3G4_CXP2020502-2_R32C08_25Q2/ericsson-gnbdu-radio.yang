      description "Distribution of timing advance (TA) values at successful random access. TA values are expressed as distance between UE and antenna site. Unit: N/A Ranges: Bin[0]: [0..49] m Bin[1]: [50..99] m Bin[2]: [100..149] m Bin[3]: [150..199] m Bin[4]: [200..299] m Bin[5]: [300..399] m Bin[6]: [400..499] m Bin[7]: [500..599] m Bin[8]: [600..699] m Bin[9]: [700..799] m Bin[10]: [800..999] m Bin[11]: [1000..1199] m Bin[12]: [1200..1399] m Bin[13]: [1400..1599] m Bin[14]: [1600..1799] m Bin[15]: [1800..1999] m Bin[16]: [2000..2499] m Bin[17]: [2500..2999] m Bin[18]: [3000..3499] m Bin[19]: [3500..3999] m Bin[20]: [4000..4999] m Bin[21]: [5000..5999] m Bin[22]: [6000..6999] m Bin[23]: [7000..7999] m Bin[24]: [8000..8999] m Bin[25]: [9000..9999] m Bin[26]: [10000..10999] m Bin[27]: [11000..11999] m Bin[28]: [12000..12999] m Bin[29]: [13000..13999] m Bin[30]: [14000..14999] m Bin[31]: [15000..] m.";
      type uint64;
      max-elements 32;
    }
    leaf-list pmMacTimeDlDrbSampQos {
      description "Aggregated number of samples for measuring time for HARQ initial transmission scheduling of downlink DRB while there is data in buffer. Accumulates samples from all DRBs with same QoS. Unit: N/A Compressed: True.";
      type ietfyang:mac-address;
      max-elements 256;
    }
    leaf-list pmMacRBSymUsedPdcchTypeAAggrLvl8Sssg {
      description "Number of resource block symbols used by PDCCH with aggregation level 8 for scheduling of PDSCH or PUSCH using mapping type A in search space set group. Includes DMRS and PTRS embedded in resources. PDF ranges: Bin[0]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 8 for UEs that are not configured with search space set group switching. Bin[1]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 8 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a dense search space set group. Bin[2]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 8 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a sparse search space set group. Bin[3]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 8 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 2 for UEs configured with a dense search space set group. ... Bin[15]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 8 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a dense search space set group. Bin[16]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 8 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a sparse search space set group. Unit: N/A.";
      type ietfyang:mac-address;
      max-elements 17;
    }
    leaf-list pmRadioRaCfPreambleFailedDistr {
      description "Number of failed allocations of CFRA preambles for each PRACH period during measurement period. Unit: N/A Ranges: Bin[0]: One failed preamble assignment. Bin[1]: Two failed preamble assignments. Bin[2]: Three failed preamble assignments. Bin[3]: More than three failed preamble assignments. Deprecated: Since 25.Q1. Planned to be removed. Replaced by NRCellDU::pmRadioRaCfPreambleFailedUlCaDistr and NRCellDU::pmRadioRaCfPreambleFailedHoDistr; MOM flags: noNotification.";
      type uint64;
      max-elements 4;
    }
    leaf pmMacHarqDlNack16QamInit {
      description "Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM modulation. Initial transmission is first transmission on HARQ process. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacPdcchBlockingPdschOccasions {
      description "Incremented for each scheduling occasion when PDCCH limits number of sessions served by PDSCH. A scheduling occasion is when any number of requests are allocated PDCCH, PDSCH and PUSCH. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmRadioUeRepCqi256QamRank4Distr {
      description "Distribution of UE-reported CQI values related to rank 4 transmissions when highest modulation order supported in downlink (DL) in NR cell is configured to be 256-QAM. CQI values and interpretations correspond to entries in Table 5.2.2.1-3 in 3GPP 38.214 for reporting CQI based on QPSK, 16-QAM, 64-QAM, and 256-QAM. Unit: N/A Ranges: Bin[0]: CQI = 0 Bin[1]: CQI = 1 Bin[2]: CQI = 2 Bin[3]: CQI = 3 Bin[4]: CQI = 4 Bin[5]: CQI = 5 Bin[6]: CQI = 6 Bin[7]: CQI = 7 Bin[8]: CQI = 8 Bin[9]: CQI = 9 Bin[10]: CQI = 10 Bin[11]: CQI = 11 Bin[12]: CQI = 12 Bin[13]: CQI = 13 Bin[14]: CQI = 14 Bin[15]: CQI = 15.";
      type uint64;
      max-elements 16;
    }
    leaf pmCellTimeSamp {
      description "Number of times corresponding cell downtime and uptime counters accumulate new sample..";
      type uint64;
      config false;
    }
    leaf-list pmSessionTimeUeBwpSumDistr {
      description "Shows accumulated time sessions of UEs with BWP in NRCellDU MO by BWPSet MO. PDF ranges: Bin[0]: Accumulated time sessions of UEs with first BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Bin[1]: Accumulated time sessions of UEs with second BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Bin[2]: Accumulated time sessions of UEs with third BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute ... Bin[15]: Accumulated time sessions of UEs with sixteenth BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute.";
      type uint64;
      max-elements 16;
    }
    leaf pmMacTimeDlDrb {
      description "Aggregated time for HARQ initial transmission scheduling of downlink DRB, while there is data in buffer. Unit: 125 microseconds.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmPuschAvailSlot {
      description "Total number of slots where gNodeB scheduler can schedule on PUSCH. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf pmMacHarqUlFail {
      description "Number of complete uplink HARQ failures. When HARQ transmission reaches maximum number of retransmissions, it is not retransmitted again and is regarded as scheduling activity with complete HARQ failure. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmUeCtxtModSuccWvfSwitchDistr {
      description "Counts successful RRC Reconfiguration attempts during UE Context Modification procedure for UE uplink waveform switch. Unit: N/A Ranges: Bin[0]: NR SA MCG CP-OFDM Bin[1]: EN-DC SCG CP-OFDM Bin[2]: NR-DC SCG CP-OFDM Bin[3]: NR SA MCG DFTs-OFDM Bin[4]: EN-DC SCG DFTs-OFDM Bin[5]: NR-DC SCG DFTs-OFDM.";
      type uint64;
      max-elements 6;
    }
    leaf pmCellDowntimeAuto {
      description "Length of time the cell is automatically disabled. Unit: seconds.";
      type uint64;
      config false;
    }
    leaf-list pmMacPdcchCongestionUlDistr {
      description "Distribution of uplink PDCCH congestion rate averaged over one second. Ranges Bin[0]: [0..5] % Bin[1]: [6..10] % Bin[2]: [11..15] % Bin[3]: [16..20] % Bin[4]: [21..25] % Bin[5]: [26..30] % Bin[6]: [31..35] % Bin[7]: [36..40] % Bin[8]: [41..45] % Bin[9]: [46..50] % Bin[10]: [51..55] % Bin[11]: [56..60] % Bin[12]: [61..65] % Bin[13]: [66..70] % Bin[14]: [71..75] % Bin[15]: [76..80] % Bin[16]: [81..85] % Bin[17]: [86..90] % Bin[18]: [91..95] % Bin[19]: [96..] % Unit: N/A.";
      type ietfyang:mac-address;
      max-elements 20;
    }
    leaf pmMacVolDlDrbSingleBurstSamp {
      description "Aggregated number of samples when new downlink packet arrives to empty buffer. Buffer is drained by single scheduling occasion. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacVolDlDrbSingleBurstSampQos {
      description "Aggregated number of samples when new downlink packet arrives to empty buffer for each QoS. Buffer is drained by single scheduling occasion. Unit: N/A Compressed: True.";
      type ietfyang:mac-address;
      max-elements 256;
    }
    leaf pmRadioRaCbFailMsg3Crnti {
      description "Number of RACH attempts failed due to Msg3 received with wrong CRNTI. Unit: messages.";
      type uint64;
      config false;
    }
    leaf pmMacThpDlDrbMax {
      description "Maximum downlink MAC DRB throughput achieved when restricted by air interface. Unit: kbps.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmRadioPuschTable2McsDistr {
      description "Distribution of MCS used for PUSCH transmissions where MCS index table 2 is applied and UE instances are enabled with up to 256-QAM. For more information, see 3GPP TS 38.214, Table 5.1.3.1-2. Each bin represents a specific MCS. Unit: N/A Ranges: Bin[0]: MCS = 0 Bin[1]: MCS = 1 Bin[2]: MCS = 2 Bin[3]: MCS = 3 Bin[4]: MCS = 4 Bin[5]: MCS = 5 Bin[6]: MCS = 6 Bin[7]: MCS = 7 Bin[8]: MCS = 8 Bin[9]: MCS = 9 Bin[10]: MCS = 10 Bin[11]: MCS = 11 Bin[12]: MCS = 12 Bin[13]: MCS = 13 Bin[14]: MCS = 14 Bin[15]: MCS = 15 Bin[16]: MCS = 16 Bin[17]: MCS = 17 Bin[18]: MCS = 18 Bin[19]: MCS = 19 Bin[20]: MCS = 20 Bin[21]: MCS = 21 Bin[22]: MCS = 22 Bin[23]: MCS = 23 Bin[24]: MCS = 24 Bin[25]: MCS = 25 Bin[26]: MCS = 26 Bin[27]: MCS = 27 Bin[28]: MCS = 28 Bin[29]: MCS = 29 Bin[30]: MCS = 30 Bin[31]: MCS = 31.";
      type uint64;
      max-elements 32;
    }
    leaf pmMacPduVolDlUePCell {
      description "Aggregated volume of HARQ initially transmitted and retransmitted downlink MAC PDUs for DRB or SRB using cell as PCell or PSCell. Unit: bytes.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMeasGapUeMnMaxDistr {
      description "Peak number of active UEs that have measurement gap configured by MN which impacts SN during dual connectivity. Sample is taken every 5 seconds. Unit: N/A Ranges: Bin[0]: Gap pattern 0 Bin[1]: Gap pattern 1 Bin[2]: Gap pattern 2 Bin[3]: Gap pattern 3 Bin[4]: Not used Bin[5]: Not used Bin[6]: Not used Bin[7]: Not used Bin[8]: Not used Bin[9]: Not used Bin[10]: Not used Bin[11]: Not used Bin[12]: Not used Bin[13]: Not used Bin[14]: Gap pattern 14 Bin[15]: Not used Bin[16]: Not used Bin[17]: Not used Bin[18]: Not used Bin[19]: Not used Bin[20]: Not used Bin[21]: Not used Bin[22]: Not used Bin[23]: Not used Compressed: True.";
      type int64;
      max-elements 24;
    }
    leaf pmPdschAvailSlot {
      description "Total number of slots where gNodeB scheduler can schedule on PDSCH. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf pmMacRBSymEstimatedPdschTypeA {
      description "Aggregated number of resource block symbols estimated for PDSCH mapping type A during a complete Result Output Period (ROP) without use of Energy-Optimized Power Allocation feature. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacRBSymUsedPdschAdvMimoSinrThresUserDistr {
      description "Distribution of aggregated number of resource block symbols used for PDSCH by a variable number of users that meet preset SINR thresholding conditions as a result of advanced beamforming. This PM counter can be used together with NRCellDU.pmMacVolPdschAdvMimoSinrThresUserDistr PM counter to calculate SRS reciprocity resource block spectral efficiency. DMRS and PTRS embedded in PDSCH resources are included. Unit: N/A Ranges: Bin[0]: Distribution of aggregated number of resource block symbols for one user. Bin[1]: Distribution of aggregated number of resource block symbols for two users. Bin[2]: Distribution of aggregated number of resource block symbols for three users. Bin[3]: Distribution of aggregated number of resource block symbols for four users. Bin[4]: Distribution of aggregated number of resource block symbols for five users. Bin[5]: Distribution of aggregated number of resource block symbols for six users. Bin[6]: Distribution of aggregated number of resource block symbols for seven users. Bin[7]: Distribution of aggregated number of resource block symbols for eight users. Bin[8]: Reserved for future MU-MIMO. Bin[9]: Reserved for future MU-MIMO. Bin[10]: Reserved for future MU-MIMO. Bin[11]: Reserved for future MU-MIMO. Bin[12]: Reserved for future MU-MIMO. Bin[13]: Reserved for future MU-MIMO. Bin[14]: Reserved for future MU-MIMO. Bin[15]: Reserved for future MU-MIMO..";
      type ietfyang:mac-address;
      max-elements 16;
    }
    leaf-list pmRadioRaCfPreambleUnusedDistr {
      description "Number of unused CFRA preambles during a PRACH period. If there is failed allocation for HO, this counter is not stepped. But it can be stepped if there is failed allocation for UL CA. Unit: N/A Ranges: Bin[0]: All CFRA preambles are in use and no preamble assignment failures. Bin[1]: One unused CFRA preamble, no preamble assignment failures. Bin[2]: Two unused CFRA preambles, no preamble assignment failures. Bin[3]: Three unused CFRA preambles, no preamble assignment failures. Bin[4]: Four unused CFRA preambles, no preamble assignment failures. Bin[5]: Five unused CFRA preambles, no preamble assignment failures. Bin[6]: Six unused CFRA preambles, no preamble assignment failures. Bin[7]: Seven unused CFRA preambles, no preamble assignment failures. Bin[8]: Eight unused CFRA preambles, no preamble assignment failures. Bin[9]: Nine unused CFRA preambles, no preamble assignment failures. Bin[10]: Ten unused CFRA preambles, no preamble assignment failures. Bin[11]: Eleven unused CFRA preambles, no preamble assignment failures. Bin[12]: Twelve unused CFRA preambles, no preamble assignment failures. Bin[13]: More than twelve available CFRA preambles, no preamble assignment failures..";
      type uint64;
      max-elements 14;
    }
    leaf pmMassiveMimoSleepTimeEco {
      description "Accumulates actual amount of time a cell is set to ECO state. Unit: seconds.";
      type uint64;
      config false;
    }
    leaf-list pmRadioRaCfPreambleFailedHoDistr {
      description "Number of failed CFRA preamble allocations for handover UEs for each PRACH period during measurement period. Unit: N/A Ranges: Bin[0]: One failed preamble assignment for handover. Bin[1]: Two failed preamble assignments for handover. Bin[2]: Three failed preamble assignments for handover. Bin[3]: More than three failed preamble assignments for handover..";
      type uint64;
      max-elements 4;
    }
    leaf-list pmRadioPdschTable3MbsfnMcsDistr {
      description "Distribution of MCS used for PDSCH transmissions in MBSFN subframes where MCS index table 3 is applied, and UE instances are enabled with up to 64-QAM. For more information, see 3GPP TS 38.214, Table 5.1.3.1-3. Each bin represents a specific MCS. Unit: N/A Ranges: Bin[0]: MCS = 0 Bin[1]: MCS = 1 Bin[2]: MCS = 2 Bin[3]: MCS = 3 Bin[4]: MCS = 4 Bin[5]: MCS = 5 Bin[6]: MCS = 6 Bin[7]: MCS = 7 Bin[8]: MCS = 8 Bin[9]: MCS = 9 Bin[10]: MCS = 10 Bin[11]: MCS = 11 Bin[12]: MCS = 12 Bin[13]: MCS = 13 Bin[14]: MCS = 14 Bin[15]: MCS = 15 Bin[16]: MCS = 16 Bin[17]: MCS = 17 Bin[18]: MCS = 18 Bin[19]: MCS = 19 Bin[20]: MCS = 20 Bin[21]: MCS = 21 Bin[22]: MCS = 22 Bin[23]: MCS = 23 Bin[24]: MCS = 24 Bin[25]: MCS = 25 Bin[26]: MCS = 26 Bin[27]: MCS = 27 Bin[28]: MCS = 28 Bin[29]: MCS = 29 Bin[30]: MCS = 30 Bin[31]: MCS = 31.";
      type uint64;
      max-elements 32;
    }
    leaf-list pmMacVolDlDrbLastSlotQos {
      description "Aggregated volume of downlink MAC SDUs transmitted for HARQ initial transmission in last slot of burst when buffer is emptied for each QoS. HARQ retransmission is excluded. Unit: bytes Compressed: True.";
      type ietfyang:mac-address;
      max-elements 256;
    }
    leaf-list pmMacVolDlSssg {
      description "Aggregated volume of successfully transmitted downlink MAC PDUs for DRB or SRB using cell as PCell or PSCell. PDF ranges: Bin[0]: Aggregated volume of successfully transmitted downlink MAC PDUs for DRB or SRB for UEs that are not configured with search space set group switching. Bin[1]: Aggregated volume of successfully transmitted downlink MAC PDUs for DRB or SRB for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a dense search space set group. Bin[2]: Aggregated volume of successfully transmitted downlink MAC PDUs for DRB or SRB for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a sparse search space set group. Bin[3]: Aggregated volume of successfully transmitted downlink MAC PDUs for DRB or SRB for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 2 for UEs configured with a dense search space set group. ... Bin[15]: Aggregated volume of successfully transmitted downlink MAC PDUs for DRB or SRB for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a dense search space set group. Bin[16]: Aggregated volume of successfully transmitted downlink MAC PDUs for DRB or SRB for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a sparse search space set group. Unit: 100 bytes.";
      type ietfyang:mac-address;
      max-elements 17;
    }
    leaf-list pmMacRBSymUsedPdcchTypeAAggrLvl4Sssg {
      description "Number of resource block symbols used by PDCCH with aggregation level 4 for scheduling of PDSCH or PUSCH using mapping type A in search space set group. Includes DMRS and PTRS embedded in resources. PDF ranges: Bin[0]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 4 for UEs that are not configured with search space set group switching. Bin[1]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 4 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a dense search space set group. Bin[2]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 4 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 1 for UEs configured with a sparse search space set group. Bin[3]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 4 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 2 for UEs configured with a dense search space set group. ... Bin[15]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 4 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a dense search space set group. Bin[16]: Accumulated downlink resource block symbols that use PDCCH with aggregation level 4 for UEs configured with search space set group switching. Value of SssgSwitchUeCfg.sssgSwitchPmIdentity attribute must be 8 for UEs configured with a sparse search space set group. Unit: N/A.";
      type ietfyang:mac-address;
      max-elements 17;
    }
    leaf pmMacHarqDlNack64QamInit {
      description "Total number of unsuccessful initial downlink HARQ transmissions using 64-QAM modulation. Initial transmission is first transmission on HARQ process. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmRadioBeamSwitchSucc {
      description "Number of wide beam switches with successful uplink decoding after quasi co-location (QCL) switch. Measured when this cell is used as PSCell. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf-list pmRadioUeRepCqi64QamRank1Distr {
      description "Distribution of UE-reported CQI values related to rank 1 transmissions when highest modulation order supported in downlink (DL) in NR cell is 64-QAM. CQI values and interpretations correspond to entries in Table 5.2.2.1-2 in 3GPP 38.214 for reporting CQI based on QPSK, 16-QAM, and 64-QAM. Unit: N/A Ranges: Bin[0]: CQI = 0 Bin[1]: CQI = 1 Bin[2]: CQI = 2 Bin[3]: CQI = 3 Bin[4]: CQI = 4 Bin[5]: CQI = 5 Bin[6]: CQI = 6 Bin[7]: CQI = 7 Bin[8]: CQI = 8 Bin[9]: CQI = 9 Bin[10]: CQI = 10 Bin[11]: CQI = 11 Bin[12]: CQI = 12 Bin[13]: CQI = 13 Bin[14]: CQI = 14 Bin[15]: CQI = 15.";
      type uint64;
      max-elements 16;
    }
    leaf pmMacThpDlMax {
      description "Maximum throughput of successfully transmitted downlink MAC PDUs for DRB or SRB using cell as PCell, SCell, or PSCell. In the case of carrier aggregation, counter value is a combination of PCell (PSCell) and SCell and is accumulated in PCell (PSCell). Time period is fixed at one second. Unit: bytes per second.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmPuschSchedActivity {
      description "Total duration of slots where at least one MAC SDU is received on PUSCH. Unit: 125 microseconds.";
      type uint64;
      config false;
    }
    leaf-list pmRadioNarrowBeamAcqTimeDistr {
      description "Number of instances when time between PRACH and P2 refinement falls within a specific time range. P2 refinement means successful switch from wide beam to narrow beam. Unit: N/A Ranges: Bin[0]: [0..1] ms Bin[1]: ]1..2] ms Bin[2]: ]2..3] ms Bin[3]: ]3..4] ms Bin[4]: ]4..5] ms Bin[5]: ]5..6] ms Bin[6]: ]6..7] ms Bin[7]: ]7..8] ms Bin[8]: ]8..9] ms Bin[9]: ]9..10] ms Bin[10]: ]10..20] ms Bin[11]: ]20..30] ms Bin[12]: ]30..40] ms Bin[13]: ]40..50] ms Bin[14]: ]50..60] ms Bin[15]: ]60..70] ms Bin[16]: ]70..80] ms Bin[17]: ]80..90] ms Bin[18]: ]90..100] ms Bin[19]: ]100..] ms.";
      type uint64;
      max-elements 20;
    }
    leaf-list pmRadioRecInterferencePwrSpecialSlot4Distr {
      description "Absolute power value of SRS comb offsets in each uplink symbol of special slot 4. The absolute power value is expressed in units of 0.1 dBm. Bins correspond to SRS comb offsets in each uplink symbol. This ensures compatibility between the lengths of uplink symbols in a special slot. To extract average interference power for each bin across a ROP, divide by pmRadioRecInterferencePwrSlotSamp. Number of bins corresponds to maximum six uplink symbols in a special slot and four comb offsets in each uplink symbol. Bins support the following symbol number and comb offset combinations: Bin[0]: First comb offset in last uplink symbol of special slot Bin[1]: Second comb offset in last uplink symbol of special slot Bin[2]: Third comb offset in last uplink symbol of special slot Bin[3]: Fourth comb offset in last uplink symbol of special slot Bin[4]: First comb offset in second uplink symbol from last of special slot Bin[5]: Second comb offset in second uplink symbol from last of special slot .... Bin[22]: Third comb offset in sixth uplink symbol from last of special slot Bin[23]: Fourth comb offset in sixth uplink symbol from last of special slot Note: For TDD UL-DL pattern 'DDSSUUDDDD DDSSUUDDDD', there's no ul symbol in the first and the third S slot. Only the second and the fourth S slot will be pegged. So, only pmRadioRecInterferencePwrSpecialSlot1Distr and pmRadioRecInterferencePwrSpecialSlot2Distr will be used..";
      type uint64;
      max-elements 24;
    }
    leaf pmMacHarqUlNack256Qam {
      description "Total number of unsuccessful HARQ transmissions with 256-QAM UL. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacVolDlSCell {
      description "Aggregated volume of successfully transmitted DL MAC PDUs for DRB or SRB using cell as SCell. Unit: bytes.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmMacHarqDlAckQpsk {
      description "Total number of successful downlink HARQ transmissions using QPSK modulation. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacLatTimeDlDrxSyncQos {
      description "Aggregated time for downlink MAC latency measurement for each QoS with DRX impact but without out-of-sync impact. DL MAC latency measures MAC scheduling latency between reception of packet in empty DL buffer and transmission of first packet. Unit: 125 microseconds Compressed: True.";
      type ietfyang:mac-address;
      max-elements 256;
    }
    leaf pmMacHarqDlDtx16Qam {
      description "Total number of occasions when downlink HARQ feedback for HARQ transmission using 16-QAM modulation could not be detected from UE. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacHarqDlNack16QamInitSlotDistr {
      description "For each downlink slot, bin that corresponds to number of unsuccessful initial HARQ PDSCH transmissions using 16-QAM modulation in slot is incremented. HARQ transmissions used for BWP DCI switch Scheduling Request (SR) are not pegged. Unit: N/A Ranges: Bin[0]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 0. Bin[1]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 1. Bin[2]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 2. Bin[3]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 3. Bin[4]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 4. Bin[5]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 5. Bin[6]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 6. Bin[7]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 7. Bin[8]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 8. Bin[9]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 9. Bin[10]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 10. Bin[11]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 11. Bin[12]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 12. Bin[13]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 13. Bin[14]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 14. Bin[15]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 15. Bin[16]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 16. Bin[17]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 17. Bin[18]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 18. Bin[19]: Total number of unsuccessful initial downlink HARQ transmissions using 16-QAM on slot 19..";
      type ietfyang:mac-address;
      max-elements 20;
    }
    leaf pmCellDowntimeMan {
      description "Length of time the cell is manually disabled. Unit: seconds.";
      type uint64;
