      description "Number of requests for eDRX RRC paging routed to cell. Both core network paging and RAN paging are included. Counter is a subset of NRCellDU.pmPagReceived PM counter. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf pmMacHarqDlDtx64QamInit {
      description "Total number of occasions when downlink HARQ feedback for initial HARQ transmission using 64-QAM modulation could not be detected from UE. Initial transmission is first transmission on HARQ process. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmMacRBSymUsedPdcchTypeAAggrLvl4Bwp {
      description "Number of resource block symbols used by PDCCH with aggregation level 4 for scheduling of PDSCH or PUSCH using mapping type A in BWP. This includes DMRS and PTRS embedded in resources. PDF ranges: Bin[0]: Accumulated downlink resource block symbols used by PDCCH with aggregation level 4 in the first BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Bin[1]: Accumulated downlink resource block symbols used by PDCCH with aggregation level 4 in the second BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Bin[2]: Accumulated downlink resource block symbols used by PDCCH with aggregation level 4 in the third BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute ... Bin[15]: Accumulated downlink resource block symbols used by PDCCH with aggregation level 4 in the sixteenth BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Unit: N/A.";
      type ietfyang:mac-address;
      max-elements 16;
    }
    leaf pmPdschPimBlankingReq {
      description "Number of slots sending blanking request when PIM is detected and there are UEs vulnerable to PIM. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf-list pmSssgUeConfSumDistr {
      description "Bin[0]: Number of UEs not capable of search space set group switching. Bin[1]: Number of UEs capable of and configured with search space set group switching. Bin[2]: Number of UEs capable of but not configured with search space set group switching..";
      type uint64;
      max-elements 3;
    }
    leaf-list pmRadioPdschTable3McsDistr {
      description "Distribution of MCS used for PDSCH transmissions where MCS index Table 3 is applied and UE instances are enabled. For more information, see 3GPP TS 38.214, Table 5.1.3.1-3. Each bin represents a specific MCS. Unit: N/A Ranges: Bin[0]: MCS = 0 Bin[1]: MCS = 1 Bin[2]: MCS = 2 Bin[3]: MCS = 3 Bin[4]: MCS = 4 Bin[5]: MCS = 5 Bin[6]: MCS = 6 Bin[7]: MCS = 7 Bin[8]: MCS = 8 Bin[9]: MCS = 9 Bin[10]: MCS = 10 Bin[11]: MCS = 11 Bin[12]: MCS = 12 Bin[13]: MCS = 13 Bin[14]: MCS = 14 Bin[15]: MCS = 15 Bin[16]: MCS = 16 Bin[17]: MCS = 17 Bin[18]: MCS = 18 Bin[19]: MCS = 19 Bin[20]: MCS = 20 Bin[21]: MCS = 21 Bin[22]: MCS = 22 Bin[23]: MCS = 23 Bin[24]: MCS = 24 Bin[25]: MCS = 25 Bin[26]: MCS = 26 Bin[27]: MCS = 27 Bin[28]: MCS = 28 Bin[29]: MCS = 29 Bin[30]: MCS = 30 Bin[31]: MCS = 31.";
      type uint64;
      max-elements 32;
    }
    leaf pmMacHarqDlDtxQpsk {
      description "Total number of occasions when downlink HARQ feedback for a HARQ transmission using QPSK modulation could not be detected from UE. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
