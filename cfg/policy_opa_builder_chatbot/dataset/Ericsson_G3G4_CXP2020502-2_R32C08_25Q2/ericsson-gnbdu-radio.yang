      description "Accumulates total number of SRS resources available for SRS antenna switching from every SRS slot. Each SRS resource is a combination of symbol, comb, and cyclic shift. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf pmMacHarqDlAck64QamInit {
      description "Total number of successful initial downlink HARQ transmissions using 64-QAM modulation. Initial transmission is first transmission on HARQ process. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmSssgUeConfSamp {
      description "Number of times NRCellDU.pmSssgUeConfSumDistr PM counter accumulates new sample. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf-list pmMacHarqDlAckQpskInitSlotDistr {
      description "For each downlink slot, bin that corresponds to number of successful initial HARQ PDSCH transmissions using QPSK modulation in slot is incremented. HARQ transmissions used for BWP DCI switch Scheduling Request (SR) are not pegged. Unit: N/A Ranges: Bin[0]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 0. Bin[1]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 1. Bin[2]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 2. Bin[3]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 3. Bin[4]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 4. Bin[5]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 5. Bin[6]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 6. Bin[7]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 7. Bin[8]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 8. Bin[9]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 9. Bin[10]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 10. Bin[11]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 11. Bin[12]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 12. Bin[13]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 13. Bin[14]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 14. Bin[15]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 15. Bin[16]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 16. Bin[17]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 17. Bin[18]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 18. Bin[19]: Total number of successful initial downlink HARQ transmissions using QPSK on slot 19..";
      type ietfyang:mac-address;
      max-elements 20;
    }
    leaf-list pmRadioUeRepCqi64QamLowSeRank3Distr {
      description "Distribution of UE-reported CQI values with low Spectral Efficiency related to rank 3 transmissions when highest modulation order supported in downlink (DL) in NR cell is 64-QAM. CQI values and interpretations correspond to entries in Table 5.2.2.1-4 in 3GPP 38.214 for reporting CQI based on QPSK, 16-QAM, and 64-QAM. Unit: N/A Ranges: Bin[0]: CQI = 0 Bin[1]: CQI = 1 Bin[2]: CQI = 2 Bin[3]: CQI = 3 Bin[4]: CQI = 4 Bin[5]: CQI = 5 Bin[6]: CQI = 6 Bin[7]: CQI = 7 Bin[8]: CQI = 8 Bin[9]: CQI = 9 Bin[10]: CQI = 10 Bin[11]: CQI = 11 Bin[12]: CQI = 12 Bin[13]: CQI = 13 Bin[14]: CQI = 14 Bin[15]: CQI = 15.";
      type uint64;
      max-elements 16;
    }
    leaf-list pmPimAvoidPowerExcessReportMissDistr {
      description "Distribution of number of times when PIM power excess feedback is continuously missing. There is one system constant: pimMissingReportSamplesThreshold to limit the maximum times. The possible value for this SC is 5, 6, ..., 20. Once the threshold is reached, then stop PIM avoidance. Ranges: Bin[0]: one time Bin[1]: two times Bin[2]: three times Bin[3]: four times Bin[4]: five times Bin[5]: six times Bin[6]: seven times Bin[7]: eight times Bin[8]: nine times Bin[9]: ten times Bin[10]: eleven time Bin[11]: twelve time Bin[12]: thirteen times Bin[13]: fourteen times Bin[14]: fifteen times Bin[15]: sixteen times Bin[16]: seventeen times Bin[17]: eighteen times Bin[18]: nineteen times Bin[19]: twenty times.";
      type uint64;
      max-elements 20;
    }
    leaf pmSessionTimeUeSssgSamp {
      description "Number of times corresponding NRCellDU.pmSessionTimeUeSssgSumDistr PM counter is incremented. Unit: N/A.";
      type uint64;
      config false;
    }
    leaf-list pmPdschSchedEntityDistr {
      description "For each downlink slot, bin that corresponds to number of PDSCH-scheduled entities is incremented, including PDSCH-scheduling activities of Msg2 or Msg4, paging, or SI. Unit: N/A Ranges: Bin[0]: Number of PDSCH scheduled 0 SE is incremented. Bin[1]: Number of PDSCH scheduled 1 SE is incremented. Bin[2]: Number of PDSCH scheduled 2 SEs is incremented. Bin[3]: Number of PDSCH scheduled 3 SEs is incremented. Bin[4]: Number of PDSCH scheduled 4 SEs is incremented. Bin[5]: Number of PDSCH scheduled 5 SEs is incremented. Bin[6]: Number of PDSCH scheduled 6 SEs is incremented. Bin[7]: Number of PDSCH scheduled 7 SEs is incremented. Bin[8]: Number of PDSCH scheduled 8 SEs is incremented. Bin[9]: Number of PDSCH scheduled 9 SEs is incremented. Bin[10]: Number of PDSCH scheduled 10 SEs is incremented. Bin[11]: Number of PDSCH scheduled 11 SEs is incremented. Bin[12]: Number of PDSCH scheduled 12 SEs is incremented. Bin[13]: Number of PDSCH scheduled 13 SEs is incremented. Bin[14]: Number of PDSCH scheduled 14 SEs is incremented. Bin[15]: Number of PDSCH scheduled 15 SEs is incremented. Bin[16]: Number of PDSCH scheduled 16 SEs is incremented..";
      type uint64;
      max-elements 17;
    }
    leaf-list pmMacBsrLcg7Distr {
      description "Distribution of highest possible buffer size reported in BSRs in MAC Control Elements in UL LCG ID 7. Unit: N/A Ranges: Bin[0]: 0 bytes Bin[1]: [1..19] bytes Bin[2]: [20..36] bytes Bin[3]: [37..66] bytes Bin[4]: [67..124] bytes Bin[5]: [125..233] bytes Bin[6]: [234..436] bytes Bin[7]: [437..817] bytes Bin[8]: [818..1532] bytes Bin[9]: [1533..2873] bytes Bin[10]: [2874..5387] bytes Bin[11]: [5388..10104] bytes Bin[12]: [10105..18951] bytes Bin[13]: [18952..35543] bytes Bin[14]: [35544..66663] bytes Bin[15]: [66664..125030] bytes Bin[16]: [125031..] bytes.";
      type ietfyang:mac-address;
      max-elements 17;
    }
    leaf pmMacRBSymAvailDl {
      description "Aggregated number of resource block symbols available for downlink transmission during complete ROP. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf-list pmRadioRecInterferencePwrSpecialSlot2Distr {
      description "Absolute power value of SRS comb offsets in each uplink symbol of special slot 2. The absolute power value is expressed in units of 0.1 dBm. Bins correspond to SRS comb offsets in each uplink symbol. This ensures compatibility between the lengths of uplink symbols in a special slot. To extract average interference power for each bin across a ROP, divide by pmRadioRecInterferencePwrSlotSamp. Number of bins corresponds to maximum six uplink symbols in a special slot and four comb offsets in each uplink symbol. Bins support the following symbol number and comb offset combinations: Bin[0]: First comb offset in last uplink symbol of special slot Bin[1]: Second comb offset in last uplink symbol of special slot Bin[2]: Third comb offset in last uplink symbol of special slot Bin[3]: Fourth comb offset in last uplink symbol of special slot Bin[4]: First comb offset in second uplink symbol from last of special slot Bin[5]: Second comb offset in second uplink symbol from last of special slot .... Bin[22]: Third comb offset in sixth uplink symbol from last of special slot Bin[23]: Fourth comb offset in sixth uplink symbol from last of special slot Note: For TDD UL-DL pattern 'DDSSUUDDDD DDSSUUDDDD', there's no ul symbol in the first and the third S slot. Only the second and the fourth S slot will be pegged. So, only pmRadioRecInterferencePwrSpecialSlot1Distr and pmRadioRecInterferencePwrSpecialSlot2Distr will be used..";
      type uint64;
      max-elements 24;
    }
    leaf-list pmPuschSchedActivityBwp {
      description "Total duration of slots where at least one MAC SDU is received on PUSCH. PDF ranges: Bin[0]: Total duration of slots where at least one MAC SDU is received on PUSCH in the first BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Bin[1]: Total duration of slots where at least one MAC SDU is received on PUSCH in the second BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Bin[2]: Total duration of slots where at least one MAC SDU is received on PUSCH in the third BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute ... Bin[15]: Total duration of slots where at least one MAC SDU is received on PUSCH in the sixteenth BWP referenced in NRCellDU MO by BWPSet.allBWPRegularRef attribute Unit: 125 microseconds.";
      type uint64;
      max-elements 16;
    }
    leaf-list pmRadioRecInterferencePwrUlSlot5Distr {
      description "Absolute power for each symbol in uplink slot 5 in one radio frame. Bins correspond to uplink symbol 2 and uplink symbol 11 respectively. To get average interference power for each bin across a Result Output Period (ROP), divide by NRCellDU.pmRadioRecInterferencePwrSlotSamp. Unit: 0.1 dBm/PRB.";
      type uint64;
      max-elements 2;
    }
    leaf-list pmRadioPreambleSinrMsg3DtxDistr {
      description "Total number of Msg3 DTX counts for a preamble SINR range. Ranges: Bin[0]: [..-15] dB Bin[1]: ]-15..-12] dB Bin[2]: ]-12..-9] dB Bin[3]: ]-9..-6] dB Bin[4]: ]-6..-3] dB Bin[5]: ]-3..] dB.";
      type uint64;
      max-elements 6;
    }
    leaf-list pmRadioPuschTable3McsDistr {
      description "Distribution of MCS used for PUSCH transmissions where MCS index table 3 is applied and UE instances are enabled. For more information, see 3GPP TS 38.214, Table 6.1.4.1-2 and Table 5.1.3.1-3 (depending on whether Transform Precoding is enabled/disabled). Each bin represents a specific MCS. Unit: N/A Ranges: Bin[0]: MCS = 0 Bin[1]: MCS = 1 Bin[2]: MCS = 2 Bin[3]: MCS = 3 Bin[4]: MCS = 4 Bin[5]: MCS = 5 Bin[6]: MCS = 6 Bin[7]: MCS = 7 Bin[8]: MCS = 8 Bin[9]: MCS = 9 Bin[10]: MCS = 10 Bin[11]: MCS = 11 Bin[12]: MCS = 12 Bin[13]: MCS = 13 Bin[14]: MCS = 14 Bin[15]: MCS = 15 Bin[16]: MCS = 16 Bin[17]: MCS = 17 Bin[18]: MCS = 18 Bin[19]: MCS = 19 Bin[20]: MCS = 20 Bin[21]: MCS = 21 Bin[22]: MCS = 22 Bin[23]: MCS = 23 Bin[24]: MCS = 24 Bin[25]: MCS = 25 Bin[26]: MCS = 26 Bin[27]: MCS = 27 Bin[28]: MCS = 28 Bin[29]: MCS = 29 Bin[30]: MCS = 30 Bin[31]: MCS = 31.";
      type uint64;
      max-elements 32;
    }
    leaf pmMacVolUlResUeLastSlot {
      description "Data volume in MAC SDUs successfully received in uplink while restricted by air interface. Received in last slot of burst. Unit: byte Deprecated: Since 24.Q1. Planned to be removed. Replaced by GNBDU::GNBDU_NRCellDU::pmMacVolUlUeLastSlot; MOM flags: noNotification.";
      type ietfyang:mac-address;
      config false;
      status deprecated;
    }
    leaf-list pmMacRBSymUsedPdschAdvEisMimoUserDistr {
      description "Distribution of aggregated number of resource block symbols used for PDSCH by different number of users as a result of advanced Ericsson Interference Sensing (EIS) beamforming. DMRS and PTRS embedded in PDSCH resources are included. Unit: N/A Ranges: Bin[0]: Distribution of aggregated number of resource block symbols for 1 user case. Bin[1]: Distribution of aggregated number of resource block symbols for 2 users case. Bin[2]: Distribution of aggregated number of resource block symbols for 3 users case. Bin[3]: Distribution of aggregated number of resource block symbols for 4 users case. Bin[4]: Distribution of aggregated number of resource block symbols for 5 users case. Bin[5]: Distribution of aggregated number of resource block symbols for 6 users case. Bin[6]: Distribution of aggregated number of resource block symbols for 7 users case. Bin[7]: Distribution of aggregated number of resource block symbols for 8 users case. Bin[8]: Reserved for future MU-MIMO. Bin[9]: Reserved for future MU-MIMO. Bin[10]: Reserved for future MU-MIMO. Bin[11]: Reserved for future MU-MIMO. Bin[12]: Reserved for future MU-MIMO. Bin[13]: Reserved for future MU-MIMO. Bin[14]: Reserved for future MU-MIMO. Bin[15]: Reserved for future MU-MIMO..";
      type ietfyang:mac-address;
      max-elements 16;
    }
    leaf pmMacRBSymUsedPdcchTypeBAggrLvl1 {
      description "Number of resource block symbols used by PDCCH with aggregation level 1 for scheduling of PDSCH or PUSCH using mapping type B. This includes DMRS and PTRS embedded in resources scheduling. Unit: N/A.";
      type ietfyang:mac-address;
      config false;
    }
    leaf pmRadioRaCbFailMsg1MaxMsg3Sched {
      description "Number of CBRA preambles (Msg1) that are discarded because maximum number of random access Msg3 scheduled is reached. Unit: messages.";
      type uint64;
      config false;
    }
    leaf-list pmRadioRecInterferencePwrUlSlot1Distr {
      description "Absolute power for each symbol in uplink slot 1 in one radio frame. Bins correspond to uplink symbol 2 and uplink symbol 11 respectively. To get average interference power for each bin across a Result Output Period (ROP), divide by NRCellDU.pmRadioRecInterferencePwrSlotSamp. Unit: 0.1 dBm/PRB.";
      type uint64;
      max-elements 2;
    }
    leaf-list pmRadioPathlossUlDistr {
      description "Distribution of uplink path loss values calculated for each UE scheduling on slot basis. Unit: N/A Ranges: Bin[0]: [..50] dB Bin[1]: ]50..55] dB Bin[2]: ]55..60] dB Bin[3]: ]60..65] dB Bin[4]: ]65..70] dB Bin[5]: ]70..75] dB Bin[6]: ]75..80] dB Bin[7]: ]80..85] dB Bin[8]: ]85..90] dB Bin[9]: ]90..95] dB Bin[10]: ]95..100] dB Bin[11]: ]100..105] dB Bin[12]: ]105..110] dB Bin[13]: ]110..115] dB Bin[14]: ]115..120] dB Bin[15]: ]120..125] dB Bin[16]: ]125..130] dB Bin[17]: ]130..135] dB Bin[18]: ]135..140] dB Bin[19]: ]140..145] dB Bin[20]: ]145..] dB.";
      type uint64;
      max-elements 21;
    }
    leaf pmUeCtxtAllocatedSum {
      description "Sum of the number of allocated UE contexts from periodic readings..";
      type uint64;
      config false;
    }
    leaf-list pmRadioUeRepCqi256QamRank2Distr {
      description "Distribution of UE-reported CQI values related to rank 2 transmissions when highest modulation order supported in downlink (DL) in NR cell is configured to be 256-QAM. CQI values and interpretations correspond to entries in Table 5.2.2.1-3 in 3GPP 38.214 for reporting CQI based on QPSK, 16-QAM, 64-QAM, and 256-QAM. Unit: N/A Ranges: Bin[0]: CQI = 0 Bin[1]: CQI = 1 Bin[2]: CQI = 2 Bin[3]: CQI = 3 Bin[4]: CQI = 4 Bin[5]: CQI = 5 Bin[6]: CQI = 6 Bin[7]: CQI = 7 Bin[8]: CQI = 8 Bin[9]: CQI = 9 Bin[10]: CQI = 10 Bin[11]: CQI = 11 Bin[12]: CQI = 12 Bin[13]: CQI = 13 Bin[14]: CQI = 14 Bin[15]: CQI = 15.";
      type uint64;
      max-elements 16;
    }
    leaf-list pmRadioSinrPuschDistr {
      description "Distribution of SINR values calculated for PUSCH transmissions. Unit: N/A Ranges: Bin[0]: [..-5] dB Bin[1]: ]-5..-2] dB Bin[2]: ]-2..1] dB Bin[3]: ]1..4] dB Bin[4]: ]4..7] dB Bin[5]: ]7..10] dB Bin[6]: ]10..13] dB Bin[7]: ]13..16] dB Bin[8]: ]16..19] dB Bin[9]: ]19..22] dB Bin[10]: ]22..25] dB Bin[11]: ]25..] dB.";
      type uint64;
      max-elements 12;
    }
    leaf-list pmRadioSinrPucchDistr {
      description "Distribution of SINR values calculated for PUCCH. Unit: N/A Ranges: Bin[0]: [..-15] dB Bin[1]: ]-15..-12] dB Bin[2]: ]-12..-9] dB Bin[3]: ]-9..-6] dB Bin[4]: ]-6..-3] dB Bin[5]: ]-3..0] dB Bin[6]: ]0..3] dB Bin[7]: ]3..] dB.";
      type uint64;
      max-elements 8;
    }
    leaf-list pmMacOverlapTimeDlDrbExtSCellQoS {
      description "Counter that records time overlap between carrier aggregation data bursts where original data burst time is overlapped with subsequent data burst times due to scheduling delay on external SCell. Accumulates measured time from all DRBs with same QoS. This time is subtracted from other counters intended for user throughput calculation. Unit: 125 microseconds Compressed: True.";
      type ietfyang:mac-address;
      max-elements 256;
    }
    leaf-list pmRadioSinrPuschAckDistr {
      description "Total number of PUSCH ACKs pegged at SINR values for each PUSCH transmission. Ranges: Bin[0]: [..-11] dB Bin[1]: ]-11..-8] dB Bin[2]: ]-8..-5] dB Bin[3]: ]-5..-2] dB Bin[4]: ]-2..1] dB Bin[5]: ]1..4] dB Bin[6]: ]4..7] dB Bin[7]: ]7..10] dB Bin[8]: ]10..13] dB Bin[9]: ]13..16] dB Bin[10]: ]16..] dB.";
      type uint64;
      max-elements 11;
    }
    leaf pmRadioRaCbFailMsg2Disc {
      description "Number of CBRA preambles for which no random access Msg2 is sent due to expiry of random access response window. Unit: messages.";
      type uint64;
      config false;
    }
  }
  grouping NRPimCancellationConfig-attributes {
    leaf createdBy {
      description "Whether NRPimCancellationConfig instance is created by operator or by the system..";
      type enumeration {
        enum SYSTEM;
        enum OPERATOR;
      }
      config false;
    }
    leaf dlPimCandidate {
      description "Whether DL carriers for PIM calculation are included.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf nRPimCancellationConfigId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf pimCancellationFunctionRef {
      description "Reference to an instance of PimCancellationFunction MO. Reference specifies PIM cancellation function in which NRSectorCarrier instance participates. NRPimCancellationConfig instances belonging to same NRSectorCarrier instance cannot refer to same PimCancellationFunction instance..";
      type string;
      mandatory true;
    }
    leaf ulPimCancellationMode {
      description "PIM cancellation mode on uplink carriers. Cannot be set to value different than EXCLUDED for more than one NRPimCancellationConfig instance under an NRSectorCarrier instance..";
      type enumeration {
        enum EXCLUDED;
        enum DEACTIVATED;
        enum ACTIVATED;
      }
    }
  }
  grouping NRSectorCarrier-attributes {
    leaf administrativeState {
      description "The administrative state. If set to SHUTTINGDOWN, the state is immediately brought to LOCKED..";
      type enumeration {
        enum LOCKED;
        enum UNLOCKED;
        enum SHUTTINGDOWN;
      }
    }
    leaf altitude {
      description "Altitude of transmitter antenna position measured in meters. Positive value means height, negative value means depth. Altitude is in relation to WGS84 reference ellipsoid. WGS84 reference ellipsoid is based on theoretical mean sea level. If empty, value is not defined.; range -32768..32767.";
      type int32 {
        range "-32768..32767";
      }
      units "m";
    }
    leaf arfcnDL {
      description "NR Absolute Radio Frequency Channel Number (NR-ARFCN) for downlink. If value is less than 600000, value must be a multiple of 20, except for band n41 cells, where value must be multiple of 6. Only even values if between 600000 and 2016666. Only odd values supported if above 2016667.; range 0..3279165.";
      type eytypes:int32_range_0-3279165;
      mandatory true;
    }
    leaf arfcnUL {
      description "NR Absolute Radio Frequency Channel Number (NR-ARFCN) for uplink. If value is less than 600000, value must be a multiple of 20, except for band n41 cells, where value must be multiple of 6. Only even values if between 600000 and 2016666. Only odd values supported if above 2016667. If 0, uplink channel number for Low-Band cells is not applicable if txDirection is DL.; range 0..3279165.";
      type eytypes:int32_range_0-3279165;
      mandatory true;
    }
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operationalState..";
      type AvailStatus;
      min-elements 0;
    }
    list azimuthNull {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct sequence entry.";
      }
      min-elements 0;
      max-elements 7;
      uses AzimuthNull-struct;
    }
    leaf bbOnlyBackoffAllowed {
      description "Whether EVM-aware power backoff is allowed when Radio Unit cannot support reporting backoff data. Only applicable to Remote Radio Units. Only applicable to Low-Band and Mid-Band sector carriers.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf bSChannelBwDL {
      description "BS Channel bandwidth in MHz for downlink..";
      type int32 {
        range "5 | 10 | 15 | 20 | 25 | 30 | 35 | 40 | 50 | 60 | 70 | 80 | 90 | 100 | 200";
      }
      mandatory true;
      units "MHz";
    }
    leaf bSChannelBwUL {
      description "BS Channel bandwidth in MHz for uplink. Not applicable to Low-Band cells if txDirection is DL..";
      type int32 {
        range "5 | 10 | 15 | 20 | 25 | 30 | 35 | 40 | 50 | 60 | 70 | 80 | 90 | 100 | 200";
      }
      mandatory true;
      units "MHz";
    }
    leaf cbrsEnabled {
      description "Whether sector carrier is externally supervised by authorized channel of Spectrum Access System. For CBRS sector carrier, set to true. Only applicable to Mid-Band sector carriers.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf cbrsTxExpireTime {
      description "When to stop the transmission on assigned spectrum in UTC. Sector carrier becomes disabled when it expires or is empty. Updated by setCbrsTxExpireTime action. String format is YYYY-MM-DDThh:mm:ssZ. Only applicable when cbrsEnabled is true. Only applicable to Mid-Band sector carriers..";
      type string;
      config false;
    }
    leaf configuredMaxTxPower {
      description "Maximum output power to be used in an NRSectorCarrier instance. Output power is evenly distributed over antenna connectors used for TX transmission allocated for NRSectorCarrier instance. For High-Band and mmWave, EIRP value per cross-polarized beam pair must be used. Value 0 must not be used. Note: Value has an impact on maxTransmissionPower which displays the used output power.; range 0..10000000; Default value: 20000.";
      type eytypes:int32_range_0-10000000;
      default "20000";
      units "mW";
    }
    list coverage {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "Transmission point coverage. Described by radius, bearing and opening angle..";
      uses NRCoverage-struct;
    }
    list dlCalibrationData {
      config false;
      description "Downlink antenna calibration information. Only applicable to Mid-Band sector carriers.; MOM flags: isNillable=true; Status info: Since 25.Q2. Planned to be removed..";
      uses DlCalibrationDataRO-struct;
    }
    leaf dlCalibrationEnabled {
      description "Whether downlink antenna calibration is enabled. If true, Antenna Calibration DL Failure alarm is raised on AAS-capable radios. Only applicable to Mid-Band sector carriers.; Default value: true; Takes effect: Next MO unlock; Status info: Since 25.Q2. Planned to be removed..";
      type boolean;
      status deprecated;
      default "true";
      reference "Takes effect: Next MO unlock.";
    }
    list elevationNull {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct sequence entry.";
      }
      min-elements 0;
      max-elements 3;
      uses ElevationNull-struct;
    }
    leaf essScLocalId {
      description "The gNodeB internal ID attribute for SectorCarrier within Ericsson Shared Spectrum. Must be unique and non-zero in gNodeB for ESS NRSectorCarrier instances.; range 1..99999.";
      type int32 {
        range "1..99999";
      }
    }
    leaf essScPairId {
      description "ID attribute that pairs SectorCarriers from gNodeB and eNodeB in Ericsson Spectrum Sharing (ESS). Must be unique within gNodeB and eNodeB.; range 1..9223372036854775807.";
      type int64 {
        range "1..9223372036854775807";
      }
    }
    leaf frameStartOffset {
      description "Radio frame start offset of sector carrier at antenna reference point-relative GPS time. Tc = 1 / (480 * 10e3 * 4096) seconds.; range 0..19660799; Default value: 0.";
      type uint32 {
        range "0..19660799";
      }
      default "0";
      units "Tc";
    }
    leaf frequencyDL {
      description "RF Reference Frequency of downlink channel..";
      type int32;
      config false;
      units "kHz";
    }
    leaf frequencyUL {
      description "RF Reference Frequency of uplink channel..";
      type int32;
      config false;
      units "kHz";
    }
    leaf latitude {
      description "Latitude of transmitter antenna position. Positive value means north, negative value means south.; range -90000000..90000000.";
      type int32 {
        range "-90000000..90000000";
      }
      units "degree";
    }
    list lcsToGcsTranslation {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "Local Coordinate System (LCS) to Global Coordinate System (GCS) translation information. If empty, this attribute is not used. Only applicable to Low-Band and Mid-Band cells..";
      uses LcsToGcsTranslation-struct;
    }
    leaf longitude {
      description "Longitude of transmitter antenna position. Positive value means east, negative value means west.; range -180000000..180000000.";
      type int32 {
        range "-180000000..180000000";
      }
      units "degree";
    }
    leaf massiveMimoSleepEnabled {
      description "Whether Massive MIMO Sleep Mode feature is enabled. Only applicable to Mid-Band sector carriers..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
        enum DETECTION;
      }
    }
    leaf massiveMimoSleepState {
      description "Status of feature Massive MIMO Sleep Mode. Only applicable to Mid-Band sector carriers..";
      type enumeration {
        enum DEACTIVATED;
        enum TXMUTE;
        enum ECO;
        enum ECO_PENDING;
      }
      config false;
    }
    leaf maxAllowedEirpPsd {
      description "Maximum EIRP density threshold per MHz required for EIRP restriction. If -1, no EIRP restriction. Only applicable to Mid-Band sector carriers.; Default value: -1.";
      type int32 {
        range "-1 | 1..10000";
      }
      default "-1";
      units "dBm/MHz";
    }
    leaf maxEirpPsdThresh {
      description "Maximum EIRP density threshold per MHz required for EIRP restriction. Only applicable for limiting EIRP within maximum EIRP stated by Ericsson product specifications. Only recommended for markets with restrictions on EIRP. If empty, EIRP restriction is not employed. If non-empty, attributes on CommonBeamforming MO cannot be updated while NRSectorCarrier::administrativeState is UNLOCKED.; range 1..1000.";
      type int32 {
        range "1..1000";
      }
      units "dBm/MHz";
    }
    leaf maxRegPowerLimit {
      description "Maximum downlink transmission power. If -1, configuredMaxTxPower is unrestricted.; range -1..10000000; Default value: -1.";
      type int32 {
        range "-1..10000000";
      }
      default "-1";
      units "mW";
    }
    leaf maxTransmissionPower {
      description "Maximum possible power at antenna reference point. Measured for all downlink channels in all TX branches used simultaneously in NRSectorCarrier instance..";
      type int32;
      config false;
      units "mW";
    }
    leaf mMimoSleepTimeGroupRef {
      description "Reference to an instance of MMimoSleepTimeGroup MO. If empty, no MMimoSleepTimeGroup instance is used in this sector carrier. Only applicable to Mid-Band sector carriers..";
      type string;
    }
    leaf muEirpPmiDistBasedThreshold {
      description "A PMI distance-based threshold used for adaptive power limitation in Advanced Downlink MU-MIMO. Used to determine if UEs must be of the same group. Only applicable to AAS radios. Only applicable to Mid-Band sector carriers.; range 0..31; Default value: 4.";
      type eytypes:int32_range_0-31-13;
      default "4";
    }
    leaf noOfRxAntennas {
      description "Number of antennas NRSectorCarrier MO uses for uplink transmission. Only used for NRSectorCarrier instances on sectors with non-AAS capable radios. If 0, NRSectorCarrier instance uses maximum number of RX antennas, else specified number is used. For Low-Band cells, value must be less than or equal to 8. For Mid-Band cells, value must be less than or equal to 8. For High-Band cells, value must be less than or equal to 2.; Default value: 0.";
      type int32 {
        range "0..2 | 4 | 8";
      }
      default "0";
    }
    leaf noOfTxAntennas {
      description "Number of antennas NRSectorCarrier MO uses for downlink transmission. Only used for NRSectorCarrier instances on sectors with non-AAS capable radios. If 0, NRSectorCarrier instance uses maximum number of TX antennas, else specified number is used. For Low-Band cells, value must be less than or equal to 4. For Mid-Band cells, value must be less than or equal to 8. For High-Band cells, value must be less than or equal to 2.; Default value: 0.";
      type int32 {
        range "0..2 | 4 | 8 | 16";
      }
      default "0";
    }
    leaf noOfUsedRxAntennas {
      description "Number of used RX antennas. Maximum number is determined by noOfRxAntennas. Empty means undefined..";
      type int32;
      config false;
    }
    leaf noOfUsedTxAntennas {
      description "Number of used TX antennas. Maximum number is determined by noOfTxAntennas. Empty means undefined..";
      type int32;
      config false;
    }
    leaf noTxPowerAction {
      description "Recovery action when no downlink TX power is detected. Controls which recovery action is performed when Advanced Cell Supervision feature detects no downlink TX power on sector carrier..";
      type enumeration {
        enum NO_ACTION;
        enum SC_AND_CELL_RESTART;
      }
    }
    leaf nRMicroSleepTxEnabled {
      description "Whether NR Micro Sleep TX feature is enabled. If false, feature is disabled. Not applicable to NRSectorCarrier instances that are on sectors with AAS capable radios nor RDS. Only applicable in radio equipment supporting Micro Sleep TX. For more information on hardware support, see NR Micro Sleep TX feature description.; Default value: true.";
      type boolean;
      default "true";
    }
    leaf nrppaCellPortionId {
      description "NRPPa Cell Portion ID. Only applicable to Low-Band and Mid-Band cells.; range 0..4095.";
      type eytypes:int32_range_0-4095;
      config false;
    }
    leaf nRSectorCarrierId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf nullSteeringMode {
      description "Spatial null-steering mode that determines impacted downlink channels. Only applicable to Mid-Band..";
      type enumeration {
        enum ALL;
        enum COMMON_BEAMFORMING;
        enum CSI_RS_MAPPING;
      }
    }
    leaf operationalState {
      description "The operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf pimAvoidDlMutingPeriod {
      description "Minimum slot interval between two blanked slots in downlink. Only applicable to Low-Band sector carriers.; range 1..15; Default value: 8.";
      type int32 {
        range "1..15";
      }
      default "8";
      units "slot";
    }
    leaf pimAvoidLevel {
      description "PIM Avoidance behavior level. Only applicable to Low-Band sector carriers..";
      type enumeration {
        enum DISABLED;
        enum LOW;
        enum MEDIUM;
        enum HIGH;
      }
    }
    leaf pimAvoidStatus {
      description "Whether PIM Avoidance is enabled on Baseband. True if both of following conditions apply: - Value of pimAvoidLevel is not DISABLED. - Value of pimDetected is true. Only applicable to Low-Band sector carriers..";
      type boolean;
      config false;
    }
    leaf pimDetected {
      description "Whether SectorCarrier is identified as a PIM victim. PIM Detection can identify a SectorCarrier as a PIM victim if SectorCarrier is affected by interference from passive intermodulation. Details on interference can be collected with PM events. If empty, PIM Detection is not active for this SectorCarrier instance. Only applicable to Low-Band NRSectorCarrier instances.; MOM flags: noNotification, isNillable=true; Status info: Since 24.Q1. Planned to be removed..";
      type boolean;
      config false;
      status deprecated;
    }
    leaf pimDetectionEnabled {
      description "Whether PIM Detection is activated for SectorCarrier.; Default value: false; Status info: Since 24.Q1. Planned to be removed..";
      type boolean;
      status deprecated;
      default "false";
    }
    list polygon {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct sequence entry.";
      }
      min-elements 0;
      max-elements 15;
      uses NRPolygonCorner-struct;
    }
    leaf powerBackoffMode {
      description "Backoff mode for Modulation-Aware Power Control feature. Not applicable to radio equipment that supports AAS High-Band configuration..";
      type enumeration {
        enum AUTO;
        enum OFF;
        enum STATIC;
      }
    }
    leaf powerBackoffOffset {
      description "Backoff offset. Optional backoff offset for higher order modulation in addition to value calculated by Modulation-Aware Power Control feature. A negative offset reduces backoff but never boosts power over nominal output power. Not applicable to radio equipment that supports AAS High-Band configuration.; range -20..20; Default value: 0.";
      type int32 {
        range "-20..20";
      }
      default "0";
      units "dB";
    }
    leaf powerMeasAvgTime {
      description "Power averaging time for EMF exposure power measurements in Massive MIMO AAS Systems. Only applicable to High-Band cells. Must be empty for Low-Band and Mid-Band cells. If empty in High-Band cell, system uses value 360.; range 30..1800.";
      type uint32 {
        range "30..1800";
      }
      units "s";
    }
    leaf radioReportControlled {
      description "Whether radio report is evaluated for EVM-aware power backoff. Only applicable to Remote Radio Units. Only applicable to Low-Band and Mid-Band sector carriers.; Default value: true.";
      type boolean;
      default "true";
    }
    leaf radioTransmitPerfMode {
      description "Radio transmit operating mode. Better performance can be achieved in downlink according to cell traffic profile when radio is configured to maximum output level. Green modes are power saving modes, which can reduce energy consumption when radio transmits in low power modes..";
      type enumeration {
        enum COVERAGE;
        enum CAPACITY;
        enum COVERAGE_GREEN;
        enum CAPACITY_GREEN;
      }
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf-list rfBranchRxRef {
      description "References to instances of RfBranch or MulticastAntennaBranch MO. References are used for deterministic RX carrier allocation if noOfRxAntennas is greater than 0. If empty, carrier allocation is based on the RF Branch MOM list by default behavior..";
      type string;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf-list rfBranchTxRef {
      description "References to instances of RfBranch or MulticastAntennaBranch MO. The references are used for deterministic TX carrier allocation if noOfTxAntennas is greater than 0. If empty, carrier allocation is based on the RF Branch MOM list by default behavior..";
      type string;
      ordered-by user;
      min-elements 0;
      max-elements 16;
    }
    leaf scaledTransmissionPower {
      description "Used power at antenna reference point. Covers all downlink channels in all TX branches used simultaneously in NRSectorCarrier instance. Represents the scaled power based on scaling factor, txPowerRatio, being applied to the allocated power at antenna reference point, maxTransmissionPower. Value is set every time txPowerState is set to STABLE..";
      type int32;
      config false;
      units "mW";
    }
    leaf sectorEquipmentFunctionRef {
      description "Reference to an instance of SectorEquipmentFunction MO..";
      type string;
      mandatory true;
    }
    leaf txDirection {
      description "Transmission direction. Value DL is only allowed in Low-Band and High-Band cells. For Low-Band cells, value DL is only applicable if license for NR Downlink-Only Cell Support for Carrier Aggregation feature is present and feature is active..";
      type enumeration {
        enum DL_AND_UL;
        enum DL;
      }
    }
    leaf txPowerChangeRate {
      description "Change rate for downlink output power to reach txPowerRatio. Example: If 5, a change of txPowerRatio from 100 to 80 will take 4 seconds.; range 1..10; Default value: 1.";
      type int32 {
        range "1..10";
      }
      default "1";
      units "%/s";
    }
    leaf txPowerPersistentLock {
      description "Whether configuredMaxTxPower is locked. If true, configuredMaxTxPower cannot be changed and MO cannot be deleted. Once set to true there is no possibility to change the value back to false unless a node re-integration is performed.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf txPowerRatio {
      description "DL output power ratio. Default value is 100 %. At unlock of NRSectorCarrier the current value will be set directly. When the value is changed on an unlocked NRSectorCarrier instance, the TX power changes with rate txPowerChangeRate.; range 10..100; Default value: 100.";
      type eytypes:int32_range_10-100;
      default "100";
      units "percent";
    }
    leaf txPowerState {
      description "DL output power state..";
      type enumeration {
        enum INVALID;
        enum STABLE;
        enum CHANGING;
      }
      config false;
    }
    leaf ueAssistedPrecodingOptEnabled {
      description "Whether NR UE-Assisted Precoding Optimization feature is enabled. Only applicable to Low-Band and Mid-Band sector carriers.; Default value: false.";
      type boolean;
      default "false";
    }
    leaf ueAssistedPrecodingOptStatus {
      description "Status of NR UE Assisted Precoding Optimization feature. Only applicable to Low-Band and Mid-Band sector carriers..";
      type enumeration {
        enum INACTIVE;
        enum ACTIVE_NO_UPDATE;
        enum ACTIVE_FAILED;
        enum ACTIVE_CALIBRATED;
        enum ACTIVE_CALIBRATED_UPDATING;
      }
      config false;
    }
    leaf ueAssistedPrecodingOptTimeGap {
      description "Time gap between two NR UE Assisted Precoding Optimization events. Only applicable to Low-Band and Mid-Band sector carriers.; range 0..43198; Default value: 300.";
      type int32 {
        range "0..43198";
      }
      default "300";
      units "s";
    }
    list ulCalibrationData {
      config false;
      description "Uplink antenna calibration information. Only applicable to Mid-Band sector carriers.; MOM flags: isNillable=true; Status info: Since 25.Q2. Planned to be removed..";
      uses UlCalibrationDataRO-struct;
    }
    leaf-list pmEmfPwrBackoffPwrDir6Distr {
      description "Estimated average power distribution over time relative to maximum TX power for sectorcarrier for direction 6. Only backoff related to Directional EMF feature is reflected in this counter. Power Spectral Density limitation related to other features is not shown. Unit: N/A Ranges: Bin[0]: [0..2.5] % Bin[1]: ]2.5..5] % Bin[2]: ]5..7.5] % Bin[3]: ]7.5..10] % Bin[4]: ]10..12.5] % Bin[5]: ]12.5..15] % Bin[6]: ]15..17.5] % Bin[7]: ]17.5..20] % Bin[8]: ]20..22.5] % Bin[9]: ]22.5..25] % Bin[10]: ]25..27.5] % Bin[11]: ]27.5..30] % Bin[12]: ]30..32.5] % Bin[13]: ]32.5..35] % Bin[14]: ]35..37.5] % Bin[15]: ]37.5..40] % Bin[16]: ]40..42.5] % Bin[17]: ]42.5..45] % Bin[18]: ]45..47.5] % Bin[19]: ]47.5..50] % Bin[20]: ]50..52.5] % Bin[21]: ]52.5..55] % Bin[22]: ]55..57.5] % Bin[23]: ]57.5..60] % Bin[24]: ]60..62.5] % Bin[25]: ]62.5..65] % Bin[26]: ]65..67.5] % Bin[27]: ]67.5..70] % Bin[28]: ]70..72.5] % Bin[29]: ]72.5..75] % Bin[30]: ]75..77.5] % Bin[31]: ]77.5..80] % Bin[32]: ]80..82.5] % Bin[33]: ]82.5..85] % Bin[34]: ]85..87.5] % Bin[35]: ]87.5..90] % Bin[36]: ]90..92.5] % Bin[37]: ]92.5..95] % Bin[38]: ]95..97.5] % Bin[39]: ]97.5..100] %.";
      type uint64;
      max-elements 40;
    }
