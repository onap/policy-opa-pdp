      max-elements 256;
    }
    leaf-list pmMacBsrLcg6Distr {
      description "Distribution of highest possible buffer size reported in BSRs in MAC Control Elements in UL LCG ID 6. Unit: N/A Ranges: Bin[0]: 0 bytes Bin[1]: [1..19] bytes Bin[2]: [20..36] bytes Bin[3]: [37..66] bytes Bin[4]: [67..124] bytes Bin[5]: [125..233] bytes Bin[6]: [234..436] bytes Bin[7]: [437..817] bytes Bin[8]: [818..1532] bytes Bin[9]: [1533..2873] bytes Bin[10]: [2874..5387] bytes Bin[11]: [5388..10104] bytes Bin[12]: [10105..18951] bytes Bin[13]: [18952..35543] bytes Bin[14]: [35544..66663] bytes Bin[15]: [66664..125030] bytes Bin[16]: [125031..] bytes.";
      type ietfyang:mac-address;
      max-elements 17;
    }
