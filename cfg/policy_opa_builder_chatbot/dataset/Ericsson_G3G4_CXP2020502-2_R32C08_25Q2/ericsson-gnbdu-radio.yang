  grouping SssgSwitchPwrOpt-attributes {
    leaf downDlThreshold {
      description "Threshold used for SSSG switch from dense to sparse SSSG in downlink. If 0, switch timer lowDlActivityTimer starts directly after downlink buffer is empty.; range 0..2000; Default value: 10.";
      type eytypes:int32_range_0-2000;
      default "10";
      units "slot";
    }
    leaf downUlThreshold {
      description "Threshold used for SSSG switch from dense to sparse SSSG in uplink. If 0, switch timer lowUlActivityTimer starts directly after uplink buffer is empty.; range 0..2000; Default value: 10.";
      type eytypes:int32_range_0-2000;
      default "10";
      units "slot";
    }
    leaf lowDlActivityTimer {
      description "Timer used for SSSG switch from dense to sparse SSSG in downlink. If 0, switch can be triggered as soon as amount of data in downlink buffer is not bigger than switch threshold calculated from downDlThreshold.; range 0..5000; Default value: 200.";
      type eytypes:int32_range_0-5000-4;
      default "200";
      units "ms";
    }
    leaf lowUlActivityTimer {
      description "Timer used for SSSG switch from dense to sparse SSSG in uplink. If 0, switch can be triggered as soon as amount of data in uplink buffer is not bigger than switch threshold calculated from downUlThreshold.; range 0..5000; Default value: 200.";
      type eytypes:int32_range_0-5000-4;
      default "200";
      units "ms";
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf sssgSwitchPwrOptId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf upDlThreshold {
      description "Threshold used for SSSG switch from sparse to dense SSSG in downlink. If 0, switch is triggered as soon as downlink buffer is non-empty.; range 0..2000; Default value: 100.";
      type eytypes:int32_range_0-2000;
      default "100";
      units "slot";
    }
    leaf upUlThreshold {
      description "Threshold used for SSSG switch from sparse to dense SSSG in uplink. If 0, switch is triggered as soon as uplink buffer is non-empty.; range 0..2000; Default value: 100.";
      type eytypes:int32_range_0-2000;
      default "100";
      units "slot";
    }
    leaf userLabel {
      description "Label for free use..";
      type string;
    }
  }
  grouping SssgSwitchUeCfg-attributes {
    leaf-list prefUeGroupList {
      description "Preference UE group list. List of preference UE group identifiers. If empty, MO instance matches preference UE group identifiers not defined in prefUeGroupList of any other MO instances under parent MO instance..";
      type eytypes:int32_range_1-255;
      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf sssgSwitchPmIdentity {
      description "Identity of bins of SSSG switch-related PM counters. Used to match given configuration profile for SSSG switch with PM counter bins in which measured metrics are available.; range 1..8.";
      type eytypes:int32_range_1-8;
      config false;
    }
    leaf sssgSwitchPwrOptRef {
      description "Reference to an instance of SssgSwitchPwrOpt MO. If empty, SSSG switching is not enabled in given SSSG switch configuration profile..";
      type string;
    }
