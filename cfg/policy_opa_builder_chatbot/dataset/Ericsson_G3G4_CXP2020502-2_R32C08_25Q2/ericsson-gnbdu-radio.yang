      ordered-by user;
      min-elements 0;
      max-elements 8;
    }
    leaf puschRepMode {
      description "PUSCH Repetition operational mode for UE. Only applicable if license for NR Dynamic Slot Aggregation for VoNR is present and feature is active..";
