      description "Defines the administrative state. Note: State \"SHUTTING_DOWN\" will immediately be switched to \"LOCKED\"..";
      type enumeration {
        enum LOCKED;
        enum UNLOCKED;
        enum SHUTTINGDOWN;
      }
    }
