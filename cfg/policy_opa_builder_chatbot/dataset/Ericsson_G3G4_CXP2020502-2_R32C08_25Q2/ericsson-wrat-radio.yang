    }
    leaf pmSumNonEmptyUserBuffers3McPqSpi12 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 12 and belonging to UEs units configured to use cell as serving HS-DSCH cell in 3MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumTransmittedBitsSpi10 {
      description "Measurement to observe the total amount of data, in kbits, sent on MAC-hs level per scheduling priority class 10. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBitsSpi00 {
      description "Total amount of acknowledged data sent on MAC-hs level per scheduling priority class 00. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumDelaySpi00 {
      description "Sum of delay of transmitted data before it is scheduled for scheduling priority class 00. Counter unit: 1 ms..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBits3McPqSpi03 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in 3MC mode. Only acknowledged data originating from a PQ with scheduling priority class 03 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBits3McPqSpi15 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in 3MC mode. Only acknowledged data originating from a PQ with scheduling priority class 15 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumNoOfUsersSpi10 {
      description "Counts the total number of users for scheduling priority class 10 selected for each 2 ms subframe that is transmitted in the cell. For an MC-PQ only the counter in the serving HS-DSCH cell (of the UE to which the MC-PQ belongs) is updated. However, the aggregated measurement, based on all cells where the MC-PQ may be served, is considered when that counter is updated. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmNoInactiveRequiredSubFramesSpi06 {
      description "Number of subframes in which no data with scheduling priority class 06 is transmitted although there is user data to be sent in the validated PQ. This user data is either waiting for first transmission, or data waiting for transmission (NACK is received or no ACK/NACK). If a subframe goes without scheduling priority class 06, that is, just carrying other scheduling priority classes or going totally empty, then the counter is stepped. If the buffer of an MC-PQ is emptied, due to prior scheduling in another cell in the same subframe, and no other buffer in the cell contains data the counter is not incremented. The counter reflects the cell perspective..";
      type uint16;
      config false;
    }
    leaf pmSumAckedBits3McPqSpi05 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in 3MC mode. Only acknowledged data originating from a PQ with scheduling priority class 05 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumTransmittedBitsSpi07 {
      description "Measurement to observe the total amount of data, in kbits, sent on MAC-hs level per scheduling priority class 07. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmIubMacdPduCellReceivedBits {
      description "Number of Mbit (1 000 000 bits) received over Iub HS MAC-d PDU in the cell. MAC-d PDUs, belonging to a MC-PQ, are counted in the serving HS-DSCH cell of the UE to which the PQ belongs (regardless of if the PDU is sent in that cell or not). The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumNoOfUsersSpi07 {
      description "Counts the total number of users for scheduling priority class 07 selected for each 2 ms subframe that is transmitted in the cell. For an MC-PQ only the counter in the serving HS-DSCH cell (of the UE to which the MC-PQ belongs) is updated. However, the aggregated measurement, based on all cells where the MC-PQ may be served, is considered when that counter is updated. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf-list pmDelayDistributionSpi12 {
      description "Measurement to observe the distribution of the scheduling delay for scheduling priority class 12 on each subframe on those priority queue(s) selected for transmission. Bins: [0]: Number of delays in [0..10[ % [1]: Number of delays in [10..20[ % ... [9]: Number of delays in [90..100[ % [10]: Number of delays greater than or equal to 100%.";
      type uint32;
      max-elements 11;
    }
    leaf pmCapacityLimitHsDschUsers {
      description "Licensed limit for number of HS-DSCH users in the cell. License key value if valid license key, else default value of NodeBLocalCell::maxNumHsdpaUsers if invalid/missing license key, else max value of NodeBLocalCell::maxNumHsdpaUsers if emergency unlock is active..";
      type int64;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersPqSpi00 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 00 and belonging to UEs units configured to use cell as serving HS-DSCH cell are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf-list pmSumTransmissionsUsersRlim {
      description "Distribution over number of multiplexed UE units for each 2ms TTI, of total amount of transmissions to UE units configured to use cell, including retransmissions, on MAC-hs or MAC-ehs level until acknowledgement is received, under resource-limited conditions. Scheduling decision is defined to be resource-limited if transport block size is limited only by available codes or power, or both. In addition, condition is not fulfilled if any retransmissions or transmissions to UE units configured in MIMO or HS-FACH mode occur among multiplexed UE units. Ranges: [0] : Number of transmissions for data initially scheduled in 2ms TTIs with 2 multiplexed UE units [1] : Number of transmissions for data initially scheduled in 2ms TTIs with 3 multiplexed UE units [2] : Number of transmissions for data initially scheduled in 2ms TTIs with 4 multiplexed UE units.";
      type uint16;
      max-elements 3;
    }
    leaf pmSumDelaySpi12 {
      description "Sum of delay of transmitted data before it is scheduled for scheduling priority class 12. Counter unit: 1 ms..";
      type uint32;
      config false;
    }
    leaf-list pmAck64Qam {
      description "Counting the number of received ACKs for a specified transport block size (TBS) with 64 QAM. The number of successful HARQ transmissions are counted of the MAC-hs layer. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter does not consider ACK/NACKs corresponding to HS-SCCH orders. The counter reflects the cell perspective. Bins: [0]: Number of ACKs for transport block with size [0..1000[ bits [1]: Number of ACKs for transport block with size [1000..2000[ bits ... [15]: Number of ACKs for transport block with size [15000..16000[ bits [16]: Number of ACKs for transport block with size [16000..17000[ bits [17]: Number of ACKs for transport block with size [17000..19000[ bits [16]: Number of ACKs for transport block with size [19000..21000[ bits ... [28]: Number of ACKs for transport block with size [39000..41000[ bits [29]: Number of ACKs for transport block with size [41000..43000[ bits.";
      type uint32;
      max-elements 30;
    }
    leaf pmNoInactiveRequiredSubFramesSpi04 {
      description "Number of subframes in which no data with scheduling priority class 04 is transmitted although there is user data to be sent in the validated PQ. This user data is either waiting for first transmission, or data waiting for transmission (NACK is received or no ACK/NACK). If a subframe goes without scheduling priority class 04, that is, just carrying other scheduling priority classes or going totally empty, then the counter is stepped. If the buffer of an MC-PQ is emptied, due to prior scheduling in another cell in the same subframe, and no other buffer in the cell contains data the counter is not incremented. The counter reflects the cell perspective..";
      type uint16;
      config false;
    }
    leaf pmSumAckedBits3McPqSpi01 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in 3MC mode. Only acknowledged data originating from a PQ with scheduling priority class 01 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumJitterSpi06 {
      description "Sum of delay jitter of transmitted data before it is scheduled for scheduling priority class 06. The jitter delay is defined as a time difference between current delay and the previous one. Counter unit: 1 ms..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffers3McPqSpi07 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 07 and belonging to UEs units configured to use cell as serving HS-DSCH cell in 3MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf-list pmUsedTbs64Qam {
      description "Counting the number of used transport block size (TBS) with 64 QAM. The number of successful HARQ transmissions are counted on the MAC-hs layer. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective. Bins: [0]: Number of used transport blocks with size [0..1000[ bits [1]: Number of used transport blocks with size [1000..2000[ bits ... [15]: Number of used transport blocks with size [15000..16000[ bits [16]: Number of used transport blocks with size [16000..17000[ bits [17]: Number of used transport blocks with size [17000..19000[ bits [16], number of used transport blocks with size [19000..21000[ bits ... [28]: Number of used transport blocks with size [39000..41000[ bits [29]: Number of used transport blocks with size [41000..43000[ bits.";
      type uint32;
      max-elements 30;
    }
    leaf pmSumNonEmptyUserBuffersPqSpi07 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 07 and belonging to UEs units configured to use cell as serving HS-DSCH cell are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersPqSpi06 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 06 and belonging to UEs units configured to use cell as serving HS-DSCH cell are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmNoInactiveRequiredSubFramesSpi10 {
      description "Number of subframes in which no data with scheduling priority class 10 is transmitted although there is user data to be sent in the validated PQ. This user data is either waiting for first transmission, or data waiting for transmission (NACK is received or no ACK/NACK). If a subframe goes without scheduling priority class 10, that is, just carrying other scheduling priority classes or going totally empty, then the counter is stepped. If the buffer of an MC-PQ is emptied, due to prior scheduling in another cell in the same subframe, and no other buffer in the cell contains data the counter is not incremented. The counter reflects the cell perspective..";
      type uint16;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersMcPqSpi02 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 02 and belonging to UEs units configured to use cell as serving HS-DSCH cell in MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmNoActiveSubFramesSpi15 {
      description "Sum of active 2 ms subframes for scheduling priority class 15..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBitsSpi11 {
      description "Total amount of acknowledged data sent on MAC-hs level per scheduling priority class 11. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmCapacityAllocRejHsDschUsers {
      description "Number of rejected attempts to allocate resources for new HS-DSCH user (related to pmCapacityLimitHsDschUsers)..";
      type uint64;
      config false;
    }
    leaf-list pmSamplesSumAckedBits {
      description "Distribution states how many sample values pmSumAckedBits is incremented. Ranges: [0] : Number of increments of pmSumAckedBits[0] [1] : Number of increments of pmSumAckedBits[1] ... [30] : Number of increments of pmSumAckedBits[30].";
      type uint16;
      max-elements 31;
    }
    leaf pmSumNonEmptyUserBuffersMcPqSpi01 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 01 and belonging to UEs units configured to use cell as serving HS-DSCH cell in MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf-list pmUnusedPowerWHs {
      description "Distribution of HS power not used in the cell and available for other cells. Presented as percentage of maximum power visible in NodeBSectorCarrier::pmTransmittedCarrierPowerWLimit. Bins: [0]: Number of sampled values in range [0..2[ % [1]: Number of sampled values in range [2..4[ % [2]: Number of sampled values in range [4..6[ % ... [49]: Number of sampled values in range [98..100] %.";
      type uint32;
      max-elements 50;
    }
    leaf pmNoActiveSubFramesSpi12 {
      description "Sum of active 2 ms subframes for scheduling priority class 12..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffers3McPqSpi02 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 02 and belonging to UEs units configured to use cell as serving HS-DSCH cell in 3MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBits3McPqSpi13 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in 3MC mode. Only acknowledged data originating from a PQ with scheduling priority class 13 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBits3McPqSpi12 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in 3MC mode. Only acknowledged data originating from a PQ with scheduling priority class 12 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf-list pmNoOfHsUsersPerTti {
      description "Average number of users (including HS-FACH users) scheduled in cell at each 2 ms subframe. A HS-FACH user is a UE unit that is in the RRC state CELL_FACH (on the RNC level) and uses transport channel HS-DSCH, not FACH. The counter reflects the cell perspective. Bins: [0]: Number of samples equal to 0 users [1]: Number of samples equal to 1 user [2]: Number of samples equal to 2 users [3]: Number of samples equal to 3 users [4]: Number of samples equal to 4 users.";
      type uint16;
      max-elements 5;
    }
    leaf pmAqmBasedDiscardSpi08 {
      description "Number of discards performed by the AQM feature for all Priority Queues (PQs) for Scheduling Priority Indicator (SPI) 08..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersPqSpi13 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 13 and belonging to UEs units configured to use cell as serving HS-DSCH cell are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumTransmittedBitsSpi09 {
      description "Measurement to observe the total amount of data, in kbits, sent on MAC-hs level per scheduling priority class 09. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumMcSecActUes {
      description "Number of UEs configured to use cell as activated secondary serving HS-DSCH cell. As a consequence only UEs in MC mode are considered by the counter. The counter is the aggregate of sample values taken every 100 ms. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumJitterSpi11 {
      description "Sum of delay jitter of transmitted data before it is scheduled for scheduling priority class 11. The jitter delay is defined as a time difference between current delay and the previous one. Counter unit: 1 ms..";
      type uint32;
      config false;
    }
    leaf pmSumScAndMcActUes {
      description "The number of UEs configured to use the cell as serving HS-DSCH cell or as activated secondary serving HS-DSCH cell. As a consequence both UEs in single-carrier mode and in multi-carrier mode are considered by the counter. The counter is the aggregate of sample values taken every 100 ms. The counter reflects the cell perspective..";
      type uint16;
      config false;
    }
    leaf pmSumNonEmptyUserBuffers3McPqSpi00 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 00 and belonging to UEs units configured to use cell as serving HS-DSCH cell in 3MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBitsMcPqSpi07 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in MC mode. Only acknowledged data originating from a PQ with scheduling priority class 07 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersPqSpi09 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 09 and belonging to UEs units configured to use cell as serving HS-DSCH cell are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmAqmBasedDiscardSpi06 {
      description "Number of discards performed by the AQM feature for all Priority Queues (PQs) for Scheduling Priority Indicator (SPI) 06..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersPqSpi14 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 14 and belonging to UEs units configured to use cell as serving HS-DSCH cell are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumTransmittedBitsSpi03 {
      description "Measurement to observe the total amount of data, in kbits, sent on MAC-hs level per scheduling priority class 03. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf-list pmCapacityOfHsDschUsers {
      description "Distribution of number of HS-DSCH users, as percentages of the license controlled limit visible in pmCapacityLimitHsDschUsers. Bins: [0]: Number of sampled values in range [0..5[ % [1]: Number of sampled values in range [5..10[ % ... [18]: Number of sampled values in range [90..95[ % [19]: Number of sampled values >= 95%.";
      type uint64;
      max-elements 20;
    }
    leaf pmCapacityLimitHsPdschCodes {
      description "Licensed limit for number of HS-PDSCH codes in the cell. License key value if valid license key, else default value of NodeBLocalCell::maxNumHsPdschCodes if invalid/missing license key, else max value of NodeBLocalCell::maxNumHsPdschCodes if emergency unlock is active..";
      type int64;
      config false;
    }
    leaf pmSumAckedBitsPqSpi02 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell. Only acknowledged data originating from a PQ with scheduling priority class 02 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf-list pmDelayDistributionSpi09 {
      description "Measurement to observe the distribution of the scheduling delay for scheduling priority class 09 on each subframe on those priority queue(s) selected for transmission. Bins: [0]: Number of delays in [0..10[ % [1]: Number of delays in [10..20[ % ... [9]: Number of delays in [90..100[ % [10]: Number of delays greater than or equal to 100%.";
      type uint32;
      max-elements 11;
    }
    leaf pmSumAckedBitsMcPqSpi05 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in MC mode. Only acknowledged data originating from a PQ with scheduling priority class 05 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumMcSecDeactUes {
      description "Number of UEs configured to use cell as deactivated secondary serving HS-DSCH cell. As a consequence only UEs in multi-carrier mode are considered by the counter. The counter is the aggregate of sample values taken every 100 ms. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmAqmBasedDiscardSpi01 {
      description "Number of discards performed by the AQM feature for all Priority Queues (PQs) for Scheduling Priority Indicator (SPI) 01..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersPqSpi04 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 04 and belonging to UEs units configured to use cell as serving HS-DSCH cell are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersMcPqSpi00 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 00 and belonging to UEs units configured to use cell as serving HS-DSCH cell in MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumTransmittedBitsSpi08 {
      description "Measurement to observe the total amount of data, in kbits, sent on MAC-hs level per scheduling priority class 08. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumTransmittedBitsSpi06 {
      description "Measurement to observe the total amount of data, in kbits, sent on MAC-hs level per scheduling priority class 06. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf-list pmSumAckedBitsRlim {
      description "Distribution over CQI, of total amount of acknowledged data sent on MAC-hs or MAC-ehs level to UE units configured to use cell, under resource limited conditions. Scheduling decision is defined to be resource-limited if transport block size is limited only by available codes or power, or both. In addition, only one single UE unit must be scheduled for data transmission in 2ms TTI. CQI value used to index distribution is one reported by UE units and applicable during initial transmission. For non-64QAM-capable UE units, CQI value is mapped down to align with CQI reporting for 64QAM-capable UE units, as further described for PDF range 26...30. Ranges: [0] : Sum of acknowledged data sent for reported CQI=0 at initial transmission [1] : Sum of acknowledged data sent for reported CQI=1 at initial transmission ... [25] : Sum of acknowledged data sent for reported CQI=25 at initial transmission [26] : Sum of acknowledged data sent for reported CQI=26 for 64QAM-capable UE units, or reported CQI=26 and 27 for non-64QAM-capable UE units, at initial transmission [27] : Sum of acknowledged data sent for reported CQI=27 for 64QAM-capable UE units, or reported CQI=28 and 29 for non-64QAM-capable UE units, at initial transmission [28] : Sum of acknowledged data sent for reported CQI=28 for 64QAM-capable UE units, or reported CQI=30 for non-64QAM-capable UE units, at initial transmission [29] : Sum of acknowledged data sent for reported CQI=29 at initial transmission for 64QAM-capable UE units (not used for non-64QAM-capable UE units) [30] : Sum of acknowledged data sent for reported CQI=30 at initial transmission for 64QAM-capable UE units (not used for non-64QAM-capable UE units).";
      type uint32;
      max-elements 31;
    }
    leaf pmAqmBasedDiscardSpi00 {
      description "Number of discards performed by the AQM feature for all Priority Queues (PQs) for Scheduling Priority Indicator (SPI) 00..";
      type uint32;
      config false;
    }
    leaf pmSumNoOfUsersSpi08 {
      description "Counts the total number of users for scheduling priority class 08 selected for each 2 ms subframe that is transmitted in the cell. For an MC-PQ only the counter in the serving HS-DSCH cell (of the UE to which the MC-PQ belongs) is updated. However, the aggregated measurement, based on all cells where the MC-PQ may be served, is considered when that counter is updated. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
  }
  grouping Iub-attributes {
    leaf iubId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf userLabel {
      description "Label for free use.; length 1..128.";
      type string {
        length "1..128";
      }
    }
    leaf ipv4Address {
      description "Reference to the MO AddressIPv4, which is used to carry Frame Protocol..";
      type ietfinet:ipv4-address;
      mandatory true;
    }
    leaf rbsId {
      description "Used by OSS-RC to identify a Node B and the corresponding Iub in RNC. The attribute is not used by the Node B itself, it only serves as storage for OSS-RC..";
      type uint32;
      mandatory true;
    }
    leaf rSiteRef {
      description "A label used for grouping radio nodes located at the same site.; length 1..35.";
      type string {
        length "1..35";
      }
      config false;
    }
    leaf pmNoOfDiscardedMsg {
      description "Number of discarded messages because of SCTP congestion control on the control plane over Iub..";
      type uint64;
      config false;
    }
    leaf pmTotalTimeIubLinkCongestedUl {
      description "The time the Iub link is congested for the NBAP Common part of the control plane in the uplink direction..";
      type uint64;
      config false;
    }
  }
  grouping IubDataStreams-attributes {
    leaf iubDataStreamsId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf maxHsRate {
      description "Maximum HSDPA bit rate over Iub.; range 1..10000; Default value: 470.";
      type int16 {
        range "1..10000";
      }
      default "470";
      units "Mbps";
    }
    leaf hsDataFrameDelayThreshold {
      description "Maximum build-up delay for transport network buffer, a dynamic delay. Measured dynamic delay above this limit is interpreted as IUB congestion detection.; range 10..200; Default value: 60.";
      type int16 {
        range "10..200";
      }
      default "60";
      units "ms";
    }
    leaf hsRbrDiscardProbability {
      description "Discard probability for flow where IUB congestion is detected. Used when HSDPA RBR QoS Profiling feature and AQM-based congestion control for HSDPA feature are both activated.; range 0..100; Default value: 0.";
      type eytypes:int16_range_0-100;
      default "0";
      units "percent";
    }
    leaf-list hsRbrWeight {
      description "Attribute controls relative bitrates that users get. Weight ranges of value are normalized for peak factor around 100% when being calculated or configured. Weight is needed to implement RBR functions. Weight is used by the algorithm HSDPA Flow Control and its AIMD method, which is used for Transport Network limited scenarios. For SPIs where value OFF is set for IubDataStreams::schHsFlowControlOnOff, value 100% is used for hsRbrWeight. This attribute is not supported when AQM-based congestion control for HSDPA is activated. The first value in the sequence represents SPI0 and the last SPI15.; Default values sequence: 100,100,50,100,200,100,100,100,100,100,100,100,100,100,100,100.";
      type int16 {
        range "32..320";
      }
      ordered-by user;
      min-elements 16;
      max-elements 16;
    }
    leaf noOfCommonStreams {
      description "Total number of common data streams and HS-DSCH data streams allocated in Node B.; range 0..999.";
      type int16 {
