      description "Measurement to observe the distribution of the scheduling delay for scheduling priority class 01 on each subframe on those priority queue(s) selected for transmission. Bins: [0]: Number of delays in [0..10[ % [1]: Number of delays in [10..20[ % ... [9]: Number of delays in [90..100[ % [10]: Number of delays greater than or equal to 100%.";
      type uint32;
      max-elements 11;
    }
    leaf pmSumAckedBitsPqSpi10 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell. Only acknowledged data originating from a PQ with scheduling priority class 10 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
