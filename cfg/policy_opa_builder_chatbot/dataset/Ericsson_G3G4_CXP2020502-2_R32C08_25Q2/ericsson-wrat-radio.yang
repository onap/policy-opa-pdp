        enum ENABLED;
      }
      config false;
    }
    leaf numOfBch {
      description "Current number of BCHs (Broadcast CHannels) in the cell. The BCH is a fixed rate point to multi point downlink channel, used to convey system information in the whole coverage area of the cell.; range 0..1.";
      type eytypes:int16_range_0-1;
      config false;
    }
    leaf numOfPccpch {
      description "Current number of PCCPCHs (Primary Common Control Physical CHannel) in the cell. This downlink physical channel carries the transport channel BCH.; range 0..1.";
      type eytypes:int16_range_0-1;
      config false;
    }
    leaf numOfPcpich {
      description "Current number of PCPICHs (Primary Common Pilot CHannel) in the cell. This is a fixed rate downlink physical channel that carries a predefined symbol sequence. PCPICH is used as phase reference for other downlink physical channels. No transport channel is carried on PCPICH.; range 0..1.";
      type eytypes:int16_range_0-1;
      config false;
    }
    leaf numOfPsch {
      description "Current number of PSCHs (Primary Synchronization CHannel) in the cell. This is a downlink physical channel used to find the scrambling code of the cell. The PSCH transmits the Primary Synchronization Code, which is the same for every cell in the system and known by each UE. It is sent simultaneously with the transmission on the SSCH. No transport channel is carried on PSCH.; range 0..1.";
      type eytypes:int16_range_0-1;
      config false;
    }
    leaf numOfScpich {
      description "Current number of SCPICHs (Secondary Common Pilot CHannel) in the cell. This is a fixed rate downlink physical channel that carries a predefined symbol sequence. SCPICH is used as phase reference for other downlink physical channels on a second antenna branch in certain MIMO configurations. No transport channel is carried on SCPICH.; range 0..1.";
      type eytypes:int16_range_0-1;
      config false;
    }
    leaf numOfSsch {
      description "Current number of SSCHs (Secondary Synchronization CHannel) in the cell. This is a downlink physical channel used to find the scrambling code of the cell. SSCH transmits a sequence of 15 codes, simultaneously with transmission on the PSCH. By identifying the sequence the UE can derive the primary scrambling code of the cell. No transport channel is carried on SSCH.; range 0..1.";
      type eytypes:int16_range_0-1;
      config false;
    }
  }
