      type string;
      mandatory true;
    }
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operationalState..";
      type AvailStatus;
      min-elements 0;
    }
    leaf operationalState {
      description "Defines the operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf numOfAich {
      description "Current number of AICHs (Acquisition Indication CHannel) in the cell. AICH is a fixed rate downlink physical channel that carries the acquisition indications for reception of preambles on RACH. No transport channel is carried on AICH.; range 0..1.";
      type eytypes:int16_range_0-1;
      config false;
    }
    leaf numOfFach {
      description "Current number of FACHs (Forward Access link CHannel) in the cell. FACH is a downlink common transport channel is used by the network to send messages to a specific UE when no dedicated channels have been established.; range 0..2.";
      type int16 {
        range "0..2";
      }
      config false;
    }
    leaf numOfPch {
      description "Current number of PCHs (Paging CHannel) in the cell. PCH is a downlink common control channel used by the network to broadcast paging messages to find a UE when no dedicated channels have been established.; range 0..1.";
      type eytypes:int16_range_0-1;
      config false;
    }
    leaf numOfPich {
      description "Current number of PICHs (Paging Indication CHannel) in the cell. PICH is a downlink physical channel used to notify UEs that they must listen for paging messages on the PCH. No transport channel is carried on PICH.; range 0..1.";
      type eytypes:int16_range_0-1;
      config false;
    }
    leaf numOfSccpch {
      description "Current number of SCCPCHs (Secondary Common Control Physical CHannel) in the cell. SCCPCH is a downlink physical channel that carries the transport channels FACH or PCH.; range 0..2.";
      type int16 {
        range "0..2";
      }
      config false;
    }
    leaf pmNoOfTfc2OnFach1 {
      description "Number of frames of format TFC2 on FACH1. This counter, together with pmNoOfTfc1OnFach1 and pmNoOfTfc3OnFach2, can be used to calculate the average transmitted output power on FACH..";
      type uint64;
      config false;
    }
    leaf pmNoOfTfc3OnFach2 {
      description "Number of frames of format TFC3 on FACH2. This counter, together with pmNoOfTfc1OnFach1 and pmNoOfTfc2OnFach1, can be used to calculate the average transmitted output power on FACH..";
      type uint64;
      config false;
    }
    leaf pmAichPositiveMessages {
      description "This is a peg counter counting the number of positive Acquisition Indicator (AI) messages sent on the Acquisition Indicator CHannel (AICH), per granularity period..";
      type uint64;
      config false;
    }
    leaf pmNoOfTfc1OnFach1 {
      description "Number of frames of format TFC1 on FACH1. This counter, together with pmNoOfTfc2OnFach1 and pmNoOfTfc3OnFach2, can be used to calculate the average transmitted output power on FACH..";
      type uint64;
      config false;
    }
    leaf pmAichNegativeMessages {
      description "This is a peg counter counting the number of negative Acquisition Indicator (AI) messages sent on the Acquisition Indicator CHannel (AICH), per granularity period..";
      type uint64;
      config false;
    }
    leaf pmAichPositiveMessagesEulFach {
      description "Number of positive Acquisition Indicator messages sent on AICH for EUL FACH assigned signatures..";
      type uint64;
      config false;
    }
    leaf-list pmAichNegativeMessagesEulFach {
      description "Number of negative Acquisition Indicator messages sent on AICH for EUL FACH assigned signatures. Bins: [0]: The C-EDCH resource (selected by the preamble signature) is occupied. [1]: The C-EDCH resource (selected by the preamble signature) is free, but lacks HW decoder..";
      type uint64;
      max-elements 2;
    }
  }
  grouping CommonChannelResourcesUl-attributes {
    leaf commonChannelResourcesUlId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operationalState..";
      type AvailStatus;
      min-elements 0;
    }
    leaf operationalState {
      description "Defines the operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf numOfPrach {
      description "Current number of PRACHs (Physical Random Access CHannel) in the cell. PRACH is an uplink physical channel used to carry RACH.; range 0..1.";
      type eytypes:int16_range_0-1;
      config false;
    }
    leaf numOfRach {
      description "Current number of RACHs (Random Access CHannel) in the cell. RACH is an uplink common control channel used by any UE to send messages to the network when no dedicated channels have been established.; range 0..1.";
      type eytypes:int16_range_0-1;
      config false;
    }
    leaf pmPrachPropagationDelayMax {
      description "Maximum propagation delay within the cell (i.e. from the cell range to the antenna) in number of chips (0..2562)..";
      type int64;
      config false;
    }
    leaf-list pmAccessIntensityEulFach {
      description "Number of EUL_FACH accesses during a sampling period. Bins: [0]: Number of sampling periods with 0 accesses [1]: Number of sampling periods with 1 access [2]: Number of sampling periods with 2 accesses ... [25]: Number of sampling periods with 25 accesses [26]: Number of sampling periods with more than 25 accesses.";
      type uint64;
      max-elements 27;
    }
    leaf-list pmPrachPropagationDelay {
      description "Propagation delay between UEs and the antenna for a cell, as percentage of the maximum propagation delay within the cell (indicated by the counter pmPrachPropagationDelayMax). Bins: [0]: 0 (not used) [1]: Number of samples less than 1 % [2]: Number of samples in range [1..2[ % ... [10]: Number of samples in range [9..10[ % [11]: Number of samples in range [10..12[ % [12]: Number of samples in range [12..14[ % ... [20]: Number of samples in range [28..30[ % [21]: Number of samples in range [30..33[ % [22]: Number of samples in range [33..36[ % ... [30]: Number of samples in range [57..60[ % [31]: Number of samples in range [60..64[ % [32]: Number of samples in range [64..68[ % ... [40]: Number of samples greater than or equal to 96 %.";
      type uint64;
      max-elements 41;
    }
    leaf pmPrachSuccReceivedBlocks {
      description "The number of successfully received transport blocks during a granularity period..";
      type uint64;
      config false;
    }
    leaf-list pmAccessIntensityRach {
      description "Number of RACH accesses during a sampling period. Bins: [0]: Number of sampling periods with 0 accesses [1]: Number of sampling periods with 1 access [2]: Number of sampling periods with 2 accesses ... [25]: Number of sampling periods with 25 accesses [26]: Number of sampling periods with more than 25 accesses.";
      type uint64;
      max-elements 27;
    }
    leaf-list pmPrachReceivedPreambleSir {
      description "The signal to interference ratio (SIR) of all access attempts (above the preamble threshold) except false detection (noise) on RACH. Bins: [0]: Number of sampled values less than -25 dB [1]: Number of sampled values in range [-25..-24[ dB [2]: Number of sampled values in range [-24..-23[ dB ... [25]: Number of sampled values in range [-1..0[ dB [26]: Number of sampled values greater than or equal to 0.";
      type uint64;
      max-elements 27;
    }
    leaf pmPrachUnsuccReceivedBlocks {
      description "The number of unsuccessfully received transport blocks during a granularity period..";
      type uint64;
      config false;
    }
    leaf pmPrachNoPreambleFalseDetection {
      description "The number of false detections owing to noise on RACH..";
      type uint64;
      config false;
    }
  }
  grouping CommunicationContexts-attributes {
    leaf communicationContextsId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf noOfCommunicationContexts {
      description "Total number of Communication Contexts allocated in the Node B.; range 0..9999.";
      type int16 {
        range "0..9999";
      }
      config false;
    }
  }
  grouping DlPowerSharing-attributes {
    leaf dlPowerSharingId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf extraPowerHsdpaMixedMode {
      description "Maximum borrowed power from other standards on the PA referenced by rfBranchTxRef.; range 0..160; Default value: 160.";
      type int16 {
        range "0..160";
      }
      default "160";
      units "W";
    }
    leaf rfBranchTxRef {
      description "Refers to RF branch instance corresponding to shared PA..";
      type string;
      config false;
    }
    leaf-list nodeBLocalCellRef {
      description "List of NodeBLocalCell MOs using rfBranchTxRef as TX branch and with NodeBLocalCell::featCtrlHsdpaMmPowerSharing = ON..";
      type string;
      min-elements 0;
      max-elements 4;
    }
    leaf pmNoOfPowLimSlots {
      description "The number of power-limited slots during a granularity period..";
      type uint64;
      config false;
    }
  }
  grouping EDchResources-attributes {
    leaf eDchResourcesId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operationalState..";
      type AvailStatus;
      min-elements 0;
    }
    leaf operationalState {
      description "Defines the operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf pmSumNackedBitsCellEulFach {
      description "Counter for the total amount of nacked data received after HARQ process on MAC-i level for all EUL FACH 10 ms TTI users in a cell. Unit 1 kilobit..";
      type uint64;
      config false;
    }
    leaf pmNoAllowedEul {
      description "Number of times uplink interference is above load threshold for E-DCH traffic, causing stop of E-DCH traffic..";
      type uint64;
      config false;
    }
    leaf-list pmLDch {
      description "The measured uplink Uu load of a cell for users configured with only Release 99 DCH on the uplink. Load contributions from DPDCH, DPCCH and HS-DPCCH are included. The sampled value is a load factor and is unitless with range 0..1, where 0 means no load and 1 is maximum possible load. Bins: [0]: Number of samples in range [0..0.02[ [1]: Number of samples in range [0.02..0.04[ ... [49]: Number of samples in range [0.98..1].";
      type uint64;
      max-elements 50;
    }
    leaf pmCapacityAllocAttServEDchUsers {
      description "Number of attempts to allocate resources for new Serving E-DCH user. If the corresponding carrier is part of a cell using more than one carrier, its value is undefined. Deprecated: Since 17.Q2. Replaced by EDchResourcesCell::pmCapacityAllocAttServEDchUsers.; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf-list pmGrantReductionReasonEul {
      description "Number of grant reductions made by EUL Scheduler due to different reasons. Count for each reason is given by a separate bin. Bins: [0]: TN Congestion -- Incremented every time a grant reduction is triggered due to a TCI (TNL Congestion Indication) received by the scheduler. [1]: Uu Congestion Serving -- Incremented every time an absolute grant overload action is taken due insufficient scheduling headroom. [2]: Uu Congestion Non-serving -- Incremented every time a relative grant overload action is taken due insufficient scheduling headroom. [3]: HW Congestion -- Incremented every time an overload action is taken due insufficient UL HW. [4]: Low usage happy -- Incremented every time a happy user's grant is reduced due to consistently low usage of the granted rate. [5]: Low usage unhappy -- Incremented every time an unhappy user's grant is reduced due to consistently low usage of the granted rate. [6]: Not used -- Always reported as 0. [7]: Inactivity at high grant -- Incremented when a user with a high grant is reduced to the minimum UL HW allocation due to data inactivity on the UL. [8]: Rescheduling -- Incremented every time a user's rate is reduced due to rescheduling in the scheduler..";
      type uint64;
      max-elements 9;
    }
    leaf pmNoActive2msFramesEul {
      description "Sum of used 2 ms frames (TTI) that receive E-DCH data in a cell during a granularity period for all E-DCH users, excluding frames that are not decoded due to lack of hardware. Note that this counter also includes TTIs for TD Scheduled users. An E-DCH user may belong to several cells or sector carriers (in case of a cell using more than one carrier) at the same time. If so is the case the user will be counted in each of these cells or sector carriers (in case of a cell using more than one carrier)..";
      type uint64;
      config false;
    }
    leaf-list pmCapacityOfServEDchUsers {
      description "Distribution of number of Serving E-DCH users, as percentages of licensed limit visible in pmCapacityLimitServEDchUsers. If the corresponding carrier is part of a cell using more than one carrier, all values are undefined. Bins: [0]: Number of sampled values in range [0..20[ % [1]: Number of sampled values in range [20..40[ % [2]: Number of sampled values in range [40..50[ % [3]: Number of sampled values in range [50..60[ % [4]: Number of sampled values in range [60..70[ % [5]: Number of sampled values in range [70..80[ % [6]: Number of sampled values in range [80..85[ % [7]: Number of sampled values in range [85..90[ % [8]: Number of sampled values in range [90..95[ % [9]: Number of sampled values >= 95%. Deprecated: Since 17.Q2. Replaced by EDchResourcesCell::pmCapacityOfServEDchUsers.; MOM flags: noNotification.";
      type uint64;
      max-elements 10;
    }
    leaf pmSumAckedBitsCellEulTti10 {
      description "Counter for the total amount of acked data received in kbits after HARQ process on MAC-e/MAC-i level for all 10 ms TTI users in a cell. Note that k = 1000. An E-DCH user may belong to several cells or sector carriers (in case of a cell using more than one carrier) at the same time. If so is the case the user will be counted in each of these cells or sector carriers (in case of a cell using more than one carrier)..";
      type uint64;
      config false;
    }
    leaf-list pmTotalRotCoverage {
      description "Counter per cell for the total Rise over Thermal (RoT) (including all uplink traffic and external interference) that affects the coverage. Bins: [0]: Number of samples less than 0.5 dB [1]: Number of samples in range [0.5..1.0[ dB [2]: Number of samples in range [1.0..1.5[ dB ... [49]: Number of samples in range [24.5..25[ dB [50]: Number of samples greater than or equal to 25 dB.";
      type uint64;
      max-elements 51;
    }
    leaf pmNoActive2msFramesEulTd {
      description "Sum of used 2 ms frames (TTI) for TD-scheduled E-DCH users. TD-scheduled E-DCH users which receive scheduled or non-scheduled E-DCH data in the frame, in a cell during a granularity period..";
      type uint64;
      config false;
    }
    leaf pmSumAckedBitsCellEulTti2Td {
      description "Total amount of acked data received in kbits after HARQ process. Received data is on MAC-e/MAC-i level for all TD-scheduled users in a cell. Note that k = 1000..";
      type uint64;
      config false;
    }
    leaf pmNoUlUuLoadLimitEul {
      description "Counter for the number of times a scheduling decision is taken to increase the Uu rate of an E-DCH user and there is a need to decrease the Uu rate for another E-DCH user owing to UL Uu load limitations..";
      type uint64;
      config false;
    }
    leaf-list pmEdchThpGlim {
      description "Number of times that throughput for grant limited EUL users was in range during ROP. In case of PSI or combined cell configuration, E-DCH users can belong to several sector carriers. If so, user is counted in each of these sector carriers(cell portion level). Bins: [0]: Number of samples in range [0] kbps [1]: Number of samples in range ]0..25[ kbps [2]: Number of samples in range [25..50[ kbps [3]: Number of samples in range [50..100[ kbps [4]: Number of samples in range [100..200[ kbps ... [12]: Number of samples in range [900..1000[ kbps [13]: Number of samples in range [1000..1200[ kbps [14]: Number of samples in range [1200..1400[ kbps ... [17]: Number of samples in range [1800..2000[ kbps [18]: Number of samples in range [2000..2500[ kbps [19]: Number of samples in range [2500..3000[ kbps ... [23]: Number of samples in range [4500..5000[ kbps [24]: Number of samples in range [5000..6000[ kbps [25]: Number of samples in range [6000..7000[ kbps [26]: Number of samples in range [7000..8000[ kbps [27]: Number of samples in range [8000..9000[ kbps [28]: Number of samples in range [9000..10000[ kbps [29]: Number of samples in range [10000..11000[ kbps [30]: Number of samples in range [11000..12000[ kbps [31]: Number of samples greater than or equal to 12000 kbps.";
      type uint32;
      max-elements 32;
    }
    leaf pmNoActive2msIntervalsEulNonGlim {
      description "The total amount of 2ms intervals in a cell in which the transmission of one or more E-DCH frames are detected for non-grant-limited users. In case of PSI or combined cell configuration, E-DCH users can belong to several sector carriers. If so, user is counted in each of these sector carriers(cell portion level)..";
      type uint32;
      config false;
    }
    leaf pmNoActive2msIntervalsEulTti2 {
      description "Counter for the total amount of 2 ms intervals in a cell in which the transmission of one or more E-DCH frames has been detected, excluding frames that are not decoded due to lack of hardware to decode the frame. An E-DCH user may belong to several cells or sector carriers at the same time. If so is the case the user will be counted in each of these cells or sector carriers..";
      type uint64;
      config false;
    }
    leaf-list pmBurstLengthEulFach {
      description "Total number of bits acked (MAC level) in an EUL FACH access. This counter only applies to DCCH/DTCH transmissions and not to CCCH transmissions. Bins: [0]: [1..500[ bits [1]: [500..1000[ bits [2]: [1000..1500[ bits ... [30]: [15000-15500[ bits [31]: >= 15500 bits.";
      type uint64;
      max-elements 32;
    }
    leaf pmSumAckedBitsCellEulGlim {
      description "Total received acked data in a cell for grant-limited 2ms and 10ms TTI users in the following conditions: - after HARQ process on MAC-e/MAC-i level - grant-limited user existed in a sampling interval (100 ms by default) Given in kbits. In case of PSI or combined cell configuration, E-DCH users can belong to several sector carriers. If so, user is counted in each of these sector carriers(cell portion level)..";
      type uint64;
      config false;
    }
    leaf pmSumAckedBitsCellEulFach {
      description "Counter for the total amount of acked data received after HARQ process on MAC-i level for all EUL FACH 10 ms TTI users in a cell. Unit 1 kilobit..";
      type uint64;
      config false;
    }
    leaf-list pmLCEdch {
      description "The C-EDCH Uu load estimate in a cell. Includes component from E-DPDCH, E-DPCCH and DPCCH for EUL FACH users in the cell, but not that from the HS-DPCCH. The sampled value is a load factor and is unitless with range 0..1, where 0 means no load and 1 is infinite load. Bins: [0]: Number of samples in range [0..0.02[ [1]: Number of samples in range [0.02..0.04[ ... [49]: Number of samples in range [0.98..1].";
      type uint64;
      max-elements 50;
    }
    leaf pmNoActive10msIntervalsEulTti10 {
      description "Counter for the total amount of 10 ms intervals in a cell in which the transmission of one or more E-DCH frames has been detected, excluding frames that are not decoded due to lack of hardware to decode the frame. An E-DCH user may belong to several cells or sector carriers at the same time. If so is the case the user will be counted in each of these cells or sector carriers..";
      type uint64;
      config false;
    }
    leaf-list pmOwnUuLoad {
      description "Counter per cell for the power-controlled noise rise caused by the intra-cell interference that affects the Uu load. Bins: [0]: Number of samples in range [0..0.2[ dB [1]: Number of samples in range [0.2..0.4[ dB ... [49]: Number of samples in range [9.8..10[ dB [50]: Number of samples greater than or equal to 10 dB.";
      type uint64;
      max-elements 51;
    }
    leaf-list pmEdchThpAppLim {
      description "Number of times that throughput for low utilization EUL users was in range during ROP. In case of PSI or combined cell configuration, E-DCH users can belong to several sector carriers. If so, user is counted in each of these sector carriers(cell portion level). Bins: [0]: Number of samples in range [0] kbps [1]: Number of samples in range ]0..25[ kbps [2]: Number of samples in range [25..50[ kbps [3]: Number of samples in range [50..100[ kbps [4]: Number of samples in range [100..200[ kbps ... [12]: Number of samples in range [900..1000[ kbps [13]: Number of samples in range [1000..1200[ kbps [14]: Number of samples in range [1200..1400[ kbps ... [17]: Number of samples in range [1800..2000[ kbps [18]: Number of samples in range [2000..2500[ kbps [19]: Number of samples in range [2500..3000[ kbps ... [23]: Number of samples in range [4500..5000[ kbps [24]: Number of samples in range [5000..6000[ kbps [25]: Number of samples in range [6000..7000[ kbps [26]: Number of samples in range [7000..8000[ kbps [27]: Number of samples in range [8000..9000[ kbps [28]: Number of samples in range [9000..10000[ kbps [29]: Number of samples in range [10000..11000[ kbps [30]: Number of samples in range [11000..12000[ kbps [31]: Number of samples greater than or equal to 12000 kbps.";
      type uint32;
      max-elements 32;
    }
    leaf-list pmFirstDecodedFrameEulFach {
      description "Frame number when E-DPDCH data is first correctly decoded. Bins: [0]: Correct data in 1st expected frame [1]: Correct data in 2nd expected frame [2]: Correct data in 3rd expected frame ... [11]: Correct data in 12th expected frame [12]: Correct data after 12th expected frame.";
      type uint64;
      max-elements 13;
    }
    leaf pmSumAckedBitsCellEulNonGlim {
      description "Total received acked data in a cell for non-grant-limited 2ms and 10ms TTI users in the following conditions: - after HARQ process on MAC-e/MAC-i level - non-grant-limited user existed in a sampling interval (100 ms by default) Given in kbits. In case of PSI or combined cell configuration, E-DCH users can belong to several sector carriers. If so, user is counted in each of these sector carriers(cell portion level)..";
      type uint64;
      config false;
    }
    leaf-list pmLEDchTot {
      description "The measured uplink Uu load of a cell that is caused by users configured with an E-DCH. Load contributions from E-DPDCH (both scheduled and not scheduled), E-DPCCH, DPCCH, and DPDCH (if one is configured) are included, but not that from the HS-DPCCH. The sampled value is a load factor and is unitless with range 0..1, where 0 means no load and 1 is maximum possible load. Bins: [0]: Number of samples in range [0..0.02[ [1]: Number of samples in range [0.02..0.04[ ... [48]: Number of samples in range [0.96..0.98[ [49]: Number of samples in range [0.98..1].";
      type uint64;
      max-elements 50;
    }
    leaf pmNoActive10msFramesEulFach {
      description "Indicated the number of used 10ms frames (TTI) in which data is received in C-EDCH for all EUL-FACH users..";
      type uint64;
      config false;
    }
    leaf pmSumNackedBitsCellEulTti2Td {
      description "Total amount of nacked data received in kbits after HARQ process. Received data is on MAC-e/MAC-i level for all TD-scheduled users in a cell. Excludes data that is NACKed due to lack of hardware to decode the frame. Note that k = 1000..";
      type uint64;
      config false;
    }
    leaf-list pmNoUsersCEdchEul {
      description "Number of simultaneous EUL FACH users. Increased bin is the number of simultaneous C-EDCH resources being allocated in the carrier at that moment. The pmNoUsersCEdchEul counter will be updated in the carrier with best signal in pre-amble detection, if the corresponding carrier is part of a cell using more than one carrier. Bins: [0]: No resources in use [1]: 1 resource in use ... [32]: 32 resources in use.";
      type uint64;
      max-elements 33;
    }
    leaf pmNoActive2msIntervalsEulGlim {
      description "The total amount of 2ms intervals in a cell in which the transmission of one or more E-DCH frames are detected for grant limited users. In case of PSI or combined cell configuration, E-DCH users can belong to several sector carriers. If so, user is counted in each of these sector carriers(cell portion level)..";
      type uint32;
      config false;
    }
    leaf pmSamplesCapacityServEDchUsers {
      description "Number of samples in pmSumCapacityServEDchUsers. pmSamplesCapacityServEDchUsers = pmSamplesCapacityServEDchUsers + 1, whenever pmSumCapacityServEDchUsers is updated. If the corresponding carrier is part of a cell using more than one carrier, its value is undefined. Deprecated: Since 17.Q2. Replaced by EDchResourcesCell::pmSamplesCapacityServEDchUsers.; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf pmSumCapacityServEDchUsers {
      description "Sum of sample values recorded during ROP for number of Serving E-DCH users. If the corresponding carrier is part of a cell using more than one carrier, its value is undefined. Deprecated: Since 17.Q2. Replaced by EDchResourcesCell::pmSumCapacityServEDchUsers.; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf pmSumNackedBitsCellEulTti10 {
      description "Counter for the total amount of nacked data received in kbits after HARQ process on MAC-e/MAC-i level for all 10 ms TTI users in a cell, excluding data that is NACKed due to lack of hardware to decode the frame. Note that k = 1000. An E-DCH user may belong to several cells or sector carriers (in case of a cell using more than one carrier) at the same time. If so is the case the user will be counted in each of these cells or sector carriers (in case of a cell using more than one carrier)..";
      type uint64;
      config false;
    }
    leaf-list pmLOther {
      description "The estimated distribution of the Uplink load caused by inter-cell and external interferers. The sampled value is a load factor and is unitless with range 0..1, where 0 means no load and 1 is maximum possible load. Bins: [0]: Number of samples in range [0..0.02[ [1]: Number of samples in range [0.02..0.04[ ... [48]: Number of samples in range [0.96..0.98[ [49]: Number of samples in range [0.98..1].";
      type uint64;
      max-elements 50;
    }
    leaf-list pmCommonChPowerEul {
      description "Total DL power used for the E-AGCH, E-RGCH and E-HICH in the cell. If the corresponding carrier is part of a cell using more than one carrier, all values are undefined. Bins: [0]: Number of samples in range [0..1[ dBm [1]: Number of samples in range [1..2[ dBm ... [39]: Number of samples in range [39..40[ dBm [40]: Number of samples greater than or equal to 40 dBm. Deprecated: Since 17.Q2. Replaced by EDchResourcesCell::pmCommonChPowerEul.; MOM flags: noNotification.";
      type uint16;
      max-elements 41;
    }
    leaf-list pmNoSchEdchEul {
      description "The total number of simultaneous scheduled E-DCH users having a rate greater than 0 kbits/s. Bins: [0]: Number of samples in range [0..1[ E-DCH user [1]: Number of samples in range [1..2[ E-DCH users ... [9]: Number of samples in range [9..10[ E-DCH users [10]: Number of samples in range [10..15[ E-DCH users [11]: Number of samples in range [15..20[ E-DCH users [12]: Number of samples in range [20..25[ E-DCH users [13]: Number of samples in range [25..30[ E-DCH users [14]: Number of samples in range [30..40[ E-DCH users [15]: Number of samples in range [40..50[ E-DCH users ... [19]: Number of samples in range [80..90[ E-DCH users [20]: Number of samples greater than or equal to 90 E-DCH users.";
      type uint64;
      max-elements 21;
    }
    leaf-list pmWaitingTimeEul {
      description "The waiting time for an E-DCH user from when a rate increase request is received when the scheduled grant = 0 to when a scheduled grant greater than 0 is sent to the UE with an absolute grant. Bins: [0]: Number of samples in range [0..10[ ms [1]: Number of samples in range [10..20[ ms ... [9]: Number of samples in range [90..100[ ms [10]: Number of samples in range [100..200[ ms ... [18]: Number of samples in range [900..1000[ ms [19]: Number of samples in range [1000..2000[ ms ... [27]: Number of samples in range [9000..10 000[ ms [28]: Number of samples greater than or equal to 10 000 ms.";
      type uint64;
      max-elements 29;
    }
    leaf pmSumAckedBitsCellEulTti2 {
      description "Counter for the total amount of acked data received in kbits after HARQ process on MAC-e/MAC-i level for all 2 ms TTI users in a cell. Note that k = 1000. An E-DCH user may belong to several cells or sector carriers (in case of a cell using more than one carrier) at the same time. If so is the case the user will be counted in each of these cells or sector carriers (in case of a cell using more than one carrier)..";
      type uint64;
      config false;
    }
    leaf pmNoActive2msIntervalsEul {
      description "Counter for the total amount of 2 ms intervals in a cell in which the transmission of one or more E-DCH frames has been detected, excluding frames that are not decoded due to lack of hardware to decode the frame. An E-DCH user may belong to several cells or sector carriers at the same time. If so is the case the user will be counted in each of these cells or sector carriers..";
      type uint64;
      config false;
    }
    leaf-list pmTotRateGrantedEul {
      description "Total granted Uu rate. Counter for the total granted Uu rate for all E-DCH users including soft/softer handover by the scheduler per cell. Bins: [0]: Number of samples in range [0..100[ kbits/s [1]: Number of samples in range [100..200[ kbits/s ... [59]: Number of samples in range [5900..6000[ kbits/s [60]: Number of samples greater than or equal to 6000 kbits/s.";
      type uint64;
      max-elements 61;
    }
    leaf-list pmEdchThpNonGlim {
      description "Number of times that throughput for non-grant limited EUL users was in range during ROP. In case of PSI or combined cell configuration, E-DCH users can belong to several sector carriers. If so, user is counted in each of these sector carriers(cell portion level). Bins: [0]: Number of samples in range [0] kbps [1]: Number of samples in range ]0..25[ kbps [2]: Number of samples in range [25..50[ kbps [3]: Number of samples in range [50..100[ kbps [4]: Number of samples in range [100..200[ kbps ... [12]: Number of samples in range [900..1000[ kbps [13]: Number of samples in range [1000..1200[ kbps [14]: Number of samples in range [1200..1400[ kbps ... [17]: Number of samples in range [1800..2000[ kbps [18]: Number of samples in range [2000..2500[ kbps [19]: Number of samples in range [2500..3000[ kbps ... [23]: Number of samples in range [4500..5000[ kbps [24]: Number of samples in range [5000..6000[ kbps [25]: Number of samples in range [6000..7000[ kbps [26]: Number of samples in range [7000..8000[ kbps [27]: Number of samples in range [8000..9000[ kbps [28]: Number of samples in range [9000..10000[ kbps [29]: Number of samples in range [10000..11000[ kbps [30]: Number of samples in range [11000..12000[ kbps [31]: Number of samples greater than or equal to 12000 kbps.";
      type uint32;
      max-elements 32;
    }
    leaf pmNoActive10msIntervalsEulFach {
      description "Counter for the total amount of 10 ms intervals in a cell in which the transmission of one or more E-DCH frames has been detected for EUL FACH users..";
      type uint64;
      config false;
    }
    leaf pmNoActive10msFramesEul {
      description "Sum of used 10 ms frames (TTI) that receive E-DCH data in a cell during a granularity period for all E-DCH users, excluding frames that are not decoded due to lack of hardware. An E-DCH user may belong to several cells or sector carriers (in case of a cell using more than one carrier) at the same time. If so is the case the user will be counted in each of these cells or sector carriers (in case of a cell using more than one carrier)..";
      type uint64;
      config false;
    }
    leaf-list pmCEdchReleaseCause {
      description "The C-EDCH release cause. Bins: [0]: UL Synch never achieved (post verification procedure failed, timer expired). Note that this counter has 2 contributions that cannot be distinguished, that is, unsuccessful accesses and false preamble detections. [1]: UL Synch Achieved but no data could be decoded. [2]: SI(TEBS=0) received for CCCH. [3]: SI(TEBS=0) received for DCCH/DTCH. [4]: CCCH timeout. [5]: DTCH/DCCH timeout (AG=INACTIVE sent). [6]: RL failure. [7]: Up-switch attempt. [8]: Up-switch timeout..";
      type uint64;
      max-elements 9;
    }
    leaf pmSumNackedBitsCellEulTti2 {
      description "Counter for the total amount of nacked data received in kbits after HARQ process on MAC-e/MAC-i level for all 2 ms TTI users in a cell, excluding data that is NACKed due to lack of hardware to decode the frame. Note that k = 1000. Note also that this counter also includes kbits for TD Scheduled users. An E-DCH user may belong to several cells or sector carriers (in case of a cell using more than one carrier) at the same time. If so is the case the user will be counted in each of these cells or sector carriers (in case of a cell using more than one carrier)..";
      type uint64;
      config false;
    }
    leaf pmCapacityAllocRejServEDchUsers {
      description "Number of rejected attempts to allocate resources for new Serving E-DCH user (related to pmCapacityLimitServEDchUser). If the corresponding carrier is part of a cell using more than one carrier, its value is undefined. Deprecated: Since 17.Q2. Replaced by EDchResourcesCell::pmCapacityAllocRejServEDchUsers.; MOM flags: noNotification.";
      type uint64;
      config false;
      status deprecated;
    }
    leaf-list pmNoSchEdchEulTd {
      description "Total number of simultaneous TD scheduled E-DCH users in a cell during a granularity period. Bins: [0]: Number of samples where there is no TD-scheduled user. [1]: Number of samples where there is only one user TD-scheduled. User can use all-HARQ-process grant because no other user shares TD schedule, or it can use one or more HARQ-process grants after other TD users removed. [2]: Number of samples where there are two TD users in TD Schedule, each with one or more HARQ-process grants. [3]: Number of samples where there are three TD users in TD Schedule, each with one or more HARQ-process grants. ... [8]: Number of samples where there are eight TD users in TD Schedule, each with one or more HARQ-process grants..";
      type uint64;
      max-elements 9;
    }
    leaf pmEulFachHarqTransmFailure {
      description "Number of HARQ failures for EUL FACH traffic..";
      type uint64;
      config false;
    }
    leaf pmCapacityLimitServEDchUsers {
      description "Licensed limit for number of Serving E-DCH users in the cell. License key value if valid license key, else default value of NodeBLocalCell::maxNumEulUsers if invalid/missing license key, else max value of NodeBLocalCell::maxNumEulUsers if emergency unlock is active. If the corresponding carrier is part of a cell using more than one carrier, its value is undefined. Deprecated: Since 17.Q2. Replaced by EDchResourcesCell::pmCapacityLimitServEDchUsers.; MOM flags: noNotification.";
      type int64;
      config false;
      status deprecated;
    }
    leaf-list pmNoiseFloorHighRes {
      description "The distribution of estimated thermal noise level. The estimated thermal noise level is used in Rise over Thermal (RoT) calculations when NodeBSectorCarrier::eulNoiseFloorLock is not set. It is limited to be at least -110 dBm. Bins: [0]: Number of samples less than -110.0 dBm [1]: Number of samples in range [-110.0..-109.75[ dBm [2]: Number of samples in range [-109.75..-109.5[ dBm ... [200]: Number of samples in range [-60.25..-60[ dBm [201]: Number of samples greater than or equal to -60 dBm.";
      type uint64;
      max-elements 202;
    }
    leaf-list pmEulFachHarqTransm {
      description "Number of HARQ transmissions attempted until correct reception. Bins: [0]: E-TFCI acked at first transmission [1]: E-TFCI acked after 1 re-transmission [2]: E-TFCI acked after 2 re-transmissions [3]: E-TFCI acked after 3 or more re-transmissions.";
      type uint64;
      max-elements 4;
    }
    leaf-list pmLMaxEDch {
      description "The total uplink Uu load headroom for a cell available to users configured with an E-DCH. The system aims to secure that total load from E-DCH users for this cell (see pmLEDchTot for a description) does not exceed the total uplink Uu load headroom. The sampled value is a load factor and is unitless with range 0..1, where 0 means no load and 1 is maximum possible load. Bins: [0]: Number of samples in range [0..0.02[ [1]: Number of samples in range [0.02..0.04[ ... [48]: Number of samples in range [0.96..0.98[ [49]: Number of samples in range [0.98..1].";
      type uint64;
      max-elements 50;
    }
  }
  grouping EDchResourcesCell-attributes {
    leaf eDchResourcesCellId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf pmAllocRejEdchRlEul {
      description "Number of rejected attempts to allocate E-DCH radio links in EUL scheduler. Includes number of removed E-DCH radio links due EUL user setup, when limit is reached of total number of E-DCH radio links in baseband pool..";
      type uint64;
      config false;
    }
    leaf-list pmCapacityOfServEDchUsers {
      description "Distribution of number of Serving E-DCH users, as percentages of licensed limit visible in pmCapacityLimitServEDchUsers. Bins: [0]: Number of sampled values in range [0..20[ % [1]: Number of sampled values in range [20..40[ % [2]: Number of sampled values in range [40..50[ % [3]: Number of sampled values in range [50..60[ % [4]: Number of sampled values in range [60..70[ % [5]: Number of sampled values in range [70..80[ % [6]: Number of sampled values in range [80..85[ % [7]: Number of sampled values in range [85..90[ % [8]: Number of sampled values in range [90..95[ % [9]: Number of sampled values >= 95%.";
      type uint64;
      max-elements 10;
    }
    leaf-list pmCommonChPowerEul {
      description "Total DL power used for the E-AGCH, E-RGCH and E-HICH in the cell. Bins: [0]: Number of samples in range [0..1[ dBm [1]: Number of samples in range [1..2[ dBm ... [39]: Number of samples in range [39..40[ dBm [40]: Number of samples greater than or equal to 40 dBm.";
      type uint16;
      max-elements 41;
    }
    leaf pmCapacityAllocRejServEDchUsers {
      description "Number of rejected attempts to allocate resources for new Serving E-DCH user (related to pmCapacityLimitServEDchUser)..";
      type uint64;
      config false;
    }
    leaf pmCapacityAllocAttServEDchUsers {
      description "Number of attempts to allocate resources for new Serving E-DCH user. If the corresponding carrier is part of a cell using more than one carrier, its value is undefined.";
      type uint64;
      config false;
    }
    leaf pmSamplesCapacityServEDchUsers {
      description "Number of samples in pmSumCapacityServEDchUsers. pmSamplesCapacityServEDchUsers = pmSamplesCapacityServEDchUsers + 1, whenever pmSumCapacityServEDchUsers is updated..";
      type uint64;
      config false;
    }
    leaf pmCapacityLimitServEDchUsers {
      description "Licensed limit for number of Serving E-DCH users in the cell. License key value if valid license key, else default value of NodeBLocalCell::maxNumEulUsers if invalid/missing license key, else max value of NodeBLocalCell::maxNumEulUsers if emergency unlock is active..";
      type int64;
      config false;
    }
    leaf pmSumCapacityServEDchUsers {
      description "Sum of sample values recorded during ROP for number of Serving E-DCH users..";
      type uint64;
      config false;
    }
  }
  grouping HsDschResources-attributes {
    leaf hsDschResourcesId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operationalState..";
      type AvailStatus;
      min-elements 0;
    }
    leaf operationalState {
      description "Defines the operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf maxAvailMixedModeExtraPower {
      description "Maximum value of available extra power borrowed from other RAT(s). Undefined value: -1 Unit: 0.1 W.";
      type int32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersPqSpi15 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 15 and belonging to UEs units configured to use cell as serving HS-DSCH cell are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBits3McPqSpi11 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in 3MC mode. Only acknowledged data originating from a PQ with scheduling priority class 11 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf-list pmDelayDistributionSpi00 {
      description "Measurement to observe the distribution of the scheduling delay for scheduling priority class 00 on each subframe on those priority queue(s) selected for transmission. Bins: [0]: Number of delays in [0..10[ % [1]: Number of delays in [10..20[ % ... [9]: Number of delays in [90..100[ % [10]: Number of delays greater than or equal to 100%.";
      type uint32;
      max-elements 11;
    }
    leaf pmSumAckedBitsSpi14 {
      description "Total amount of acknowledged data sent on MAC-hs level per scheduling priority class 14. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf-list pmDelayDistributionSpi07 {
      description "Measurement to observe the distribution of the scheduling delay for scheduling priority class 07 on each subframe on those priority queue(s) selected for transmission. Bins: [0]: Number of delays in [0..10[ % [1]: Number of delays in [10..20[ % ... [9]: Number of delays in [90..100[ % [10]: Number of delays greater than or equal to 100%.";
      type uint32;
      max-elements 11;
    }
    leaf-list pmTransmittedCarrierPowerWNonHs {
      description "The transmitted carrier power for all non high-speed codes in the cell, as a percentage of the maximum power (indicated by the counter NodeBLocalCell::pmTransmittedCarrierPowerWLimit). Bins: [0]: Number of sampled values in range [0..2[ % [1]: Number of sampled values in range [2..4[ % [2]: Number of sampled values in range [4..6[ % ... [49]: Number of sampled values in range [98..100] %.";
      type uint64;
      max-elements 50;
    }
    leaf pmNackReceived {
      description "Number of occasions when NACK is received, not counting repetitions of NACK transmissions. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter does not consider ACK/NACKs corresponding to HS-SCCH orders. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumTransmittedBitsSpi01 {
      description "Measurement to observe the total amount of data, in kbits, sent on MAC-hs level per scheduling priority class 01. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf-list pmSamplesSumAckedBitsRlim {
      description "Distribution states how many sample values pmSumAckedBitsRlim is incremented. Ranges: [0] : Number of increments of pmSumAckedBitsRlim[0] [1] : Number of increments of pmSumAckedBitsRlim[1] ... [30] : Number of increments of pmSumAckedBitsRlim[30].";
      type uint16;
      max-elements 31;
    }
    leaf pmSumNoOfUsersSpi02 {
      description "Counts the total number of users for scheduling priority class 02 selected for each 2 ms subframe that is transmitted in the cell. For an MC-PQ only the counter in the serving HS-DSCH cell (of the UE to which the MC-PQ belongs) is updated. However, the aggregated measurement, based on all cells where the MC-PQ may be served, is considered when that counter is updated. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBitsMcPqSpi08 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in MC mode. Only acknowledged data originating from a PQ with scheduling priority class 08 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmAqmBasedDiscardSpi15 {
      description "Number of discards performed by the AQM feature for all Priority Queues (PQs) for Scheduling Priority Indicator (SPI) 15..";
      type uint32;
      config false;
    }
    leaf-list pmDelayDistributionSpi11 {
      description "Measurement to observe the distribution of the scheduling delay for scheduling priority class 11 on each subframe on those priority queue(s) selected for transmission. Bins: [0]: Number of delays in [0..10[ % [1]: Number of delays in [10..20[ % ... [9]: Number of delays in [90..100[ % [10]: Number of delays greater than or equal to 100%.";
      type uint32;
      max-elements 11;
    }
    leaf-list pmSumTransmissions {
      description "Distribution over CQI, of total number of transmissions to UE units configured to use cell, including retransmissions, on MAC-hs or MAC-ehs level until acknowledgement is received. CQI value used to index distribution is one reported by UE units and applicable during initial transmission. For non-64QAM-capable UE units, CQI value is mapped down to align with CQI reporting for 64QAM-capable UE units, as further described for PDF range 26...30. Ranges: [0] : Number of transmissions for reported CQI=0 at initial transmission [1] : Number of transmissions for reported CQI=1 at initial transmission ... [25] : Number of transmissions for reported CQI=25 at initial transmission [26] : Number of transmissions for reported CQI=26 for 64QAM-capable UE units, or reported CQI=26 and 27 for non-64QAM-capable UE units, at initial transmission [27] : Number of transmissions for reported CQI=27 for 64QAM-capable UE units, or reported CQI=28 and 29 for non-64QAM-capable UE units, at initial transmission [28] : Number of transmissions for reported CQI=28 for 64QAM-capable UE units, or reported CQI=30 for non-64QAM-capable UE units, at initial transmission [29] : Number of transmissions for reported CQI=29 at initial transmission for 64QAM-capable UE units (not used for non-64QAM-capable UE units) [30] : Number of transmissions for reported CQI=30 at initial transmission for 64QAM-capable UE units (not used for non-64QAM-capable UE units).";
      type uint16;
      max-elements 31;
    }
    leaf-list pmDelayDistributionSpi08 {
      description "Measurement to observe the distribution of the scheduling delay for scheduling priority class 08 on each subframe on those priority queue(s) selected for transmission. Bins: [0]: Number of delays in [0..10[ % [1]: Number of delays in [10..20[ % ... [9]: Number of delays in [90..100[ % [10]: Number of delays greater than or equal to 100%.";
      type uint32;
      max-elements 11;
    }
    leaf pmAqmBasedDiscardSpi10 {
      description "Number of discards performed by the AQM feature for all Priority Queues (PQs) for Scheduling Priority Indicator (SPI) 10..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffers3McPqSpi03 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 03 and belonging to UEs units configured to use cell as serving HS-DSCH cell in 3MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBitsSpi08 {
      description "Total amount of acknowledged data sent on MAC-hs level per scheduling priority class 08. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumTransmittedBitsSpi13 {
      description "Measurement to observe the total amount of data, in kbits, sent on MAC-hs level per scheduling priority class 13. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersMcPqSpi04 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 04 and belonging to UEs units configured to use cell as serving HS-DSCH cell in MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmNoActiveSubFramesSpi09 {
      description "Sum of active 2 ms subframes for scheduling priority class 09..";
      type uint32;
      config false;
    }
    leaf pmAvailableMixedModeExtraPowerLimit {
      description "Indicates the maximum value of available extra power borrowed from other RAT(s) Unit: 0.1 W.";
      type int32;
      config false;
    }
    leaf pmSumAckedBits3McPqSpi14 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in 3MC mode. Only acknowledged data originating from a PQ with scheduling priority class 14 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumCapacityHsPdschCodes {
      description "Aggregation of all sample values within the ROP for number of available HS-PDSCH codes..";
      type uint64;
      config false;
    }
    leaf pmNoActiveSubFramesSpi08 {
      description "Sum of active 2 ms subframes for scheduling priority class 08..";
      type uint32;
      config false;
    }
    leaf pmNoActiveSubFramesSpi06 {
      description "Sum of active 2 ms subframes for scheduling priority class 06..";
      type uint32;
      config false;
    }
    leaf pmSum3McPriUes {
      description "Number of UEs configured to use cell as primary serving HS-DSCH cell in 3 MC mode. Consequently, only UEs in 3 MC mode are considered by the counter. The counter is the aggregate of sample values taken every 100 ms. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersSpi09 {
      description "Number of user buffers for scheduling priority class 09 with data in buffer for each 2 ms subframes. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmAqmBasedDiscardSpi04 {
      description "Number of discards performed by the AQM feature for all Priority Queues (PQs) for Scheduling Priority Indicator (SPI) 04..";
      type uint32;
      config false;
    }
    leaf-list pmAckQpsk {
      description "Number of received ACKs for a specified transport block size (TBS) with QPSK. The number of successful HARQ transmissions are counted on the MAC-hs layer. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter does not consider ACK/NACKs corresponding to HS-SCCH orders. The counter reflects the cell perspective. Bins: [0]: Number of ACKs for transport block with size [0..1000[ bits [1]: Number of ACKs for transport block with size [1000..2000[ bits [2]: Number of ACKs for transport block with size [2000..3000[ bits ... [28]: Number of ACKs for transport block with size [28000..29000[ bits [29]: Number of ACKs for transport block with size [29000..30000[ bits.";
      type uint32;
      max-elements 30;
    }
    leaf pmSumCapacityHsDschUsers {
      description "Aggregate of all sample values (measurement_value) recorded within the granularity period for number of HS-DSCH users..";
      type uint64;
      config false;
    }
    leaf pmNoInactiveRequiredSubFramesSpi03 {
      description "Number of subframes in which no data with scheduling priority class 03 is transmitted although there is user data to be sent in the validated PQ. This user data is either waiting for first transmission, or data waiting for transmission (NACK is received or no ACK/NACK). If a subframe goes without scheduling priority class 03, that is, just carrying other scheduling priority classes or going totally empty, then the counter is stepped. If the buffer of an MC-PQ is emptied, due to prior scheduling in another cell in the same subframe, and no other buffer in the cell contains data the counter is not incremented. The counter reflects the cell perspective..";
      type uint16;
      config false;
    }
    leaf pmSumNonEmptyUserBuffers3McPqSpi01 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 01 and belonging to UEs units configured to use cell as serving HS-DSCH cell in 3MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBitsMcPqSpi10 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in MC mode. Only acknowledged data originating from a PQ with scheduling priority class 10 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersPqSpi12 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 12 and belonging to UEs units configured to use cell as serving HS-DSCH cell are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumNoOfUsersSpi09 {
      description "Counts the total number of users for scheduling priority class 09 selected for each 2 ms subframe that is transmitted in the cell. For an MC-PQ only the counter in the serving HS-DSCH cell (of the UE to which the MC-PQ belongs) is updated. However, the aggregated measurement, based on all cells where the MC-PQ may be served, is considered when that counter is updated. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBitsMcPqSpi12 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in MC mode. Only acknowledged data originating from a PQ with scheduling priority class 12 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffers {
      description "Number of user buffers with data in the buffer for each 2 ms subframe..";
      type uint32;
      config false;
    }
    leaf pmSumDelaySpi07 {
      description "Sum of delay of transmitted data before it is scheduled for scheduling priority class 07. Counter unit: 1 ms..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersPqSpi11 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 11 and belonging to UEs units configured to use cell as serving HS-DSCH cell are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffers3McPqSpi08 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 08 and belonging to UEs units configured to use cell as serving HS-DSCH cell in 3MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBits3McPqSpi08 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in 3MC mode. Only acknowledged data originating from a PQ with scheduling priority class 08 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBits3McPqSpi06 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in 3MC mode. Only acknowledged data originating from a PQ with scheduling priority class 06 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersPqSpi05 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 05 and belonging to UEs units configured to use cell as serving HS-DSCH cell are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf-list pmReportedCqi64Qam {
      description "The UE reported CQI received for a 64 QAM enabled HS-DSCH. Note that it is the true (unadjusted) CQI that is counted for 64 QAM enabled HS-DSCHs. Bins: [0]: Number of reported CQI with value 0 [1]: Number of reported CQI with value 1 ... [30]: Number of reported CQI with value 30 [31]: Number of reported CQI with invalid value.";
      type uint32;
      max-elements 32;
    }
    leaf pmSumDelaySpi01 {
      description "Sum of delay of transmitted data before it is scheduled for scheduling priority class 01. Counter unit: 1 ms..";
      type uint32;
      config false;
    }
    leaf-list pmSumAckedBits {
      description "Distribution over CQI, of total amount of acknowledged data sent on MAC-hs or MAC-ehs level to UE units configured to use cell. CQI value used to index distribution is one reported by UE units and applicable during initial transmission. For non-64QAM-capable UE units, CQI value is mapped down to align with CQI reporting for 64QAM-capable UE units, as further described for PDF range 26...30. Ranges: [0] : Sum of acknowledged data sent for reported CQI=0 at initial transmission [1] : Sum of acknowledged data sent for reported CQI=1 at initial transmission ... [25] : Sum of acknowledged data sent for reported CQI=25 at initial transmission [26] : Sum of acknowledged data sent for reported CQI=26 for 64QAM-capable UE units, or reported CQI=26 and 27 for non-64QAM-capable UE units, at initial transmission [27] : Sum of acknowledged data sent for reported CQI=27 for 64QAM-capable UE units, or reported CQI=28 and 29 for non-64QAM-capable UE units, at initial transmission [28] : Sum of acknowledged data sent for reported CQI=28 for 64QAM-capable UE units, or reported CQI=30 for non-64QAM-capable UE units, at initial transmission [29] : Sum of acknowledged data sent for reported CQI=29 at initial transmission for 64QAM-capable UE units (not used for non-64QAM-capable UE units) [30] : Sum of acknowledged data sent for reported CQI=30 at initial transmission for 64QAM-capable UE units (not used for non-64QAM-capable UE units).";
      type uint32;
      max-elements 31;
    }
    leaf pmSumNonEmptyUserBuffersMcPqSpi11 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 11 and belonging to UEs units configured to use cell as serving HS-DSCH cell in MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersSpi15 {
      description "Number of user buffers for scheduling priority class 15 with data in buffer for each 2 ms subframes. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBitsMcPqSpi03 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in MC mode. Only acknowledged data originating from a PQ with scheduling priority class 03 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumNoOfUsersSpi04 {
      description "Counts the total number of users for scheduling priority class 04 selected for each 2 ms subframe that is transmitted in the cell. For an MC-PQ only the counter in the serving HS-DSCH cell (of the UE to which the MC-PQ belongs) is updated. However, the aggregated measurement, based on all cells where the MC-PQ may be served, is considered when that counter is updated. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf-list pmSumAckedBitsUsersRlim {
      description "Distribution over number of multiplexed UE units for each 2ms TTI, of total amount of acknowledged data sent on MAC-hs or MAC-ehs level to UE units configured to use cell, under resource limited conditions. Scheduling decision is defined to be resource-limited if transport block size is limited only by available codes or power, or both. In addition, condition is not fulfilled if any retransmissions or transmissions to UE units configured in MIMO or HS-FACH mode occur among multiplexed UE units. Ranges: [0] : Sum of acknowledged data sent in 2ms TTIs with 2 multiplexed UE units [1] : Sum of acknowledged data sent in 2ms TTIs with 3 multiplexed UE units [2] : Sum of acknowledged data sent in 2ms TTIs with 4 multiplexed UE units.";
      type uint32;
      max-elements 3;
    }
    leaf pmSumAckedBitsMcPqSpi04 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in MC mode. Only acknowledged data originating from a PQ with scheduling priority class 04 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmIubBasedDiscardFrameLossUserSpi09 {
      description "Number of Iub discards on all Priority Queues (PQs), that experienced the frame loss due to Iub congestion, for Scheduling Priority Indicator (SPI) 09..";
      type uint32;
      config false;
    }
    leaf pmCapacityAllocAttHsPdschCodes {
      description "Number of attempts to allocate HS-PDSCH codes. Attempts to allocate HS-DSCH codes can be done in the following cases: - When RNC sets up or releases HS-PDSCH codes. If codes are released by the RNC, they might be allocated by RBS dynamically if dynamic code allocation is active. - Fluctuating R99 traffic with dynamic code allocation active might increase the counter. If increased R99 traffic cause a code collision in the code tree for one cell, then dynamically allocated HS-PDSCH codes are released and used for R99 traffic instead. Later when the R99 traffic is released, then the codes will be dynamically allocated again and thus increase the counter..";
      type uint64;
      config false;
    }
    leaf pmSumNonEmptyUserBuffers3McPqSpi05 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 05 and belonging to UEs units configured to use cell as serving HS-DSCH cell in 3MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf-list pmUsedExtraPowerWHs {
      description "Distribution of total used extra HS power borrowed from other WCDMA cells or other RAT(s) cells. Presented as percentage of maximum power visible in NodeBSectorCarrier::pmTransmittedCarrierPowerWLimit. Bins: [0]: Number of sampled values in range [0..2[ % [1]: Number of sampled values in range [2..4[ % [2]: Number of sampled values in range [4..6[ % ... [49]: Number of sampled values is greater or equal to 98 %.";
      type uint32;
      max-elements 50;
    }
    leaf pmSumNonEmptyUserBuffersMcPqSpi10 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 10 and belonging to UEs units configured to use cell as serving HS-DSCH cell in MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumNoOfUsersSpi11 {
      description "Counts the total number of users for scheduling priority class 11 selected for each 2 ms subframe that is transmitted in the cell. For an MC-PQ only the counter in the serving HS-DSCH cell (of the UE to which the MC-PQ belongs) is updated. However, the aggregated measurement, based on all cells where the MC-PQ may be served, is considered when that counter is updated. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf-list pmSumOfHsUsedPwrHsFach {
      description "The distribution of transmitted carrier power used for HS-FACH (HS-PDSCH + HS-SCCH). Bins: [0]: Number of samples with values less than 0 dBm or no transmission [1]: Number of samples in range [0..0.5[ dBm [2]: Number of samples in range [0.5..1[ dBm ... [101]: Number of samples in range [50..50.5[ dBm [102]: Number of samples >= 50.5 dBm.";
      type uint16;
      max-elements 103;
    }
    leaf pmSumNonEmptyUserBuffers3McPqSpi14 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 14 and belonging to UEs units configured to use cell as serving HS-DSCH cell in 3MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf-list pmDelayDistributionSpi06 {
      description "Measurement to observe the distribution of the scheduling delay for scheduling priority class 06 on each subframe on those priority queue(s) selected for transmission. Bins: [0]: Number of delays in [0..10[ % [1]: Number of delays in [10..20[ % ... [9]: Number of delays in [90..100[ % [10]: Number of delays greater than or equal to 100%.";
      type uint32;
      max-elements 11;
    }
    leaf pmAqmBasedDiscardSpi13 {
      description "Number of discards performed by the AQM feature for all Priority Queues (PQs) for Scheduling Priority Indicator (SPI) 13..";
      type uint32;
      config false;
    }
    leaf pmNoActiveSubFramesSpi11 {
      description "Sum of active 2 ms subframes for scheduling priority class 11..";
      type uint32;
      config false;
    }
    leaf pmNoActiveSubFramesSpi04 {
      description "Sum of active 2 ms subframes for scheduling priority class 04..";
      type uint32;
      config false;
    }
    leaf pmSumMcPriUes {
      description "Number of UEs configured to use cell as primary serving HS-DSCH cell in MC mode. Consequently, only UEs in MC mode are considered by the counter. The counter is the aggregate of sample values taken every 100 ms. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersPqSpi03 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 03 and belonging to UEs units configured to use cell as serving HS-DSCH cell are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmNoActiveSubFramesSpi07 {
      description "Sum of active 2 ms subframes for scheduling priority class 07..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffers3McPqSpi04 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 04 and belonging to UEs units configured to use cell as serving HS-DSCH cell in 3MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmIubBasedDiscardFrameLossUserSpi03 {
      description "Number of Iub discards on all Priority Queues (PQs), that experienced the frame loss due to Iub congestion, for Scheduling Priority Indicator (SPI) 03..";
      type uint32;
      config false;
    }
    leaf-list pmUsedExtraMixedModePowerWHs {
      description "Distribution of used extra HS power borrowed from other RAT(s). Presented as percentage of maximum power visible in NodeBSectorCarrier::pmTransmittedCarrierPowerWLimit. Bins: [0]: Number of sampled values in range [0..2[ % [1]: Number of sampled values in range [2..4[ % [2]: Number of sampled values in range [4..6[ % ... [49]: Number of sampled values is greater or equal to 98 %.";
      type uint32;
      max-elements 50;
    }
    leaf pmSumTransmittedBitsSpi11 {
      description "Measurement to observe the total amount of data, in kbits, sent on MAC-hs level per scheduling priority class 11. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersSpi00 {
      description "Number of user buffers for scheduling priority class 00 with data in buffer for each 2 ms subframes. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumDelaySpi11 {
      description "Sum of delay of transmitted data before it is scheduled for scheduling priority class 11. Counter unit: 1 ms..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersMcPqSpi13 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 13 and belonging to UEs units configured to use cell as serving HS-DSCH cell in MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumBlockedTransmissions {
      description "Counts number of 2ms TTIs where UE units are blocked. UE unit is considered blocked in TTI if it is not scheduled to transmit any data even though it has data available in its queues. Incremented each 2ms TTI, by one for each UE unit with data available in its queues, that is not scheduled for data transmission..";
      type uint32;
      config false;
    }
    leaf pmNoInactiveRequiredSubFrames {
      description "The number of subframes in which no data is transmitted although there is user data to be sent in the validated PQ. This user data is either waiting for first transmission, or data waiting for transmission (NACK is received or no ACK/NACK). If the buffer of an MC-PQ is emptied, due to prior scheduling in another cell in the same subframe, and no other buffer in the cell contains data the counter is not incremented. The counter reflects the cell perspective. The counter is per cell and per subframe, meaning increments with max 1 per subframe. A \"subframe\" is a 2 ms TTI for HS-DSCH..";
      type uint16;
      config false;
    }
    leaf pmSumAckedBitsPqSpi04 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell. Only acknowledged data originating from a PQ with scheduling priority class 04 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmNoActiveSubFramesSpi14 {
      description "Sum of active 2 ms subframes for scheduling priority class 14..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersMcPqSpi07 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 07 and belonging to UEs units configured to use cell as serving HS-DSCH cell in MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf-list pmTransmittedCarrierPowerWHs {
      description "Measurement to observe the distribution of transmitted carrier power for all codes used for transmission of HSDPA channels including HS-PDSCH, HS-SCCH, HS-FACH, E-AGCH, E-RGCH and E-HICH, as a percentage of the maximum power (indicated by the counter NodeBLocalCell::pmTransmittedCarrierPowerWLimit). Bins: [0]: Number of sampled values in range [0..2[ % [1]: Number of sampled values in range [2..4[ % [2]: Number of sampled values in range [4..6[ % ... [99]: Number of sampled values in range [198..200] %.";
      type uint64;
      max-elements 100;
    }
    leaf pmIubBasedDiscardFrameLossUserSpi11 {
      description "Number of Iub discards on all Priority Queues (PQs), that experienced the frame loss due to Iub congestion, for Scheduling Priority Indicator (SPI) 11..";
      type uint32;
      config false;
    }
    leaf pmAqmBasedDiscardSpi07 {
      description "Number of discards performed by the AQM feature for all Priority Queues (PQs) for Scheduling Priority Indicator (SPI) 07..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBits3McPqSpi02 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in 3MC mode. Only acknowledged data originating from a PQ with scheduling priority class 02 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmIubBasedDiscardFrameLossUserSpi13 {
      description "Number of Iub discards on all Priority Queues (PQs), that experienced the frame loss due to Iub congestion, for Scheduling Priority Indicator (SPI) 13..";
      type uint32;
      config false;
    }
    leaf pmSumDelaySpi05 {
      description "Sum of delay of transmitted data before it is scheduled for scheduling priority class 05. Counter unit: 1 ms..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersSpi02 {
      description "Number of user buffers for scheduling priority class 02 with data in buffer for each 2 ms subframes. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBitsMcPqSpi06 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in MC mode. Only acknowledged data originating from a PQ with scheduling priority class 06 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumJitterSpi15 {
      description "Sum of delay jitter of transmitted data before it is scheduled for scheduling priority class 15. The jitter delay is defined as a time difference between current delay and the previous one. Counter unit: 1 ms..";
      type uint32;
      config false;
    }
    leaf pmAllocRejHwHsDschUsers {
      description "Number of rejected attempts to allocate resources for new HS-DSCH user because of lack of HS resource capacity..";
      type uint64;
      config false;
    }
    leaf pmNoInactiveRequiredSubFramesSpi08 {
      description "Number of subframes in which no data with scheduling priority class 08 is transmitted although there is user data to be sent in the validated PQ. This user data is either waiting for first transmission, or data waiting for transmission (NACK is received or no ACK/NACK). If a subframe goes without scheduling priority class 08, that is, just carrying other scheduling priority classes or going totally empty, then the counter is stepped. If the buffer of an MC-PQ is emptied, due to prior scheduling in another cell in the same subframe, and no other buffer in the cell contains data the counter is not incremented. The counter reflects the cell perspective..";
      type uint16;
      config false;
    }
    leaf pmSumDelaySpi13 {
      description "Sum of delay of transmitted data before it is scheduled for scheduling priority class 13. Counter unit: 1 ms..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersPqSpi02 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 02 and belonging to UEs units configured to use cell as serving HS-DSCH cell are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf-list pmSumTransmissionsRlim {
      description "Distribution over CQI, of total number of transmissions to UE units configured to use cell, including retransmissions, on MAC-hs or MAC-ehs level until acknowledgement is received, under resource-limited conditions. Scheduling decision is defined to be resource-limited if transport block size is limited only by available codes or power, or both. In addition, only one single UE unit must be scheduled for data transmission in 2ms TTI. CQI value used to index distribution is one reported by UE units and applicable during initial transmission. For non-64QAM-capable UE units, CQI value is mapped down to align with CQI reporting for 64QAM-capable UE units, as further described for PDF range 26...30. Ranges: [0] : Number of transmissions for reported CQI=0 at initial transmission [1] : Number of transmissions for reported CQI=1 at initial transmission ... [25] : Number of transmissions for reported CQI=25 at initial transmission [26] : Number of transmissions for reported CQI=26 for 64QAM-capable UE units, or reported CQI=26 and 27 for non-64QAM-capable UE units, at initial transmission [27] : Number of transmissions for reported CQI=27 for 64QAM-capable UE units, or reported CQI=28 and 29 for non-64QAM-capable UE units, at initial transmission [28] : Number of transmissions for reported CQI=28 for 64QAM-capable UE units, or reported CQI=30 for non-64QAM-capable UE units, at initial transmission [29] : Number of transmissions for reported CQI=29 at initial transmission for 64QAM-capable UE units (not used for non-64QAM-capable UE units) [30] : Number of transmissions for reported CQI=30 at initial transmission for 64QAM-capable UE units (not used for non-64QAM-capable UE units).";
      type uint16;
      max-elements 31;
    }
    leaf pmSumJitterSpi14 {
      description "Sum of delay jitter of transmitted data before it is scheduled for scheduling priority class 14. The jitter delay is defined as a time difference between current delay and the previous one. Counter unit: 1 ms..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersSpi14 {
      description "Number of user buffers for scheduling priority class 14 with data in buffer for each 2 ms subframes. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf-list pmSumOfHsScchUsedPwr {
      description "HS-SCCH transmitted power for each cell. Includes HS-SCCH power used for HS-FACH. If more than one HS-SCCH code is used, registered value is the sum of individual values. Bins: [0]: Number of samples with values lower than 0 dBm or 'no transmission' [1]: Number of samples in range [0..0.5[ dBm [2]: Number of samples in range [0.5..1[ dBm ... [101]: Number of samples in range [50..50.5[ dBm [102]: Number of samples greater than or equal to 50.5 dBm.";
      type uint16;
      max-elements 103;
    }
    leaf pmSumAckedBitsSpi04 {
      description "Total amount of acknowledged data sent on MAC-hs level per scheduling priority class 04. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBits3McPqSpi00 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell in 3MC mode. Only acknowledged data originating from a PQ with scheduling priority class 00 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf-list pmUsedHsPdschCodes {
      description "The distribution of the HS-PDSCH code utilization, as the number of HS-PDSCH codes used by the scheduler. Also includes codes used for HS-FACH. Bins: [0]: 0 codes [1]: 1 code [2]: 2 codes [3]: 3 codes [4]: 4 codes [5]: 5 codes [6]: 6 codes [7]: 7 codes [8]: 8 codes [9]: 9 codes [10]: 10 codes [11]: 11 codes [12]: 12 codes [13]: 13 codes [14]: 14 codes [15]: 15 codes.";
      type uint32;
      max-elements 16;
    }
    leaf pmNoInactiveRequiredSubFramesSpi12 {
      description "Number of subframes in which no data with scheduling priority class 12 is transmitted although there is user data to be sent in the validated PQ. This user data is either waiting for first transmission, or data waiting for transmission (NACK is received or no ACK/NACK). If a subframe goes without scheduling priority class 12, that is, just carrying other scheduling priority classes or going totally empty, then the counter is stepped. If the buffer of an MC-PQ is emptied, due to prior scheduling in another cell in the same subframe, and no other buffer in the cell contains data the counter is not incremented. The counter reflects the cell perspective..";
      type uint16;
      config false;
    }
    leaf pmSumNoOfUsersSpi13 {
      description "Counts the total number of users for scheduling priority class 13 selected for each 2 ms subframe that is transmitted in the cell. For an MC-PQ only the counter in the serving HS-DSCH cell (of the UE to which the MC-PQ belongs) is updated. However, the aggregated measurement, based on all cells where the MC-PQ may be served, is considered when that counter is updated. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmSumJitterSpi10 {
      description "Sum of delay jitter of transmitted data before it is scheduled for scheduling priority class 10. The jitter delay is defined as a time difference between current delay and the previous one. Counter unit: 1 ms..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBitsPqSpi14 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell. Only acknowledged data originating from a PQ with scheduling priority class 14 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersSpi13 {
      description "Number of user buffers for scheduling priority class 13 with data in buffer for each 2 ms subframes. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumSqrCapacityHsPdschCodes {
      description "Aggregate of the squares of the sample values in pmSumCapacityHsPdschCodes. That is, pmSumSqrCapacityHsPdschCodes = pmSumSqrCapacityHsPdschCodes + sqr(measurement_value)..";
      type uint64;
      config false;
    }
    leaf-list pmSumOfHsUsedPwr {
      description "The distribution of transmitted power for HS (HS-FACH as well as HS traffic on CELL_DCH). Bins: [0]: Number of samples with values less than 0 dBm or no transmission [1]: Number of samples in range [0..0.5[ dBm [2]: Number of samples in range [0.5..1[ dBm ... [101]: Number of samples in range [50..50.5[ dBm [102]: Number of samples greater than or equal to 50.5 dBm.";
      type uint16;
      max-elements 103;
    }
    leaf pmSumTransmittedBitsSpi00 {
      description "Measurement to observe the total amount of data, in kbits, sent on MAC-hs level per scheduling priority class 00. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf-list pmAck16Qam {
      description "Number of received ACKs for a specified transport block size (TBS) with 16 QAM. The number of successful HARQ transmissions are counted on the MAC-hs layer. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter does not consider ACK/NACKs corresponding to HS-SCCH orders. The counter reflects the cell perspective. Bins: [0]: Number of ACKs for transport block with size [0..1000[ bits [1]: Number of ACKs for transport block with size [1000..2000[ bits [2]: Number of ACKs for transport block with size [2000..3000[ bits ... [28]: Number of ACKs for transport block with size [28000..29000[ bits [29]: Number of ACKs for transport block with size [29000..30000[ bits.";
      type uint32;
      max-elements 30;
    }
    leaf pmSumNonEmptyUserBuffersSpi05 {
      description "Number of user buffers for scheduling priority class 05 with data in buffer for each 2 ms subframes. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBitsPqSpi01 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell. Only acknowledged data originating from a PQ with scheduling priority class 01 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBitsPqSpi15 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell. Only acknowledged data originating from a PQ with scheduling priority class 15 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmIubBasedDiscardFrameLossUserSpi06 {
      description "Number of Iub discards on all Priority Queues (PQs), that experienced the frame loss due to Iub congestion, for Scheduling Priority Indicator (SPI) 06..";
      type uint32;
      config false;
    }
    leaf pmSumAckedBitsPqSpi05 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell. Only acknowledged data originating from a PQ with scheduling priority class 05 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumJitterSpi12 {
      description "Sum of delay jitter of transmitted data before it is scheduled for scheduling priority class 12. The jitter delay is defined as a time difference between current delay and the previous one. Counter unit: 1 ms..";
      type uint32;
      config false;
    }
    leaf-list pmCapacityOfHsPdschCodes {
      description "Distribution of HS-PDSCH codes allocated (including HS-PDSCH codes allocated by the RNC). Values are expressed as percentage of the license controlled level visible in pmCapacityLimitHsPdschCodes. The number of allocated HS-PDSCH code can be reduced below the license limit by non-HS traffic. This means that number of allocated HS-PDSCH codes may not reach 100%. When feature Dynamic Code Allocation is inoperable, HS-PDSCH Codes are only allocated by the RNC. Bins: [0]: Number of sampled values in range [0..20[ % [1]: Number of sampled values in range [20..40[ % [2]: Number of sampled values in range [40..50[ % [3]: Number of sampled values in range [50..60[ % [4]: Number of sampled values in range [60..70[ % [5]: Number of sampled values in range [70..80[ % [6]: Number of sampled values in range [80..85[ % [7]: Number of sampled values in range [85..90[ % [8]: Number of sampled values in range [90..95[ % [9]: Number of sampled values >= 95%.";
      type uint64;
      max-elements 10;
    }
    leaf pmSumAckedBitsPqSpi08 {
      description "Total amount of acknowledged MAC-hs/ehs data to UEs using any cell as serving HS-DSCH cell. Only acknowledged data originating from a PQ with scheduling priority class 08 is considered. The counter reflects the PQ perspective. Unit: 1 kilobit..";
      type uint32;
      config false;
    }
    leaf pmSumTransmittedBitsSpi14 {
      description "Measurement to observe the total amount of data, in kbits, sent on MAC-hs level per scheduling priority class 14. The counter does not consider whether or not the transmitted data originates from an MC-PQ. The counter reflects the cell perspective..";
      type uint32;
      config false;
    }
    leaf pmSumNonEmptyUserBuffersMcPqSpi15 {
      description "Number of PQs with data in the buffer for each 2 ms subframe. Only PQs with scheduling priority class 15 and belonging to UEs units configured to use cell as serving HS-DSCH cell in MC mode are considered. The counter reflects the PQ perspective..";
      type uint32;
      config false;
    }
    leaf pmNoActiveSubFramesSpi03 {
      description "Sum of active 2 ms subframes for scheduling priority class 03..";
      type uint32;
      config false;
