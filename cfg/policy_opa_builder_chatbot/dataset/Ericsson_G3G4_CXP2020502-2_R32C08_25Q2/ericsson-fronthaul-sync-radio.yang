  description "Auto-generated from Ericsson CPI MOM XML 15554-lza7016014_33-v1uenfk.xml\nSynchronization Fronthaul input Model.";
  revision "2026-03-29" {
    description "Ericsson G3G4, version: CXP2020502/2-R32C08";
  }

  augment "/emael:ManagedElement/emael:Transport/ptprdo:Ptp" {
    list FronthaulBoundaryOrdinaryClock {
      description "Additional definitions from MOM:min/max-elements:0/2;root; Boundary clock for synchronization over eCPRI ports. Clock type is restricted to boundary clock.";
