      enum CLOCK_ACCURACY_25MS {
      }
      enum CLOCK_ACCURACY_100MS {
      }
      enum CLOCK_ACCURACY_250MS {
      }
      enum CLOCK_ACCURACY_1S {
      }
      enum CLOCK_ACCURACY_10S {
      }
      enum CLOCK_ACCURACY_MORETHAN_10S {
      }
      enum CLOCK_ACCURACY_UNKNOWN {
      }
      enum CLOCK_ACCURACY_RESERVED {
      }
    }
  }
  typedef ClockStatus {
    description "Clock status.";
    type enumeration {
      enum NO_FAULT {
        description "No fault detected.";
      }
      enum PDV_PROBLEM {
        description "Too many Packet Delay Variation (PDV) in network.";
      }
      enum CLOCK_CLASS {
        description "Received clock class is not good enough for synchronization.";
      }
      enum CLOCK_ACCURACY {
        description "Received clock accuracy is not good enough for synchronization.";
      }
      enum TIME_NOT_TRACEABLE {
        description "Time is not traceable to primary time reference clock.";
      }
      enum TIME_SCALE_NOT_PTP {
        description "Time scale is not PTP from primary time reference clock.";
      }
      enum ERRATIC_SYNC {
        description "Synchronization messages arriving irregularly, but not totally missing. Could indicate packet loss in network.";
      }
      enum LOW_ANNOUNCE_RATE {
        description "Too few announce messages received per second.";
      }
      enum LOW_SYNC_RATE {
        description "Too few sync messages received per time interval.";
      }
      enum LOW_DELAY_REQ_RATE {
        description "Allowed delay request rate indicated from master is too low.";
      }
      enum LOW_DELAY_RSP_RATE {
        description "Too few delay response messages received per second.";
      }
      enum NO_ANNOUNCE {
        description "No announce messages are detected.";
      }
      enum NO_SYNC {
        description "No synchronization messages are detected.";
      }
      enum NO_DELAY_RSP {
        description "No delay response messages are detected.";
      }
      enum NO_MESSAGES {
        description "No messages are detected. Check ptpPortStatus attribute in PtpBcOcPort MO for PTP port information.";
      }
      enum UNKNOWN {
        description "Status information not available.";
      }
    }
  }
  typedef PtpProfile {
    description "PTP profile type.";
    type enumeration {
      enum IEEE_1588_J3 {
        description "Default profile based on IEEE1588-2008 appendix J3. Selecting this profile requires that ptpMulticastAddress attribute in PtpBcOcPort MO must be set according to network planning.";
      }
      enum G_8275_1 {
        description "Telecom profile for time synchronization according to G.8275.1. Selecting this profile requires that ptpMulticastAddress attribute in PtpBcOcPort MO must be set according to network planning.";
      }
      enum G_8265_1 {
        description "Telecom profile for frequency synchronization according to G.8265.1. Selecting this profile requires that associated grandmaster attribute in PtpBcOcPort MO must be set.";
      }
      enum G_8275_2 {
        description "Telecom profile for assisted partial time support, according to G.8275.2. Selecting this profile requires that associated grandmaster attribute in PtpBcOcPort MO must be set.";
      }
      enum IEEE_1588_TIME_DEFAULT {
        description "Default profile based on IEEE1588-2008 appendix J3 with packet rate of 8 event packets per seconds. Selecting this profile requires that ptpMulticastAddress attribute in PtpBcOcPort MO must be set according to network planning.";
      }
      enum IEEE_1588_TIME_SLOW {
        description "Default profile based on IEEE1588-2008 appendix J3 with packet rate of 64 event packets per second and long locking time. Selecting this profile requires that ptpMulticastAddress attribute in PtpBcOcPort MO must be set according to network planning.";
      }
      enum IEEE_1588_CUSTOM {
        description "Custom profile for synchronization. Selecting this profile requires that associated grandmaster attribute in PtpBcOcPort MO is set.";
      }
      enum ECPRI_CUSTOM {
        description "Custom profile for synchronization over eCPRI ports.";
      }
    }
  }
