        type leafref {
          path "../attributes/ptpProfileMeasurementId";
        }
      }
      container attributes {
      uses PtpProfileMeasurement-attributes;
      }
    }
  }
  typedef MeasStatus {
    description "Status of measurements.";
    type enumeration {
      enum NOT_STARTED {
        description "Measurements are not started.";
      }
      enum STARTED {
        description "Measurements are started.";
      }
      enum FINISHED {
        description "Measurements are finished.";
      }
    }
  }
  typedef OperState {
    description "The operational states of a resource.";
    type enumeration {
      enum DISABLED {
        description "The resource is totally inoperable.";
      }
      enum ENABLED {
        description "The resource is partially or fully operable.";
      }
    }
  }
  grouping MeasStats-struct {
    description "Measurement values for selected dataset.";
    leaf averageValue {
      type string;
    }
    leaf maximumValue {
      type string;
    }
    leaf minimumValue {
      type string;
    }
  }
  grouping MtieMetric-struct {
    description "Measurement result for selected MTIE metric.";
    leaf limit {
      type string;
    }
    leaf measurementPassed {
      type string;
    }
  }
  grouping PtpMetric-struct {
    description "Measurement values for selected PTP metric.";
    leaf limit {
      type uint32;
      units "ns";
    }
    leaf measuredValue {
      type uint64;
      units "ns";
    }
    leaf measurementPassed {
      type string;
    }
  }
  grouping PtpProfileMeasurement-attributes {
    list highPassFilterTE {
      config false;
      description "Time Error (TE) value after first-order high-pass filter with bandwidth of 0.1 Hz is applied. Measurement values are updated every 5 seconds. Unit: 1 ns.";
      uses MeasStats-struct;
    }
    list lowPassFilterTE {
      config false;
      description "Time Error value after first-order low-pass filter with bandwidth of 0.1 Hz is applied. Measurement values are updated every 5 seconds. Unit: 1 ns.";
      uses MeasStats-struct;
    }
    list maskMaxTimeIntervalError {
      config false;
      description "Whether measured MTIE is under defined mask limit..";
      uses MtieMetric-struct;
    }
    list maxAbsLowPassFilterTE {
      config false;
      description "Maximum absolute value of low-pass filtered Time Error according to ITU-T. Measurement values are updated every 5 seconds. Unit: 1 ns.";
      uses PtpMetric-struct;
    }
    list maxAbsPktSelected2WayTE {
      config false;
      description "Maximum absolute value of pktSelected2WayTE according to ITU-T. Measurement values are updated every 20 seconds. Unit: 1 ns.";
      uses PtpMetric-struct;
    }
    leaf measurementDuration {
      description "Duration of measurement.; range 900..86400; Default value: 10000.";
