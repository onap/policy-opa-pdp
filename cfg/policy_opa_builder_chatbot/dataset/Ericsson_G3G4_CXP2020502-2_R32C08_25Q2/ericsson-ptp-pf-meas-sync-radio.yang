      description "Measured high-pass filtered Time Error is reported with offset of +1.000.000.000. To convert it to nano seconds, use following formula: TE[ns] = value_reported - 1.000.000.000. Example: Report value of 999.999.946 represents -54 ns, value of 1.000.000.035 represents 35 ns..";
      type int64;
      max-elements 180;
    }
