    list p2pPktSelected2WayTE {
      config false;
      description "Peak-to-peak value of pktSelected2WayTE according to ITU-T. Measurement values are updated every 20 seconds. Unit: 1 ns.";
      uses PtpMetric-struct;
    }
    list pktSelected2WayTE {
      config false;
      description "Value of pktSelected2WayTE according to ITU-T. Measurement values are updated every 20 seconds. Unit: 1 ns.";
      uses MeasStats-struct;
    }
    leaf ptpProfileMeasurementId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list ptpPktSelected2wayTE {
      description "Measured packet-selected two-way Time Error is reported with offset of +1.000.000.000. To convert it to nano seconds, use following formula: TE[ns] = value_reported - 1.000.000.000. Example: Report value of 999.999.946 represents -54 ns, value of 1.000.000.035 represents 35 ns..";
      type int64;
      max-elements 45;
    }
    leaf-list ptpLowPassFilterTE {
      description "Measured low-pass filtered Time Error is reported with offset of +1.000.000.000. To convert it to nano seconds, use following formula: TE[ns] = value_reported - 1.000.000.000. Example: Report value of 999.999.946 represents -54 ns, value of 1.000.000.035 represents 35 ns..";
