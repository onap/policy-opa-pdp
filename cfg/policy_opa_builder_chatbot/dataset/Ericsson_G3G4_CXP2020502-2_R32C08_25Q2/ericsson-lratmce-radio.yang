      min-elements 0;
    }
    leaf administrativeState {
      description "The administrative state. Note: If this attribute is set to SHUTTING_DOWN, it will immediately go into the state LOCKED..";
      type enumeration {
        enum LOCKED;
        enum UNLOCKED;
        enum SHUTTINGDOWN;
      }
    }
    leaf domainName {
      description "The fully-qualified domain name of the MME. A valid domain name consists of 1 or more labels separated by dots (.). Valid characters for a label are limited to letters a - z, A - Z, digits 0 - 9, and the character - (dash). Character case is preserved. Length of a label may not exceed 255 characters. NOTE: The first and last character in the domain name must be one of the following alphanumeric characters a - z, A - Z or digits 0 - 9. For more information refer to RFC 952, 1101 and 1123. To set this attribute, administrativeState must be LOCKED.; length 0..255.";
      type string {
        length "0..255";
      }
    }
    leaf ipAddress1 {
      description "The primary IP address of the MME. A unique IP address is required for each MME. The input format is four fields of digits, separated by dots. Each field consists of three digits. The value of each field must be in the range 0-255. To set this attribute, administrativeState must be LOCKED.; length 7..15; Default value: 0.0.0.0.";
      type string {
        length "7..15";
      }
      default "0.0.0.0";
    }
    leaf ipAddress2 {
      description "The secondary IP address of the MME. A unique IP address is required for each MME. The input format is four fields of digits, separated by dots. Each field consists of three digits. The value of each field must be in the range 0-255. To set this attribute, administrativeState must be LOCKED.; length 7..15; Default value: 0.0.0.0.";
      type string {
        length "7..15";
      }
      default "0.0.0.0";
    }
    leaf ipv6Address1 {
      description "The primary IPv6 address of the MME. The input format is eight fields, separated by colons. Each field consists of four hexadecimal characters. The value of each field must be in the range 0-FFFF. Leading zeroes can be omitted in a field, and multiple groups of 16 bits of zeroes can be compressed to ::. The :: can be used only once in an address. To set this attribute, administrativeState must be LOCKED.; length 2..39; Default value: ::.";
      type string {
        length "2..39";
      }
      default "::";
    }
    leaf ipv6Address2 {
      description "The secondary IPv6 address of the MME. The input format is eight fields, separated by colons. Each field consists of four hexadecimal characters. The value of each field must be in the range 0-FFFF. Leading zeroes can be omitted in a field, and multiple groups of 16 bits of zeroes can be compressed to ::. The :: can be used only once in an address. To set this attribute, administrativeState must be LOCKED.; length 2..39; Default value: ::.";
      type string {
        length "2..39";
      }
      default "::";
    }
    leaf operationalState {
      description "The operational state. This attribute is set by the application in the RBS..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf usedIpAddress {
      description "The destination address used for initialization of the underlying SCTP association of the latest successful M3-Setup. The IP address can be an IPv4 or an IPv6 address. Note: usedIpAddress never changes during the lifetime of the SCTP association.; length 2..39.";
      type string {
        length "2..39";
      }
      config false;
    }
  }
