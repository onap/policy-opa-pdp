  grouping MceFunction-attributes {
    leaf mceFunctionId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf useM3dnsFormat {
      description "This parameter specifies if the DNS lookup shall use the M3 or S1 format for the TAI domain name: m3mme.tac-lb<tac-lb>.tac-hb<tac-hb>.tac.epc.mnc<mnc>.mcc<mcc>.3gppnetwork.org (true) s1mme.tac-lb<tac-lb>.tac-hb<tac-hb>.tac.epc.mnc<mnc>.mcc<mcc>.3gppnetwork.org (false); Default value: false.";
      type boolean;
      default "false";
    }
    leaf release {
      description "The product release of the ManagedFunction. It commonly contains the Managed Function release, for example L12.0, 13A, R1A.";
      type string;
      config false;
    }
    leaf userLabel {
      description "Used for product free-text description..";
      type string;
    }
    leaf pmMbmsSessionEnd {
      description "The total number of times an MBMS session is stopped by MBMS session duration timeout. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmMbmsSessionStopMmeNoSession {
      description "The total number of times the eNodeB receives the MBMS SESSION STOP REQUEST message for an MBMS session that is already stopped. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmMbmsSessionEstabSucc {
      description "The total number of times an MBMS session is successfully established in the eNodeB. It is incremented each time the MBMS SESSION START RESPONSE is sent. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmMbmsSessionEstabFailUpdate {
      description "The total number of times an MBMS session start fails due to unsupported MBMS session parameter update. It is incremented each time the MBMS SESSION START FAILURE is sent for an already started session. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmMbmsSessionUpdateFailParam {
      description "Total failures of MBMS session update caused by unsupported MBMS session update parameter. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmMbmsSessionUpdateAtt {
      description "The total number of MBMS session update attempts. It is incremented each time the MBMS SESSION UPDATE REQUEST is received. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmMbmsSessionUpdateFailNotSupp {
      description "Total failures of MBMS session update caused by unsupported eNodeB configuration. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmMbmsSessionEstabFailNotSupp {
      description "The total number of MBMS sessions that have failed to be established due to unsupported configuration in eNodeB. It is incremented each time the MBMS SESSION START FAILURE is sent. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmMbmsSessionStopAuditTimer {
      description "The total number of times an MBMS session is stopped by the MBMS audit timer. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmMbmsSessionEstabAtt {
      description "The total number of MBMS session establishment attempts. It is incremented each time the MBMS SESSION START REQUEST is received. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmMbmsSessionUpdateSucc {
      description "The total number of times an MBMS session update is successfully handled in the eNodeB. It is incremented each time the MBMS SESSION UPDATE RESPONSE is sent. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmZtemporary102 {
      description "Normally this counter is not used, it can however sometimes be temporarily used for very late additions in a release. If so, for description see Network Impact Report in the CPI. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmZtemporary103 {
      description "Normally this counter is not used, it can however sometimes be temporarily used for very late additions in a release. If so, for description see Network Impact Report in the CPI. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
    leaf pmMbmsSessionStopMme {
      description "The total number of times an MBMS session is stopped by a received MBMS SESSION STOP REQUEST message. Scanner: Not included in any predefined scanner.";
      type uint32;
      config false;
    }
  }
  grouping TermPointToMmeM3-attributes {
    leaf termPointToMmeM3Id {
      description "The value component of the RDN..";
