    }
    leaf pmPsLostDl {
      description "Number of lost PS DL traffic frames..";
      type uint64;
      config false;
    }
    leaf pmPsSentUl {
      description "Number of sent PS UL traffic frames..";
      type uint64;
      config false;
    }
    leaf pmCpriExtDelayChange {
      description "Total number of times there has been extended delay change in this GSM Sector..";
      type uint64;
      config false;
    }
    leaf pmMicroTxSleepGsmTime {
      description "Accumulated time in seconds when none of the TX connected to an MCPA indicates power. Measured for each MCPA in each radio in the GSM Sector, and summed up. This counter is part of feature Micro TX Sleep GSM, and indicates the total amount of time when power savings can be achieved with radios capable of Micro TX Sleep GSM..";
      type uint64;
      config false;
    }
    leaf pmJitBufDelSamp {
      description "Number of jitter buffer delay samples..";
      type uint64;
      config false;
    }
    leaf pmJitBufDelSum {
      description "Accumulated jitter buffer delay..";
      type uint64;
      config false;
    }
    leaf pmCsLostDl {
      description "Number of lost CS and CSD DL traffic frames..";
      type uint64;
      config false;
    }
    leaf pmMicroTxSleepGsmMeasPeriod {
      description "Accumulated time in seconds for all enabled TX bursts in the GsmSector; to be used as a reference for pmMicroTxSleepGsmTime..";
      type uint64;
      config false;
    }
  }
  grouping Trx-attributes {
    leaf trxId {
      description "The value component of the RDN. Recommended values: 0-11, to allow trxId and trxIndex (TEI) to have the same numeric value. (trxId numeric values >11 is converted to trxIndex <12).";
      type string;
      mandatory true;
    }
    leaf administrativeState {
      description "The administrative state..";
      type enumeration {
        enum LOCKED;
        enum UNLOCKED;
        enum SHUTTINGDOWN;
      }
    }
    leaf operationalState {
      description "Operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operationalState..";
      type AvailStatus;
      min-elements 0;
    }
    leaf userLabel {
      description "Label for free use.; length 1..128.";
      type string {
        length "1..128";
      }
    }
    leaf abisRxState {
      description "State of the RX AO in Abis model towards BSC. Normally a result of BSC actions on the Abis OML..";
      type enumeration {
        enum RESET;
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf abisTxState {
      description "State of TX AO in Abis model towards BSC. Normally a result of BSC actions on Abis OML..";
      type enumeration {
        enum RESET;
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf abisTrxcOmlState {
      description "Link state (OML) between the SO TRXC and the BSC..";
      type enumeration {
        enum DOWN;
        enum UP;
      }
      config false;
    }
    leaf abisTrxcState {
      description "State of TRXC SO in Abis model towards BSC. Normally a result of BSC actions on Abis OML..";
      type enumeration {
        enum RESET;
        enum STARTED;
      }
      config false;
    }
    leaf abisTrxRslState {
      description "Link state (RSL) between the TRX and the BSC..";
      type enumeration {
        enum DOWN;
        enum UP;
      }
      config false;
    }
    leaf-list abisTsState {
      description "According to the GSM standard a TRX has 8 TS numbered from 0 to 7 over Abis. Current state of TS AO in Abis Operation and Maintenance model towards BSC in the following order TS0, TS1, ..., TS6, TS7. Normally a result of BSC actions on the Abis OML..";
      type AbisAoState;
      min-elements 0;
      max-elements 8;
    }
    leaf arfcnMax {
      description "Highest frequency the TRX can use for a GSM carrier. Absolute Frequency Number (ARFCN) is a 3GPP defined attribute, which specifies a unique UL and DL frequency pair for each band. Frequency range specified by arfcnMin and arfcnMax must fit within the IBW of MCPA HW in the RUS.; range 0..1023.";
      type uint16 {
        range "0..1023";
      }
      mandatory true;
    }
    leaf arfcnMin {
      description "Lowest frequency the TRX can use for a GSM carrier. Absolute Frequency Number (ARFCN) is a 3GPP defined attribute, which specifies a unique UL and DL frequency pair for each band. Frequency range specified by arfcnMin and arfcnMax must fit within the IBW of MCPA HW in the RUS.; range 0..1023.";
      type uint16 {
        range "0..1023";
      }
      mandatory true;
    }
    leaf frequencyBand {
      description "Used to configure TRX frequency band. The frequency bands are according to 3GPP TS 37.104, Operating bands and Band Categories, (Band 0 is Ericsson defined). Possible Values: 0 = GSM 900 MHz (GSM) 2 = GSM 1900 MHz (PCS 1900) 3 = GSM 1800 MHz (DCS 1800) 5 = GSM 850 MHz (GSM 850) 8 = GSM 900 MHz Extended (E-GSM).";
      type uint8 {
        range "0 | 2..3 | 5 | 8";
      }
      mandatory true;
    }
    leaf noOfRxAntennas {
      description "Number of RX antennas used by the TRX.; Default value: 2.";
      type uint8 {
        range "1..2 | 4";
      }
      default "2";
    }
    leaf noOfTxAntennas {
      description "Number of TX antennas used by the TRX.; range 1..2; Default value: 1.";
      type uint8 {
        range "1..2";
      }
      default "1";
    }
    leaf trxIndex {
      description "Used both as OML L3 and OML/RSL/TFP/PGSL L2 address (TEI). Set to attribute trxId in this TRX if it is an unique number between 0..11 otherwise lowest unused number in range 0..11 is used. (Values 12-126 are reserved for future use); range 0..126.";
      type uint8 {
        range "0..126";
      }
      config false;
    }
    leaf sectorEquipmentFunctionRef {
      description "Reference to MO SectorEquipmentFunction instance, LDN. MO represents radio and antenna resources used by the TRX..";
      type string;
      mandatory true;
    }
    leaf configuredMaxTxPower {
      description "Configured absolute power for TRX (equally distributed over noOfTxAntennas).; range 0..10000000; Default value: 20000.";
      type eytypes:uint32_range_0-10000000;
      default "20000";
      units "mW";
    }
    leaf maxTxPowerCapability {
      description "Power allocated for TRX, sum for noOfTxAntennas.; range 0..700.";
      type eytypes:uint16_range_0-700;
      config false;
      units "dBm";
    }
    leaf bscMaxTxPower {
      description "Amount of power requested for TRX (equally distributed over noOfTxAntennas) from the BSC.; range 0..700.";
      type eytypes:uint16_range_0-700;
      config false;
      units "dBm";
    }
    leaf-list rfBranchRxRef {
      description "References to RfBranch, CcBranch and MulticastAntennaBranch MO instances that represent RF branches that TRX uses for RX. Data type is LDN. Contains references to RF branches, CC branches or MultiCastAntenna branches whose RF ports are to be used for RX carrier allocations for this particular GSM carrier. This is used only for deterministic carrier allocation. Values are taken into consideration if noOfRxAntennas > 0. If no reference is specified, carrier allocation is based on RF branch MOM list available in SectorEquipmentFunction::rfBranchRef (default behavior)..";
      type string;
      min-elements 0;
      max-elements 4;
    }
    leaf-list rfBranchTxRef {
      description "References to RfBranch and MulticastAntennaBranch MO instances that represent RF branches that TRX uses for TX. Data type is LDN. Contains references to RF branches or MultiCastAntenna branches whose RF ports are to be used for TX carrier allocations for this particular GSM carrier. This is used only for deterministic carrier allocation. Values are taken into consideration if noOfTxAntennas > 0. If no reference is specified, carrier allocation is based on RF branch MOM list available in SectorEquipmentFunction::rfBranchRef (default behavior)..";
      type string;
      min-elements 0;
      max-elements 2;
    }
    leaf-list rfBranchTx {
      description "References to RfBranch and MulticastAntennaBranch MO instances that represent RF branches that TRX uses for TX. Data type is LDN. Identifies the RF branches (MCPA) for which PM counters are valid..";
      type string;
      min-elements 0;
      max-elements 2;
    }
    leaf reservedMaxTxPower {
      description "Power reserved in MCPA for this TRX (equally distributed over noOfTxAntennas).; range 0..10000000.";
      type eytypes:uint32_range_0-10000000;
      units "mW";
    }
    leaf abisRxOperCondition {
      description "Operational condition of RX AO in Abis model towards BSC..";
      type enumeration {
        enum OPERATIONAL;
        enum DEGRADED;
        enum NOT_OPERATIONAL;
      }
      config false;
    }
    leaf abisTxOperCondition {
      description "Operational condition of TX AO in Abis model towards BSC..";
      type enumeration {
        enum OPERATIONAL;
        enum DEGRADED;
        enum NOT_OPERATIONAL;
      }
      config false;
    }
    leaf abisTrxcOperCondition {
      description "Operational condition of TRXC SO in Abis model towards BSC..";
      type enumeration {
        enum OPERATIONAL;
        enum DEGRADED;
        enum NOT_OPERATIONAL;
      }
      config false;
    }
    leaf-list abisTsOperCondition {
      description "Operational condition of TS AO in Abis model towards BSC..";
      type AbisOperCondition;
      min-elements 0;
      max-elements 8;
    }
    leaf-list rfBranchRx {
      description "References to RfBranch and MulticastAntennaBranch MO instances that represent RF branches that TRX uses for RX. Data type is LDN. One reference is used for each RX RfBranch. References can be interpreted as logical antennas..";
      type string;
      min-elements 0;
      max-elements 4;
    }
    leaf rxImbAvgDeltaMeas2 {
      description "Measured average delta imbalance between RX branches with index 2 and 3 in rfBranchRx attribute. Value updated every 5 minutes with traffic.; range 0..255.";
      type eytypes:uint8_range_0-255;
      config false;
      units "dB";
    }
    leaf rxImbNoOfSamples2 {
      description "Number of samples the rxImbAvgDeltaMeas2 is based on.; range 0..65535.";
      type eytypes:uint16_range_0-65535;
      config false;
    }
    leaf rxImbAvgDeltaMeas1 {
      description "Measured average delta imbalance between RX branches with index 0 and 1 in rfBranchRx attribute. Value updated every 5 minutes with traffic.; range 0..255.";
      type eytypes:uint8_range_0-255;
      config false;
      units "dB";
    }
    leaf rxImbNoOfSamples1 {
      description "Number of samples the rxImbAvgDeltaMeas1 is based on.; range 0..65535.";
      type eytypes:uint16_range_0-65535;
      config false;
    }
    leaf rxImbSupTimeElapsed {
      description "Time elapsed of the supervision window time.; range 0..600.";
      type uint16 {
        range "0..600";
      }
      config false;
      units "minutes";
    }
    leaf rxImbSupWindowSize {
      description "Time over which RX path imbalance value is averaged in the supervision function.; range 1..600; Default value: 288.";
      type uint16 {
        range "1..600";
      }
      default "288";
      units "minutes";
    }
    leaf rxImbMinNoOfSamples {
      description "Minimum required number of samples within the supervision window to raise/cease a fault.; range 1..65535; Default value: 7000.";
      type eytypes:uint16_range_1-65535;
      default "7000";
    }
    leaf rxImbAlarmThreshold {
      description "Imbalance between RX branches required to raise/cease of a fault with severity MINOR.; range 1..255; Default value: 60.";
      type uint8 {
        range "1..255";
      }
      default "60";
      units "dB";
    }
    leaf combinedCellType {
      description "Used to configure Combined Cell Type for TRX in a Combined Cell configuration..";
      type enumeration {
        enum NON_COMBINED_CELL;
        enum COMBINED_CELL_TYPE1;
        enum COMBINED_CELL_TYPE2;
        enum COMBINED_CELL_TYPE3;
        enum COMBINED_CELL_TYPE4;
      }
    }
    leaf-list pmPowerBackoffTotalNumOfBurstsTxB {
      description "Total number of bursts per channel type for TX antenna B. This is only used if two TX antennas is configured for TRX with Combined Cells - TX Delay Diversity feature is active..";
      type uint64;
      max-elements 4;
    }
    leaf-list pmPowerBackoffNumOfBurstsBackedOffTxB {
      description "Number of bursts with reduced output power due to power back-off per channel type for TX antenna B. This is only used if two TX antennas is configured for TRX with Combined Cells - TX Delay Diversity feature is active..";
      type uint64;
      max-elements 4;
    }
    leaf-list pmPowerBackoffTotalNumOfBursts {
      description "Power back-off statistics. Shows bursts for each channel type for TRX. This(TX A) is used if only one TX antenna is configured for the TRX..";
      type uint64;
      max-elements 4;
    }
    leaf-list pmPowerBackoffNumOfBurstsBackedOff {
      description "Power back-off statistics. Shows bursts with reduced power because of power back-off for each channel type for TRX. This(TX A) is used if only one TX antenna is configured for the TRX..";
      type uint64;
      max-elements 4;
    }
    leaf-list pmPowerBackoffAccumulatedPowerReductionTxB {
      description "The accumulated output power reduction in dB per channel type for TX antenna B. This is only used if two TX antennas is configured for TRX with Combined Cells - TX Delay Diversity feature is active..";
      type uint64;
      max-elements 4;
    }
    leaf-list pmPowerBackoffAccumulatedPowerReduction {
      description "Power back-off statistics. Shows accumulated power reduction in dB for each channel type for TRX. This(TX A) is used if only one TX antenna is configured for the TRX..";
      type uint64;
      max-elements 4;
    }
  }
}
