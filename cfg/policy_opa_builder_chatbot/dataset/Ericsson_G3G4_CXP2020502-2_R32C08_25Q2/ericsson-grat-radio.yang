      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf userLabel {
      description "Label for free use.; length 1..128.";
      type string {
        length "1..128";
      }
    }
    leaf operationalState {
      description "Operational state of the L2TP control connection..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf-list availabilityStatus {
      description "The availability status of L2TP control connection. It contains details about operationalState..";
      type AvailStatus;
      min-elements 0;
    }
    leaf bscBrokerIpAddress {
      description "BSC IPv4 address GSM Sector contacts when initial contact is made..";
      type string;
    }
    leaf peerIpAddress {
      description "IPv4 address GSM Sector is connected to. Value is different from bscBrokerIpAddress if L2TP connection was redirected..";
      type string;
      config false;
    }
    leaf gsmSectorName {
      description "gsmSectorName is used as identification when BSC is contacted. The gsmSectorName is sent as attribute HostName in L2TP message SCCRQ. The same name must be configured in the BSC. Default gsmSectorName is the same as gsmSectorId, last 20 characters.; length 1..20.";
      type string {
        length "1..20";
      }
    }
    leaf dscpSectorControlUL {
      description "DSCP code for L2TP control connection between the RBS and BSC.; range 0..63; Default value: 46.";
      type eytypes:uint8_range_0-63;
      default "46";
    }
    leaf keepAlivePeriod {
      description "Number of seconds between L2TP keep-alive procedures.; range 1..100; Default value: 1.";
      type uint16 {
        range "1..100";
      }
      default "1";
      units "s";
    }
    leaf maxRetransmission {
      description "Maximum number of retransmissions of L2TP control messages.; range 1..10; Default value: 5.";
      type uint16 {
        range "1..10";
      }
      default "5";
    }
    leaf retransmissionCap {
      description "Maximum value of the exponentially increased interval between retransmission of L2TP control messages.; range 1..10; Default value: 4.";
      type uint16 {
        range "1..10";
      }
      default "4";
      units "s";
    }
    leaf initialRetransmissionPeriod {
      description "Initial period from the original transmission to the first retransmission of L2TP control messages.; range 1..10; Default value: 1.";
      type uint16 {
        range "1..10";
      }
      default "1";
      units "s";
    }
    leaf ipv4Address {
      description "Reference to an instance of AddressIPv4 MO. Only applicable when bscBrokerIpAddress is non-empty..";
      type ietfinet:ipv4-address;
    }
    leaf ipv6Address {
      description "Reference to an instance of AddressIPv6 MO. Only applicable when bscBrokerIpv6Address is non-empty..";
      type ietfinet:ipv6-address;
    }
    leaf bscBrokerIpv6Address {
      description "BSC IPv6 address GSM Sector contacts when initial contact is made..";
      type ietfinet:ipv6-address;
    }
    leaf peerIpv6Address {
      description "IPv6 address GSM Sector is connected to. Value is different from bscBrokerIpv6Address if L2TP connection was redirected..";
      type ietfinet:ipv6-address;
      config false;
    }
    leaf pmL2tpRecPack {
      description "Number of received L2TP packets..";
      type uint64;
      config false;
    }
    leaf pmL2tpSentPack {
      description "Number of sent L2TP packets..";
      type uint64;
      config false;
    }
    leaf pmL2tpLostPack {
      description "Number of lost L2TP packets..";
