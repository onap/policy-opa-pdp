module ericsson-grat-radio {
  yang-version 1.1;
  namespace "urn:com:ericsson:ecim:Grat";
  prefix grat;
  import ietf-inet-types {
    prefix ietfinet;
  }
  import ericsson-yang-types {
    prefix eytypes;
  }
  import ericsson-managed-element {
    prefix emael;
  }
  description "Auto-generated from Ericsson CPI MOM XML 15554-lza7016014_33-v1uenfk.xml\nThe GSM MOM.";
  revision "2026-03-29" {
    description "Ericsson G3G4, version: CXP2020502/2-R32C08";
  }

  augment "/emael:ManagedElement" {
    list BtsFunction {
      description "Additional definitions from MOM:min/max-elements:0/1;root; MO BtsFunction represents the GSM functionality in the Radio Node.";
      key "btsFunctionId";
      leaf btsFunctionId {
        type leafref {
          path "../attributes/btsFunctionId";
        }
      }
      container attributes {
      uses BtsFunction-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/grat:BtsFunction" {
    list GsmSector {
      description "Additional definitions from MOM:min/max-elements:0/unbounded; A GSM Sector is a geographical area with GSM functionality. A GSM Sector is mapped to one Sector TG in BSC. The MO GsmSector groups a number of TRXs, each represented by a MO Trx. The GSM Sector is, via its TRXs, tied to one or more SectorEquipmentFunctions with the same antenna location and antenna direction. The GSM Sector can handle TRXs for one or more frequency bands. However one TRX is always single band and connected to one SectorEquipmentFunction. Transport related data is configured in the MO AbisIp.";
      key "gsmSectorId";
      leaf gsmSectorId {
        type leafref {
          path "../attributes/gsmSectorId";
        }
      }
      container attributes {
      uses GsmSector-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/grat:BtsFunction/grat:GsmSector" {
    list Trx {
      description "Additional definitions from MOM:min/max-elements:0/12; This MO represents a GSM TRX and corresponding functionality for a GSM carrier on Air interface. GSM uses narrowband (< 200 kHz bandwidth) channels in the air interface (one downlink and one uplink) handled by one TRX. A TRX handles normally 1 downlink carrier (TX) and 2 uplink carriers (RX) over a wide bandwidth by using frequency hopping. A MO Trx is connected to one SectorEquipmentFunction MO which represents the radio and antenna equipment.";
      key "trxId";
      leaf trxId {
        type leafref {
          path "../attributes/trxId";
        }
      }
      container attributes {
      uses Trx-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/grat:BtsFunction/grat:GsmSector" {
    list AbisIp {
      description "Additional definitions from MOM:min/max-elements:0/1; MO AbisIp handles configuration of L2TP tunnels for GSM Sector. The L2TP tunnels carry Abis traffic over the IP transport network between the GSM Sector and BSC. All AbisIp instances on same RAN Compute unit must be either IPv4 or IPv6. Otherwise, Inconsistent Configuration alarm is raised at AbisIp MO unlock.";
      key "abisIpId";
      leaf abisIpId {
        type leafref {
          path "../attributes/abisIpId";
        }
      }
      container attributes {
      uses AbisIp-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/grat:BtsFunction/grat:GsmSector/grat:Trx" {
    list ExtTrx {
      description "Additional definitions from MOM:min/max-elements:0/11; GSM extension TRX functionality on extension antenna site in a combined cell configuration. Extension antenna sites are used to provide coverage in areas where Main antenna site fails to provide coverage.";
      key "extTrxId";
      leaf extTrxId {
        type leafref {
          path "../attributes/extTrxId";
        }
      }
      container attributes {
      uses ExtTrx-attributes;
      }
    }
  }
  typedef AbisAoState {
    description "The different states for an Application Object (AO) in the Abis O&M G31 model.";
    type enumeration {
      enum RESET {
        description "Value used when the Abis Application Object is in state RESET. RESET is the initial state, which also is used by BSC to set the object in a defined state with previous configuration cleared.";
      }
      enum DISABLED {
        description "Value used when the Abis Application Object is in state DISABLE.";
      }
      enum ENABLED {
        description "Value used when the Abis Application Object is in state ENABLE.";
      }
    }
  }
  typedef AbisLinkState {
    description "The different states for the Abis links (OML/RSL).";
    type enumeration {
      enum DOWN {
        description "Value used when the Abis OML or RSL is not established or broken.";
      }
      enum UP {
        description "Value used when the Abis OML or RSL is established.";
      }
    }
  }
  typedef AbisOperCondition {
    description "The different operational conditions for a MO in Abis model towards BSC.";
    type enumeration {
      enum OPERATIONAL {
        description "Normal condition. Abis MO is fully operational. Default after Abis MO is reset.";
      }
      enum DEGRADED {
        description "Abnormal condition. Abis MO is partially operational; it performs normal service but with reduced functionality or performance.";
      }
      enum NOT_OPERATIONAL {
        description "Abnormal condition. Abis MO is non-operational and cannot perform normal service.";
      }
    }
  }
  typedef AbisSoState {
    description "The different states for a Service Object (SO) in the Abis O&M G31 model.";
    type enumeration {
      enum RESET {
        description "Value used when the Abis Service Object is in state RESET. RESET is the initial state, which also is used by BSC to set the object in a defined state.";
      }
      enum STARTED {
        description "Value used when the Abis Service Object is in state STARTED.";
      }
    }
  }
  typedef AdmState {
    description "Administrative state of a resource.";
    type enumeration {
      enum LOCKED {
        description "The resource is administratively prohibited from performing services for its users.";
      }
      enum UNLOCKED {
        description "The resource is administratively permitted to perform services for its users. This is independent of its inherent operability.";
      }
      enum SHUTTINGDOWN {
        description "Use of the resource is administratively permitted to existing instances of use only. While the system remains in the shutting down state the manager may at any time cause the managed object to revert to the locked state.";
      }
    }
  }
  typedef AvailStatus {
    description "The availability status is used to qualify the operational state. It indicates why the operational state has changed its value.";
    type enumeration {
      enum IN_TEST {
        description "The resource is undergoing a test procedure. If the administrative state is locked or shutting down, normal users are prevented from using the resource.";
      }
      enum FAILED {
        description "The resource has an internal fault that prevents it from operating.";
      }
      enum POWER_OFF {
        description "The resource requires power to be applied and is not powered on.";
      }
      enum OFF_LINE {
        description "The resource requires a routine operation to be performed. This routine operation is to place the resource online and make it available for use. The operation may be manual or automatic, or both. The operational state is disabled.";
      }
      enum OFF_DUTY {
        description "The resource has been made inactive by an internal control process.";
      }
      enum DEPENDENCY {
        description "The resource cannot operate because some other resource on which it depends is unavailable.";
      }
      enum DEGRADED {
        description "The service available from the resource is degraded in some respect.";
      }
      enum NOT_INSTALLED {
        description "The resource represented by the managed object is not present, or is incomplete.";
      }
      enum LOG_FULL {
        description "Indicates a log full condition. The semantics are defined in CCITT Rec. X.735 | ISO/IEC 10164-6.";
      }
      enum DEPENDENCY_LOCKED {
        description "The administrative state of a resource that this resource depends on is locked. Alternatively, the availability status of the other resource is dependency locked.";
      }
      enum DEPENDENCY_FAILED {
        description "The availability status of a resource that this resource depends on is failed or dependency failed.";
      }
      enum DEPENDENCY_SHUTTINGDOWN {
        description "The administrative state of a resource that this resource depends on is shutting down. Alternatively, the availability status of the other resource is dependency shutting down.";
      }
      enum DEPENDENCY_RECOVERY {
        description "Resource that this resource depends on is undergoing a recovery procedure.";
      }
      enum DEPENDENCY_HOLDING {
        description "Resource cannot operate because some other resource on which it depends is currently unavailable. The situation is expected to be resolved. Actions to facilitate dependency resolution may be ongoing.";
      }
    }
  }
  typedef CombinedCellType {
    description "The different types for a Combined Cell, defines network scenario related to Combined Cell. Extension antenna sites with extension TRXs are used to provide coverage in areas where Main antenna site fails to provide coverage. Normally, use the same CombinedCellType value for all TRX in a GsmSector.";
    type enumeration {
      enum NON_COMBINED_CELL {
        description "For TRX without ExtTrx children in combined cell configuration.";
      }
      enum COMBINED_CELL_TYPE1 {
        description "Combined cell with main antenna site that acts as dominant radio transmitter and defines outer cell coverage border. Radio propagation distance between extension antenna sites and main antenna site is shorter than 2 km.";
      }
      enum COMBINED_CELL_TYPE2 {
        description "Combined cell with main antenna site that acts as dominant radio transmitter and defines outer cell coverage border. Radio propagation distance between at least one extension antenna site and main antenna site is longer than 2 km.";
      }
      enum COMBINED_CELL_TYPE3 {
        description "Combined cell with no dominant main antenna site. Outer coverage border of combined cell is defined by aggregated coverage area of main and extension antenna sites. Distance between antenna sites in combined cell are relatively short, from few meters up to maximum distance of 2 km.";
      }
      enum COMBINED_CELL_TYPE4 {
        description "Combined cell with no dominant main antenna site and used for high speed train. Outer coverage border of combined cell is defined by aggregated coverage area in main and extension antenna sites. Maximum distance between neighboring antenna sites in combined cell is in the order of 1-2 Km.";
      }
    }
  }
  typedef OperState {
    description "Operational states of a resource.";
    type enumeration {
      enum DISABLED {
        description "The resource is totally inoperable.";
      }
      enum ENABLED {
        description "The resource is partially or fully operable.";
      }
    }
  }
  typedef TfMode {
    description "Synchronization mode in the Cluster Group of the TF AO in Abis model towards BSC. Normally a result of BSC actions on the Abis OML.";
    type enumeration {
      enum MASTER {
      }
      enum STANDALONE {
      }
      enum SLAVE {
      }
      enum UNDEFINED {
      }
    }
  }
  grouping AbisIp-attributes {
    leaf administrativeState {
      description "The administrative state..";
      type enumeration {
        enum LOCKED;
        enum UNLOCKED;
        enum SHUTTINGDOWN;
      }
