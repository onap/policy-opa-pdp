      config false;
    }
    leaf release {
      description "The product release of the GSM managed function..";
      type string;
      config false;
    }
    leaf userLabel {
      description "Label for free use.; length 1..128.";
      type string {
        length "1..128";
      }
    }
  }
  grouping ExtTrx-attributes {
    leaf operationalState {
      description "Operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operationalState..";
      type AvailStatus;
      min-elements 0;
    }
    leaf sectorEquipmentFunctionRef {
      description "Reference to MO SectorEquipmentFunction instance, LDN. MO represents radio and antenna resources used by the extension TRX..";
      type string;
      mandatory true;
    }
    leaf extTrxId {
      description "The value component of the RDN. Recommendation: naming convention for extTrxId: extTrxId=<antSiteIndex>_<parent main trxIndex>.";
      type string;
      mandatory true;
    }
    leaf configuredMaxTxPower {
      description "Configured absolute power for this extension TRX.; range 0..10000000; Default value: 20000.";
      type eytypes:uint32_range_0-10000000;
      default "20000";
      units "mW";
    }
    leaf reservedMaxTxPower {
      description "Power reserved in MCPA for this extension TRX.; range 0..10000000.";
      type eytypes:uint32_range_0-10000000;
      units "mW";
    }
    leaf maxTxPowerCapability {
      description "Power allocated for extension TRX.; range 0..700.";
      type eytypes:uint16_range_0-700;
      config false;
      units "dBm";
    }
    leaf-list rfBranchRx {
      description "References to RfBranch and MulticastAntennaBranch MO instances that represent RF branches that extension TRX uses for RX. Data type is LDN. One reference is used for each RX RfBranch. References can be interpreted as logical antennas..";
      type string;
      min-elements 0;
      max-elements 2;
    }
    leaf-list rfBranchRxRef {
      description "References to RfBranch, CcBranch and MulticastAntennaBranch MO instances that represent RF branches that extension TRX uses for RX. Data type is LDN. Contains references to RF branches, CC branches or MultiCastAntenna branches whose RF ports are to be used for RX carrier allocations for this particular GSM carrier. This is used only for deterministic carrier allocation. Values are taken into consideration if noOfRxAntennas > 0. If no reference is specified, carrier allocation is based on RF branch MOM list available in SectorEquipmentFunction::rfBranchRef (default behavior)..";
      type string;
      min-elements 0;
      max-elements 2;
    }
    leaf-list rfBranchTx {
      description "References to RfBranch and MulticastAntennaBranch MO instances that represent RF branches that extension TRX uses for TX. Data type is LDN. Identifies the RF branches (MCPA) for which PM counters are valid..";
      type string;
      min-elements 0;
      max-elements 2;
    }
    leaf-list rfBranchTxRef {
      description "References to RfBranch and MulticastAntennaBranch MO instances that represent RF branches that extension TRX uses for TX. Data type is LDN. Contains references to RF branches or MultiCastAntenna branches whose RF ports are to be used for TX carrier allocations for this particular GSM carrier. This is used only for deterministic carrier allocation. Values are taken into consideration if noOfTxAntennas > 0. If no reference is specified, carrier allocation is based on RF branch MOM list available in SectorEquipmentFunction::rfBranchRef (default behavior)..";
      type string;
      min-elements 0;
      max-elements 2;
    }
    leaf rxImbAlarmThreshold {
      description "Imbalance between RX branches required to raise/cease of a fault with severity MINOR.; range 1..255; Default value: 60.";
      type uint8 {
        range "1..255";
      }
      default "60";
      units "dB";
    }
    leaf rxImbAvgDeltaMeas1 {
      description "Measured average delta imbalance between RX branches with index 0 and 1 in rfBranchRx attribute. Value updated every 5 minutes with traffic.; range 0..255.";
      type eytypes:uint8_range_0-255;
      config false;
      units "dB";
    }
    leaf rxImbMinNoOfSamples {
      description "Minimum required number of samples within the supervision window to raise/cease a fault.; range 1..65535; Default value: 7000.";
      type eytypes:uint16_range_1-65535;
      default "7000";
    }
    leaf rxImbNoOfSamples1 {
      description "Number of samples the rxImbAvgDeltaMeas1 is based on.; range 0..65535.";
      type eytypes:uint16_range_0-65535;
      config false;
    }
    leaf rxImbSupTimeElapsed {
      description "Time elapsed of the supervision window time.; range 0..600.";
      type uint16 {
        range "0..600";
      }
      config false;
      units "minutes";
    }
    leaf rxImbSupWindowSize {
      description "Time over which RX path imbalance value is averaged in the supervision function.; range 1..600; Default value: 288.";
      type uint16 {
        range "1..600";
      }
      default "288";
      units "minutes";
    }
    leaf userLabel {
      description "Label for free use.; length 1..128.";
      type string {
        length "1..128";
      }
    }
    leaf extTrxDistance {
      description "Radio propagation distance between main antenna site and extension antenna site.; range 0..350; Default value: 0.";
      type uint16 {
        range "0..350";
      }
      default "0";
      units "meters";
    }
    leaf extTrxRadius {
      description "Planned size of the downlink radio coverage area for extension site expressed as an “Equal signal strength radius”. “Equal signal strength radius” is the distance from extension antenna site at which an MS is expected to receive equal signal strength contributions from main antenna site and extension antenna site if both main TX and extension TX are sending with nominal TX power.; range 1..20; Default value: 1.";
      type uint8 {
        range "1..20";
      }
      default "1";
      units "meters";
    }
    leaf extAntSiteIndex {
      description "Used for identifying a Extension Antenna Site in Combined cells site statistics in BSC and OSS/ENM. Normally use the same extAntSiteIndex value for all MO ExtTrx instances on an Extension Antenna Site. Recommended values 1..7. Value 0 is reserved for Main Antenna Site. Not recommended values 0 and 8..63 will be changed to 7, and these changes will affect PM data from BSC to OSS/ENM. Recommendation: Also to be used together with trxIndex attribute of parent main Trx in naming convention for extTrxId. extTrxId=<extAntSiteIndex>_<parent main trxIndex>.; range 0..63; Default value: 7.";
      type eytypes:uint8_range_0-63;
      default "7";
    }
    leaf antSiteIndex {
      description "Used for identifying an Extension Antenna Site in Combined cells site statistics in BSC and OSS/ENM. Normally use the same antSiteIndex value for all MO ExtTrx instances on an Extension Antenna Site. Recommendation: Also to be used together with trxIndex attribute of parent main Trx in naming convention for extTrxId. extTrxId=<antSiteIndex>_<parent main trxIndex>.; range 1..7.";
      type uint8 {
        range "1..7";
      }
      mandatory true;
    }
    leaf-list pmPowerBackoffTotalNumOfBursts {
      description "Power back-off statistics. Shows bursts for each channel type for extension TRX..";
      type uint64;
      max-elements 4;
    }
    leaf-list pmPowerBackoffNumOfBurstsBackedOff {
      description "Power back-off statistics. Shows bursts with reduced power because of power back-off for each channel type for extension TRX..";
      type uint64;
      max-elements 4;
    }
    leaf-list pmPowerBackoffTotalNumOfBurstsTxB {
      description "Number of bursts with reduced output power due to power back-off for each channel type for TX antenna B. Only used if two TX antennas are configured for extension TRX..";
      type uint64;
      max-elements 4;
    }
    leaf-list pmPowerBackoffAccumulatedPowerReduction {
      description "Power back-off statistics. Shows accumulated power reduction in dB for each channel type for extension TRX..";
      type uint64;
      max-elements 4;
    }
    leaf-list pmPowerBackoffAccumulatedPowerReductionTxB {
      description "Accumulated output power reduction in dB for each channel type for TX antenna B. Only used if two TX antennas are configured for extension TRX..";
      type uint64;
      max-elements 4;
    }
    leaf-list pmPowerBackoffNumOfBurstsBackedOffTxB {
      description "Number of bursts with reduced output power due to power back-off for each channel type for TX antenna B. Only used if two TX antennas are configured for extension TRX..";
      type uint64;
      max-elements 4;
    }
  }
