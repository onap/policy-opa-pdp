  grouping BtsFunction-attributes {
    leaf btsFunctionId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf btsVersion {
      description "BTS Version is composed of: <Manufacturer Id><BTS Generation><BTS Revision><BTS Variant>. Used for fleet management by grouping different generations of BTS hardware and to see which main GSM RAN software level that is running.; length 12..12.";
      type string {
        length "12";
      }
      config false;
    }
    leaf gsmMcpaIpmCapacity {
      description "Used capacity units for the GSM MCPA Intelligent Power Management Baseband feature..";
