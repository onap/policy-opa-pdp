      description "Label for free use.; length 1..128.";
      type string {
        length "1..128";
      }
    }
    leaf cabinetTemperature {
      description "Temperature from SCU temp sensor. Undefined value represented by 999, indicates invalid temperature readings from the SCU.; range -55..125.";
      type int32 {
        range "-55..125";
      }
      config false;
      units "°C";
    }
    leaf fanSpeedSupervision {
      description "Time period for fan speed supervision. If fan speed is continuously high (>= 90%) during time period, an alarm is raised. Use '6' if located near households. Use '24' if fan speed supervision is needed and noise level does not matter, no neighbors. Valid values: 0: fan speed supervision off 6, 12, 24: time period in hours; Default value: 12.";
      type int32 {
        range "0 | 6 | 12 | 24";
      }
      default "12";
      units "hours";
    }
    leaf boostInternalThreshold {
      description "Threshold at which cabinet temperatures contribute to fan speed regulation. If empty, cabinet default is used.; range 10..40.";
      type int32 {
        range "10..40";
      }
      units "°C";
    }
    list enhancedModeSetup {
      key "id";
      leaf id {
        type uint32;
        description "Synthetic key for struct attribute.";
      }
      description "Setup for Enhanced Climate Control Mode..";
      uses ApcEnhancedModeSetup-struct;
    }
    leaf pmSpmBarometricAirPressure {
      description "Average differential air pressure. Unit: kPa..";
      type int32;
      config false;
    }
    leaf-list pmCabinetTemperature {
      description "Average cabinet temperature with +1000 offset. To convert to Celsius, following formula is used: (value reported - 1000). [0]: Average temperature from 0 to 299 seconds of ROP. [1]: Average temperature from 300 to 599 seconds of ROP. [2]: Average temperature from 600 to 899 seconds of ROP..";
      type int32;
      max-elements 3;
    }
    leaf pmSpmDifferentialAirPressure {
      description "Avarage differential air pressure. Unit: Pa.";
      type int32;
      config false;
    }
    leaf-list pmCabinetFanSpeedExternal {
      description "Average external fan speed. [0]: Average external fan speed from 0 to 299 seconds of ROP, % of maximum fan speed. [1]: Average internal fan speed from 300 to 599 seconds of ROP, % of maximum fan speed. [2]: Average internal fan speed from 600 to 899 seconds of ROP, % of maximum fan speed..";
