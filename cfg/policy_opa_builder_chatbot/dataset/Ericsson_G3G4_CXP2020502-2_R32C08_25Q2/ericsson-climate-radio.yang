      max-elements 3;
    }
    leaf-list pmCabinetFanSpeed {
      description "Average internal fan speed. [0]: Average internal fan speed from 0 to 299 seconds of ROP, % of maximum fan speed. [1]: Average internal fan speed from 300 to 599 seconds of ROP, % of maximum fan speed. [2]: Average internal fan speed from 600 to 899 seconds of ROP, % of maximum fan speed..";
