    type enumeration {
      enum DISABLED {
        description "The resource is totally inoperable.";
      }
      enum ENABLED {
        description "The resource is partially or fully operable.";
      }
    }
  }
  grouping ApcEnhancedModeSetup-struct {
    description ".";
    leaf internalFanRampUpTemp {
      description "range 15..40.";
      type int32 {
        range "15..40";
      }
    }
    leaf externalFanStartTemp {
      description "range 15..40.";
      type int32 {
        range "15..40";
      }
    }
  }
  grouping Climate-attributes {
    leaf climateId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf controlDomainRef {
      description "The cabinet or the shelf where functions represented by this MO are deployed..";
      type string;
    }
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operationalState..";
      type AvailStatus;
