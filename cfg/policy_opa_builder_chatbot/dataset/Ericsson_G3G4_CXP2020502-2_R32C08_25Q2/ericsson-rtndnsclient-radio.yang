  augment "/emael:ManagedElement/emael:Transport/l3rtrdo:Router/rtndnscl:DnsClient" {
    list DomainFilter {
      description "Additional definitions from MOM:min/max-elements:0/2; Represents domain filter, that enables sending DNS requests for one or more domains to special DNS server. Default DNS server is defined in DnsClient MO and DomainFilter MO can provide exceptions for specific domains.";
