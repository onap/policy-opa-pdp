      default "40";
    }
    leaf localIpAddress {
      description "Reference to address. If set, DNS requests are sent from address configured by referenced MO type AddressIPv4 or AddressIPv6. If unset, DNS requests are sent from address, within Router MO, selected by system..";
      type string;
    }
    leaf-list reservedBy {
