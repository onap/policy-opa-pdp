  grouping Coordinates-struct {
    description "Latitude and longitude.";
    leaf latitude {
      description "range -90000000..90000000; Default value: 0.";
      type int32 {
        range "-90000000..90000000";
      }
      default "0";
      units "degree";
    }
    leaf longitude {
      description "range -180000000..180000000; Default value: 0.";
      type int32 {
        range "-180000000..180000000";
      }
      default "0";
      units "degree";
    }
  }
  grouping GeolocationMonitorConfig-struct {
    description "Configuration parameters of geolocation monitor.";
    leaf altitudeTolerance {
      description "Default value: -1.";
      type int32 {
        range "-1 | 1..100";
      }
      default "-1";
      units "m";
    }
    leaf azimuthTolerance {
      description "Default value: -1.";
      type int32 {
        range "-1 | 1..1800";
      }
      default "-1";
      units "degree";
    }
    leaf boundingRadius {
      description "Default value: -1.";
      type int32 {
        range "-1 | 1..1000";
      }
      default "-1";
      units "m";
    }
    leaf downtiltTolerance {
      description "Default value: -1.";
      type int32 {
        range "-1 | 1..900";
      }
      default "-1";
      units "degree";
    }
    leaf sensitivity {
      description "range 1..10; Default value: 3.";
      type eytypes:int32_range_1-10;
      default "3";
    }
    leaf verificationPeriod {
      description "range 1..10080; Default value: 720.";
      type int32 {
        range "1..10080";
      }
      default "720";
      units "min";
    }
  }
  grouping LastReset-struct {
