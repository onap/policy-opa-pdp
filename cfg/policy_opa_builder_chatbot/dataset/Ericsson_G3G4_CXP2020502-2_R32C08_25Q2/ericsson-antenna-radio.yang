  grouping MechanicalAzimuth-struct {
    description "ASD type attribute.";
    leaf calculated {
      description "range 0..3599.";
      type uint16 {
        range "0..3599";
      }
      units "degree";
    }
    leaf highestCalculated {
      description "range 0..3599.";
      type uint16 {
        range "0..3599";
      }
      units "degree";
    }
    leaf lowestCalculated {
      description "range 0..3599.";
      type uint16 {
        range "0..3599";
      }
      units "degree";
    }
    leaf precision {
      description "range 0..3599.";
      type uint16 {
        range "0..3599";
      }
      units "degree";
    }
  }
  grouping MechanicalRoll-struct {
    description "ASD type attribute.";
    leaf calculated {
      description "range -1799..1799.";
      type int16 {
        range "-1799..1799";
      }
      units "degree";
    }
    leaf highestCalculated {
      description "range -1799..1799.";
      type int16 {
        range "-1799..1799";
      }
      units "degree";
    }
    leaf lowestCalculated {
      description "range -1799..1799.";
