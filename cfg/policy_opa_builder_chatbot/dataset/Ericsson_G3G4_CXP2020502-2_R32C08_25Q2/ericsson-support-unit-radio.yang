        enum NOT_SUPPORTED;
        enum AIR_INLET_TEMP;
        enum AIR_OUTLET_TEMP;
      }
      config false;
    }
    leaf-list pmFanSpeed {
      description "Average fan tray unit fan speed. [0]: Average fan speed from 0 to 299 seconds of ROP, % of maximum fan speed. [1]: Average fan speed from 300 to 599 seconds of ROP, % of maximum fan speed. [2]: Average fan speed from 600 to 899 seconds of ROP, % of maximum fan speed..";
      type int32;
      max-elements 3;
    }
    leaf-list pmFanOperatingTemperature {
      description "Average fan operating temperature. The temperature is calculated as average air inlet temperature, or average air outlet temperature depending on fan tray type. Measured air temperature from fan tray is reported with offset of +1000. To convert it to degree Celsius, use following formula: T = (value_reported - 1000)/10. [0]: Average unit temperature 0 to 299 seconds of ROP. [1]: Average unit temperature 300 to 599 seconds of ROP. [2]: Average unit temperature 600 to 899 seconds of ROP..";
