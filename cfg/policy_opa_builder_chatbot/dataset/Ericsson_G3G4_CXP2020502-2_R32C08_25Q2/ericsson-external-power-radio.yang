  augment "/emael:ManagedElement/eqsupfnrdo:EquipmentSupportFunction" {
    list ExternalPower {
      description "Additional definitions from MOM:min/max-elements:0/1;root;systemCreated; Logical resource providing power to radio node. One instance per radio node, child of first instance of EquipmentSupportFunction. RDN of this MO is ExternalPower=1.";
      key "externalPowerId";
