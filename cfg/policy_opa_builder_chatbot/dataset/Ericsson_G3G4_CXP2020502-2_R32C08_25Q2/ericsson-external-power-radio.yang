  }
  import ericsson-managed-element {
    prefix emael;
  }
  description "Auto-generated from Ericsson CPI MOM XML 15554-lza7016014_33-v1uenfk.xml\nLogical resource providing power to radio node. One instance per radio node, child of first instance of EquipmentSupportFunction. RDN of this MO is ExternalPower=1.";
