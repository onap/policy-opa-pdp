    leaf-list peerInnerAddresses {
      description "List of peer inner IP addresses. List can include both IPv4 and IPv6 addresses..";
      type string;
      min-elements 1;
    }
    leaf peerIpsecTunnelId {
      description "The value component of the RDN. Outer IP address (IPsec endpoint) of peer node with serial number or inner IP address of peer node. Can be IPv4 or IPv6 address. If outer IP address is used, multiple items are possible in attributes localInnerAddresses and peerInnerAddresses. If inner IP address is used, only one item is possible in attributes localInnerAddresses and peerInnerAddresses. On gNodeB, attribute peerOuterAddress can be empty. Examples: Outer IP address of peer node with serial number: 1.1.2.2-1 Inner IP address of peer node: 2.2.1.1.";
      type string;
      mandatory true;
    }
    leaf peerOuterAddress {
