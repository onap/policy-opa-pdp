        type leafref {
          path "../attributes/peerIpsecTunnelId";
        }
      }
      container attributes {
      uses PeerIpsecTunnel-attributes;
      }
    }
  }
  typedef OperState {
    description "The operational states of a resource.";
    type enumeration {
      enum DISABLED {
        description "The resource is totally inoperable.";
      }
      enum ENABLED {
        description "The resource is partially or fully operable.";
      }
    }
  }
  grouping PeerIpsecTunnel-attributes {
    leaf localInnerAddress {
      description "Local inner IP address. Reference to AddressIPv4 MO or AddressIPv6 MO. Includes one of references in attribute localInnerAddresses..";
      type string;
      config false;
    }
    leaf-list localInnerAddresses {
      description "List of local inner IP addresses. List can include references to AddressIPv4 MOs and AddressIPv6 MOs..";
      type string;
      min-elements 1;
    }
    leaf localOuterAddress {
      description "Local outer IP address. Reference to AddressIPv4 MO or AddressIPv6 MO..";
      type string;
      config false;
    }
    leaf operationalState {
      description "The operational state. Disabled if not possible to establish direct IPsec VPN connection, that means not possible to establish IKE SA..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf operationalStateIPv4 {
      description "The operational state for IPv4. Disabled if not possible to use direct IPsec VPN connection for IPv4 traffic, that means not possible to establish Child SA pair for IPv4..";
      type ietfinet:ipv4-address;
      config false;
    }
    leaf operationalStateIPv6 {
      description "The operational state for IPv6. Disabled if not possible to use direct IPsec VPN connection for IPv6 traffic, that means not possible to establish Child SA pair for IPv6..";
      type ietfinet:ipv6-address;
