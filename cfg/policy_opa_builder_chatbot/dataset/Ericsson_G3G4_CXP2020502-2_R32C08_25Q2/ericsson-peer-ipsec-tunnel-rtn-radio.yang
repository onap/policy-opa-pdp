      type string;
      config false;
    }
    leaf ipIfStatsOutFragCreates {
      description "Number of datagram fragments generated as result of IP fragmentation. Specification: RFC 4293, section 5..";
      type uint64;
      config false;
    }
    leaf unavailableSecondsIPv4 {
      description "Number of seconds elapsed when no Child SA pair established for IPv4. Stepped only if IPv4 address is in attribute peerInnerAddresses..";
      type ietfinet:ipv4-address;
      config false;
    }
    leaf ikeFailures {
      description "Number of times IKE SA went down. Only transition from established to non-established is counted..";
