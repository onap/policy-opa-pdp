      type uint64;
      config false;
    }
    leaf ipIfStatsInError {
      description "Number of incoming packets successfully passed IPsec processing, but discarded due to errors detected at inner IP interface. For example due to unknown protocols or various header errors..";
      type uint64;
      config false;
    }
  }
}
