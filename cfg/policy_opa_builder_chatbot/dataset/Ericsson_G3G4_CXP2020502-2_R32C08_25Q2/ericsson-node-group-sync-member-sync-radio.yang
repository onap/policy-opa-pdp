      type string;
    }
    leaf syncOverCpriConnStatus {
      type enumeration {
        enum UNKNOWN;
        enum OK_ACTIVE;
        enum OK_NOT_ACTIVE;
        enum CPRI_LINK_NOT_AVAILABLE;
        enum FREQUENCY_ERROR;
        enum PHASE_ERROR;
        enum FREQUENCY_MEASUREMENTS_LOSS;
        enum PHASE_MEASUREMENTS_LOSS;
        enum ENTERING_NODE_GROUP;
        enum CONNECTED_TO_SHARED_UNIT_ONLY;
        enum NO_SYNC_COMMUNICATION;
        enum NODE_PRIORITY_COLLISION;
        enum SELECTION_MODE_MISMATCH;
      }
    }
  }
  grouping SyncProviderInfo-struct {
    description "Synchronization Provider information.";
    leaf syncProviderNodePriority {
      type string;
    }
    leaf syncProviderState {
      type enumeration {
        enum UNKNOWN;
        enum TIME_MODE;
        enum FREQUENCY_MODE;
        enum FREE_RUNNING;
      }
    }
  }
  grouping NodeGroupSyncMember-attributes {
    leaf administrativeState {
      description "The administrative state..";
      type enumeration {
        enum LOCKED;
        enum UNLOCKED;
        enum SHUTTINGDOWN;
      }
    }
    list localNodeInformation {
      config false;
      description "Synchronization information of node group member..";
      uses LocalNodeInfo-struct;
    }
    leaf nodeGroupSyncMemberId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf selectionMode {
      description "Role selection mode of node group member..";
      type enumeration {
        enum NODE_PRIORITY;
        enum REFERENCE_AND_NODE_PRIORITY;
      }
    }
    leaf syncNodePriority {
      description "Identifies node group member and gives node priority value to select Synchronization Provider. Every node group member must have unique number. Value 1 has highest priority.; range 1..15.";
      type eytypes:uint8_range_1-15;
      mandatory true;
    }
    list syncOverCpriConnInfo {
      config false;
      min-elements 0;
      uses SyncOverCpriConnInfo-struct;
    }
    list syncProviderInformation {
      config false;
      description "Information about Synchronization Provider. This means node group member synchronizing to reference external to node group..";
      uses SyncProviderInfo-struct;
    }
    leaf-list syncRiPortCandidate {
      description "Empty by default, which means NGSM will automatically detect available Synchronization over CPRI Connections (SoCCs). Attribute is configurable with list of RiPort MOs used to identify available SoCC. RiPort MOs must have available SoCCs to other nodes in NG, otherwise node startup is prolonged to its maximum value. For best performance of NG, attribute must be configured as recommended by “Manage Node Group Synchronization”..";
      type string;
      min-elements 0;
      max-elements 18;
    }
    leaf-list syncRiPortStatus {
      description "Status of Radio Interface (RI) ports configured as candidates for node group synchronization. Order of synchronization RI ports are same as for attribute syncRiPortCandidate.; MOM flags: noNotification; Status info: Replaced by syncOverCpriConnInfo attribute. Planned to be removed..";
      type RiPortStatus;
      min-elements 0;
      max-elements 18;
    }
    leaf userLabel {
      description "Label for free use.; length 1..128.";
      type string {
        length "1..128";
      }
    }
  }
}
