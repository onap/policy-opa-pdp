  augment "/emael:ManagedElement/emael:SystemFunctions/rcssysm:SysM" {
    list OamAccessPoint {
      description "Additional definitions from MOM:min/max-elements:0/unbounded;systemCreated; An OaM Access Point instance for the ME. Alternative access point has limited OaM support. It is recommended to use only to repair problems with primary access point.";
      key "oamAccessPointId";
      leaf oamAccessPointId {
        type leafref {
          path "../attributes/oamAccessPointId";
        }
      }
      container attributes {
      uses OamAccessPoint-attributes;
      }
    }
  }

  augment "/emael:ManagedElement/emael:SystemFunctions/rcssysm:SysM" {
