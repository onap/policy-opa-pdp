        type ietfinet:domain-name;
      }
      mandatory true;
    }
    leaf transportAutomationAgentId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf trustCategory {
      description "Set of certificates trusted for TLS over Ericsson internal interface Ni1 between TIF and TIF agent. DN of TrustCategory MO in certificate management. If set, communication over Ni1 is secured using TLS. If not set, communication over Ni1 is not secured..";
      type string;
    }
    leaf userLabel {
      description "Label for free use.; length 1..128.";
      type string {
        length "1..128";
      }
