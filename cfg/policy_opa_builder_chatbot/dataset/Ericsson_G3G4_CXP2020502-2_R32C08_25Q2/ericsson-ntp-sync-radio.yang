      mandatory true;
    }
    leaf-list availabilityStatus {
      description "The availability status. It contains details about operationalState..";
      type AvailStatus;
      min-elements 0;
    }
    leaf cachedIpAddress {
      description "The IPv4 address of the NTP server obtained from a DNS..";
      type string;
      config false;
    }
    leaf dscp {
      description "The DSCP value used for SNTP/UDP/IP transmitted packets.; range 0..63; Default value: 54.";
      type eytypes:uint8_range_0-63;
      default "54";
    }
    leaf ingressUdpPort {
      description "The ingress UDP port number used by the NTP frequency synchronization reference..";
      type string;
      config false;
    }
    leaf ntpFrequencySyncId {
      description "The value component of the RDN..";
      type string;
      mandatory true;
    }
    leaf-list ntpFrequencySyncStatus {
      description "Indicates the detailed fault status of the NTP frequency synchronization reference..";
      type NtpFrequencySyncStatus;
      min-elements 1;
      max-elements 6;
    }
    leaf operationalState {
      description "The operational state..";
      type enumeration {
        enum DISABLED;
        enum ENABLED;
      }
      config false;
    }
    leaf-list reservedBy {
      description "Contains a list of MO instances that reserve this MO instance..";
      type string;
      min-elements 0;
    }
    leaf syncServerNtpIpAddress {
      description "The IPv4 address or domain name of the NTP server..";
      type union {
        type ietfinet:ip-address;
        type ietfinet:domain-name;
      }
      mandatory true;
    }
